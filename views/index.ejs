        }

        function editOfficer(username) {
            let u = state.authorizedPersonnel[username]; if(!u) return;
            document.getElementById('p-user').value = u.username;
            document.getElementById('p-user').readOnly = true;
            document.getElementById('p-pass').value = u.password;
            document.getElementById('p-name').value = u.displayName;
            document.getElementById('p-role').value = u.role;
            document.getElementById('p-agency').value = u.agency;
            document.getElementById('p-isEdit').value = "true";
            document.getElementById('form-provision-title').innerHTML = `<i class="fa-solid fa-user-gear text-sky-400"></i> Hiệu chỉnh thông tin tài khoản cán bộ`;
            document.getElementById('btn-submit-provision').innerText = "Cập Nhật Tài Khoản";
            document.getElementById('btn-cancel-edit').classList.remove('hidden');
        }

        function resetProvisionForm() {
            document.getElementById('p-user').value = ''; document.getElementById('p-user').readOnly = false; document.getElementById('p-pass').value = ''; document.getElementById('p-name').value = ''; document.getElementById('p-isEdit').value = "false";
            document.getElementById('form-provision-title').innerHTML = `<i class="fa-solid fa-id-card-clip"></i> Thiết Lập / Phân Quyền Nhân Sự Quốc Gia`;
            document.getElementById('btn-submit-provision').innerText = "Kích Hoạt Tài Khoản Cán Bộ"; document.getElementById('btn-cancel-edit').classList.add('hidden');
        }

        async function deleteOfficer(username) { if(!confirm(`Xóa vĩnh viễn tài khoản cán bộ nghiệp vụ [${username}]?`)) return; await fetch('/api/officer/delete', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username }) }); }

        async function registerResidentByOfficer(e, mode) {
            e.preventDefault();
            let payload = { mode };
            if(mode === 'licenses_only') {
                payload.username = document.getElementById('lic-user').value.trim();
                payload.licenses = document.getElementById('lic-list').value.trim();
            } else {
                payload.username = document.getElementById('res-user').value.trim();
                payload.name = document.getElementById('res-name').value.trim();
                payload.dob = document.getElementById('res-dob').value.trim();
                payload.gender = document.getElementById('res-gender').value;
                payload.pob = document.getElementById('res-pob').value.trim();
                payload.job = document.getElementById('res-job').value.trim();
                payload.status = document.getElementById('res-status').value;
            }
            payload.officerName = activeUser.displayName;
            
            await fetch('/api/resident/register', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
            soundSuccess(); alert(`Đã đồng bộ cập nhật thông tin cư dân thành công!`);
        }

        async function submitForm(e) {
            e.preventDefault(); const sender = document.getElementById('app-sender').value.trim(); const docType = document.getElementById('app-docType').value; const agency = document.getElementById('app-agency').value; const content = document.getElementById('app-content').value.trim();
            const res = await fetch('/api/applications/submit', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sender, agency, docType, content }) });
            const data = await res.json(); document.getElementById('app-content').value = ''; document.getElementById('track-id').value = data.id; soundSuccess(); trackApplication();
        }

