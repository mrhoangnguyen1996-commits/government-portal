<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CỔNG THÔNG TIN ĐIỆN TỬ CHÍNH PHỦ - QUỐC GIA SỐ HÓA REALTIME</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Space+Grotesk:wght@400;500;600;700&display=swap');
        body { font-family: 'Space Grotesk', sans-serif; background-color: #030712; color: #f3f4f6; }
        .font-mono-tech { font-family: 'Share Tech Mono', monospace; }
        
        /* ĐỒ HỌA CON DẤU PHÔI ĐIỆN TỬ ĐỘNG */
        .stamp-box { position: relative; font-size: 11px; font-weight: 900; text-transform: uppercase; padding: 6px 14px; border-radius: 6px; border: 3px dashed; display: inline-block; text-align: center; letter-spacing: 1px; transform: rotate(-8deg) scale(1.05); text-shadow: 0 0 6px currentColor; box-shadow: inset 0 0 8px rgba(0,0,0,0.3); animation: stampAppear 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
        .stamp-approved { border-color: #10b981; color: #10b981; background: rgba(16, 185, 129, 0.12); }
        .stamp-rejected { border-color: #ef4444; color: #ef4444; background: rgba(239, 68, 68, 0.12); }
        .stamp-pending { border-color: #f59e0b; color: #f59e0b; background: rgba(245, 158, 11, 0.12); }
        .stamp-forwarded { border-color: #3b82f6; color: #3b82f6; background: rgba(59, 130, 246, 0.12); }
        .stamp-leader { border-color: #c084fc; color: #c084fc; background: rgba(192, 132, 252, 0.15); border-style: double; border-width: 5px; }
        .stamp-archived { border-color: #94a3b8; color: #94a3b8; background: rgba(148, 163, 184, 0.15); }

        @keyframes stampAppear { 0% { transform: scale(2.5) rotate(-35deg); opacity: 0; filter: blur(4px); } 100% { transform: scale(1.05) rotate(-8deg); opacity: 1; filter: blur(0); } }
        
        /* BẢNG CHỮ CHẠY CẢNH BÁO LED */
        .marquee-container { width: 100%; overflow: hidden; white-space: nowrap; background: #0b1329; border-top: 1px solid #1f2937; border-bottom: 1px solid #1f2937; position: relative; }
        .marquee-content { display: inline-block; padding-left: 100%; animation: marquee 30s linear infinite; font-size: 13px; font-weight: 700; color: #f59e0b; text-shadow: 0 0 8px rgba(245, 158, 11, 0.5); }
        @keyframes marquee { 0% { transform: translate3d(0, 0, 0); } 100% { transform: translate3d(-100%, 0, 0); } }

        /* PHÔI CĂN CƯỚC SỐ HÓA CAO CẤP PHÁT QUANG */
        .national-card { background: linear-gradient(135deg, #111827 0%, #1f2937 50%, #030712 100%); border: 2px solid #4b5563; position: relative; overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.7), inset 0 1px 2px rgba(255,255,255,0.15); border-radius: 16px; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        .national-card::before { content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: linear-gradient(45deg, transparent, rgba(255,255,255,0.03), transparent); transform: rotate(45deg); pointer-events: none; }
        .national-card:hover { transform: translateY(-6px) scale(1.01); border-color: #f59e0b; box-shadow: 0 25px 50px rgba(245, 158, 11, 0.15); }
        .card-chip { width: 42px; height: 32px; background: linear-gradient(135deg, #fcd34d 0%, #b45309 100%); border-radius: 6px; position: relative; border: 1px solid #d97706; box-shadow: 0 0 10px rgba(217, 119, 6, 0.3); }
        .card-chip::after { content: ''; position: absolute; inset: 5px; border: 1px solid rgba(0,0,0,0.25); border-radius: 3px; background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.05) 2px, rgba(0,0,0,0.05) 4px); }
        
        /* KHUNG CHAT BOT AI */
        #bot-zone { background: linear-gradient(180deg, #0f172a 0%, #020617 100%); border: 1px solid #1e293b; border-radius: 16px; }
        
        /* ĐƯỜNG CUỘN ĐẸP */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #030712; }
        ::-webkit-scrollbar-thumb { background: #1f2937; border-radius: 99px; }
        ::-webkit-scrollbar-thumb:hover { background: #374151; }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between">

    <div>
        <header class="bg-[#090d1a] border-b border-gray-800 px-6 py-4 flex flex-wrap justify-between items-center shadow-2xl relative">
            <div class="flex items-center space-x-4">
                <div class="relative flex items-center justify-center">
                    <div class="absolute inset-0 bg-red-600/30 blur-xl rounded-full animate-pulse"></div>
                    <div class="bg-gradient-to-br from-red-600 via-amber-500 to-yellow-500 p-3 rounded-2xl text-black border border-amber-400 shadow-xl z-10">
                        <i class="fa-solid fa-building-columns text-2xl text-white drop-shadow"></i>
                    </div>
                </div>
                <div>
                    <span class="text-[10px] tracking-widest text-amber-500 uppercase font-black font-mono-tech block">QUỐC VỤ LIÊN THÔNG REALTIME PLATFORM</span>
                    <h1 class="text-2xl font-extrabold text-white tracking-tight flex items-center gap-2">CỔNG DỊCH VỤ CÔNG QUỐC GIA <span class="text-xs font-mono bg-red-950 text-red-400 border border-red-800 px-2 py-0.5 rounded-md font-bold">V2.0-ULTRA</span></h1>
                </div>
            </div>

            <div class="flex items-center space-x-4 text-xs mt-3 lg:mt-0">
                <div id="officer-alert-light" onclick="jumpToActiveNotification()" class="hidden bg-red-950/80 border border-red-500 px-3 py-2 rounded-xl flex items-center gap-2 animate-pulse cursor-pointer shadow-[0_0_15px_rgba(239,68,68,0.2)]">
                    <span class="h-2.5 w-2.5 rounded-full bg-red-500 shadow-[0_0_12px_#ef4444]"></span>
                    <span id="alert-light-text" class="text-red-400 font-extrabold text-[11px] tracking-wider uppercase">CÓ HỒ SƠ / BIÊN BẢN CẦN THẨM ĐỊNH</span>
                </div>
                <div class="bg-[#111827] px-4 py-2 rounded-xl border border-gray-800 font-mono text-amber-400 font-black tracking-widest text-sm shadow-inner" id="clock">00:00:00</div>
                <div class="bg-[#111827] px-3 py-2 rounded-xl border border-gray-800 flex items-center gap-2">
                    <i class="fa-solid fa-shield-halved text-emerald-400 animate-pulse"></i>
                    <span id="security-txt" class="font-black text-[11px] tracking-wider uppercase text-emerald-400"><%= state.securityLevel %></span>
                </div>
                <div id="auth-panel"></div>
            </div>
        </header>

        <div class="marquee-container py-2 flex items-center">
            <div class="bg-red-700 text-white font-black text-[10px] px-2.5 py-0.5 rounded-md uppercase tracking-widest mx-4 z-10 shadow-md border border-red-500 animate-pulse">CHỈ THỊ KHẨN</div>
            <div class="marquee-content" id="live-marquee"><%= state.tickerMessage %></div>
        </div>

        <nav class="bg-[#090d1a]/90 border-b border-gray-800 px-6 py-1 flex flex-wrap gap-1 backdrop-blur-xl sticky top-0 z-40">
            <button onclick="tab('tab-news')" id="btn-tab-news" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-amber-500 text-amber-500 transition-all duration-200"><i class="fa-solid fa-layer-group mr-1.5"></i> Trung Tâm Sắc Lệnh</button>
            <button onclick="tab('tab-id')" id="btn-tab-id" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-gray-400 hover:text-white transition-all duration-200"><i class="fa-solid fa-fingerprint mr-1.5"></i> Tra cứu dân cư</button>
            <button onclick="tab('tab-cards')" id="btn-tab-cards" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-sky-400 hover:text-sky-300 transition-all duration-200"><i class="fa-solid fa-id-card mr-1.5"></i> Kết Xuất Phôi Hành Chính</button>
            <button onclick="tab('tab-services')" id="btn-tab-services" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-purple-400 hover:text-purple-300 transition-all duration-200"><i class="fa-solid fa-paste mr-1.5"></i> Cổng Nộp Đơn Trực Tuyến</button>
            <button onclick="tab('tab-officer')" id="btn-tab-officer" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-emerald-400 hover:text-emerald-300 hidden relative transition-all duration-200">
                <i class="fa-solid fa-briefcase mr-1.5"></i> Bàn Làm Việc Bộ Ngành 
                <span id="badge-count-app" class="absolute top-2 right-1.5 bg-red-600 text-white text-[9px] font-black px-1.5 py-0.5 rounded-full shadow animate-bounce hidden">0</span>
            </button>
            <button onclick="tab('tab-admin')" id="btn-tab-admin" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-red-400 hover:text-red-300 hidden transition-all duration-200"><i class="fa-solid fa-gavel mr-1.5"></i> Giám Sát Tối Cao Tòa Án/Admin</button>
        </nav>

        <main class="p-6 max-w-[1700px] w-full mx-auto space-y-6">
            
            <section id="tab-news" class="grid grid-cols-1 xl:grid-cols-4 gap-6">
                <div class="xl:col-span-2 space-y-4">
                    <h2 class="text-xs font-black text-gray-400 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-2"><i class="fa-solid fa-scroll text-amber-500 text-sm"></i> Văn Bản Chỉ Thị Thượng Cấp</h2>
                    <div id="news-feed" class="space-y-3"></div>
                </div>
                <div class="space-y-4">
                    <h2 class="text-xs font-black text-red-400 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-2"><i class="fa-solid fa-triangle-exclamation text-sm"></i> Danh Sách Truy Nã Đặc Biệt</h2>
                    <div id="wanted-feed" class="space-y-3"></div>
                </div>
                <div class="space-y-4">
                    <h2 class="text-xs font-black text-teal-400 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-2"><i class="fa-solid fa-robot text-sm text-teal-400 animate-pulse"></i> Trợ Lý Số Hóa Tuệ Đức Quốc Vụ</h2>
                    <div id="bot-zone" class="p-4 flex flex-col justify-between h-[420px] shadow-2xl">
                        <div id="bot-chat-flow" class="flex-1 overflow-y-auto space-y-2.5 pr-1 text-xs">
                            <div class="bg-teal-950/40 border border-teal-900/60 p-2.5 rounded-xl text-teal-300">
                                <span class="font-black text-[10px] uppercase block text-teal-400"><i class="fa-solid fa-robot"></i> Tuệ Đức Quốc Vụ</span>
                                Xin chào công dân! Tôi có thể tra cứu thủ tục, kiểm tra lý lịch định danh khẩn cấp tại cổng liên thông quốc gia. Hãy nhập câu hỏi phía dưới.
                            </div>
                        </div>
                        <div class="pt-2 border-t border-gray-800 flex gap-2">
                            <input type="text" id="bot-input" placeholder="Hỏi về thủ tục Căn Cước, Vũ Khí, Khiếu Nại..." class="flex-1 bg-gray-950 border border-gray-700 p-2 text-xs text-white rounded-xl focus:outline-none focus:border-teal-500 font-medium">
                            <button onclick="askAiBot()" class="bg-teal-600 hover:bg-teal-700 text-white font-black px-4 text-xs rounded-xl uppercase tracking-wider transition-all">Hỏi</button>
                        </div>
                    </div>
                </div>
            </section>

            <section id="tab-id" class="hidden max-w-3xl mx-auto bg-[#090d1a] border border-gray-800 p-6 rounded-2xl shadow-2xl">
                <h2 class="text-sm font-black text-center text-white uppercase tracking-widest mb-4 flex items-center justify-center gap-2"><i class="fa-solid fa-user-shield text-amber-500"></i> Hệ Thống Tra Cứu Thông Tin Dân Cư Lõi</h2>
                <div class="flex gap-2 mb-4">
                    <input type="text" id="id-search" placeholder="Nhập mã tài khoản cư dân định danh (Ví dụ: Nguyen_Manh_Hoang)..." class="flex-1 bg-gray-950 border border-gray-700 px-4 py-2.5 text-sm rounded-xl text-white font-mono focus:outline-none focus:border-amber-500">
                    <button onclick="searchCitizen()" class="bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-600 hover:to-amber-700 text-black px-6 text-xs font-black uppercase rounded-xl shadow-lg tracking-wider">Truy Xuất</button>
                </div>
                <div id="id-result"></div>
            </section>

            <section id="tab-cards" class="hidden max-w-6xl mx-auto space-y-6">
                <div class="bg-[#090d1a] border border-gray-800 p-6 rounded-2xl shadow-xl max-w-xl mx-auto">
                    <h2 class="text-xs font-black text-center text-sky-400 uppercase tracking-widest mb-4 flex items-center justify-center gap-2"><i class="fa-solid fa-passport text-sky-500"></i> Xuất Đồ Họa Căn Cước & Giấy Phép Nghiệp Vụ</h2>
                    <div class="flex gap-2">
                        <input type="text" id="card-search-input" placeholder="Nhập tài khoản cư dân (Họ_Tên)..." class="flex-1 bg-gray-950 border border-gray-700 px-3 py-2.5 text-sm rounded-xl text-white font-mono focus:outline-none">
                        <button onclick="generateCitizenCards()" class="bg-sky-600 hover:bg-sky-700 text-white px-5 text-xs font-black uppercase rounded-xl tracking-wider shadow-md">Kết Xuất Phôi</button>
                    </div>
                </div>

                <div class="space-y-4">
                    <h3 class="text-xs font-black uppercase text-gray-400 tracking-widest flex items-center gap-2"><i class="fa-solid fa-id-card text-sky-400"></i> Bản Vẽ Phôi Căn Cước Công Dân Gắn Chíp & Giấy Phép Bộ Ngành</h3>
                    <div id="cards-render-zone" class="grid grid-cols-1 md:grid-cols-2 gap-6 justify-center items-center">
                        <p class="text-center text-xs text-gray-500 col-span-2 py-12">Chưa có dữ liệu kết xuất. Hãy nhập tài khoản cư dân hệ thống phía trên.</p>
                    </div>
                </div>

                <div class="space-y-4">
                    <h3 class="text-xs font-black uppercase text-red-400 tracking-widest flex items-center gap-2"><i class="fa-solid fa-gavel text-red-500"></i> Lịch Sử Xử Lý Tư Pháp & Biên Bản Vi Phạm Quốc Gia</h3>
                    <div id="violation-render-zone" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <p class="text-center text-xs text-gray-500 col-span-2 py-6">Lý lịch tư pháp trống.</p>
                    </div>
                </div>
            </section>

            <section id="tab-services" class="hidden grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="bg-[#090d1a] border border-gray-800 p-5 rounded-2xl space-y-4 shadow-xl">
                    <h3 class="text-xs font-black text-gray-300 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-1.5"><i class="fa-solid fa-file-signature text-amber-500"></i> Khởi Tạo Hồ Sơ Trực Tuyến Liên Thông</h3>
                    <form onsubmit="submitForm(event)" class="space-y-4 text-xs">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                            <div class="md:col-span-1">
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Mã Tài Khoản (Họ_Tên)</label>
                                <input type="text" id="app-sender" required placeholder="Nguyen_Manh_Hoang" class="w-full bg-gray-950 border border-gray-700 p-2.5 rounded-xl text-white font-mono focus:outline-none">
                            </div>
                            <div class="md:col-span-1">
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Thủ Tục Đăng Ký</label>
                                <select id="app-docType" class="w-full bg-gray-950 border border-gray-700 p-2.5 rounded-xl text-white font-bold text-amber-400 focus:outline-none">
                                    <option value="CĂN CƯỚC CÔNG DÂN">Căn Cước Công Dân Gắn Chíp</option>
                                    <option value="GIẤY PHÉP SỬ DỤNG CÔNG CỤ HỖ TRỢ">Giấy Phép Sử Dụng Vũ Khí / CCHT</option>
                                    <option value="HỘ CHIẾU QUỐC TẾ">Hộ Chiếu Quốc Tế (Visa)</option>
                                    <option value="GIẤY PHÉP KINH DOANH DOANH NGHIỆP">Giấy Phép Thành Lập Doanh Nghiệp</option>
                                    <option value="ĐĂNG KÝ SỬ DỤNG TẦN SỐ BỘ ĐÀM">Đăng Ký Tần Số Bộ Đàm Quốc Gia</option>
                                    <option value="GIẤY PHÉP VẬN TẢI LOGISTICS">Giấy Phép Vận Tải / Logistics</option>
                                </select>
                            </div>
                            <div class="md:col-span-1">
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Mức Độ Khẩn</label>
                                <select id="app-priority" class="w-full bg-gray-950 border border-gray-700 p-2.5 rounded-xl text-white font-bold text-red-400 focus:outline-none">
                                    <option value="BÌNH THƯỜNG">Bình Thường (Tiêu chuẩn)</option>
                                    <option value="HỎA TỐC">Hỏa Tốc (Ưu tiên xử lý)</option>
                                    <option value="THƯỢNG KHẨN">Thượng Khẩn Quốc Gia</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Cơ Quan Thẩm Định Chỉ Định</label>
                            <select id="app-agency" class="w-full bg-gray-950 border border-gray-700 p-2.5 rounded-xl text-white font-bold text-sky-400 focus:outline-none">
                                <option value="CHÍNH PHỦ">VĂN PHÒNG CHÍNH PHỦ TỐI CAO</option>
                                <option value="THANH TRA">THANH TRA CHÍNH PHỦ</option>
                                <option value="CÔNG AN">BỘ CÔNG AN QUỐC GIA</option>
                                <option value="QUÂN ĐỘI">BỘ CHỈ HUY QUÂN SỰ TRƯỞNG</option>
                                <option value="TOÀ ÁN">TÒA ÁN NHÂN DÂN TỐI CAO</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Nội Dung Thuyết Minh Chi Tiết Kịch Bản</label>
                            <textarea id="app-content" rows="4" required placeholder="Ghi rõ thông tin yêu cầu giải quyết kịch bản lý do chi tiết..." class="w-full bg-gray-950 border border-gray-700 p-2.5 rounded-xl text-white focus:outline-none focus:border-amber-500 font-medium"></textarea>
                        </div>
                        <button type="submit" class="w-full bg-gradient-to-r from-amber-500 to-yellow-500 font-black text-black py-3 rounded-xl uppercase tracking-widest shadow-lg hover:from-amber-600 transition-all">Ký Gửi Đơn Lên Trục Hệ Thống</button>
                    </form>
                </div>

                <div class="bg-[#090d1a] border border-gray-800 p-5 rounded-2xl flex flex-col h-full min-h-[480px] shadow-xl">
                    <h3 class="text-xs font-black text-gray-300 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-1.5"><i class="fa-solid fa-satellite-dish text-sky-400 animate-pulse"></i> Cổng Thẩm Vấn & Tra Cứu Hồ Sơ Trực Tuyến</h3>
                    <div class="flex gap-2 my-3">
                        <input type="text" id="track-id" placeholder="Nhập chính xác mã đơn (Ví dụ: HS-1001)..." class="flex-1 bg-gray-950 border border-gray-700 px-3 py-2 text-xs rounded-xl text-white font-mono focus:outline-none">
                        <button onclick="trackApplication()" class="bg-sky-600 hover:bg-sky-700 text-white px-5 text-xs font-black rounded-xl uppercase tracking-wider transition-all">Truy Vấn</button>
                    </div>
                    <div id="track-details" class="flex-1 flex flex-col justify-between hidden space-y-3"></div>
                    <div id="track-empty" class="text-center py-24 text-gray-500 text-xs flex-1 flex flex-col justify-center items-center"><i class="fa-solid fa-folder-open text-4xl mb-3 text-gray-700"></i> Vui lòng điền mã đơn hành chính để mở kênh đàm thoại tương tác với Cán bộ chuyên trách.</div>
                </div>
            </section>

            <section id="tab-officer" class="hidden grid grid-cols-1 xl:grid-cols-3 gap-6">
                <div class="xl:col-span-2 space-y-5">
                    <div class="bg-[#090d1a] border border-gray-800 p-4 rounded-2xl shadow-xl">
                        <div class="flex flex-wrap justify-between items-center mb-3 gap-2">
                            <h3 class="text-xs font-black text-emerald-400 uppercase tracking-wider flex items-center gap-2"><i class="fa-solid fa-folder-closed"></i> Thống Kê Đơn Thư Luồng Liên Thông Đơn Vị</h3>
                            <span id="office-badge" class="text-[10px] font-mono font-bold bg-emerald-950/60 text-emerald-400 px-3 py-1 rounded-xl border border-emerald-800/80">Cơ Quan Tiếp Nhận Thẩm Định</span>
                        </div>
                        <div class="overflow-x-auto text-xs">
                            <table class="w-full text-left">
                                <thead class="bg-gray-950 text-gray-400 font-bold uppercase text-[9px] tracking-widest border-b border-gray-800">
                                    <tr>
                                        <th class="p-3">Mã Hồ Sơ</th>
                                        <th class="p-3">Cư Dân</th>
                                        <th class="p-3">Nghiệp Vụ</th>
                                        <th class="p-3">Độ Khẩn</th>
                                        <th class="p-3">Trạng Thái</th>
                                        <th class="p-3 text-right">Thao Tác</th>
                                    </tr>
                                </thead>
                                <tbody id="officer-table" class="divide-y divide-gray-800/60"></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="bg-[#090d1a] border border-gray-800 p-5 rounded-2xl space-y-4 shadow-xl">
