                            <div class="grid grid-cols-2 gap-2">
                                <div>
                                    <label class="text-gray-400 block mb-1 font-bold">Cấp Phân Quyền</label>
                                    <select id="p-role" class="w-full bg-gray-950 border border-gray-800 p-2.5 rounded-xl text-white font-bold focus:outline-none">
                                        <option value="CHUYÊN VIÊN">CHUYÊN VIÊN TIẾP NHẬN</option>
                                        <option value="LÃNH ĐẠO">LÃNH ĐẠO ĐƠN VỊ</option>
                                        <option value="THANH TRA">THANH TRA CHÍNH PHỦ</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="text-gray-400 block mb-1 font-bold">Đơn Vị Ban Ngành</label>
                                    <select id="p-agency" class="w-full bg-gray-950 border border-gray-800 p-2.5 rounded-xl text-white font-bold focus:outline-none">
                                        <option value="CÔNG AN">BỘ CÔNG AN</option>
                                        <option value="QUÂN ĐỘI">BỘ CHỈ HUY QUÂN SỰ</option>
                                        <option value="THANH TRA">THANH TRA CHÍNH PHỦ</option>
                                        <option value="CHÍNH PHỦ">VĂN PHÒNG CHÍNH PHỦ</option>
                                    </select>
                                </div>
                            </div>
                            <div class="flex gap-2 pt-2">
                                <button type="button" id="btn-cancel-edit" onclick="resetProvisionForm()" class="bg-gray-800 text-gray-400 font-bold px-4 rounded-xl uppercase text-[11px] hidden">Hủy</button>
                                <button type="submit" id="btn-submit-provision" class="flex-1 bg-purple-600 text-white font-black py-2.5 rounded-xl uppercase shadow-md transition-all">Kích Hoạt Quyền</button>
                            </div>
                        </form>
                    </div>
                    <div class="xl:col-span-2 bg-[#0a0f24] border border-gray-800 p-5 rounded-2xl flex flex-col h-full shadow-xl border-red-900/30">
                        <h3 class="text-xs font-black text-red-400 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-1.5"><i class="fa-solid fa-terminal text-xs animate-pulse"></i> Nhật Ký Trục Lõi Liên Thông Toàn Quốc (Thời Gian Thực - Realtime)</h3>
                        <div id="admin-system-logs" class="flex-1 space-y-2 mt-3 font-mono text-[11px] overflow-y-auto max-h-[280px] bg-black p-3 rounded-xl border border-gray-900 shadow-inner"></div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <footer class="mt-12 bg-[#04060d] border-t-2 border-cyan-900/80 py-6 px-6 text-center shadow-inner">
        <div class="max-w-4xl mx-auto space-y-2">
            <div class="flex justify-center items-center gap-2 text-cyan-500 font-black tracking-widest text-[11px] uppercase"><i class="fa-solid fa-triangle-exclamation animate-pulse"></i> ĐIỀU KHOẢN PHÁP LÝ GIẢ LẬP NHẬP VAI ĐỘC QUYỀN ROBLOX V6 <i class="fa-solid fa-triangle-exclamation animate-pulse"></i></div>
            <p class="text-xs text-gray-400 font-bold leading-relaxed tracking-wide uppercase">CẢNH BÁO: Đây là trang mô phỏng số hóa phục vụ kịch bản giải trí nhập vai của cộng đồng game trên nền tảng Roblox. Toàn bộ thông tin, con dấu, văn bằng hoàn toàn không có giá trị thật ngoài đời thực.</p>
            <div class="text-[10px] text-gray-600 font-mono pt-1">&copy; 2026 Gaming Simulator Project. Powered by Central Core System. All Simulated Rights Reserved.</div>
        </div>
    </footer>

    <div id="login-modal" class="fixed inset-0 bg-black/95 backdrop-blur-md flex items-center justify-center hidden p-4 z-50">
        <div class="bg-[#050814] border border-gray-800 p-6 rounded-2xl max-w-sm w-full space-y-4 text-xs shadow-2xl relative">
            <div class="text-center space-y-1"><i class="fa-solid fa-fingerprint text-4xl text-cyan-500 mb-1 animate-pulse"></i><h3 class="text-sm font-black text-white uppercase tracking-widest">Xác Thực Chứng Thư Nghiệp Vụ Gốc</h3></div>
            <div><label class="text-gray-400 block mb-1 font-bold">Mã Định Danh Cán Bộ</label><input type="text" id="log-user" class="w-full bg-gray-950 border border-gray-800 p-2.5 rounded-xl text-white font-mono focus:outline-none"></div>
            <div><label class="text-gray-400 block mb-1 font-bold">Mật Mã Hệ Thống</label><input type="password" id="log-pass" class="w-full bg-gray-950 border border-gray-800 p-2.5 rounded-xl text-white focus:outline-none"></div>
            <div class="flex gap-2 pt-2"><button onclick="closeLogin()" class="w-1/3 bg-gray-800 text-gray-400 py-2.5 rounded-xl uppercase font-black">Hủy</button><button onclick="login()" class="w-2/3 bg-gradient-to-r from-cyan-500 to-blue-600 text-white py-2.5 rounded-xl uppercase font-black">Xác Thực</button></div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/theme-matrix.js"></script>
    <script>
        const socket = io();
        let state = {}; let registry = {}; let violations = {}; 
        let activeUser = null; let activeFileId = null;

        function startClock() { setInterval(() => { document.getElementById('clock').innerText = new Date().toLocaleTimeString('vi-VN'); }, 1000); }

        socket.on('initData', (data) => { updateDataAndRender(data); checkAndRestoreSession(); });
        socket.on('stateUpdate', (data) => { updateDataAndRender(data); });
        socket.on('newApplicationAlert', (appInfo) => {
            if (activeUser && (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ' || appInfo.agency === activeUser.agency)) {
                document.getElementById('officer-alert-light').classList.remove('hidden'); 
                if(typeof AudioCentral !== 'undefined') AudioCentral.alert();
            }
        });
        socket.on('newChatMessage', (chatInfo) => {
            if (document.getElementById('track-id').value == chatInfo.fileId) trackApplication();
            if (activeFileId == chatInfo.fileId) renderOfficerDesk();
        });

        function updateDataAndRender(data) {
            state = data.systemState; registry = data.citizenIdentityRegistry; violations = data.criminalRecordsRegistry;
            if (activeUser) activeUser = state.authorizedPersonnel[activeUser.username];
            
            if (activeUser) {
                let filtered = Object.values(state.applications).filter(a => {
                    if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ') return true;
                    return a.agency === activeUser.agency;
                });
                const badgeCount = document.getElementById('badge-count-app');
                if (filtered.length > 0) { badgeCount.innerText = filtered.length; badgeCount.classList.remove('hidden'); } 
                else { badgeCount.classList.add('hidden'); }
            }
            renderAll();
            if (activeFileId) renderOfficerDesk();
        }

        function checkAndRestoreSession() {
            let savedSession = localStorage.getItem('sessionUser');
            if(savedSession) {
                try {
                    let creds = JSON.parse(savedSession);
                    if (state.authorizedPersonnel[creds.username] && state.authorizedPersonnel[creds.username].password === creds.password) {
                        activeUser = state.authorizedPersonnel[creds.username];
                        applyUserRoleLayout();
                    }
                } catch(e) { localStorage.removeItem('sessionUser'); }
            } else { renderAuth(); }
        }

        function jumpToActiveNotification() { tab('tab-officer'); document.getElementById('officer-alert-light').classList.add('hidden'); }

        function tab(id) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            document.getElementById(id).classList.remove('hidden');
            document.querySelectorAll('nav button').forEach(b => { b.classList.remove('border-cyan-500', 'text-cyan-500'); b.classList.add('border-transparent', 'text-gray-400'); });
            const btn = document.getElementById(`btn-${id}`);
            if(btn) { btn.classList.remove('border-transparent', 'text-gray-400'); btn.classList.add('border-cyan-500', 'text-cyan-500'); }
            if (id === 'tab-officer') { document.getElementById('officer-alert-light').classList.add('hidden'); subtab('sub-app'); }
            sessionStorage.setItem('activeTab', id);
        }

        function subtab(subId) {
            ['sub-app', 'sub-transfer', 'sub-licensing', 'sub-vio', 'sub-reg', 'sub-rpt'].forEach(id => document.getElementById(id).classList.add('hidden'));
            document.getElementById(subId).classList.remove('hidden');
            document.querySelectorAll('[id^="btn-sub-"]').forEach(btn => { btn.classList.remove('sub-active'); btn.classList.add('border-transparent', 'text-gray-400'); });
            document.getElementById(`btn-${subId}`).classList.add('sub-active');
        }

        async function askAiBot() {
            const msg = document.getElementById('bot-input').value.trim();
            if(!msg) return;
            const flow = document.getElementById('bot-chat-flow');
            flow.innerHTML += `<div class="bg-gray-800 p-2.5 rounded-xl text-right text-gray-200"><span class="text-[9px] block text-gray-500 font-bold">Cư Dân</span>${msg}</div>`;
            document.getElementById('bot-input').value = '';
            
            const res = await fetch('/api/bot/chat', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }) });
            const data = await res.json();
            
            setTimeout(() => {
                flow.innerHTML += `<div class="bg-teal-950/40 border border-teal-900/40 p-2.5 rounded-xl text-teal-300"><b class="block text-[10px] text-teal-400 uppercase"><i class="fa-solid fa-robot"></i> Tuệ Đức v6</b>${data.reply}</div>`;
                flow.scrollTop = flow.scrollHeight;
                if(typeof AudioCentral !== 'undefined') AudioCentral.success();
            }, 100);
        }

        async function submitShiftReport(e) {
            e.preventDefault();
            const taskStatus = document.getElementById('rpt-taskStatus').value;
            const content = document.getElementById('rpt-content').value.trim();
            await fetch('/api/officer/report', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ officer: activeUser.displayName, agency: activeUser.agency, taskStatus, content }) });
            document.getElementById('rpt-content').value = ''; 
            if(typeof AudioCentral !== 'undefined') AudioCentral.success();
            alert('Nhật ký tiến độ công việc hàng ngày đã được nộp phê duyệt!');
        }

        async function submitLicensingForm(e) {
            e.preventDefault();
            const username = document.getElementById('lic-user').value.trim();
            const licenseName = document.getElementById('lic-name').value;
            const issueAgency = document.getElementById('lic-agency').value.trim();
            const signOfficer = document.getElementById('lic-officer').value.trim();
            const duration = document.getElementById('lic-duration').value.trim();
            const res = await fetch('/api/resident/add-license', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, licenseName, issueAgency, signOfficer, duration }) });
            if(res.ok) {
                document.getElementById('lic-user').value = ''; document.getElementById('lic-agency').value = ''; document.getElementById('lic-officer').value = ''; document.getElementById('lic-duration').value = '';
                if(typeof AudioCentral !== 'undefined') AudioCentral.stamp();
                alert(`Đóng dấu phôi và phê duyệt cấp văn bằng [${licenseName}] thành công!`);
            } else { alert("Không tìm thấy tài khoản công dân trên hệ thống."); }
        }

        async function submitViolationForm(e) {
            e.preventDefault();
            const username = document.getElementById('vio-user').value.trim(); const type = document.getElementById('vio-type').value; const lawClause = document.getElementById('vio-clause').value.trim(); const fine = document.getElementById('vio-fine').value.trim() || "0 VND"; const status = document.getElementById('vio-status').value;
            await fetch('/api/resident/violation', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, type, lawClause, fine, status, officerName: activeUser.displayName }) });
            document.getElementById('vio-user').value = ''; document.getElementById('vio-clause').value = ''; document.getElementById('vio-fine').value = '';
            if(typeof AudioCentral !== 'undefined') AudioCentral.stamp();
            alert(`Đã ấn ký ban hành biên bản xử lý vi phạm kịch bản.`);
        }

        async function executeForwardApplication() {
            if(!activeFileId) { alert("Vui lòng mở xem hồ sơ cụ thể cần luân chuyển ở phòng thẩm định bên phải."); return; }
            const targetAgency = document.getElementById('transfer-target-agency').value;
            const res = await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: activeFileId, action: 'forward', targetAgency, officerName: activeUser.displayName, officerRole: activeUser.role }) });
            if(res.ok) {
                if(typeof AudioCentral !== 'undefined') AudioCentral.stamp(); 
                alert(`Đã thực thi luân chuyển hồ sơ mang số định danh sang cơ quan [${targetAgency}].`);
                activeFileId = null;
                document.getElementById('officer-desk-active').classList.add('hidden');
                document.getElementById('officer-desk-empty').classList.remove('hidden');
            }
        }

        function generateCitizenCards() {
            const username = document.getElementById('card-search-input').value.trim();
            const zone = document.getElementById('cards-render-zone'); const vioZone = document.getElementById('violation-render-zone');
            if(!registry[username]) {
                zone.innerHTML = `<p class="text-center text-xs text-red-500 font-bold col-span-2 py-6 bg-red-950/20 border border-red-900/30 rounded-xl">⚠️ KHÔNG TÌM THẤY PHÔI GIẤY TỜ KHỞI TẠO CHO CƯ DÂN TRÊN TRỤC DB QUỐC GIA.</p>`;
                vioZone.innerHTML = ''; return;
            }
            const citizen = registry[username];
            if(typeof AudioCentral !== 'undefined') AudioCentral.success();
            
            zone.innerHTML = `
                <div class="national-card w-full max-w-md p-6 text-gray-100 font-sans space-y-4 border-cyan-500/30 relative">
                    <div class="flex justify-between items-start border-b border-cyan-500/20 pb-2.5">
                        <div>
                            <h4 class="text-[10px] font-black tracking-wider text-cyan-400 uppercase">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</h4>
                            <p class="text-[8px] font-bold text-gray-400 uppercase tracking-widest mt-0.5">CĂN CƯỚC CÔNG DÂN / CITIZEN IDENTITY</p>
                        </div>
                        <i class="fa-solid fa-star text-amber-400 text-lg"></i>
                    </div>
                    <div class="flex gap-4 items-center">
                        <div class="w-22 h-28 bg-gray-950 border border-gray-800 flex flex-col items-center justify-center rounded-2xl text-gray-700 relative overflow-hidden">
                            <i class="fa-solid fa-user text-5xl mt-4 text-gray-800"></i>
                            <div class="absolute bottom-0 w-full bg-cyan-500/20 text-[8px] font-mono font-black text-center text-cyan-400 py-1 border-t border-cyan-500/20">ROBLOX CORE</div>
                        </div>
                        <div class="flex-1 text-[11px] space-y-1.5">
                            <p class="font-mono text-cyan-400 font-black text-xs">Số / No: <span class="text-white tracking-widest font-black">0680${1000 + Math.floor(Math.random() * 9000)}</span></p>
                            <p class="text-gray-400 font-bold">Họ và tên: <span class="text-sm font-black text-white uppercase block">${citizen.name}</span></p>
                            <p class="text-gray-400 font-bold">Ngày sinh: <span class="text-white font-mono">${citizen.dob}</span> | Giới tính: <span class="text-white">${citizen.gender}</span></p>
                            <p class="text-gray-400 font-bold">Nguyên quán: <span class="text-white text-[10px] block">${citizen.pob}</span></p>
                        </div>
                    </div>
                    <div class="flex justify-between items-center pt-2.5 border-t border-gray-800">
                        <div class="card-chip"></div>
                        <span class="text-[9px] font-black bg-emerald-950 text-emerald-400 border border-emerald-800 px-2.5 py-0.5 rounded-lg uppercase tracking-wider">${citizen.status}</span>
                    </div>
                </div>
            `;
            citizen.licenses.forEach(lic => {
                zone.innerHTML += `
                    <div class="national-card w-full max-w-md p-5 border-emerald-500/30 text-gray-100 font-sans space-y-3 shadow-2xl relative">
                        <div class="flex justify-between items-center border-b border-emerald-500/20 pb-1.5"><span class="text-[9px] font-black font-mono tracking-widest text-emerald-400 uppercase"><i class="fa-solid fa-shield mr-1"></i> VĂN BẰNG ĐIỆN TỬ BAN NGÀNH CHÍNH PHỦ SỐ</span></div>
                        <div class="p-3 bg-black/60 border border-gray-800 rounded-xl space-y-1 text-[11px] font-medium text-gray-300">
                            <p class="text-cyan-400 font-black text-xs"><i class="fa-solid fa-certificate"></i> ${lic}</p>
                            <p class="text-[10px] text-gray-500 font-bold uppercase mt-1">Ấn dấu phôi chứng thư an toàn kịch bản</p>
                        </div>
                    </div>
                `;
            });
            let vioHtml = '';
            if (violations[username] && violations[username].length > 0) {
                violations[username].forEach(v => {
                    vioHtml += `
                        <div class="border border-red-900/60 bg-red-950/10 p-4 rounded-xl space-y-2 shadow-lg">
                            <div class="flex justify-between items-center border-b border-red-900/40 pb-2"><span class="text-xs font-black text-red-500 font-mono">BIÊN BẢN HÌNH PHẠT: ${v.id}</span></div>
                            <div class="text-[11px] space-y-1">
                                <p class="text-gray-400 font-bold">Cơ quan xử lý: <span class="text-white font-black">${v.type}</span></p>
                                <p class="text-gray-400 font-bold">Nội dung luật: <span class="text-amber-500 font-medium block mt-0.5 bg-black/40 p-1.5 rounded border border-gray-800">${v.lawClause}</span></p>
                                <p class="text-gray-400 font-bold">Khung phạt: <b class="text-yellow-500 font-mono text-xs">${v.fine}</b></p>
                            </div>
                            <div class="pt-2 border-t border-red-900/20"><span class="text-[11px] font-black uppercase text-center text-white bg-red-900 border border-red-700 py-1 rounded block shadow-md">Tình trạng: [${v.status}]</span></div>
                        </div>
                    `;
                });
            } else { vioHtml = `<p class="text-center text-xs text-emerald-400 font-bold col-span-2 py-6 bg-emerald-950/10 border border-emerald-900/30 rounded-xl"><i class="fa-solid fa-circle-check"></i> LÝ LỊCH TƯ PHÁP TRONG SẠCH - CHƯA PHÁT HIỆN TIỀN ÁN KỊCH BẢN.</p>`; }
            vioZone.innerHTML = vioHtml;
        }

        function renderAll() {
            if(!state.announcements) return;
            document.getElementById('live-marquee').innerText = state.tickerMessage;
            document.getElementById('security-txt').innerText = state.securityLevel;
            
            const feed = document.getElementById('news-feed'); feed.innerHTML = '';
            state.announcements.forEach(a => {
                feed.innerHTML += `
                    <div class="bg-[#0a0f24] border border-gray-800 p-4 rounded-xl shadow-md">
                        <span class="text-[9px] font-black text-cyan-400 uppercase bg-cyan-950 px-2 py-0.5 rounded border border-cyan-800">${a.type}</span>
                        <h4 class="text-sm font-black text-white mt-1.5">${a.title}</h4>
                        <p class="text-xs text-gray-400 font-medium mt-1 leading-relaxed">${a.content}</p>
                    </div>
                `;
            });
            const wanted = document.getElementById('wanted-feed'); wanted.innerHTML = '';
            state.criminalWantedList.forEach(c => {
                wanted.innerHTML += `<div class="bg-red-950/20 border border-red-900/50 p-3 rounded-xl"><p class="text-xs text-red-400 font-black"><i class="fa-solid fa-bullseye"></i> TRUY NÃ: @${c.name}</p><p class="text-xs text-gray-300 font-medium mt-1">Tội danh: ${c.crime}</p></div>`;
            });
            if (activeUser) {
                document.getElementById('office-badge').innerText = `CƠ QUAN CHỦ QUẢN: [${activeUser.agency}] — CÁN BỘ THỤ LÝ: ${activeUser.displayName} [${activeUser.role}]`;
                const tbody = document.getElementById('officer-table'); tbody.innerHTML = '';
                Object.values(state.applications).forEach(app => {
                    if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ' || app.agency === activeUser.agency) {
                        tbody.innerHTML += `
                            <tr class="hover:bg-gray-900/40 border-b border-gray-800 text-xs transition-all">
                                <td class="p-3 font-black font-mono text-cyan-400">${app.id}</td>
                                <td class="p-3 font-bold">@${app.sender}</td>
                                <td class="p-3"><span class="bg-gray-800 text-gray-300 px-2 py-0.5 rounded border border-gray-700 font-bold">${app.docType}</span></td>
                                <td class="p-3 font-black"><span class="text-red-400 font-mono text-[10px] bg-red-950/40 px-1.5 py-0.5 rounded border border-red-900/40">${app.priority}</span></td>
                                <td class="p-3 text-right"><button onclick="selectFile('${app.id}')" class="bg-emerald-600 hover:bg-emerald-700 font-black text-white px-3 py-1 rounded-lg text-[11px] shadow">Thẩm Định</button></td>
                            </tr>
                        `;
                    }
                });
                const rptFeed = document.getElementById('shift-reports-feed');
                if(rptFeed) {
                    rptFeed.innerHTML = '';
                    state.shiftReports.forEach(r => {
                        let isLead = (activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN');
                        let actionBtns = (isLead && r.status === 'CHỜ PHÊ DUYỆT') ? `
                            <div class="flex gap-1 mt-2">
                                <button onclick="actionShiftReport('${r.id}', 'ĐÃ PHÊ DUYỆT')" class="bg-emerald-600 text-white font-black text-[9px] px-2 py-0.5 rounded-md">Phê Duyệt ✅</button>
                                <button onclick="actionShiftReport('${r.id}', 'KỶ LUẬT NHẮC NHỞ')" class="bg-red-600 text-white font-black text-[9px] px-2 py-0.5 rounded-md">Kỷ Luật 🚨</button>
                            </div>
                        ` : '';
                        rptFeed.innerHTML += `
                            <div class="bg-gray-950 p-2.5 rounded-xl border border-gray-800 text-[11px] space-y-1">
                                <div class="flex justify-between text-gray-400 font-mono text-[10px]"><span>Trực ban: ${r.officer} [${r.agency}]</span> <b class="text-amber-500">${r.status}</b></div>
                                <div class="text-[10px] font-black text-sky-400 uppercase">[${r.taskStatus}]</div>
                                <p class="text-white bg-black/20 p-2 rounded border border-gray-900 font-medium">${r.content}</p>
                                ${r.feedback ? `<p class="text-teal-400 text-[10px] font-bold">Chỉ đạo: ${r.feedback}</p>` : ''}
                                ${actionBtns}
                            </div>
                        `;
                    });
                }
            }

            document.getElementById('st-staff').innerText = Object.keys(state.authorizedPersonnel).length - 1;
            document.getElementById('st-files').innerText = Object.keys(state.archivedApplications).length;
            
            const logBox = document.getElementById('admin-system-logs');
            if(logBox) {
                logBox.innerHTML = '';
                state.systemLogs.forEach(l => {
                    logBox.innerHTML += `<div class="py-1 border-b border-gray-900"><span class="text-cyan-400 font-bold">[${l.time}]</span> <span class="text-gray-300 font-medium">${l.text}</span></div>`;
                });
            }

            const analytics = document.getElementById('admin-analytics-list');
            if (analytics) {
                analytics.innerHTML = '';
                Object.values(state.authorizedPersonnel).forEach(u => {
                    if (u.username !== 'admin') {
                        analytics.innerHTML += `
                            <div class="bg-gray-950/80 p-3.5 rounded-xl border border-gray-800 text-xs space-y-2">
                                <div class="flex justify-between font-black text-white border-b border-gray-800 pb-1.5"><span>${u.displayName}</span><span class="text-purple-400 text-[10px] uppercase bg-purple-950 px-1.5 rounded border border-purple-800">${u.role}</span></div>
                                <div class="text-[11px] text-gray-400 font-mono flex justify-between"><span>Đơn vị: <b class="text-sky-400">${u.agency}</b></span> <span>Ratings: +${u.positiveRatings}</span></div>
                                <div class="flex gap-2 pt-1 border-t border-gray-800/60"><button onclick="editOfficer('${u.username}')" class="flex-1 bg-sky-600 text-white font-bold py-1 rounded text-[10px] uppercase">Sửa đổi</button><button onclick="deleteOfficer('${u.username}')" class="bg-red-600 text-white font-bold px-2 py-1 rounded text-[10px] uppercase">Tước Quyền</button></div>
                            </div>
                        `;
                    }
                });
            }
        }

        async function actionShiftReport(id, status) {
            const feedback = prompt("Nhập ý kiến chỉ đạo sắc lệnh cấp cao:");
            await fetch('/api/officer/report-action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, status, feedback }) });
        }

        function editOfficer(username) {
            let u = state.authorizedPersonnel[username]; if(!u) return;
            document.getElementById('p-user').value = u.username; document.getElementById('p-user').readOnly = true;
            document.getElementById('p-pass').value = u.password; document.getElementById('p-name').value = u.displayName;
            document.getElementById('p-role').value = u.role; document.getElementById('p-agency').value = u.agency;
            document.getElementById('p-isEdit').value = "true";
            document.getElementById('form-provision-title').innerHTML = `<i class="fa-solid fa-user-gear text-sky-400"></i> Điều Chỉnh Chứng Thư Nhân Sự`;
            document.getElementById('btn-submit-provision').innerText = "Cập Nhật Quyết Định";
            document.getElementById('btn-cancel-edit').classList.remove('hidden');
        }

        function resetProvisionForm() {
            document.getElementById('p-user').value = ''; document.getElementById('p-user').readOnly = false;
            document.getElementById('p-pass').value = ''; document.getElementById('p-name').value = '';
            document.getElementById('p-isEdit').value = "false";
            document.getElementById('form-provision-title').innerHTML = `<i class="fa-solid fa-id-card-clip"></i> Cấp Chứng Thư Bổ Nhiệm Công Vụ`;
            document.getElementById('btn-submit-provision').innerText = "Kích Hoạt Quyền";
            document.getElementById('btn-cancel-edit').classList.add('hidden');
        }

        async function deleteOfficer(username) {
            if(!confirm(`Bãi nhiệm chức vụ nhân sự cán bộ [${username}]?`)) return;
            await fetch('/api/officer/delete', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username }) });
        }

        async function registerResidentByOfficer(e) {
            e.preventDefault();
            const username = document.getElementById('res-user').value.trim(); const name = document.getElementById('res-name').value.trim(); const dob = document.getElementById('res-dob').value.trim(); const gender = document.getElementById('res-gender').value; const pob = document.getElementById('res-pob').value.trim();
            const job = document.getElementById('res-job').value.trim(); const licenses = document.getElementById('res-licenses').value.trim(); const status = document.getElementById('res-status').value;
            await fetch('/api/resident/register', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, name, dob, gender, pob, job, licenses, status }) });
            document.getElementById('res-user').value = ''; document.getElementById('res-name').value = ''; document.getElementById('res-dob').value = ''; document.getElementById('res-pob').value = ''; document.getElementById('res-job').value = ''; document.getElementById('res-licenses').value = '';
            if(typeof AudioCentral !== 'undefined') AudioCentral.success();
            alert(`Đồng bộ dữ liệu số hóa cư dân mới thành công!`);
        }

        async function submitForm(e) {
            e.preventDefault();
            const sender = document.getElementById('app-sender').value.trim(); const docType = document.getElementById('app-docType').value; const priority = document.getElementById('app-priority').value; const agency = document.getElementById('app-agency').value; const content = document.getElementById('app-content').value.trim();
            const res = await fetch('/api/applications/submit', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sender, agency, docType, content, priority }) });
            const data = await res.json();
            document.getElementById('app-content').value = ''; document.getElementById('track-id').value = data.id;
            if(typeof AudioCentral !== 'undefined') AudioCentral.success(); 
            trackApplication();
        }

        function trackApplication() {
            const id = document.getElementById('track-id').value.trim();
            const area = document.getElementById('track-details'); const empty = document.getElementById('track-empty');
            let app = state.applications[id] || state.archivedApplications[id];
            if (!app) { area.classList.add('hidden'); empty.classList.remove('hidden'); return; }
            empty.classList.add('hidden'); area.classList.remove('hidden');

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-gray-950 p-2.5 rounded border border-gray-900 text-[11px]"><p class="text-[9px] font-bold text-gray-500">${l.sender} • ${l.time}</p><p class="text-white mt-0.5 font-medium">${l.msg}</p></div>`;
            });
            let satBlock = '';
            if (!app.satisfaction && !app.archivedApplications) {
                satBlock = `
                    <div class="space-y-1.5 p-2 bg-gray-950 border border-gray-800 rounded-xl flex gap-2 justify-center">
                        <button onclick="sendAction('${id}', 'satisfaction', 'HÀI LÒNG')" class="bg-emerald-600 text-white font-black px-4 py-1.5 rounded-lg text-[10px] uppercase">Hài Lòng 👍</button>
                        <button onclick="sendAction('${id}', 'satisfaction', 'KHIẾU NẠI CẤP CAO')" class="bg-red-600 text-white font-black px-4 py-1.5 rounded-lg text-[10px] uppercase animate-pulse">🚨 Khiếu Nại 🚨</button>
                    </div>
                `;
            } else if (app.satisfaction) {
                satBlock = `<div class="text-center text-[10px] font-black uppercase text-cyan-400 bg-gray-950 p-2 rounded-xl border border-gray-800">Đánh giá chất lượng: [${app.satisfaction}]</div>`;
            }

            area.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3 max-h-[300px] pr-1">
                    <div class="bg-gray-950 p-3 rounded-xl border border-gray-100/10 flex justify-between items-center shadow-md">
                        <div><p class="font-black text-cyan-400">${app.id} [${app.docType}]</p><span class="text-[9px] font-mono text-gray-500 block">Tiếp nhận: [${app.agency}]</span></div>
                        <div class="stamp-box ${app.stamp}">${app.status}</div>
                    </div>
                    <div class="space-y-2" id="citizen-chat-flow">${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-gray-800 space-y-2">
                    ${satBlock}
                    <div class="flex gap-2">
                        <input type="text" id="citizen-chat-msg" placeholder="Nhập văn bản đàm thoại..." class="flex-1 bg-gray-950 border border-gray-800 p-2 text-xs text-white rounded-xl focus:outline-none">
                        <button onclick="citizenChat('${app.id}')" class="bg-cyan-500 font-black text-black px-4 text-xs rounded-xl uppercase">Gửi</button>
                    </div>
                </div>
            `;
            setTimeout(() => { const el = document.getElementById('citizen-chat-flow'); if (el) el.scrollTop = el.scrollHeight; }, 50);
        }

        async function citizenChat(id) {
            const msg = document.getElementById('citizen-chat-msg').value.trim(); if (!msg) return;
            let app = state.applications[id] || state.archivedApplications[id];
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action: 'chat', msg, officerName: `Công Dân (@${app.sender})` }) });
            document.getElementById('citizen-chat-msg').value = '';
        }

        function selectFile(id) { activeFileId = id; document.getElementById('officer-desk-empty').classList.add('hidden'); document.getElementById('officer-desk-active').classList.remove('hidden'); renderOfficerDesk(); }

        function renderOfficerDesk() {
            let app = state.applications[activeFileId] || state.archivedApplications[activeFileId]; if(!app) return;
            const desk = document.getElementById('officer-desk-active');

            let citizenInfoHtml = `<p class="text-amber-500 text-[10px] font-bold">⚠️ Sơ đồ định danh trống. Hãy số hóa tài khoản này trước.</p>`;
            if (registry[app.sender]) {
                let c = registry[app.sender]; let v = criminalRecordsRegistry[app.sender] || [];
                citizenInfoHtml = `
                    <div class="bg-black/50 border border-gray-800 p-3 rounded-xl text-[11px] space-y-1 text-gray-300 font-medium">
                        <p class="text-xs font-black text-cyan-400 border-b border-gray-900 pb-1 flex justify-between"><span>Họ Tên: ${c.name}</span></p>
                        <p>Bằng cấp: <span class="text-sky-400 font-bold">${c.licenses.join(' — ') || 'Chưa cấp phôi'}</span></p>
                        <p class="flex justify-between font-bold"><span>Lý lịch: <b class="text-emerald-400">${c.status}</b></span> <span>Vi phạm: <b class="text-red-500">${v.length}</b></span></p>
                    </div>
                `;
            }

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-gray-950 p-2 rounded border border-gray-900 text-[11px]"><p class="text-[9px] text-gray-500 font-bold">${l.sender} • ${l.time}</p><p class="text-white mt-0.5">${l.msg}</p></div>`;
            });
            let actionsHtml = '';
            if (state.applications[activeFileId]) {
                if (app.status === 'Đang Chờ Tiếp Nhận') {
                    actionsHtml = `<button onclick="sendAction('${app.id}', 'claim_packet')" class="w-full bg-gradient-to-r from-sky-500 to-blue-600 text-white font-black py-2.5 rounded-xl text-xs uppercase shadow-md tracking-wider">Ký Nhận Thụ Lý Đơn Thư</button>`;
                } else if (app.isLocked) {
                    let isLead = (activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN');
                    actionsHtml = isLead ? 
                        `<button onclick="sendAction('${app.id}', 'archive')" class="w-full bg-purple-600 text-white font-black py-2 rounded-xl text-[10px] uppercase shadow-md">🔒 Ký Phê Duyệt Lưu Kho Mật Quốc Gia</button>` : 
                        `<div class="text-center text-[10px] text-amber-500 bg-amber-950/20 p-2 border border-amber-900/40 rounded-xl font-bold">Hồ sơ đã khóa do công dân HÀI LÒNG. Đang chờ cấp Lãnh đạo đóng kho lưu trữ.</div>`;
                } else {
                    let isLead = (activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN');
                    actionsHtml = `
                        <div class="grid grid-cols-2 gap-2">
                            ${isLead ? `
                                <button onclick="sendAction('${app.id}', 'status', 'Đã Phê Duyệt', 'stamp-approved')" class="bg-emerald-600 text-white font-black py-1.5 rounded-xl text-[10px] uppercase shadow">Phê Duyệt</button>
                                <button onclick="sendAction('${app.id}', 'status', 'Bị Bác Bỏ', 'stamp-rejected')" class="bg-red-600 text-white font-black py-1.5 rounded-xl text-[10px] uppercase shadow">Bác Bỏ</button>
                            ` : `
                                <button onclick="sendAction('${app.id}', 'status', 'Trình Duyệt Sắc Lệnh', 'stamp-leader')" class="bg-amber-600 text-black font-black py-1.5 col-span-2 rounded-xl text-[10px] uppercase shadow">Trình Tấu Thượng Cấp Lãnh Đạo</button>
                            `}
                        </div>
                    `;
                }
            } else { actionsHtml = `<div class="text-center text-[10px] text-purple-400 font-bold uppercase bg-purple-950/20 p-2 rounded-xl border border-purple-900/40">🔒 Văn bản đã niêm phong lưu kho bảo mật quốc gia</div>`; }

            desk.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3.5 max-h-[380px] pr-1">
                    <div class="bg-gray-950 p-2.5 rounded-xl border border-gray-900 text-[11px] relative shadow-inner">
                        <div class="absolute top-2 right-2 stamp-box ${app.stamp}">${app.status}</div>
                        <p class="font-black text-cyan-400 font-mono">MÃ ĐƠN: ${app.id}</p>
                        <p class="text-gray-400 italic mt-2 bg-black/40 p-2 rounded border border-gray-900 font-medium">"${app.content}"</p>
                    </div>
                    ${citizenInfoHtml}
                    <div class="space-y-2" id="officer-chat-flow">${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-gray-800 space-y-2">
                    ${actionsHtml}
                    <div class="flex gap-2">
                        <input type="text" id="officer-chat-msg" placeholder="Chỉ thị gửi công dân..." class="flex-1 bg-gray-950 border border-gray-800 p-2 text-xs text-white rounded-xl focus:outline-none">
                        <button onclick="officerChat()" class="bg-emerald-600 font-black text-white px-4 text-xs rounded-xl uppercase">Gửi</button>
                    </div>
                </div>
            `;
            setTimeout(() => { const el = document.getElementById('officer-chat-flow'); if (el) el.scrollTop = el.scrollHeight; }, 50);
        }

        async function officerChat() {
            const msg = document.getElementById('officer-chat-msg').value.trim(); if (!msg) return;
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: activeFileId, action: 'chat', msg, officerName: `${activeUser.displayName} (${activeUser.agency})` }) });
            document.getElementById('officer-chat-msg').value = '';
        }

        async function sendAction(id, action, status = '', stamp = '') {
            if(action === 'satisfaction' && status === 'HÀI LÒNG' && typeof AudioCentral !== 'undefined') AudioCentral.lock();
            else if(typeof AudioCentral !== 'undefined') AudioCentral.stamp();
            
            const res = await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action, status, stamp, officerName: activeUser ? activeUser.displayName : 'Hệ thống', officerRole: activeUser ? activeUser.role : 'Hệ thống' }) });
            if (!res.ok) { const err = await res.json(); alert(err.error); }
        }

        async function publishDocument() {
            const type = document.getElementById('pub-type').value; const title = document.getElementById('pub-title').value.trim(); const content = document.getElementById('pub-content').value.trim(); if(!title || !content) return;
            await fetch('/api/national/publish', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ type, title, content }) });
            document.getElementById('pub-title').value = ''; document.getElementById('pub-content').value = ''; if(typeof AudioCentral !== 'undefined') AudioCentral.success();
        }

        async function updateTicker() {
            const msg = document.getElementById('pub-ticker').value.trim(); if(!msg) return;
            await fetch('/api/national/ticker', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }) });
            document.getElementById('pub-ticker').value = ''; if(typeof AudioCentral !== 'undefined') AudioCentral.success();
        }

        async function setSecurity(level) { await fetch('/api/national/security', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ level }) }); }
        
        async function provisionAccount(e) { 
            e.preventDefault(); const username = document.getElementById('p-user').value.trim(); const password = document.getElementById('p-pass').value; const displayName = document.getElementById('p-name').value.trim(); const role = document.getElementById('p-role').value; const agency = document.getElementById('p-agency').value;
            await fetch('/api/officer/save', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, password, displayName, role, agency }) });
            resetProvisionForm(); if(typeof AudioCentral !== 'undefined') AudioCentral.success(); 
        }

        function searchCitizen() {
            const q = document.getElementById('id-search').value.trim(); const resArea = document.getElementById('id-result');
            if (registry[q]) {
                let r = registry[q]; let v = criminalRecordsRegistry[q] || []; if(typeof AudioCentral !== 'undefined') AudioCentral.success();
                resArea.innerHTML = `
                    <div class="bg-[#0a0f24] border border-gray-800 p-5 text-xs space-y-3 rounded-2xl shadow-2xl">
                        <p class="text-base font-black text-cyan-400 uppercase flex items-center gap-1.5"><i class="fa-solid fa-passport"></i> Định Danh Cư Dân: ${r.name}</p>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-2 text-gray-300 font-medium">
                            <p>Ngày sinh: <span class="text-white font-mono">${r.dob}</span></p>
                            <p>Nguyên quán: <span class="text-white">${r.pob}</span></p>
                            <p>Nghề nghiệp: <span class="text-white">${r.job}</span></p>
                            <p>Lý lịch quốc gia: <span class="text-emerald-400 font-bold">${r.status}</span></p>
                        </div>
                        <div class="p-3 bg-black/40 border border-gray-800 rounded-xl"><p class="text-sky-400 font-black font-mono tracking-wide">${r.licenses.join(' — ') || 'Chưa cấp phôi'}</p></div>
                    </div>
                `;
            } else { resArea.innerHTML = `<p class="text-center text-red-400 text-xs font-black bg-red-950/20 border border-red-900/40 p-4 rounded-xl">⚠️ KHÔNG TÌM THẤY DỮ LIỆU ĐỊNH DANH TRÊN MÁY CHỦ.</p>`; }
        }

        function openLogin() { document.getElementById('login-modal').classList.remove('hidden'); }
        function closeLogin() { document.getElementById('login-modal').classList.add('hidden'); }
        function login() { 
            const u = document.getElementById('log-user').value; const p = document.getElementById('log-pass').value;
            if (state.authorizedPersonnel[u] && state.authorizedPersonnel[u].password === p) { 
                activeUser = state.authorizedPersonnel[u]; localStorage.setItem('sessionUser', JSON.stringify({ username: u, password: p })); 
                closeLogin(); if(typeof AudioCentral !== 'undefined') AudioCentral.success(); applyUserRoleLayout();
            } else { alert("Sai chứng thư nghiệp vụ!"); } 
        }
        function applyUserRoleLayout() { 
            if(!activeUser) return;
            document.getElementById('btn-tab-officer').classList.remove('hidden'); 
            if(activeUser.role === 'ADMIN') document.getElementById('btn-tab-admin').classList.remove('hidden'); 
            if(activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ') { document.getElementById('leader-publish-zone').classList.remove('hidden'); } 
            else { document.getElementById('leader-publish-zone').classList.add('hidden'); } 
            renderAuth(); renderAll(); let savedTab = sessionStorage.getItem('activeTab'); tab(savedTab || 'tab-officer');
        }
        function logout() { activeUser = null; activeFileId = null; localStorage.removeItem('sessionUser'); document.getElementById('btn-tab-officer').classList.add('hidden'); document.getElementById('btn-tab-admin').classList.add('hidden'); renderAuth(); tab('tab-news'); }
        function renderAuth() { 
            const p = document.getElementById('auth-panel');
            if(!activeUser) { p.innerHTML = `<button onclick="openLogin()" class="bg-cyan-500 text-black px-4 py-2 rounded-xl text-[11px] uppercase font-black">Đăng nhập nghiệp vụ</button>`; } 
            else { p.innerHTML = `<div class="bg-gray-950 border border-gray-800 p-1.5 text-xs rounded-xl flex items-center gap-2 shadow-inner"><b class="text-white">${activeUser.displayName}</b><button onclick="logout()" class="text-red-400 ml-2"><i class="fa-solid fa-power-off"></i></button></div>`; } 
        }
        
        startClock();
    </script>
</body>
</html>
