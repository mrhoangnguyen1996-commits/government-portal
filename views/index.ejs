<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TRỤC QUỐC VỤ SỐ TOÀN DIỆN v7.0 - CYBERPUNK OVERDRIVE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Space+Grotesk:wght@400;500;600;700&display=swap');
        body { font-family: 'Space Grotesk', sans-serif; background-color: #02050e; color: #cbd5e1; overflow-x: hidden; }
        .font-mono-tech { font-family: 'Share Tech Mono', monospace; }
        
        /* PHÔI ẤN KÝ ĐIỆN TỬ PHẢN QUANG ĐA LỚP */
        .stamp-box { position: relative; font-size: 10px; font-weight: 900; text-transform: uppercase; padding: 4px 10px; border-radius: 6px; border: 2px dashed; display: inline-block; text-align: center; transform: rotate(-5deg) scale(1.02); text-shadow: 0 0 6px currentColor; background: rgba(0,0,0,0.4); box-shadow: 0 4px 10px rgba(0,0,0,0.5); animation: stampIn v7 0.2s ease forwards; }
        .stamp-approved { border-color: #10b981; color: #10b981; }
        .stamp-rejected { border-color: #ef4444; color: #ef4444; }
        .stamp-pending { border-color: #f59e0b; color: #f59e0b; }
        .stamp-forwarded { border-color: #3b82f6; color: #3b82f6; }
        .stamp-leader { border-color: #c084fc; color: #c084fc; border-style: double; border-width: 4px; }
        .stamp-archived { border-color: #64748b; color: #64748b; }
        @keyframes stampIn { 0% { transform: scale(2) rotate(-20deg); opacity: 0; } 100% { transform: scale(1) rotate(-5deg); opacity: 1; } }

        .national-card { background: radial-gradient(circle at top left, #1e293b 0%, #0f172a 70%, #020617 100%); border: 2px solid #334155; position: relative; overflow: hidden; border-radius: 16px; transition: all 0.3s ease; box-shadow: 0 20px 45px rgba(0,0,0,0.7); }
        .national-card:hover { transform: translateY(-4px); border-color: #06b6d4; box-shadow: 0 0 25px rgba(6, 182, 212, 0.25); }
        .card-chip { width: 42px; height: 32px; background: linear-gradient(135deg, #fcd34d 0%, #d97706 50%, #78350f 100%); border-radius: 6px; border: 1px solid #b45309; }
        
        .marquee-container { width: 100%; overflow: hidden; white-space: nowrap; background: #060a16; border-top: 1px solid #111827; border-bottom: 1px solid #111827; }
        .marquee-content { display: inline-block; padding-left: 100%; animation: marquee 30s linear infinite; font-size: 13px; font-weight: 700; color: #06b6d4; }
        @keyframes marquee { 0% { transform: translate3d(0, 0, 0); } 100% { transform: translate3d(-100%, 0, 0); } }
        
        .sub-active { background: linear-gradient(90deg, #083344 0%, #02141a 100%); border-color: #06b6d4; color: #fff; box-shadow: 0 0 15px rgba(6, 182, 212, 0.2); }
        
        /* BIỂU ĐỒ HÌNH KHỐI CÔNG VỤ HUD */
        .hud-bar { height: 16px; background: linear-gradient(90deg, #06b6d4 0%, #3b82f6 100%); border-radius: 4px; transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 0 10px rgba(6, 182, 212, 0.5); }
        .hud-bar-archived { height: 16px; background: linear-gradient(90deg, #a855f7 0%, #7c3aed 100%); border-radius: 4px; transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 0 10px rgba(168, 85, 247, 0.5); }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between">

    <div>
        <header class="bg-[#050814]/90 border-b border-gray-800 px-4 py-4 flex flex-col sm:flex-row justify-between items-center shadow-2xl relative backdrop-blur-md z-50 gap-4">
            <div class="flex items-center space-x-3 w-full sm:w-auto">
                <div class="bg-gradient-to-br from-cyan-600 to-indigo-600 p-3 rounded-xl text-white border border-cyan-300 shadow-[0_0_15px_rgba(6,182,212,0.4)]">
                    <i class="fa-solid fa-atom text-xl"></i>
                </div>
                <div>
                    <span class="text-[9px] tracking-widest text-cyan-400 font-black font-mono-tech block">TRỤC LIÊN THÔNG QUỐC PHÒNG TƯ PHÁP v7.0-MOBILE COMPATIBLE</span>
                    <h1 class="text-xl font-black text-white tracking-tight flex items-center gap-1.5">TỔNG CỤC CHÍNH PHỦ SỐ QUỐC GIA</h1>
                </div>
            </div>

            <div class="flex items-center justify-between sm:justify-end w-full sm:w-auto gap-2.5 text-xs">
                <div id="officer-alert-light" onclick="jumpToActiveNotification()" class="hidden bg-red-950 border border-red-500 px-2.5 py-1.5 rounded-xl flex items-center gap-1.5 animate-pulse cursor-pointer">
                    <span class="h-2 w-2 rounded-full bg-red-500"></span>
                    <span class="text-red-400 font-black text-[10px] uppercase">ĐƠN MỚI</span>
                </div>
                <div class="bg-[#0a0e1a] px-3 py-1.5 rounded-xl border border-gray-800 font-mono text-cyan-400 font-black text-xs" id="clock">00:00:00</div>
                <div class="bg-[#0a0e1a] px-2.5 py-1.5 rounded-xl border border-gray-800 text-[10px] font-black uppercase text-emerald-400" id="security-txt"><%= state.securityLevel %></div>
                <div id="auth-panel"></div>
            </div>
        </header>

        <div class="marquee-container py-1.5 flex items-center">
            <div class="bg-cyan-950 text-cyan-400 font-black text-[9px] px-2 py-0.5 rounded border border-cyan-800 mx-2">CORE CENTRAL</div>
            <div class="marquee-content" id="live-marquee"><%= state.tickerMessage %></div>
        </div>

        <nav class="bg-[#050814]/95 border-b border-gray-800 px-3 py-1 flex flex-row overflow-x-auto gap-1 sticky top-0 z-40 backdrop-blur-md scrollbar-none">
            <button onclick="tab('tab-news')" id="btn-tab-news" class="whitespace-nowrap px-4 py-3 text-xs font-black uppercase border-b-2 border-cyan-500 text-cyan-500 transition-all"><i class="fa-solid fa-scroll mr-1"></i> Ấn Bản</button>
            <button onclick="tab('tab-id')" id="btn-tab-id" class="whitespace-nowrap px-4 py-3 text-xs font-black uppercase border-b-2 border-transparent text-gray-400 hover:text-white transition-all"><i class="fa-solid fa-fingerprint mr-1"></i> Định Danh</button>
            <button onclick="tab('tab-cards')" id="btn-tab-cards" class="whitespace-nowrap px-4 py-3 text-xs font-black uppercase border-b-2 border-transparent text-sky-400 hover:text-sky-300 transition-all"><i class="fa-solid fa-print mr-1"></i> Cấp Phôi</button>
            <button onclick="tab('tab-services')" id="btn-tab-services" class="whitespace-nowrap px-4 py-3 text-xs font-black uppercase border-b-2 border-transparent text-purple-400 hover:text-purple-300 transition-all"><i class="fa-solid fa-file-invoice mr-1"></i> Cổng Nộp Đơn</button>
            <button onclick="tab('tab-officer')" id="btn-tab-officer" class="whitespace-nowrap px-4 py-3 text-xs font-black uppercase border-b-2 border-transparent text-emerald-400 hover:text-emerald-300 hidden relative">
                <i class="fa-solid fa-user-shield mr-1"></i> Bàn Cán Bộ
                <span id="badge-count-app" class="absolute top-1 right-1 bg-red-600 text-white text-[8px] px-1.5 py-0.5 rounded-full font-black hidden">0</span>
            </button>
            <button onclick="tab('tab-admin')" id="btn-tab-admin" class="whitespace-nowrap px-4 py-3 text-xs font-black uppercase border-b-2 border-transparent text-red-400 hover:text-red-300 hidden"><i class="fa-solid fa-chart-pie mr-1"></i> Bàn Giám Sát</button>
        </nav>

        <main class="p-4 max-w-[1700px] w-full mx-auto space-y-6">
            
            <section id="tab-news" class="grid grid-cols-1 lg:grid-cols-4 gap-6">
                <div class="lg:col-span-2 space-y-4">
                    <h2 class="text-xs font-black text-gray-400 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-1.5"><i class="fa-solid fa-shield text-cyan-500"></i> Chỉ Thị Sắc Lệnh Quốc Gia</h2>
                    <div id="news-feed" class="grid grid-cols-1 gap-3"></div>
                </div>
                <div class="space-y-4">
                    <h2 class="text-xs font-black text-red-400 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-1.5"><i class="fa-solid fa-mask text-red-500"></i> Lệnh Truy Nã Toàn Quốc</h2>
                    <div id="wanted-feed" class="space-y-3"></div>
                </div>
                <div class="space-y-4">
                    <h2 class="text-xs font-black text-cyan-400 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-1.5"><i class="fa-solid fa-robot text-cyan-400"></i> Siêu Trợ Lý Số Hóa Tuệ Đức v7.0</h2>
                    <div class="bg-[#0a0f24] border border-cyan-900/60 p-4 flex flex-col justify-between h-[380px] shadow-2xl rounded-2xl">
                        <div id="bot-chat-flow" class="flex-1 overflow-y-auto space-y-3 text-xs pr-1"></div>
                        <div class="pt-2 border-t border-gray-800 flex gap-2">
                            <input type="text" id="bot-input" placeholder="Nhập mã đơn thư hoặc tên cư dân..." class="flex-1 bg-gray-950 border border-gray-800 p-2 text-xs text-white rounded-xl focus:outline-none">
                            <button onclick="askAiBot()" class="bg-cyan-600 hover:bg-cyan-700 text-white font-black px-4 text-xs rounded-xl uppercase">Quét</button>
                        </div>
                    </div>
                </div>
            </section>

            <section id="tab-id" class="hidden max-w-2xl mx-auto space-y-4">
                <div class="bg-[#0a0f24] border border-gray-800 p-5 shadow-2xl rounded-2xl">
                    <h2 class="text-xs font-black text-center text-white uppercase tracking-widest mb-3"><i class="fa-solid fa-fingerprint text-cyan-500"></i> Cơ Quan Thẩm Định Hồ Sơ Định Danh Gốc</h2>
                    <div class="flex flex-col sm:flex-row gap-2">
                        <input type="text" id="id-search" placeholder="Nhập tài khoản cư dân (Ví dụ: Nguyen_Manh_Hoang)..." class="flex-1 bg-gray-950 border border-gray-700 px-3 py-2 text-xs rounded-xl text-white font-mono focus:outline-none">
                        <button onclick="searchCitizen()" class="bg-cyan-600 text-white px-5 py-2 text-xs font-black uppercase rounded-xl tracking-wider">Truy Quét</button>
                    </div>
                </div>
                <div id="id-result"></div>
            </section>

            <section id="tab-cards" class="hidden max-w-5xl mx-auto space-y-6">
                <div class="bg-[#0a0f24] border border-gray-800 p-5 max-w-md mx-auto rounded-2xl">
                    <h2 class="text-xs font-black text-center text-sky-400 uppercase tracking-widest mb-3">Kết Xuất Bản Vẽ Phôi Căn Cước / Chứng Thư Số</h2>
                    <div class="flex gap-2">
                        <input type="text" id="card-search-input" placeholder="Nhập tài khoản cư dân..." class="flex-1 bg-gray-950 border border-gray-800 px-3 py-2 text-xs rounded-xl text-white font-mono">
                        <button onclick="generateCitizenCards()" class="bg-sky-600 text-white px-4 text-xs font-black uppercase rounded-xl">Xuất Phôi</button>
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="cards-render-zone"></div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="violation-render-zone"></div>
            </section>

            <section id="tab-services" class="hidden grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="bg-[#0a0f24] border border-gray-800 p-4 space-y-3 shadow-xl rounded-2xl">
                    <h3 class="text-xs font-black text-purple-400 uppercase tracking-widest border-b border-gray-800 pb-2">Khởi Tạo Hồ Sơ Trực Tuyến</h3>
                    <form onsubmit="submitForm(event)" class="space-y-3 text-xs">
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
                            <div><label class="block text-gray-400 font-bold mb-1">Tài Khoản (Họ_Tên)</label><input type="text" id="app-sender" required placeholder="Nguyen_Manh_Hoang" class="w-full bg-gray-950 border border-gray-800 p-2 rounded-xl text-white font-mono"></div>
                            <div>
                                <label class="block text-gray-400 font-bold mb-1">Loại Thủ Tục</label>
                                <select id="app-docType" class="w-full bg-gray-950 border border-gray-800 p-2 rounded-xl text-white font-bold text-cyan-400">
                                    <option value="CĂN CƯỚC CÔNG DÂN">Căn Cước Công Dân Gắn Chíp</option>
                                    <option value="GIẤY PHÉP SỬ DỤNG CÔNG CỤ HỖ TRỢ">Giấy Phép Công Cụ Hỗ Trợ</option>
                                    <option value="XIN CHỦ TRƯƠNG ĐẦU TƯ KHÁCH SẠN">Xin Chủ Trương Đầu Tư</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-gray-400 font-bold mb-1">Độ Khẩn</label>
                                <select id="app-priority" class="w-full bg-gray-950 border border-gray-800 p-2 rounded-xl text-white font-bold text-red-400"><option value="BÌNH THƯỜNG">Bình Thường</option><option value="HỎA TỐC">Hỏa Tốc ⚡</option></select>
                            </div>
                        </div>
                        <div>
                            <label class="block text-gray-400 font-bold mb-1">Cơ Quan Tiếp Nhận</label>
                            <select id="app-agency" class="w-full bg-gray-950 border border-gray-800 p-2 rounded-xl text-white font-bold text-sky-400">
                                <option value="CÔNG AN">BỘ CÔNG AN QUỐC GIA</option>
                                <option value="QUÂN ĐỘI">BỘ CHỈ HUY QUÂN SỰ</option>
                                <option value="THANH TRA">THANH TRA CHÍNH PHỦ</option>
                                <option value="CHÍNH PHỦ">VĂN PHÒNG CHÍNH PHỦ TỐI CAO</option>
                            </select>
                        </div>
                        <div><label class="block text-gray-400 font-bold mb-1">Thuyết Minh Nội Dung</label><textarea id="app-content" rows="3" required class="w-full bg-gray-950 border border-gray-800 p-2 rounded-xl text-white font-medium"></textarea></div>
                        <button type="submit" class="w-full bg-gradient-to-r from-purple-600 to-indigo-600 font-black text-white py-2.5 rounded-xl uppercase">Gửi Đơn Lên Trục Hệ Thống</button>
                    </form>
                </div>
                <div class="bg-[#0a0f24] border border-gray-800 p-4 flex flex-col h-full min-h-[400px] shadow-xl rounded-2xl">
                    <h3 class="text-xs font-black text-gray-300 uppercase border-b border-gray-800 pb-2">Đàm Thoại & Đánh Giá Tiến Độ Hai Chiều</h3>
                    <div class="flex gap-2 my-2">
                        <input type="text" id="track-id" placeholder="Nhập mã đơn (Ví dụ: HS-1001)..." class="flex-1 bg-gray-950 border border-gray-800 px-3 py-2 text-xs rounded-xl text-white font-mono">
                        <button onclick="trackApplication()" class="bg-sky-600 text-white px-4 text-xs font-black rounded-xl uppercase">Truy Vấn</button>
                    </div>
                    <div id="track-details" class="flex-1 flex flex-col justify-between hidden space-y-3"></div>
                    <div id="track-empty" class="text-center py-20 text-gray-500 text-xs flex-1 flex flex-col justify-center items-center">Nhập chính xác mã đơn thư để mở khung tương tác phản hồi.</div>
                </div>
            </section>

            <section id="tab-officer" class="hidden grid grid-cols-1 lg:grid-cols-4 gap-6">
                <div class="lg:col-span-1 bg-[#0a0f24] border border-gray-800 p-3 flex flex-row overflow-x-auto lg:flex-col gap-1.5 shadow-2xl h-fit rounded-xl scrollbar-none">
                    <button onclick="subtab('sub-app')" id="btn-sub-app" class="whitespace-nowrap sub-active text-left px-3 py-2.5 text-xs font-black uppercase rounded-xl border border-gray-800 transition-all"><i class="fa-solid fa-folder-open mr-1"></i> 1. Đơn Tiếp Nhận</button>
                    <button onclick="subtab('sub-transfer')" id="btn-sub-transfer" class="whitespace-nowrap text-left px-3 py-2.5 text-xs font-black uppercase rounded-xl border border-transparent text-gray-400 hover:text-white transition-all"><i class="fa-solid fa-shuffle mr-1"></i> 2. Luân Chuyển Ngành</button>
                    <button onclick="subtab('sub-licensing')" id="btn-sub-licensing" class="whitespace-nowrap text-left px-3 py-2.5 text-xs font-black uppercase rounded-xl border border-transparent text-sky-400 hover:text-sky-300 transition-all"><i class="fa-solid fa-stamp mr-1"></i> 3. Kho Cấp Phôi</button>
                    <button onclick="subtab('sub-vio')" id="btn-sub-vio" class="whitespace-nowrap text-left px-3 py-2.5 text-xs font-black uppercase rounded-xl border border-transparent text-red-400 hover:text-red-300 transition-all"><i class="fa-solid fa-gavel mr-1"></i> 4. Xử Phạt Dân Sự</button>
                    <button onclick="subtab('sub-reg')" id="btn-sub-reg" class="whitespace-nowrap text-left px-3 py-2.5 text-xs font-black uppercase rounded-xl border border-transparent text-teal-400 hover:text-teal-300 transition-all"><i class="fa-solid fa-user-plus mr-1"></i> 5. Định Danh Cư Dân</button>
                    <button onclick="subtab('sub-rpt')" id="btn-sub-rpt" class="whitespace-nowrap text-left px-3 py-2.5 text-xs font-black uppercase rounded-xl border border-transparent text-amber-400 hover:text-amber-300 transition-all"><i class="fa-solid fa-clipboard-list mr-1"></i> 6. Báo Cáo Ca</button>
                </div>

                <div class="lg:col-span-2 space-y-4">
                    <div id="sub-app" class="bg-[#050814] border border-gray-800 p-3 rounded-xl shadow-xl overflow-hidden">
                        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-gray-800 pb-2 mb-2 gap-2">
                            <h3 class="text-xs font-black text-emerald-400 uppercase tracking-wider"><i class="fa-solid fa-inbox"></i> Luồng Đơn Thư Gửi Đến Bộ Phận</h3>
                            <span id="office-badge" class="text-[9px] font-mono font-bold bg-emerald-950 text-emerald-400 px-2 py-0.5 rounded border border-emerald-800 max-w-full truncate">Cơ Quan Chủ Quản</span>
                        </div>
                        <div class="overflow-x-auto text-xs w-full">
                            <table class="w-full text-left min-w-[500px]">
                                <thead class="bg-gray-950 text-gray-400 font-bold uppercase text-[9px] border-b border-gray-800">
                                    <tr>
                                        <th class="p-2.5">Mã Đơn</th>
                                        <th class="p-2.5">Tài Khoản</th>
                                        <th class="p-2.5">Thủ Tục</th>
                                        <th class="p-2.5">Trạng Thái</th>
                                        <th class="p-2.5 text-right">Tác Vụ</th>
                                    </tr>
                                </thead>
                                <tbody id="officer-table" class="divide-y divide-gray-800/50"></tbody>
                            </table>
                        </div>
                    </div>

                    <div id="sub-transfer" class="hidden bg-[#050814] border border-gray-800 p-4 rounded-xl space-y-3">
                        <h3 class="text-xs font-black text-amber-500 uppercase tracking-widest border-b border-gray-800 pb-1.5"><i class="fa-solid fa-shuffle mr-1"></i> Điều Chuyển Đơn Thư Sai Cơ Quan Tiếp Nhận</h3>
                        <div class="text-xs bg-gray-950 p-3 rounded-xl border border-gray-800 space-y-2">
                            <p class="text-gray-400">Nếu hồ sơ gửi sai ban ngành hoặc vượt quá quyền thẩm định của chuyên viên, chọn đơn ở phòng thẩm định và luân chuyển sang đúng cơ quan phụ trách.</p>
                            <div class="flex flex-col sm:flex-row gap-2 pt-1">
                                <select id="transfer-target-agency" class="flex-1 bg-gray-900 border border-gray-700 p-2 rounded-xl text-white text-xs font-bold text-sky-400">
                                    <option value="CHÍNH PHỦ">VĂN PHÒNG CHÍNH PHỦ TỐI CAO</option>
                                    <option value="CÔNG AN">BỘ CÔNG AN QUỐC GIA</option>
                                    <option value="QUÂN ĐỘI">BỘ CHỈ HUY QUÂN SỰ TRƯỞNG</option>
                                    <option value="TOÀ ÁN">TÒA ÁN NHÂN DÂN TỐI CAO</option>
                                    <option value="THANH TRA">THANH TRA CHÍNH PHỦ</option>
                                </select>
                                <button onclick="executeForwardApplication()" class="bg-amber-500 text-black font-black px-4 py-2 rounded-xl uppercase text-xs tracking-wider">Ký Chuyển Đơn</button>
                            </div>
                        </div>
                    </div>

                    <div id="sub-licensing" class="hidden bg-[#050814] border border-gray-800 p-4 rounded-xl space-y-3">
                        <h3 class="text-xs font-black text-sky-400 uppercase tracking-widest border-b border-gray-800 pb-1.5"><i class="fa-solid fa-stamp mr-1"></i> Kho Đóng Dấu Ấn Ký Cấp Phôi Điện Tử Độc Lập</h3>
                        <form onsubmit="submitLicensingForm(event)" class="grid grid-cols-1 sm:grid-cols-2 gap-2.5 text-xs">
                            <div><label class="block text-gray-400 mb-1 font-bold">Tài Khoản Nhận Phôi</label><input type="text" id="lic-user" required placeholder="Nguyen_Manh_Hoang" class="w-full bg-gray-950 border border-gray-800 p-2 rounded-xl text-white font-mono"></div>
                            <div>
                                <label class="block text-gray-400 mb-1 font-bold">Tên Phôi Văn Bằng</label>
                                <select id="lic-name" class="w-full bg-gray-950 border border-gray-800 p-2 rounded-xl text-white font-bold text-cyan-400">
                                    <option value="Bằng Lái Xe Ô Tô Hạng B2">Bằng Lái Xe Ô Tô Hạng B2</option>
                                    <option value="Giấy Phép Sử Dụng Công Cụ Hỗ TrỢ">Giấy Phép Sử Dụng Công Cụ Hỗ Trợ</option>
                                    <option value="Giấy Phép Sở Hữu Vũ Khí Quân Dụng">Giấy Phép Vũ Khí Quân Dụng</option>
                                </select>
                            </div>
