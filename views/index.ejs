        function trackApplication() {
            const id = document.getElementById('track-id').value.trim(); const area = document.getElementById('track-details'); const empty = document.getElementById('track-empty');
            let app = state.applications[id] || state.archivedApplications[id];
            if (!app) { area.classList.add('hidden'); empty.classList.remove('hidden'); return; }
            empty.classList.add('hidden'); area.classList.remove('hidden');

            let chatHtml = ''; app.logs.forEach(l => {
                chatHtml += `<div class="bg-gray-950 p-2 rounded border border-gray-900 text-[11px]"><p class="text-[9px] font-bold text-gray-500">${l.sender} • ${l.time}</p><p class="text-white mt-0.5 font-medium">${l.msg}</p></div>`;
            });
            let satBlock = '';
            if (!app.satisfaction && !state.archivedApplications[id]) {
                satBlock = `
                    <div class="p-2 bg-gray-950 border border-gray-800 rounded-xl flex gap-2 justify-center">
