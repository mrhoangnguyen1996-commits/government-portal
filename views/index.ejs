        async function deleteOfficer(username) {
            if(!confirm(`Xóa vĩnh viễn quyền lực tài khoản cán bộ nghiệp vụ [${username}]?`)) return;
            await fetch('/api/officer/delete', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username }) });
        }

        async function submitForm(e) {
            e.preventDefault();
            const sender = document.getElementById('app-sender').value.trim(); const docType = document.getElementById('app-docType').value; const agency = document.getElementById('app-agency').value; const content = document.getElementById('app-content').value.trim();
            const res = await fetch('/api/applications/submit', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sender, agency, docType, content }) });
            const data = await res.json();
            document.getElementById('app-content').value = ''; document.getElementById('track-id').value = data.id;
            soundSuccess(); trackApplication();
        }

        // HỆ THỐNG ĐÀM THOẠI TRỰC TUYẾN PHẢN HỒI REALTIME KHÔNG DELAY
        function trackApplication() {
            const id = document.getElementById('track-id').value.trim();
            const area = document.getElementById('track-details'); const empty = document.getElementById('track-empty');
            let app = state.applications[id] || state.archivedApplications[id];
            if (!app) { area.classList.add('hidden'); empty.classList.remove('hidden'); return; }
            empty.classList.add('hidden'); area.classList.remove('hidden');

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-slate-900 p-2 rounded border border-slate-800 text-[11px]"><p class="text-[9px] font-bold text-gray-500">${l.sender} • ${l.time}</p><p class="text-white mt-0.5">${l.msg}</p></div>`;
            });

            let satBlock = '';
            if ((app.status === 'Đã Phê Duyệt' || app.status === 'Bị Bác Bỏ') && !app.satisfaction) {
                satBlock = `
                    <div class="space-y-1.5 p-2 bg-slate-900 border border-slate-800 rounded-xl text-center">
                        <p class="text-[10px] text-slate-400 font-bold uppercase">Xác thực kết quả phục vụ ban ngành liên thông</p>
                        <div class="flex gap-2 justify-center">
                            <button onclick="confirmAndRouteToLeader('${id}', 'HÀI LÒNG')" class="bg-emerald-600 text-white font-black px-3 py-1 rounded text-[10px] uppercase shadow-sm">Hài Lòng & Trình Lãnh Đạo Đóng Đơn 👍</button>
                            <button onclick="sendAction('${id}', 'satisfaction', 'KHIẾU NẠI CẤP CAO')" class="bg-red-600 text-white font-black px-3 py-1 rounded text-[10px] uppercase shadow-sm">🚨 KHIẾU NẠI KHẨN 🚨</button>
                        </div>
                    </div>
                `;
            } else if (app.satisfaction) {
                satBlock = `<div class="text-center text-[10px] font-black uppercase text-amber-500 bg-slate-900 p-2 rounded-lg border border-slate-800">Phản hồi dân cư: [${app.satisfaction}]</div>`;
            }

            area.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3 max-h-[300px] pr-1">
                    <div class="bg-slate-900 p-3 rounded-xl border border-slate-800 flex justify-between items-center shadow-md">
                        <div><p class="font-black text-amber-500 font-mono">${app.id} [${app.docType}]</p></div>
                        <div class="stamp-box ${app.stamp}">${app.status}</div>
                    </div>
                    <div class="space-y-2" id="citizen-chat-flow">${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-slate-800 space-y-2">
                    ${satBlock}
                    <div class="flex gap-2">
                        <input type="text" id="citizen-chat-msg" placeholder="Phản hồi tin nhắn tức thời..." class="flex-1 bg-slate-900 border border-slate-700 p-2 text-xs text-white rounded-lg focus:outline-none">
                        <button onclick="citizenChat('${app.id}')" class="bg-amber-500 font-black text-black px-4 text-xs rounded-lg uppercase">Gửi</button>
                    </div>
                </div>
            `;
            setTimeout(() => { const el = document.getElementById('citizen-chat-flow'); if (el) el.scrollTop = el.scrollHeight; }, 30);
        }

        async function confirmAndRouteToLeader(id, status) {
            soundSuccess();
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action: 'satisfaction', status }) });
            // Tự động điều hướng đẩy đơn thư thẳng lên cấp Lãnh đạo ký niêm phong đóng kho
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action: 'to_leader', officerName: "Bộ phận phân luồng tự động" }) });
            trackApplication();
            alert("Hồ sơ đã được bạn xác nhận hài lòng! Hệ thống tự động chuyển tiếp hồ sơ lên cấp Lãnh đạo đơn vị chủ quản ký duyệt lưu kho quốc gia.");
        }

        async function citizenChat(id) {
            const msg = document.getElementById('citizen-chat-msg').value.trim(); if (!msg) return;
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action: 'chat', msg, officerName: `Công Dân (@${(state.applications[id] || state.archivedApplications[id]).sender})` }) });
            document.getElementById('citizen-chat-msg').value = '';
        }

