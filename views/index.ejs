        function editOfficer(username) {
            let u = state.authorizedPersonnel[username];
            if(!u) return;
            document.getElementById('p-user').value = u.username;
            document.getElementById('p-user').readOnly = true;
            document.getElementById('p-pass').value = u.password;
            document.getElementById('p-name').value = u.displayName;
            document.getElementById('p-role').value = u.role;
            document.getElementById('p-agency').value = u.agency;
            document.getElementById('p-isEdit').value = "true";
            document.getElementById('form-provision-title').innerHTML = `<i class="fa-solid fa-user-gear text-sky-400"></i> Hiệu chỉnh & Phân Quyền Cán Bộ`;
            document.getElementById('btn-submit-provision').innerText = "Cập Nhật Thay Đổi";
            document.getElementById('btn-cancel-edit').classList.remove('hidden');
        }

        function resetProvisionForm() {
            document.getElementById('p-user').value = '';
            document.getElementById('p-user').readOnly = false;
            document.getElementById('p-pass').value = '';
            document.getElementById('p-name').value = '';
            document.getElementById('p-isEdit').value = "false";
            document.getElementById('form-provision-title').innerHTML = `<i class="fa-solid fa-id-card-clip"></i> Thiết Lập / Phân Quyền Nhân Sự Quốc Gia`;
            document.getElementById('btn-submit-provision').innerText = "Kích Hoạt Tài Khoản";
            document.getElementById('btn-cancel-edit').classList.add('hidden');
        }

        async function deleteOfficer(username) {
            if(!confirm(`Xóa vĩnh viễn tài khoản cán bộ nghiệp vụ [${username}]?`)) return;
            await fetch('/api/officer/delete', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username }) });
        }

        async function registerResidentByOfficer(e) {
            e.preventDefault();
            const username = document.getElementById('res-user').value.trim();
            const name = document.getElementById('res-name').value.trim();
            const dob = document.getElementById('res-dob').value.trim();
            const gender = document.getElementById('res-gender').value;
            const pob = document.getElementById('res-pob').value.trim();
            const job = document.getElementById('res-job').value.trim();
            const licenses = document.getElementById('res-licenses').value.trim();
            const status = document.getElementById('res-status').value;
            await fetch('/api/resident/register', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, name, dob, gender, pob, job, licenses, status, officerName: activeUser.displayName }) });
            document.getElementById('res-user').value = '';
            document.getElementById('res-name').value = '';
            document.getElementById('res-dob').value = '';
            document.getElementById('res-pob').value = '';
            document.getElementById('res-job').value = '';
            document.getElementById('res-licenses').value = '';
            soundSuccess();
            alert(`Định danh thành công!`);
        }

        async function submitForm(e) {
            e.preventDefault();
            const sender = document.getElementById('app-sender').value.trim();
            const docType = document.getElementById('app-docType').value;
            const agency = document.getElementById('app-agency').value;
            const content = document.getElementById('app-content').value.trim();
            const res = await fetch('/api/applications/submit', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sender, agency, docType, content }) });
            const data = await res.json();
            document.getElementById('app-content').value = '';
            document.getElementById('track-id').value = data.id;
            soundSuccess();
            trackApplication();
        }

        function trackApplication() {
            const id = document.getElementById('track-id').value.trim();
            const area = document.getElementById('track-details');
            const empty = document.getElementById('track-empty');

            let app = state.applications[id] || state.archivedApplications[id];
            if (!app) { area.classList.add('hidden'); empty.classList.remove('hidden'); return; }
            empty.classList.add('hidden'); area.classList.remove('hidden');

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-slate-900 p-2 rounded border border-slate-800 text-[11px]"><p class="text-[9px] font-bold text-gray-500">${l.sender} • ${l.time}</p><p class="text-white mt-0.5">${l.msg}</p></div>`;
            });

            let satBlock = '';
            if ((app.status === 'Đã Phê Duyệt' || app.status === 'Bị Bác Bỏ') && !app.satisfaction) {
                satBlock = `
                    <div class="space-y-1.5 p-2 bg-slate-900 border border-slate-800 rounded-xl">
                        <div class="flex gap-2 justify-center">
                            <button onclick="sendAction('${id}', 'satisfaction', 'HÀI LÒNG')" class="bg-emerald-600 text-white font-black px-3 py-1 rounded text-[10px] uppercase">Hài Lòng 👍</button>
                            <button onclick="sendAction('${id}', 'satisfaction', 'KHIẾU NẠI CẤP CAO')" class="bg-red-600 text-white font-black px-3 py-1 rounded text-[10px] uppercase">🚨 KHIẾU NẠI 🚨</button>
                        </div>
                    </div>
                `;
            } else if (app.satisfaction) {
                satBlock = `<div class="text-center text-[10px] font-black uppercase text-amber-500 bg-slate-900 p-2 rounded-lg border border-slate-800">Phản hồi: [${app.satisfaction}]</div>`;
            }

            area.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3 max-h-[300px] pr-1">
                    <div class="bg-slate-900 p-3 rounded-xl border border-slate-800 flex justify-between items-center shadow-md">
                        <div><p class="font-black text-amber-500">${app.id} [${app.docType}]</p></div>
                        <div class="stamp-box ${app.stamp}">${app.status}</div>
                    </div>
                    <div class="space-y-2" id="citizen-chat-flow">${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-slate-800 space-y-2">
                    ${satBlock}
                    <div class="flex gap-2">
                        <input type="text" id="citizen-chat-msg" placeholder="Phản hồi tin nhắn..." class="flex-1 bg-slate-900 border border-slate-700 p-2 text-xs text-white rounded-lg focus:outline-none">
                        <button onclick="citizenChat('${app.id}')" class="bg-amber-500 font-black text-black px-4 text-xs rounded-lg uppercase">Gửi</button>
                    </div>
                </div>
            `;
            
            // Tự động cuộn xuống dưới cùng khung chat realtime
            setTimeout(() => {
                const el = document.getElementById('citizen-chat-flow');
                if (el) el.scrollTop = el.scrollHeight;
            }, 50);
        }

        async function citizenChat(id) {
            const msg = document.getElementById('citizen-chat-msg').value.trim();
            if (!msg) return;
            await fetch('/api/applications/action', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id, action: 'chat', msg, officerName: `Công Dân (@${(state.applications[id] || state.archivedApplications[id]).sender})` })
            });
            document.getElementById('citizen-chat-msg').value = '';
        }

        function selectFile(id) {
            activeFileId = id;
            document.getElementById('officer-desk-empty').classList.add('hidden');
            document.getElementById('officer-desk-active').classList.remove('hidden');
            renderOfficerDesk();
        }

