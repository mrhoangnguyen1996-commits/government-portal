        }

        function selectFile(id) {
            activeFileId = id;
            document.getElementById('officer-desk-empty').classList.add('hidden');
            document.getElementById('officer-desk-active').classList.remove('hidden');
            renderOfficerDesk();
        }

        /* ================= LUỒNG DUYỆT TÍCH HỢP TỰ ĐỘNG TRA CỨU ĐỊNH DANH SIÊU TỐC TẠI CHỖ ================= */
        function renderOfficerDesk() {
            let app = state.applications[activeFileId] || state.archivedApplications[activeFileId];
            if(!app) return;
            const desk = document.getElementById('officer-desk-active');

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-slate-900 p-2 rounded border border-slate-800 text-[11px]"><p class="text-[9px] font-bold text-gray-500">${l.sender} • ${l.time}</p><p class="text-white mt-0.5">${l.msg}</p></div>`;
            });

            // Tự động quét thông tin cư dân gốc của người nộp đơn để cán bộ tra cứu nhanh
            let autoSearchCitizenHtml = '';
            const targetUser = app.sender;
            if (registry[targetUser]) {
                let citizenData = registry[targetUser];
                let vioCount = (violations[targetUser]) ? violations[targetUser].length : 0;
                
                autoSearchCitizenHtml = `
                    <div class="p-3 bg-slate-900 border border-slate-800 rounded-xl space-y-1.5 text-[11px] text-slate-300">
                        <p class="text-[10px] font-black uppercase text-sky-400 border-b border-slate-800 pb-1 flex items-center gap-1"><i class="fa-solid fa-folder-open"></i> Hệ Thống Tra Cứu Lý Lịch Tư Pháp Tự Động</p>
                        <p>Họ tên: <b class="text-white font-sans uppercase">${citizenData.name}</b> | Sinh nhật: <b>${citizenData.dob}</b></p>
                        <p>Nghề nghiệp công tác: <b>${citizenData.job}</b></p>
                        <p>Văn bằng sở hữu: <span class="text-amber-400 font-bold">${citizenData.licenses.join(', ')}</span></p>
                        <p class="text-red-400 font-bold">Lịch sử vi phạm tư pháp: <span class="bg-red-950 px-1.5 rounded text-white border border-red-700 font-mono">${vioCount} vụ việc</span></p>
                        <p class="text-emerald-400 font-black">Tư pháp dân sự: ${citizenData.status}</p>
                    </div>
                `;
            } else {
                autoSearchCitizenHtml = `
                    <div class="p-2.5 bg-red-950/20 border border-red-900/40 rounded-xl text-[10px] text-red-400 text-center font-bold">
                        ⚠️ CẢNH BÁO AN NINH: CƯ DÂN CHƯA ĐƯỢC THIẾT LẬP HỒ SƠ ĐỊNH DANH GỐC TRÊN MÁY CHỦ QUỐC GIA.
                    </div>
                `;
            }

            let actionsHtml = '';
            if (state.applications[activeFileId]) {
                if (app.status === 'Đang Chờ Tiếp Nhận') {
                    actionsHtml = `<button onclick="sendAction('${app.id}', 'claim_packet')" class="w-full bg-gradient-to-r from-sky-500 to-blue-600 text-white font-black py-2 rounded-lg text-xs uppercase">Tiếp Nhận Phụ Trách Đơn Thư</button>`;
                } else {
                    actionsHtml = `
                        <div class="grid grid-cols-2 gap-2">
                            <button onclick="sendAction('${app.id}', 'status', 'Đã Phê Duyệt', 'stamp-approved')" class="bg-emerald-600 text-white font-black py-1.5 rounded-lg text-[11px] uppercase">Phê Duyệt Ký Dấu</button>
                            <button onclick="sendAction('${app.id}', 'status', 'Bị Bác Bỏ', 'stamp-rejected')" class="bg-red-600 text-white font-black py-1.5 rounded-lg text-[11px] uppercase">Bác Bỏ Đơn Thư</button>
                        </div>
                        <button onclick="sendAction('${app.id}', 'archive')" class="w-full bg-purple-600 text-white font-black py-1.5 rounded-lg text-[11px] uppercase">Đóng Dấu & Khóa Lưu Kho Quốc Gia</button>
                    `;
                }
            } else {
                actionsHtml = `<div class="text-center text-[10px] text-purple-400 font-bold bg-purple-950/20 p-2.5 border border-purple-800/40 rounded-lg uppercase">🗄️ HỒ SƠ ĐANG ĐƯỢC NIÊM PHONG TRONG KHO LƯU TRỮ QUỐC GIA</div>`;
            }

            desk.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3.5 max-h-[380px] pr-1">
                    <div class="bg-slate-900 p-2.5 rounded-xl border border-slate-800 text-[11px] relative">
                        <div class="absolute top-2 right-2 stamp-box ${app.stamp}">${app.status}</div>
                        <p class="font-black text-amber-500 font-mono">MÃ SỐ ĐƠN: ${app.id}</p>
                        <p class="text-slate-300 font-bold mt-1">Yêu cầu thủ tục: <span class="text-white">${app.docType}</span></p>
                        <p class="text-slate-400 italic mt-0.5">"${app.content}"</p>
                    </div>
                    
                    ${autoSearchCitizenHtml}
                    
                    <div class="space-y-2" id="officer-chat-flow"><p class="text-[9px] uppercase font-bold text-slate-500">Hội thoại tương tác kịch bản:</p>${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-slate-800 space-y-2">
                    ${actionsHtml}
                    <div class="flex gap-2">
                        <input type="text" id="officer-chat-msg" placeholder="Nhập chỉ thị tương tác 2 chiều..." class="flex-1 bg-slate-900 border border-slate-700 p-2 text-xs text-white rounded-lg focus:outline-none">
                        <button onclick="officerChat()" class="bg-emerald-600 font-black text-white px-4 text-xs rounded-lg uppercase">Gửi</button>
                    </div>
                </div>
            `;
            
            setTimeout(() => { const el = document.getElementById('officer-chat-flow'); if (el) el.scrollTop = el.scrollHeight; }, 50);
        }

        async function officerChat() {
            const msg = document.getElementById('officer-chat-msg').value.trim(); if (!msg) return;
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: activeFileId, action: 'chat', msg, officerName: `${activeUser.displayName} (${activeUser.agency})` }) });
            document.getElementById('officer-chat-msg').value = '';
        }

        function trackApplication() {
            const id = document.getElementById('track-id').value.trim();
            const area = document.getElementById('track-details'); const empty = document.getElementById('track-empty');

            let app = state.applications[id] || state.archivedApplications[id];
            if (!app) { area.classList.add('hidden'); empty.classList.remove('hidden'); return; }
            empty.classList.add('hidden'); area.classList.remove('hidden');

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-slate-900 p-2 rounded border border-slate-800 text-[11px]"><p class="text-[9px] font-bold text-gray-500">${l.sender} • ${l.time}</p><p class="text-white mt-0.5">${l.msg}</p></div>`;
            });

            let satBlock = '';
            if ((app.status === 'Đã Phê Duyệt' || app.status === 'Bị Bác Bỏ') && !app.satisfaction) {
                satBlock = `
                    <div class="space-y-1.5 p-2 bg-slate-900 border border-slate-800 rounded-xl">
                        <div class="flex gap-2 justify-center">
                            <button onclick="sendAction('${id}', 'satisfaction', 'HÀI LÒNG')" class="bg-emerald-600 text-white font-black px-3 py-1 rounded text-[10px] uppercase">Hài Lòng 👍</button>
                            <button onclick="sendAction('${id}', 'satisfaction', 'KHIẾU NẠI CẤP CAO')" class="bg-red-600 text-white font-black px-3 py-1 rounded text-[10px] uppercase">🚨 KHỞI SỰ KHIẾU NẠI 🚨</button>
                        </div>
                    </div>
                `;
            } else if (app.satisfaction) {
                satBlock = `<div class="text-center text-[10px] font-black uppercase text-amber-500 bg-slate-900 p-2 rounded-lg border border-slate-800">Cư dân phản hồi kết quả: [${app.satisfaction}]</div>`;
            }

            area.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3 max-h-[300px] pr-1">
                    <div class="bg-slate-900 p-3 rounded-xl border border-slate-800 flex justify-between items-center shadow-md">
                        <div><p class="font-black text-amber-500">${app.id} [${app.docType}]</p></div>
                        <div class="stamp-box ${app.stamp}">${app.status}</div>
                    </div>
                    <div class="space-y-2" id="citizen-chat-flow">${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-slate-800 space-y-2">
                    ${satBlock}
                    <div class="flex gap-2">
                        <input type="text" id="citizen-chat-msg" placeholder="Phản hồi tin nhắn..." class="flex-1 bg-slate-900 border border-slate-700 p-2 text-xs text-white rounded-lg focus:outline-none">
                        <button onclick="citizenChat('${app.id}')" class="bg-amber-500 font-black text-black px-4 text-xs rounded-lg uppercase">Gửi</button>
                    </div>
                </div>
            `;
            setTimeout(() => { const el = document.getElementById('citizen-chat-flow'); if (el) el.scrollTop = el.scrollHeight; }, 50);
        }

        async function citizenChat(id) {
            const msg = document.getElementById('citizen-chat-msg').value.trim(); if (!msg) return;
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action: 'chat', msg, officerName: `Công Dân (@${(state.applications[id] || state.archivedApplications[id]).sender})` }) });
            document.getElementById('citizen-chat-msg').value = '';
        }

        async function sendAction(id, action, status = '', stamp = '', targetAgency = '') {
            if(action === 'status' || action === 'claim_packet' || action === 'archive') { soundStamp(); }
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action, status, stamp, targetAgency, officerName: activeUser ? activeUser.displayName : 'Hệ thống', officerRole: activeUser ? activeUser.role : 'Hệ thống' }) });
        }

        async function registerResidentByOfficer(e) {
            e.preventDefault();
            const username = document.getElementById('res-user').value.trim(); const name = document.getElementById('res-name').value.trim(); const dob = document.getElementById('res-dob').value.trim(); const gender = document.getElementById('res-gender').value; const pob = document.getElementById('res-pob').value.trim(); const job = document.getElementById('res-job').value.trim(); const licenses = document.getElementById('res-licenses').value.trim(); const status = document.getElementById('res-status').value;
            await fetch('/api/resident/register', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, name, dob, gender, pob, job, licenses, status, officerName: activeUser.displayName }) });
            soundSuccess(); alert(`Cấp phát văn bằng và số hóa thông tin cư dân @${username} thành công!`);
        }

        async function submitForm(e) {
            e.preventDefault(); const sender = document.getElementById('app-sender').value.trim(); const docType = document.getElementById('app-docType').value; const agency = document.getElementById('app-agency').value; const content = document.getElementById('app-content').value.trim();
            const res = await fetch('/api/applications/submit', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sender, agency, docType, content }) });
            const data = await res.json(); document.getElementById('app-content').value = ''; document.getElementById('track-id').value = data.id; soundSuccess(); trackApplication();
        }

        function editOfficer(username) {
            let u = state.authorizedPersonnel[username]; if(!u) return;
            document.getElementById('p-user').value = u.username; document.getElementById('p-user').readOnly = true; document.getElementById('p-pass').value = u.password; document.getElementById('p-name').value = u.displayName; document.getElementById('p-role').value = u.role; document.getElementById('p-agency').value = u.agency; document.getElementById('p-isEdit').value = "true";
            document.getElementById('form-provision-title').innerHTML = `<i class="fa-solid fa-user-gear text-sky-400"></i> Hiệu chỉnh tài khoản cán bộ`;
            document.getElementById('btn-submit-provision').innerText = "Cập Nhật Thay Đổi"; document.getElementById('btn-cancel-edit').classList.remove('hidden');
        }

        function resetProvisionForm() {
            document.getElementById('p-user').value = ''; document.getElementById('p-user').readOnly = false; document.getElementById('p-pass').value = ''; document.getElementById('p-name').value = ''; document.getElementById('p-isEdit').value = "false";
            document.getElementById('form-provision-title').innerHTML = `<i class="fa-solid fa-id-card-clip"></i> Thiết Lập / Phân Quyền Nhân Sự Quốc Gia`;
            document.getElementById('btn-submit-provision').innerText = "Kích Hoạt Tài Khoản"; document.getElementById('btn-cancel-edit').classList.add('hidden');
        }

        async function deleteOfficer(username) { if(!confirm(`Xóa tài khoản cán bộ [${username}]?`)) return; await fetch('/api/officer/delete', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username }) }); }
        async function publishDocument() { const type = document.getElementById('pub-type').value; const title = document.getElementById('pub-title').value.trim(); const content = document.getElementById('pub-content').value.trim(); if(!title || !content) return; await fetch('/api/national/publish', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ type, title, content, author: activeUser.displayName }) }); document.getElementById('pub-title').value = ''; document.getElementById('pub-content').value = ''; soundSuccess(); }
        async function updateTicker() { const msg = document.getElementById('pub-ticker').value.trim(); if(!msg) return; await fetch('/api/national/ticker', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }) }); document.getElementById('pub-ticker').value = ''; soundSuccess(); }
        async function deleteNews(id) { await fetch('/api/national/delete-announcement', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) }); }
        async function setSecurity(level) { await fetch('/api/national/security', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ level }) }); }
        function openLogin() { document.getElementById('login-modal').classList.remove('hidden'); }
        function closeLogin() { document.getElementById('login-modal').classList.add('hidden'); }
        function login() { const u = document.getElementById('log-user').value; const p = document.getElementById('log-pass').value; if (state.authorizedPersonnel[u] && state.authorizedPersonnel[u].password === p) { activeUser = state.authorizedPersonnel[u]; localStorage.setItem('sessionUser', JSON.stringify({ username: u, password: p })); closeLogin(); soundSuccess(); applyUserRoleLayout(); } else { alert("Sai chứng thư!"); } }
        
        function applyUserRoleLayout() {
            if(!activeUser) return;
            document.getElementById('btn-tab-officer').classList.remove('hidden');
            if(activeUser.role === 'ADMIN') document.getElementById('btn-tab-admin').classList.remove('hidden');
            if(activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ') {
                document.getElementById('leader-publish-zone').classList.remove('hidden'); document.getElementById('leader-notice-block').classList.add('hidden');
            } else {
                document.getElementById('leader-publish-zone').classList.add('hidden'); document.getElementById('leader-notice-block').classList.remove('hidden');
            }
            renderAuth(); renderAll(); let savedTab = sessionStorage.getItem('activeTab'); tab(savedTab || 'tab-officer');
        }
        function logout() { activeUser = null; activeFileId = null; localStorage.removeItem('sessionUser'); document.getElementById('btn-tab-officer').classList.add('hidden'); document.getElementById('btn-tab-admin').classList.add('hidden'); renderAuth(); tab('tab-news'); }
        function renderAuth() { const p = document.getElementById('auth-panel'); if(!activeUser) { p.innerHTML = `<button onclick="openLogin()" class="bg-amber-500 text-black px-4 py-2 rounded-lg text-[11px] uppercase font-black">Đăng nhập nghiệp vụ</button>`; } else { p.innerHTML = `<div class="bg-slate-900 border p-1 text-xs rounded-xl flex items-center gap-2"><b class="text-white">${activeUser.displayName}</b><button onclick="logout()" class="text-red-400 ml-2"><i class="fa-solid fa-power-off"></i></button></div>`; } }
        
        startClock();
    </script>
</body>
</html>
