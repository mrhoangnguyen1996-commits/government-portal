            <div><label class="text-gray-400 block mb-1 font-bold">Mật Mã Bảo Mật Hệ Thống</label><input type="password" id="log-pass" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white focus:outline-none"></div>
