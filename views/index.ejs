        async function submitForm(e) {
            e.preventDefault();
            const sender = document.getElementById('app-sender').value.trim();
            const docType = document.getElementById('app-docType').value;
            const agency = document.getElementById('app-agency').value;
            const content = document.getElementById('app-content').value.trim();

            const res = await fetch('/api/applications/submit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ sender, agency, docType, content })
            });
            const data = await res.json();
            document.getElementById('app-content').value = '';
            document.getElementById('track-id').value = data.id;
            await syncState();
            trackApplication();
        }

        // TRA CỨU TIẾN ĐỘ VÀ KHIẾU NẠI DÀNH CHO CÔNG DÂN
        function trackApplication() {
            const id = document.getElementById('track-id').value.trim();
            const area = document.getElementById('track-details');
            const empty = document.getElementById('track-empty');

            let app = state.applications[id] || state.archivedApplications[id];
            if (!app) {
                area.classList.add('hidden'); empty.classList.remove('hidden');
                return;
            }
            empty.classList.add('hidden'); area.classList.remove('hidden');

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-slate-900 p-2 rounded border border-slate-800 text-[11px]"><p class="text-[9px] font-bold text-gray-500">${l.sender} • ${l.time}</p><p class="text-white mt-0.5">${l.msg}</p></div>`;
            });

            // Giao diện hiển thị người đang chịu trách nhiệm giải quyết đơn thư cụ thể
            let handlerInfoBox = `
                <div class="bg-[#0e1726] p-2 rounded-xl border border-slate-800 text-[11px] text-slate-300">
                    <span class="text-slate-400">Trạng vụ tiếp quản:</span> <b class="text-emerald-400">${app.handler === 'Chưa phân phối' ? 'Đang Chờ Cơ Quan Tiếp Nhận' : app.handler}</b><br>
                    <span class="text-slate-400">Chức danh hành chính:</span> <b class="text-amber-400">${app.handlerTitle}</b>
                </div>
            `;

            let satBlock = '';
            if ((app.status === 'Đã Phê Duyệt' || app.status === 'Bị Bác Bỏ') && !app.satisfaction) {
                satBlock = `
                    <div class="space-y-1.5 p-2 bg-slate-900 border border-slate-800 rounded-xl">
                        <p class="text-[10px] uppercase font-black text-center text-slate-400">Đánh giá hoặc Khiếu nại kết quả của cán bộ</p>
                        <div class="flex gap-2 justify-center">
                            <button onclick="sendAction('${id}', 'satisfaction', 'HÀI LÒNG')" class="bg-emerald-600 text-white font-black px-3 py-1 rounded text-[10px] uppercase">Đồng Ý / Hài Lòng 👍</button>
                            <button onclick="sendAction('${id}', 'satisfaction', 'KHIẾU NẠI CẤP CAO')" class="bg-red-600 text-white font-black px-3 py-1 rounded text-[10px] uppercase">🚨 KHỞI SỰ KHIẾU NẠI CẤP CAO 🚨</button>
                        </div>
                    </div>
                `;
            } else if (app.satisfaction) {
                satBlock = `<div class="text-center text-[10px] font-black uppercase text-amber-500 bg-slate-900 p-2 rounded-lg border border-slate-800">Trạng thái phản hồi cư dân: [${app.satisfaction}]</div>`;
            }

            area.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3 max-h-[300px] pr-1">
                    <div class="bg-slate-900 p-3 rounded-xl border border-slate-800 flex justify-between items-center shadow-md">
                        <div>
                            <p class="font-black text-amber-500">${app.id} [${app.docType}]</p>
                            <p class="text-[11px] text-slate-300 mt-1">Nội dung: "${app.content}"</p>
                        </div>
                        <div class="stamp-box ${app.stamp}">${app.status}</div>
                    </div>
                    ${handlerInfoBox}
                    <div class="space-y-2"><p class="text-[10px] uppercase font-black text-slate-400 tracking-wider">Nhật Ký Luồng Thẩm Định Hệ Thống:</p>${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-slate-800 space-y-2">
                    ${satBlock}
                    <div class="flex gap-2">
                        <input type="text" id="citizen-chat-msg" placeholder="Phản hồi câu hỏi, gửi bằng chứng kịch bản..." class="flex-1 bg-slate-900 border border-slate-700 p-2 text-xs text-white rounded-lg focus:outline-none">
                        <button onclick="citizenChat('${app.id}')" class="bg-amber-500 font-black text-black px-4 text-xs rounded-lg uppercase">Gửi</button>
                    </div>
                </div>
            `;
        }

        async function citizenChat(id) {
            const msg = document.getElementById('citizen-chat-msg').value.trim();
            if (!msg) return;
            await fetch('/api/applications/action', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id, action: 'chat', msg, officerName: `Công Dân (@${(state.applications[id] || state.archivedApplications[id]).sender})` })
            });
            await syncState();
            trackApplication();
        }

        function selectFile(id) {
            activeFileId = id;
            document.getElementById('officer-desk-empty').classList.add('hidden');
            document.getElementById('officer-desk-active').classList.remove('hidden');
            renderOfficerDesk();
