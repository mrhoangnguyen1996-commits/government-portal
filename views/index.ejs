<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CỔNG LIÊN THÔNG GIẢ LẬP QUỐC GIA - ROBLOX ROLEPLAY</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Share+Tech+Mono&display=swap');
        
        body { 
            font-family: 'Space Grotesk', sans-serif; 
            background-color: #060913; 
            color: #cbd5e1; 
        }
        .font-mono-tech { font-family: 'Share Tech Mono', monospace; }
        
        /* Hiệu ứng Chữ chạy (Marquee) hoạt động ổn định */
        .marquee-container {
            overflow: hidden;
            white-space: nowrap;
            display: flex;
            align-items: center;
        }
        .marquee-text {
            display: inline-block;
            animation: marqueeEffect 30s linear infinite;
        }
        @keyframes marqueeEffect {
            0% { transform: translate3d(100%, 0, 0); }
            100% { transform: translate3d(-100%, 0, 0); }
        }

        /* Phôi thẻ định danh giả lập */
        .card-mockup { 
            position: relative; 
            overflow: hidden; 
            border-radius: 8px; 
            padding: 12px; 
            font-family: 'Share Tech Mono', monospace;
            font-size: 11px;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .card-glow {
            position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
            background: linear-gradient(to right, transparent, rgba(255,255,255,0.08), transparent);
            transform: skewX(-25deg); animation: cardSwipe 4s infinite linear;
        }
        @keyframes cardSwipe { 0% { left: -100%; } 30% { left: 160%; } 100% { left: 160%; } }

        .stamp-box { 
            text-transform: uppercase; padding: 4px 10px; border-radius: 4px; 
            border: 2px dashed; display: inline-block; font-weight: bold;
            transform: rotate(-3deg); animation: stampSlam 0.3s ease-out both; 
        }
        @keyframes stampSlam { 0% { transform: scale(2); opacity: 0; } 100% { transform: rotate(-3deg) scale(1); opacity: 1; } }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between">

    <!-- HEADER HỆ THỐNG -->
    <header class="border-b border-slate-900 bg-slate-950/80 backdrop-blur px-4 py-3 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <div class="h-9 w-9 rounded-lg bg-gradient-to-tr from-red-700 to-amber-600 flex items-center justify-center text-white text-lg font-black shadow-lg">
                    <i class="fa-solid fa-building-shield"></i>
                </div>
                <div>
                    <h1 class="font-black text-white text-xs tracking-wider uppercase">CỔNG LIÊN THÔNG GIẢ LẬP QUỐC GIA</h1>
                    <p class="text-[9px] text-slate-500 font-mono-tech tracking-widest uppercase">HỆ THỐNG QUY CHẾ HỒ SƠ ROLEPLAY / ROBLOX</p>
                </div>
            </div>
            
            <div class="flex items-center gap-3">
                <div id="national-alert-light" class="hidden border border-red-900 px-2 py-0.5 rounded flex items-center gap-1.5 cursor-pointer bg-red-950/20">
                    <span class="h-1.5 w-1.5 rounded-full bg-red-500 animate-ping"></span>
                    <span class="text-red-400 font-black text-[8px] tracking-wider uppercase font-mono-tech">ĐƠN MỚI CHUYỂN TUYẾN</span>
                </div>
                <div class="border border-slate-800 px-2.5 py-0.5 rounded bg-slate-900/60 text-center">
                    <span id="live-clock" class="text-xs font-mono-tech font-bold text-amber-400">00:00:00</span>
                </div>
                <div class="border border-slate-800 px-2.5 py-0.5 rounded bg-slate-900/60 text-center">
                    <span class="text-[10px] font-mono-tech font-black text-emerald-400" id="security-level-display"><%= state.securityLevel %></span>
                </div>
                <div id="user-session-panel">
                    <button onclick="openModal('modal-login')" class="bg-slate-900 border border-slate-800 text-slate-400 font-bold px-3 py-1 rounded text-[10px] hover:text-white transition">
                        <i class="fa-solid fa-lock-open"></i> ĐĂNG NHẬP CÔNG VỤ
                    </button>
                </div>
            </div>
        </div>
    </header>

    <!-- THANH THÔNG BÁO KHẨN (CHỮ CHẠY ĐÃ ĐƯỢC SỬA) -->
    <div class="bg-slate-950 border-b border-slate-900 py-1.5 flex items-center shadow-inner">
        <span class="bg-red-900 text-white text-[9px] font-black uppercase px-2 py-0.5 ml-4 rounded shrink-0 tracking-wider">THÔNG BÁO KHẨN</span>
        <div class="w-full marquee-container ml-3">
            <div class="marquee-text font-mono-tech text-amber-400 text-xs" id="ticker-box">
                <%= state.tickerMessage %>
            </div>
        </div>
    </div>

    <!-- THANH ĐIỀU HƯỚNG TAB CHÍNH NGANG TRÊN TRANG WEB -->
    <nav class="bg-slate-950/40 border-b border-slate-900 sticky top-[53px] z-40 backdrop-blur-sm">
        <div class="max-w-md mx-auto flex justify-around text-center">
            <button id="btn-tab-services" onclick="switchTab('tab-services')" class="flex-1 py-3 text-[11px] font-black tracking-wider uppercase border-b-2 border-amber-500 text-amber-500">
                <i class="fa-solid fa-folder-plus block mb-0.5 text-xs"></i> NỘP ĐƠN THỦ TỤC
            </button>
            <button id="btn-tab-id" onclick="switchTab('tab-id')" class="flex-1 py-3 text-[11px] font-black tracking-wider uppercase border-b-2 border-transparent text-slate-400 hover:text-white transition">
                <i class="fa-solid fa-address-book block mb-0.5 text-xs"></i> TRA CỨU ĐỊNH DANH
            </button>
            <button id="btn-tab-track" onclick="switchTab('tab-track')" class="flex-1 py-3 text-[11px] font-black tracking-wider uppercase border-b-2 border-transparent text-slate-400 hover:text-white transition">
                <i class="fa-solid fa-chart-line block mb-0.5 text-xs"></i> TIẾN ĐỘ HỒ SƠ
            </button>
        </div>
    </nav>

    <!-- KHU VỰC CHÍNH BỐ TRÍ THEO DẠNG LƯỚI KHÔNG RỐI MẮT -->
    <main class="max-w-7xl mx-auto p-4 grid grid-cols-1 lg:grid-cols-12 gap-5 flex-grow w-full">
        
        <!-- CỘT TRÁI (QUYẾT ĐỊNH & TRUY NÃ) -->
        <section class="lg:col-span-4 space-y-4">
            <!-- VĂN BẢN CHỈ THỊ FROM IMAGE_3BE3A3 -->
            <div class="bg-slate-950/60 border border-slate-900 rounded-xl p-4 space-y-3">
                <h3 class="text-white font-black text-xs tracking-wider uppercase flex items-center gap-2 border-b border-slate-900/60 pb-2">
                    <i class="fa-solid fa-scroll text-amber-500"></i> VĂN BẢN CHỈ THỊ / SẮC LỆNH
                </h3>
                <div id="announcements-list" class="space-y-3 max-h-64 overflow-y-auto pr-1"></div>
            </div>

            <!-- CƠ SỞ DỮ LIỆU TRUY NÃ FROM IMAGE_3BE3A3 -->
            <div class="bg-slate-950/60 border border-slate-900 rounded-xl p-4 space-y-3">
                <h3 class="text-red-400 font-black text-xs tracking-wider uppercase flex items-center gap-2 border-b border-slate-900/60 pb-2">
                    <i class="fa-solid fa-triangle-exclamation text-red-500"></i> ĐỐI TƯỢNG TRUY NÃ QUỐC GIA
                </h3>
                <div id="wanted-list" class="space-y-2.5 max-h-56 overflow-y-auto pr-1"></div>
            </div>
        </section>

        <!-- CỘT PHẢI (NỘI DUNG CHỨC NĂNG & WORKSPACE CÁN BỘ / ADMIN) -->
        <section class="lg:col-span-8 space-y-4">
            
            <!-- KHU VỰC ĐỔI TAB CỦA NGƯỜI DÂN -->
            <div class="bg-slate-950/40 border border-slate-900 rounded-xl p-4">
                <!-- TAB 1: NỘP ĐƠN -->
                <div id="panel-tab-services" class="space-y-3">
                    <span class="text-amber-500 font-black text-xs uppercase tracking-wider block mb-2"><i class="fa-solid fa-file-signature"></i> Khởi tạo số hóa hồ sơ công dân ảo</span>
                    <form id="applyForm" onsubmit="handleFormSubmit(event)" class="space-y-3">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            <div>
                                <label class="text-[10px] text-slate-400 uppercase font-bold block mb-1">Tên tài khoản (Roblox Account):</label>
                                <input type="text" id="app-name" placeholder="Ví dụ: Quang_Minh_RP" required class="w-full bg-slate-900 border border-slate-800 rounded px-3 py-1.5 text-xs text-white focus:outline-none focus:border-amber-500">
                            </div>
                            <div>
                                <label class="text-[10px] text-slate-400 uppercase font-bold block mb-1">Loại hồ sơ đề xuất:</label>
                                <select id="app-docType" onchange="autoRouteAgency()" class="w-full bg-slate-900 border border-slate-800 rounded px-2.5 py-1.5 text-xs text-white focus:outline-none">
                                    <option value="CĂN CƯỚC CÔNG DÂN">Thẻ Căn Cước Định Danh Công Dân</option>
                                    <option value="GIẤY PHÉP LÁI XE QUỐC GIA">Giấy Phép Điều Khiển Phương Tiện Hạng B2</option>
                                    <option value="GIẤY PHÉP SỬ DỤNG CÔNG CỤ HỖ TRỢ">Giấy Phép Sử Dụng Thiết Bị Bảo Vệ</option>
                                    <option value="GIẤY PHÉP XÂY DỰNG NHÀ Ở">Giấy Phép Cải Tạo/Xây Dựng Đô Thị</option>
                                    <option value="CHỨNG CHỈ HÀNH NGHỀ Y TẾ">Chứng Chỉ Đủ Điều Kiện Hành Nghề Y Tế</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="text-[10px] text-slate-400 uppercase font-bold block mb-1">Cơ quan tiếp nhận liên thông:</label>
                            <select id="app-agency" disabled class="w-full bg-slate-950 border border-slate-900 rounded px-2.5 py-1.5 text-xs text-amber-500 font-bold opacity-80">
                                <option value="CÔNG AN">CƠ QUAN CÔNG AN QUỐC GIA</option>
                                <option value="UBND PHƯỜNG">ỦY BAN NHÂN DÂN PHƯỜNG SỐ HÓA</option>
                                <option value="SỞ GIAO THÔNG THÀNH PHỐ">SỞ GIAO THÔNG VẬN TẢI THÀNH PHỐ</option>
                                <option value="BỆNH VIỆN">BỆNH VIỆN ĐA KHOA LIÊN THÔNG</option>
                            </select>
                        </div>
                        <div>
                            <label class="text-[10px] text-slate-400 uppercase font-bold block mb-1">Cam kết nội dung / Lý do xin cấp:</label>
                            <textarea id="app-details" rows="2" placeholder="Nêu rõ mục đích sử dụng trong không gian roleplay..." required class="w-full bg-slate-900 border border-slate-800 rounded px-3 py-1.5 text-xs text-white focus:outline-none focus:border-amber-500"></textarea>
                        </div>
                        <button type="submit" class="w-full bg-amber-500 hover:bg-amber-600 text-black font-black py-2 rounded text-xs tracking-wider uppercase transition">
                            <i class="fa-solid fa-paper-plane"></i> GỬI HỒ SƠ LÊN HỆ THỐNG
                        </button>
                    </form>
                </div>

                <!-- TAB 2: TRA CỨU ĐỊNH DANH -->
                <div id="panel-tab-id" class="space-y-3 hidden">
                    <span class="text-emerald-400 font-black text-xs uppercase tracking-wider block mb-2"><i class="fa-solid fa-magnifying-glass"></i> Hệ thống tra cứu dữ liệu cư dân điện tử</span>
                    <div class="flex gap-2">
                        <input type="text" id="id-search" placeholder="Nhập chính xác tên tài khoản định danh..." class="flex-grow bg-slate-900 border border-slate-800 rounded px-3 py-1.5 text-xs text-white focus:outline-none">
                        <button onclick="searchCitizen()" class="bg-emerald-600 hover:bg-emerald-700 font-bold px-4 py-1.5 rounded text-xs text-white transition">TRA CỨU</button>
                    </div>
                    <div id="id-result" class="border border-slate-900 rounded-xl p-3 bg-slate-950/80 hidden"></div>
                </div>

                <!-- TAB 3: TIẾN ĐỘ HỒ SƠ & CHAT -->
                <div id="panel-tab-track" class="space-y-3 hidden">
                    <span class="text-sky-400 font-black text-xs uppercase tracking-wider block mb-2"><i class="fa-solid fa-receipt"></i> Kiểm tra luồng xử lý hành chính</span>
                    <div class="flex gap-2">
                        <input type="text" id="track-id" placeholder="Nhập mã hồ sơ hành chính ảo (Ví dụ: HS-123456)" class="flex-grow bg-slate-900 border border-slate-800 rounded px-3 py-1.5 text-xs text-white focus:outline-none">
                        <button onclick="trackApplication()" class="bg-sky-600 hover:bg-sky-700 font-bold px-4 py-1.5 rounded text-xs text-white transition">KIỂM TRA</button>
                    </div>
                    <div id="track-result" class="border border-slate-900 rounded-xl p-3 bg-slate-950/80 hidden space-y-3">
                        <div class="flex justify-between items-center border-b border-slate-900 pb-2">
                            <div>
                                <span class="text-xs font-mono-tech font-black text-white" id="res-id">HS-XXXXXX</span>
                                <span class="text-[9px] block text-slate-500 uppercase font-black" id="res-docType">LOẠI</span>
                            </div>
                            <span id="res-status" class="text-[9px] font-black font-mono px-2 py-0.5 rounded border">TRẠNG THÁI</span>
                        </div>
                        <div class="text-xs space-y-1">
                            <p><span class="text-slate-500">Chủ đơn ảo:</span> <span class="text-white font-bold" id="res-name">---</span></p>
                            <p><span class="text-slate-500">Cơ quan chuyển tuyến:</span> <span class="text-amber-500 font-bold" id="res-agency">---</span></p>
                            <p class="bg-slate-900 p-2 border border-slate-800 rounded text-[11px] text-slate-400" id="res-details">Nội dung...</p>
                        </div>
                        <div id="res-stamp-area" class="text-center hidden"></div>
                        <div class="border-t border-slate-900 pt-3 space-y-2">
                            <div id="res-logs" class="bg-slate-900/60 border border-slate-800 rounded p-2 h-28 overflow-y-auto font-mono text-[10px] text-slate-400 space-y-1"></div>
                            <div class="flex gap-1.5">
                                <input type="text" id="chat-msg" placeholder="Nhập phản hồi ý kiến cư dân..." class="flex-grow bg-slate-900 border border-slate-800 rounded px-2.5 py-1 text-xs text-white focus:outline-none">
                                <button onclick="sendChatMessage('CÔNG DÂN')" class="bg-emerald-600 text-white px-4 py-1 rounded text-xs font-bold hover:bg-emerald-700 transition">GỬI</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- BÀN LÀM VIỆC CỦA CÁN BỘ ĐIỀU PHỐI (KHÔI PHỤC) -->
            <div class="bg-slate-950/60 border border-slate-900 rounded-xl p-4 space-y-3">
                <div class="flex justify-between items-center border-b border-slate-900 pb-2">
                    <h4 class="text-white font-black text-xs uppercase tracking-wider"><i class="fa-solid fa-user-gear text-amber-500"></i> BÀN THẨM ĐỊNH BAN NGÀNH LIÊN THÔNG</h4>
                    <span id="officer-badge" class="text-[9px] font-mono font-bold bg-slate-900 px-2 py-0.5 rounded border border-slate-800 text-slate-500">CHỜ TRUY CẬP</span>
                </div>
                <div id="officer-lockout" class="text-center py-6 border border-dashed border-slate-800/60 rounded-xl">
                    <p class="text-xs text-slate-500">Yêu cầu đăng nhập tài khoản công chức để thực hiện quyền hạn duyệt phê đóng dấu điện tử.</p>
                </div>
                <div id="officer-workspace" class="hidden space-y-3">
                    <div id="officer-app-list" class="space-y-1.5 max-h-36 overflow-y-auto"></div>
                    <div id="officer-review-panel" class="border border-slate-900 rounded-xl p-3 bg-slate-950 hidden space-y-3">
                        <div class="flex justify-between items-center border-b border-slate-900 pb-1.5">
                            <div><span class="text-xs font-mono-tech font-black text-white" id="off-id">HS-XXXXXX</span></div>
                            <span id="off-status" class="text-[9px] font-mono font-black px-2 py-0.5 rounded bg-slate-900 text-amber-400">ĐANG DUYỆT</span>
                        </div>
                        <div id="off-card-preview-area"></div>
                        <div class="flex gap-2" id="off-actions"></div>
                        <div class="flex gap-1.5 pt-1">
                            <input type="text" id="off-chat-msg" placeholder="Hướng dẫn sửa đổi hồ sơ nếu từ chối..." class="flex-grow bg-slate-900 border border-slate-800 rounded px-2.5 py-1 text-xs text-white focus:outline-none">
                            <button onclick="sendChatMessage('CÁN BỘ')" class="bg-amber-500 text-black px-4 py-1 rounded text-xs font-black hover:bg-amber-600 transition">PHẢN HỒI</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- BẢNG GIÁM SÁT TỐI CAO ADMIN (KHÔI PHỤC) -->
            <div id="leader-panel" class="bg-slate-950/60 border border-slate-900 rounded-xl p-4 space-y-3 hidden">
                <span class="text-red-400 font-black text-xs uppercase block tracking-wider border-b border-slate-900 pb-2"><i class="fa-solid fa-gavel"></i> BAN ĐIỀU HÀNH TỐI CAO CHÍNH PHỦ ẢO (ADMIN)</span>
                <div class="grid grid-cols-3 gap-2">
                    <button onclick="updateSecurity('AN TOÀN TRÒ CHƠI')" class="bg-emerald-950/40 text-emerald-400 border border-emerald-900 py-1.5 rounded text-xs font-bold hover:bg-emerald-900/30 transition">AN TOÀN</button>
                    <button onclick="updateSecurity('NGUY CƠ XUNG ĐỘT')" class="bg-amber-950/40 text-amber-400 border border-amber-800 py-1.5 rounded text-xs font-bold hover:bg-amber-800/30 transition">NGUY CƠ</button>
                    <button onclick="updateSecurity('BÁO ĐỘNG KHẨN CẤP')" class="bg-red-950/40 text-red-400 border border-red-800 py-1.5 rounded text-xs font-bold hover:bg-red-800/30 transition">BÁO ĐỘNG</button>
                </div>
                <div class="flex gap-2">
                    <select id="pub-type" class="bg-slate-900 border border-slate-800 rounded text-xs text-white px-2 py-1">
                        <option value="QUYẾT ĐỊNH GIẢ LẬP">QUYẾT ĐỊNH</option>
                        <option value="TRUY NÃ">TRUY NÃ</option>
                    </select>
                    <input type="text" id="pub-title" placeholder="Tiêu đề văn bản / Tên đối tượng" class="flex-grow bg-slate-900 border border-slate-800 rounded px-2.5 py-1 text-xs text-white focus:outline-none">
                </div>
                <textarea id="pub-content" rows="1" placeholder="Tội danh hoặc tóm tắt chỉ thị ban hành..." class="w-full bg-slate-900 border border-slate-800 rounded p-2 text-xs text-white focus:outline-none"></textarea>
                <button onclick="publishNational()" class="w-full bg-red-800 hover:bg-red-900 text-white font-bold py-1.5 rounded text-xs uppercase tracking-wide transition">PHÁT SẮC LỆNH SỐ HÓA TOÀN SERVER</button>
            </div>
            
            <!-- XUNG NHỊP LOG HỆ THỐNG - BẢO MẬT KHÔNG HIỂN THỊ TRƯỜNG PASSWORD -->
            <div class="border border-slate-900 rounded-xl p-3 bg-slate-950/20">
                <span class="text-[9px] font-mono-tech text-slate-500 block mb-1">XUNG NHỊP CONSOLE SERVER DATA LOGS (MẬT KHẨU ĐÃ ĐƯỢC MÃ HÓA BẢO MẬT):</span>
                <div id="system-logs" class="font-mono-tech text-[10px] text-slate-600 max-h-24 overflow-y-auto space-y-0.5"></div>
            </div>
        </section>
    </main>

    <!-- FOOTER CẢNH BÁO BẢO MẬT & ĐIỀU KHOẢN PHÁP LÝ CHUẨN ĐẸP KHÔNG MẤT -->
    <footer class="border-t border-red-950/40 bg-[#060913] pt-6 pb-8 px-4 text-center">
        <div class="max-w-3xl mx-auto space-y-3.5">
            <div class="flex items-center justify-center gap-2 text-red-500 font-black text-xs tracking-wider uppercase">
                <i class="fa-solid fa-triangle-exclamation animate-pulse"></i>
                CẢNH BÁO BẢO MẬT & ĐIỀU KHOẢN PHÁP LÝ
                <i class="fa-solid fa-triangle-exclamation animate-pulse"></i>
            </div>
            
            <p class="text-red-400 font-extrabold text-xs tracking-wide uppercase leading-relaxed max-w-2xl mx-auto">
                ĐÂY LÀ TRANG WEB GIẢ LẬP KHÔNG CÓ THỰC, ĐƯỢC XÂY DỰNG ĐỘC QUYỀN PHỤC VỤ CHO CÁC KỊCH BẢN TƯƠNG TÁC NHẬP VAI (ROLEPLAY) GIẢI TRÍ TRÊN NỀN TẢNG <span class="bg-amber-500 text-black px-1 rounded font-black">ROBLOX</span>.
            </p>
            
            <p class="text-slate-500 text-[11px] leading-relaxed text-justify sm:text-center px-4 font-normal">
                Mọi thông tin, dữ liệu căn cước, văn bản số hóa, lệnh truy nã và con dấu điện tử hiển thị trên website này hoàn toàn là hư cấu do người chơi tự nhập và biên soạn, <strong>không có bất kỳ giá trị pháp lý hay giá trị sử dụng thực tế nào</strong> đối với các cơ quan ban ngành, tổ chức chính thống của <strong>nước Cộng hòa Xã hội Chủ nghĩa Việt Nam</strong>. Nghiêm cấm sử dụng trang web này vào mục đích mạo danh hoặc lừa đảo trục lợi ngoài đời thực.
            </p>
            
            <div class="text-[10px] text-slate-600 font-mono-tech pt-2 border-t border-slate-900/40">
                © 2026 Gaming Simulator Project. Powered by Co-op Coding Sandbox. All rights reserved.
            </div>
        </div>
    </footer>

    <!-- MODAL ĐĂNG NHẬP (BẢO MẬT) -->
    <div id="modal-login" class="fixed inset-0 bg-black/80 backdrop-blur-sm flex items-center justify-center p-4 z-50 hidden">
        <div class="bg-slate-950 border border-slate-800 w-full max-w-sm rounded-xl p-5 space-y-4">
            <div class="flex justify-between items-center border-b border-slate-800 pb-2">
                <span class="text-white font-black text-xs uppercase tracking-wider"><i class="fa-solid fa-fingerprint text-amber-500"></i> Xác thực cán bộ liên thông</span>
                <button onclick="closeModal('modal-login')" class="text-slate-500 hover:text-white text-sm transition"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="space-y-3">
                <div>
                    <label class="text-[9px] text-slate-400 font-bold block mb-1 uppercase">Tài khoản công vụ:</label>
                    <input type="text" id="login-user" placeholder="Tên cán bộ (ca_phuong, admin...)" class="w-full bg-slate-900 border border-slate-800 rounded px-3 py-1.5 text-xs text-white focus:outline-none">
                </div>
                <div>
                    <label class="text-[9px] text-slate-400 font-bold block mb-1 uppercase">Mật khẩu số hóa:</label>
                    <input type="password" id="login-pass" placeholder="••••••••" class="w-full bg-slate-900 border border-slate-800 rounded px-3 py-1.5 text-xs text-white focus:outline-none">
                </div>
                <button onclick="loginOfficer()" class="w-full bg-amber-500 hover:bg-amber-600 text-black font-black py-2 rounded text-xs uppercase tracking-wider transition">KẾT NỐI LIÊN THÔNG</button>
            </div>
        </div>
    </div>

    <!-- LOGIC VẬN HÀNH TOÀN TRANG -->
    <script>
        let state = <%- JSON.stringify(state) %>;
        let activeUser = null;
        let selectedOfficerAppId = null;

        function autoRouteAgency() {
            const docType = document.getElementById('app-docType').value;
            const agencySelect = document.getElementById('app-agency');
            if (docType === 'GIẤY PHÉP LÁI XE QUỐC GIA') agencySelect.value = 'SỞ GIAO THÔNG THÀNH PHỐ';
            else if (docType === 'GIẤY PHÉP XÂY DỰNG NHÀ Ở') agencySelect.value = 'UBND PHƯỜNG';
            else if (docType === 'CHỨNG CHỈ HÀNH NGHỀ Y TẾ') agencySelect.value = 'BỆNH VIỆN';
            else agencySelect.value = 'CÔNG AN';
        }

        function switchTab(tabId) {
            ['tab-services', 'tab-track', 'tab-id'].forEach(t => {
                document.getElementById(`panel-${t}`).classList.add('hidden');
                document.getElementById(`btn-${t}`).className = "flex-1 py-3 text-[11px] font-black tracking-wider uppercase border-b-2 border-transparent text-slate-400 hover:text-white transition";
            });
            document.getElementById(`panel-${tabId}`).classList.remove('hidden');
            document.getElementById(`btn-${tabId}`).className = "flex-1 py-3 text-[11px] font-black tracking-wider uppercase border-b-2 border-amber-500 text-amber-500";
        }

        function openModal(id) { document.getElementById(id).classList.remove('hidden'); }
        function closeModal(id) { document.getElementById(id).classList.add('hidden'); }

        function handleFormSubmit(e) {
            e.preventDefault();
            autoRouteAgency();
            const name = document.getElementById('app-name').value;
            const docType = document.getElementById('app-docType').value;
            const agency = document.getElementById('app-agency').value;
            const details = document.getElementById('app-details').value;

            fetch('/api/apply', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, docType, agency, details })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert(`Nộp đơn thành công ảo! Mã tra cứu: ${data.appId}`);
                    document.getElementById('track-id').value = data.appId;
                    switchTab('tab-track');
                    trackApplication();
                    syncState();
                }
            });
        }

        function trackApplication() {
            const appId = document.getElementById('track-id').value.trim();
            if (!appId) return;

            fetch('/api/track', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ appId })
            })
            .then(res => res.json())
            .then(data => {
                const resultBox = document.getElementById('track-result');
                if (data.success) {
                    resultBox.classList.remove('hidden');
                    const app = data.application;
                    document.getElementById('res-id').innerText = app.id;
                    document.getElementById('res-docType').innerText = app.docType;
                    document.getElementById('res-name').innerText = app.name;
                    document.getElementById('res-agency').innerText = app.agency;
                    document.getElementById('res-details').innerText = app.details;
                    
                    let sb = document.getElementById('res-status');
                    sb.innerText = app.status;
                    sb.className = "text-[9px] font-black font-mono px-2 py-0.5 rounded border ";
                    if (app.status === 'ĐANG CHỜ TIẾP NHẬN') sb.className += "bg-slate-900 border-slate-800 text-slate-500";
                    if (app.status === 'ĐANG XỬ LÝ') sb.className += "bg-amber-950 border-amber-900 text-amber-400";
                    if (app.status === 'ĐÃ PHÊ DUYỆT') sb.className += "bg-emerald-950 border-emerald-900 text-emerald-400";
                    if (app.status === 'BỊ TỪ CHỐI') sb.className += "bg-red-950 border-red-900 text-red-400";

                    let stampArea = document.getElementById('res-stamp-area');
                    if (app.status === 'ĐÃ PHÊ DUYỆT') {
                        stampArea.classList.remove('hidden');
                        stampArea.innerHTML = `
                            <div class="border border-dashed border-emerald-500/20 rounded-lg p-2 bg-emerald-950/5 mt-2">
                                <div class="stamp-box border-emerald-500 text-emerald-400 text-[9px] my-2">
                                    <i class="fa-solid fa-stamp"></i> ${app.stamp}
                                </div>
                                ${renderVisualCard(app.docType, app.name)}
                            </div>`;
                    } else { stampArea.classList.add('hidden'); }

                    let chatHtml = "";
                    app.logs.forEach(log => { chatHtml += `<div class="border-b border-slate-900/40 pb-1 mb-1 last:border-0">${log}</div>`; });
                    document.getElementById('res-logs').innerHTML = chatHtml;
                } else { alert(data.message); resultBox.classList.add('hidden'); }
            });
        }

        function searchCitizen() {
            const user = document.getElementById('id-search').value.trim();
            const box = document.getElementById('id-result');
            if(!user) return;

            box.classList.remove('hidden');
            let isOfficer = state.authorizedPersonnel[user];
            let name = isOfficer ? isOfficer.displayName : user;
            let role = isOfficer ? isOfficer.role : "CƯ DÂN CHƯA BIÊN CHẾ";

            box.innerHTML = `
                <div class="space-y-2 text-left">
                    <div class="flex items-center gap-2 bg-slate-900 p-2 border border-slate-800 rounded">
                        <i class="fa-solid fa-id-card text-emerald-400"></i>
                        <div>
                            <h4 class="font-black text-white text-xs">${name.toUpperCase()}</h4>
                            <p class="text-[9px] text-emerald-400 font-mono font-bold">${role}</p>
                        </div>
                    </div>
                    <div class="pt-2 border-t border-slate-900">${renderVisualCard('CĂN CƯỚC CÔNG DÂN', name)}</div>
                </div>`;
        }

        function loginOfficer() {
            const user = document.getElementById('login-user').value.trim();
            const pass = document.getElementById('login-pass').value.trim();

            if (state.authorizedPersonnel[user] && state.authorizedPersonnel[user].password === pass) {
                activeUser = {
                    username: user,
                    displayName: state.authorizedPersonnel[user].displayName,
                    role: state.authorizedPersonnel[user].role,
                    agency: state.authorizedPersonnel[user].agency
                };
                localStorage.setItem('sessionUser', JSON.stringify({ username: user, pass: pass }));
                setupOfficerPanel();
                closeModal('modal-login');
            } else { alert("Khóa mật khẩu điện tử sai!"); }
        }

        function setupOfficerPanel() {
            if(!activeUser) return;
            document.getElementById('user-session-panel').innerHTML = `
                <div class="text-[10px] text-amber-500 font-black border border-amber-900 bg-amber-950/40 px-2 py-0.5 rounded flex items-center gap-2">
                    <span>${activeUser.displayName}</span>
                    <button onclick="logout()" class="text-slate-500 hover:text-red-400"><i class="fa-solid fa-power-off"></i></button>
                </div>`;
            
            document.getElementById('officer-lockout').classList.add('hidden');
            document.getElementById('officer-workspace').classList.remove('hidden');
            document.getElementById('officer-badge').innerText = activeUser.agency.toUpperCase();

            if (activeUser.agency === 'TRUNG ƯƠNG') document.getElementById('leader-panel').classList.remove('hidden');
            loadOfficerList();
        }

        function logout() { localStorage.removeItem('sessionUser'); location.reload(); }

        function loadOfficerList() {
            const container = document.getElementById('officer-app-list');
            let html = ""; let count = 0;

            Object.keys(state.applications).forEach(id => {
                const app = state.applications[id];
                if (activeUser.agency === 'TRUNG ƯƠNG' || app.agency === activeUser.agency) {
                    count++;
                    html += `
                        <div onclick="reviewApp('${app.id}')" class="p-2 border border-slate-900 hover:border-amber-500 rounded bg-slate-900/20 cursor-pointer flex justify-between items-center text-xs">
                            <span class="font-mono text-white font-bold">${app.id} [${app.name}]</span>
                            <span class="text-[8px] px-1.5 py-0.5 bg-slate-950 text-slate-400 rounded">${app.status}</span>
                        </div>`;
                }
            });
            container.innerHTML = count === 0 ? `<div class="text-center py-2 text-xs text-slate-600">⚡ Không có hồ sơ chuyển tuyến.</div>` : html;
        }

        function reviewApp(id) {
            selectedOfficerAppId = id; const app = state.applications[id];
            if(!app) return;

            document.getElementById('officer-review-panel').classList.remove('hidden');
            document.getElementById('off-id').innerText = app.id;
            document.getElementById('off-status').innerText = app.status;
            document.getElementById('off-card-preview-area').innerHTML = renderVisualCard(app.docType, app.name);

            let actionHtml = "";
            if (app.status === 'ĐANG CHỜ TIẾP NHẬN') {
                actionHtml = `<button onclick="triggerAction('RECEIVE')" class="w-full bg-sky-600 py-1 rounded text-white text-xs font-bold">TIẾP NHẬN XỬ LÝ</button>`;
            } else if (app.status === 'ĐANG XỬ LÝ') {
                actionHtml = `
                    <button onclick="triggerAction('APPROVE')" class="flex-1 bg-emerald-600 font-bold py-1 rounded text-white text-xs"><i class="fa-solid fa-stamp"></i> PHÊ DUYỆT</button>
                    <button onclick="triggerAction('REJECT')" class="bg-red-700 font-bold py-1 px-3 rounded text-white text-xs">TỪ CHỐI</button>`;
            }
            document.getElementById('off-actions').innerHTML = actionHtml;
        }

        function triggerAction(action) {
            fetch('/api/action', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ appId: selectedOfficerAppId, action, officer: activeUser.displayName, agency: activeUser.agency })
            }).then(() => {
                document.getElementById('officer-review-panel').classList.add('hidden');
                syncState();
            });
        }

        function sendChatMessage(role) {
            const appId = role === 'CÁN BỘ' ? selectedOfficerAppId : document.getElementById('track-id').value.trim();
            const input = role === 'CÁN BỘ' ? document.getElementById('off-chat-msg') : document.getElementById('chat-msg');
            if(!appId || !input.value.trim()) return;

            fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ appId, message: input.value.trim(), sender: role === 'CÁN BỘ' ? activeUser.displayName : "CÔNG DÂN" })
            }).then(() => {
                input.value = "";
                if (role === 'CÁN BỘ') reviewApp(appId); else trackApplication();
                syncState();
            });
        }

        function updateSecurity(lvl) {
            fetch('/api/state').then(r=>r.json()).then(s => { s.securityLevel = lvl; syncState(); });
        }

        function publishNational() {
            const type = document.getElementById('pub-type').value;
            const title = document.getElementById('pub-title').value.trim();
            const content = document.getElementById('pub-content').value.trim();
            if(!title || !content) return;

            fetch('/api/national/publish', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ type, title, content, author: activeUser.displayName })
            }).then(() => {
                document.getElementById('pub-title').value = "";
                document.getElementById('pub-content').value = "";
                syncState();
            });
        }

        function renderStateUI() {
            // RENDERING LOGS - Tuyệt đối ẩn/không in mật khẩu ra ngoài
            let logHtml = "";
            state.systemLogs.forEach(l => { 
                logHtml += `<div class="text-left text-slate-500"><span class="text-slate-700">[${l.time.split(' - ')[0]}]</span> ${l.text}</div>`; 
            });
            document.getElementById('system-logs').innerHTML = logHtml;

            // RENDERING QUYẾT ĐỊNH
            let annHtml = "";
            state.announcements.forEach(a => {
                annHtml += `
                    <div class="p-3 border border-slate-900 rounded-lg bg-[#0c1222]/60 text-left">
                        <span class="bg-amber-950 text-amber-400 font-bold text-[9px] px-1.5 py-0.5 rounded uppercase block w-max mb-1">${a.type}</span>
                        <h4 class="font-black text-white text-xs leading-snug mb-1">${a.title}</h4>
                        <p class="text-slate-400 text-[11px] leading-normal mb-1.5">${a.content}</p>
                        <span class="text-[9px] text-slate-500 block">Ban hành: ${a.timestamp.split(' - ')[0]}</span>
                    </div>`;
            });
            document.getElementById('announcements-list').innerHTML = annHtml || `<div class="text-center text-slate-600 text-xs py-4">Chưa có chỉ thị mới.</div>`;

            // RENDERING TRUY NÃ
            let wantedHtml = "";
            state.criminalWantedList.forEach(w => {
                wantedHtml += `
                    <div class="p-3 bg-red-950/10 border border-red-900/30 rounded-xl text-left relative">
                        <div class="font-black text-red-500 text-[10px] uppercase mb-1">TRUY NÃ: @${w.name}</div>
                        <p class="text-[11px] text-slate-300 leading-tight mb-1"><span class="text-slate-500 font-bold">Tội danh:</span> ${w.crime}</p>
                        <div class="text-amber-400 font-mono text-xs font-black">Bounty: <span class="text-white px-1 bg-red-950 border border-red-900/40 rounded">${w.bounty}</span></div>
                    </div>`;
            });
            document.getElementById('wanted-list').innerHTML = wantedHtml || `<div class="text-center text-slate-600 text-xs py-4">Khu vực an toàn.</div>`;
        }

        function syncState() {
            fetch('/api/state').then(res => res.json()).then(ns => {
                state = ns;
                document.getElementById('security-level-display').innerText = state.securityLevel;
                document.getElementById('ticker-box').innerText = state.tickerMessage;
                renderStateUI(); loadOfficerList();
            });
        }

        function renderVisualCard(type, name) {
            const nameUpper = name.toUpperCase();
            if (type === 'CĂN CƯỚC CÔNG DÂN') {
                return `<div class="card-mockup bg-gradient-to-r from-slate-950 to-slate-900 text-left border-sky-500/30"><div class="card-glow"></div><p class="text-sky-400 font-bold text-[9px] border-b border-sky-500/10 pb-0.5 mb-1">THẺ ĐỊNH DANH CƯ DÂN SỐ HÓA</p><p class="text-white font-bold">HỌ TÊN: ${nameUpper}</p></div>`;
            }
            if (type === 'GIẤY PHÉP LÁI XE QUỐC GIA') {
                return `<div class="card-mockup bg-gradient-to-r from-slate-950 to-slate-900 text-left border-amber-500/30"><div class="card-glow"></div><p class="text-amber-400 font-bold text-[9px] border-b border-amber-500/10 pb-0.5 mb-1">GIẤY PHÉP ĐIỀU KHIỂN HẠNG B2</p><p class="text-white font-bold">HỌ TÊN: ${nameUpper}</p></div>`;
            }
            return `<div class="card-mockup bg-gradient-to-r from-slate-950 to-slate-900 text-left border-slate-700"><p class="text-white font-bold">CHỨNG CHỈ: ${nameUpper}</p></div>`;
        }

        function initClock() {
            setInterval(() => { document.getElementById('live-clock').innerText = new Date().toLocaleTimeString('vi-VN'); }, 1000);
            setInterval(() => {
                fetch('/api/national/pulse-check').then(r=>r.json()).then(d => { if(d.success) syncState(); });
            }, 5000);
        }

        window.onload = function() {
            initClock(); autoRouteAgency(); renderStateUI();
            let saved = localStorage.getItem('sessionUser');
            if(saved) {
                try {
                    let creds = JSON.parse(saved);
                    if(state.authorizedPersonnel[creds.username] && state.authorizedPersonnel[creds.username].password === creds.pass) {
                        activeUser = {
                            username: creds.username,
                            displayName: state.authorizedPersonnel[creds.username].displayName,
                            role: state.authorizedPersonnel[creds.username].role,
                            agency: state.authorizedPersonnel[creds.username].agency
                        };
                        setupOfficerPanel();
                    }
                } catch(e) { localStorage.removeItem('sessionUser'); }
            }
        };
    </script>
</body>
</html>
