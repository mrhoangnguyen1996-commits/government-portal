                            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">CĂN CƯỚC CÔNG DÂN / CITIZEN IDENTITY CARD</p>
                        </div>
                        <i class="fa-solid fa-star text-amber-400 text-lg animate-pulse"></i>
                    </div>
                    <div class="flex gap-4 items-center">
                        <div class="w-20 h-24 bg-slate-800 border border-slate-700 flex flex-col items-center justify-center rounded-lg text-slate-600 relative overflow-hidden">
                            <i class="fa-solid fa-user text-4xl mt-3"></i>
                            <div class="absolute bottom-0 w-full bg-amber-500/20 text-[8px] font-mono font-black text-center text-amber-400 py-0.5">ROBLOX RP</div>
                        </div>
                        <div class="flex-1 text-[11px] space-y-1">
                            <p class="font-mono text-amber-500 font-bold text-xs">Số / No: <span class="text-white tracking-widest">06802600${Math.floor(1000 + Math.random()*9000)}</span></p>
                            <p class="text-slate-400 font-bold">Họ và tên / Full name: <br><span class="text-sm font-black text-white uppercase">${citizen.name}</span></p>
                            <p class="text-slate-400 font-bold">Ngày sinh / Date of birth: <span class="text-white font-mono">${citizen.dob}</span></p>
                            <p class="text-slate-400 font-bold">Giới tính / Sex: <span class="text-white">${citizen.gender}</span></p>
