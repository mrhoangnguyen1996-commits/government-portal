                        <span class="text-[9px] font-black bg-emerald-950 text-emerald-400 border border-emerald-800/50 px-2 py-0.5 rounded uppercase tracking-wider">${citizen.status}</span>
                    </div>
                </div>
            `;

            // Văn Bằng Chứng Chỉ Tách Biệt
            let licensesHtml = '';
            if(citizen.licenses && citizen.licenses.length > 0) {
                citizen.licenses.forEach((lic, idx) => {
                    let isWeapon = lic.includes("Vũ Khí") || lic.includes("Công Cụ");
                    licensesHtml += `
                        <div class="national-card w-full max-w-md p-4 rounded-xl border-slate-700 font-sans space-y-3">
                            <div class="flex justify-between items-center border-b border-slate-800 pb-1.5">
                                <span class="text-[9px] font-black ${isWeapon ? 'text-red-400' : 'text-sky-400'} uppercase"><i class="fa-solid fa-shield mr-1"></i> GIẤY PHÉP QUỐC GIA CHỨNG CHỈ SỐ</span>
                                <span class="text-[9px] text-slate-500 font-mono">MÃ: CC-${hashCodeCCCD(username + idx)}</span>
                            </div>
                            <div class="text-[11px] space-y-1">
                                <p class="text-slate-400">Họ tên chủ quyền: <b class="text-white uppercase">${citizen.name}</b></p>
                                <div class="p-2 bg-black/40 border border-slate-800 rounded-lg text-amber-400 font-black flex items-center gap-2">
                                    <i class="fa-solid ${isWeapon ? 'fa-gun text-red-500' : 'fa-id-card text-sky-400'}"></i> ${lic}
                                </div>
                            </div>
                        </div>
                    `;
                });
            } else {
                licensesHtml = `<p class="text-center text-xs text-slate-600 font-bold p-4">Cư dân này chưa được cấp phát văn bằng hay giấy phép hành chính nào.</p>`;
            }
            zone.innerHTML = ccHtml + `<div class="grid grid-cols-1 gap-3 w-full">${licensesHtml}</div>`;

            // Render vi phạm
            let vioHtml = '';
            if (violations[username] && violations[username].length > 0) {
                violations[username].forEach(v => {
                    vioHtml += `
                        <div class="border-2 border-red-900/40 bg-red-950/10 p-3 rounded-xl space-y-2 text-xs relative">
                            <div class="flex justify-between items-center border-b border-red-900/20 pb-1">
