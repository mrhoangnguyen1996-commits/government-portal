        function trackApplication() {
            const id = document.getElementById('track-id').value.trim();
            const area = document.getElementById('track-details'); const empty = document.getElementById('track-empty');
            let app = state.applications[id] || state.archivedApplications[id];
            if (!app) { area.classList.add('hidden'); empty.classList.remove('hidden'); return; }
            empty.classList.add('hidden'); area.classList.remove('hidden');

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-gray-950 p-2.5 rounded border border-gray-900 text-left text-[11px]"><p class="text-[9px] font-bold text-gray-500">${l.sender} • ${l.time}</p><p class="text-white mt-0.5 font-medium">${l.msg}</p></div>`;
            });
            let satBlock = '';
            if ((app.status === 'Đã Phê Duyệt' || app.status === 'Bị Bác Bỏ') && !app.satisfaction) {
                satBlock = `
                    <div class="space-y-1.5 p-2 bg-gray-950 border border-gray-800 rounded-xl flex gap-2 justify-center">
                        <button onclick="sendAction('${id}', 'satisfaction', 'HÀI LÒNG')" class="bg-emerald-600 text-white font-black px-4 py-1.5 rounded-lg text-[10px] uppercase">Hài Lòng 👍</button>
                        <button onclick="sendAction('${id}', 'satisfaction', 'KHIẾU NẠI CẤP CAO')" class="bg-red-600 text-white font-black px-4 py-1.5 rounded-lg text-[10px] uppercase animate-pulse">🚨 KHIẾU NẠI KHẨN 🚨</button>
                    </div>
                `;
            } else if (app.satisfaction) {
                satBlock = `<div class="text-center text-[10px] font-black uppercase text-amber-500 bg-gray-950 p-2 rounded-xl border border-gray-800">Đánh giá dịch vụ từ cư dân: [${app.satisfaction}]</div>`;
            }

            area.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3 max-h-[300px] pr-1">
                    <div class="bg-gray-950 p-3 rounded-xl border border-gray-100/10 flex justify-between items-center shadow-md text-left">
                        <div><p class="font-black text-amber-500">${app.id} [${app.docType}]</p><span class="text-[9px] font-mono text-gray-500 block">Độ ưu tiên luồng: ${app.priority}</span></div>
