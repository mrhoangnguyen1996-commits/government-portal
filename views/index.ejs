        // BÀN LÀM VIỆC CHI TIẾT CỦA CÁN BỘ / LÃNH ĐẠO / THANH TRA / CHÍNH PHỦ
        function renderOfficerDesk() {
            let app = state.applications[activeFileId] || state.archivedApplications[activeFileId];
            if(!app) return;
            const desk = document.getElementById('officer-desk-active');

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-slate-900 p-2 rounded border border-slate-800 text-[11px]"><p class="text-[9px] font-bold text-gray-400">${l.sender} • ${l.time}</p><p class="text-white mt-0.5">${l.msg}</p></div>`;
            });

            let residentProfileHtml = '';
            if (registry[app.sender]) {
                let r = registry[app.sender];
                residentProfileHtml = `
                    <div class="bg-amber-500/5 border border-amber-500/20 p-3 rounded-xl text-[11px] space-y-1">
                        <p class="text-amber-500 font-black uppercase text-[9px]"><i class="fa-solid fa-server"></i> Định Danh Dân Cư Gốc:</p>
                        <p>Họ tên: <b class="text-white">${r.name}</b> | Ngày sinh: <b>${r.dob}</b></p>
                        <p>Chứng chỉ: <span class="text-amber-400 font-mono">${r.licenses.join(', ')}</span></p>
                        <p class="text-emerald-400 font-black">Tư pháp: ${r.status}</p>
                    </div>
                `;
            }

            let actionsHtml = '';
            
            // Nếu hồ sơ đang ở trạng thái Hoạt động (chưa bị đóng lưu kho)
            if (state.applications[activeFileId]) {
                // 1. NÚT TIẾP NHẬN HỒ SƠ ĐẦU KỲ
                if (app.status === 'Đang Chờ Tiếp Nhận') {
                    actionsHtml = `
                        <button onclick="sendAction('${app.id}', 'claim_packet')" class="w-full bg-gradient-to-r from-sky-500 to-blue-600 text-white font-black py-2 rounded-lg text-xs uppercase shadow-md"><i class="fa-solid fa-bell"></i> Tiếp Nhận Phụ Trách Hồ Sơ</button>
                    `;
                } else {
                    // Quyền xử lý hồ sơ thông thường của cán bộ/lãnh đạo ngành
                    let forwardLeaderBtn = (activeUser.role === 'CÁN BỘ' && app.status !== 'Đã Phê Duyệt' && app.status !== 'Bị Bác Bỏ') ? 
                        `<button onclick="sendAction('${app.id}', 'to_leader')" class="w-full bg-purple-600 hover:bg-purple-700 text-white font-black py-1.5 rounded-lg text-[11px] uppercase"><i class="fa-solid fa-paper-plane"></i> Trình Lên Lãnh Đạo Ký Duyệt</button>` : '';

                    let archiveBtn = (app.status === 'Đã Phê Duyệt' || app.status === 'Bị Bác Bỏ' || activeUser.role === 'ADMIN') ? 
                        `<button onclick="sendAction('${app.id}', 'archive')" class="w-full bg-gradient-to-r from-purple-600 to-indigo-600 text-white font-black py-2 rounded-lg text-[11px] uppercase"><i class="fa-solid fa-box-archive"></i> Đóng Hòm & Lưu Trữ Quốc Gia</button>` : '';

                    // ĐẶC QUYỀN ĐIỀU TRA CỦA THANH TRA CHÍNH PHỦ KHẨN CẤP
                    let inspectorBtn = (activeUser.role === 'THANH TRA' || activeUser.role === 'ADMIN') ? 
                        `<button onclick="sendAction('${app.id}', 'investigate')" class="w-full bg-red-950 text-red-400 border border-red-800 font-black py-1.5 rounded-lg text-[11px] uppercase"><i class="fa-solid fa-magnifying-glass-critical"></i> Lệnh Thanh Tra: Mở Cuộc Điều Tra</button>` : '';

                    actionsHtml = `
                        <div class="grid grid-cols-2 gap-2">
                            <button onclick="sendAction('${app.id}', 'status', 'Đã Phê Duyệt', 'stamp-approved')" class="bg-emerald-600 hover:bg-emerald-700 text-white font-black py-1.5 rounded-lg text-[11px] uppercase">Phê Duyệt Ký Dấu</button>
                            <button onclick="sendAction('${app.id}', 'status', 'Bị Bác Bỏ', 'stamp-rejected')" class="bg-red-600 hover:bg-red-700 text-white font-black py-1.5 rounded-lg text-[11px] uppercase">Bác Bỏ Đơn Thư</button>
                        </div>
                        ${forwardLeaderBtn}
                        ${inspectorBtn}
                        ${archiveBtn}
                        <div>
                            <select onchange="sendAction('${app.id}', 'forward', '', '', this.value)" class="w-full bg-slate-900 border border-slate-700 p-1.5 text-[11px] text-white rounded-lg font-bold">
                                <option value="">-- Điều chuyển liên ban ngành --</option>
                                <option value="CÔNG AN">BỘ CÔNG AN</option>
                                <option value="QUÂN ĐỘI">BỘ CHỈ HUY QUÂN SỰ</option>
                                <option value="UBND PHƯỜNG">ỦY BAN NHÂN DÂN</option>
                                <option value="TOÀ ÁN">TÒA ÁN NHÂN DÂN TỐI CAO</option>
                                <option value="CHÍNH PHỦ">VĂN PHÒNG CHÍNH PHỦ</option>
                            </select>
                        </div>
                    `;
                }
            } else {
                // ĐẶC QUYỀN TRẢ LẠI / KHÔI PHỤC HỒ SƠ TỪ KHO LƯU TRỮ CỦA ADMIN HOẶC LÃNH ĐẠO CHÍNH PHỦ
                let unarchiveBtn = (activeUser.role === 'ADMIN' || activeUser.agency === 'CHÍNH PHỦ') ? 
                    `<button onclick="sendAction('${app.id}', 'unarchive')" class="w-full bg-amber-500 hover:bg-amber-600 text-black font-black py-2 rounded-lg text-xs uppercase shadow-md"><i class="fa-solid fa-rotate-left"></i> Khôi Phục / Trả Lại Hồ Sơ Về Ban Ngành</button>` : '';

                actionsHtml = `
                    <div class="bg-purple-950/40 text-purple-400 p-2.5 rounded-xl border border-purple-800 text-center font-bold uppercase text-[10px] tracking-wider mb-2"><i class="fa-solid fa-box-archive"></i> Văn bản đang niêm phong trong kho lưu trữ</div>
                    ${unarchiveBtn}
                `;
            }

            desk.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3.5 max-h-[350px] pr-1">
                    <div class="bg-slate-900 p-2.5 rounded-xl border border-slate-800 text-[11px] relative">
                        <div class="absolute top-2 right-2 stamp-box ${app.stamp}">${app.status}</div>
                        <p class="font-black text-amber-500">MÃ SỐ ĐƠN: ${app.id}</p>
                        <p class="text-slate-300 font-bold mt-1">Yêu cầu thủ tục: <span class="text-white">${app.docType}</span></p>
                        <p class="text-slate-400 italic mt-0.5">" ${app.content} "</p>
                    </div>
                    ${residentProfileHtml}
                    <div class="space-y-2 font-bold text-[9px] text-slate-400 uppercase tracking-wider">Hội thoại đàm thoại: ${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-slate-800 space-y-2">
                    ${actionsHtml}
                    <div class="flex gap-2">
                        <input type="text" id="officer-chat-msg" placeholder="Nhập câu hỏi, chỉ thị gửi công dân..." class="flex-1 bg-slate-900 border border-slate-700 p-2 text-xs text-white rounded-lg focus:outline-none">
                        <button onclick="officerChat()" class="bg-emerald-600 font-black text-white px-4 text-xs rounded-lg uppercase">Gửi</button>
                    </div>
                </div>
            `;
        }

        async function officerChat() {
            const msg = document.getElementById('officer-chat-msg').value.trim();
            if (!msg) return;
            await fetch('/api/applications/action', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: activeFileId, action: 'chat', msg, officerName: `${activeUser.displayName} (${activeUser.agency})` })
            });
            await syncState();
            renderOfficerDesk();
        }

        async function sendAction(id, action, status = '', stamp = '', targetAgency = '') {
            await fetch('/api/applications/action', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    id, action, status, stamp, targetAgency, 
                    officerName: activeUser ? activeUser.displayName : 'Hệ thống tự động',
                    officerRole: activeUser ? activeUser.role : 'Hệ thống'
                })
            });
            await syncState();
            
            if (activeFileId === id) {
                // Nếu điều chuyển ngành, đóng đơn hoặc khôi phục, reset bàn làm việc
                if (action === 'forward' || action === 'to_leader' || action === 'archive' || action === 'unarchive') { 
                    activeFileId = null; 
                    document.getElementById('officer-desk-active').classList.add('hidden'); 
                    document.getElementById('officer-desk-empty').classList.remove('hidden'); 
                } else { 
                    renderOfficerDesk(); 
                }
            }
            if (document.getElementById('track-id').value === id) { trackApplication(); }
        }

        async function publishDocument() {
            const type = document.getElementById('pub-type').value;
            const title = document.getElementById('pub-title').value.trim();
            const content = document.getElementById('pub-content').value.trim();
            if(!title || !content) return;
            await fetch('/api/national/publish', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ type, title, content, author: activeUser.displayName }) });
            document.getElementById('pub-title').value = ''; document.getElementById('pub-content').value = '';
            await syncState();
        }

        async function updateTicker() {
            const msg = document.getElementById('pub-ticker').value.trim();
            if(!msg) return;
            await fetch('/api/national/ticker', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }) });
            document.getElementById('pub-ticker').value = '';
            await syncState();
        }

        async function deleteNews(id) {
            await fetch('/api/national/delete-announcement', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
            await syncState();
        }

        async function setSecurity(level) {
            await fetch('/api/national/security', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ level }) });
            await syncState();
        }

        async function provisionAccount(e) {
            e.preventDefault();
            const username = document.getElementById('p-user').value.trim();
            const password = document.getElementById('p-pass').value;
            const displayName = document.getElementById('p-name').value.trim();
            const role = document.getElementById('p-role').value;
            const agency = document.getElementById('p-agency').value;
            const isEdit = document.getElementById('p-isEdit').value === "true";

            await fetch('/api/officer/save', { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify({ username, password, displayName, role, agency, isEdit }) 
            });
            resetProvisionForm();
            await syncState();
        }

        function searchCitizen() {
            const q = document.getElementById('id-search').value.trim();
            const resArea = document.getElementById('id-result');
            if (registry[q]) {
                let r = registry[q];
                resArea.innerHTML = `
                    <div class="mt-4 p-4 bg-slate-900 border border-slate-700 rounded-xl text-xs space-y-2">
                        <p class="text-sm font-black text-amber-500 border-b border-slate-800 pb-1">${r.name}</p>
                        <p>Ngày sinh: <b>${r.dob}</b> | Giới tính: <b>${r.gender}</b></p>
                        <p>Nguyên quán: <b>${r.pob}</b> | Nghề nghiệp: <b>${r.job}</b></p>
                        <p class="text-amber-400 font-bold">Giấy phép cấp hành chính: ${r.licenses.join(' — ')}</p>
                        <p class="text-emerald-400 font-black">Tình trạng dân sự: ${r.status}</p>
                    </div>
                `;
            } else {
                resArea.innerHTML = `<p class="mt-4 text-center text-red-400 text-xs font-black">KHÔNG TÌM THẤY DỮ LIỆU ĐỊNH DANH TRÊN MÁY CHỦ QUỐC GIA.</p>`;
            }
        }

        function openLogin() { document.getElementById('login-modal').classList.remove('hidden'); }
        function closeLogin() { document.getElementById('login-modal').classList.add('hidden'); }
        
        function login() {
            const u = document.getElementById('log-user').value;
            const p = document.getElementById('log-pass').value;

            if (state.authorizedPersonnel[u] && state.authorizedPersonnel[u].password === p) {
                activeUser = state.authorizedPersonnel[u];
                
                // Lưu session tài khoản đăng nhập vào localStorage để F5 reload không bị văng ra ngoài
                localStorage.setItem('sessionUser', JSON.stringify({ username: u, password: p }));
                
                closeLogin();
                applyUserRoleLayout();
            } else {
                alert("Mật mã bảo mật nghiệp vụ không hợp lệ!");
            }
        }

        function applyUserRoleLayout() {
            if(!activeUser) return;
            document.getElementById('btn-tab-officer').classList.remove('hidden');
            if(activeUser.role === 'ADMIN') document.getElementById('btn-tab-admin').classList.remove('hidden');
            
            if(activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ') {
                document.getElementById('leader-publish-zone').classList.remove('hidden');
            } else {
                document.getElementById('leader-publish-zone').classList.add('hidden');
            }

            renderAuth(); 
            renderAll(); 
            
            // Phục hồi tab cũ trước khi F5 hoặc mặc định nhảy vào tab nghiệp vụ
            let savedTab = sessionStorage.getItem('activeTab');
            tab(savedTab || 'tab-officer');
        }

        function logout() {
            activeUser = null; activeFileId = null;
            localStorage.removeItem('sessionUser');
            sessionStorage.removeItem('activeTab');
            document.getElementById('btn-tab-officer').classList.add('hidden');
            document.getElementById('btn-tab-admin').classList.add('hidden');
            document.getElementById('leader-publish-zone').classList.add('hidden');
            document.getElementById('officer-desk-active').classList.add('hidden');
            document.getElementById('officer-desk-empty').classList.remove('hidden');
            renderAuth(); renderAll(); tab('tab-news');
        }

        function renderAuth() {
            const p = document.getElementById('auth-panel');
            if(!activeUser) {
                p.innerHTML = `<button onclick="openLogin()" class="bg-gradient-to-r from-amber-400 to-amber-500 font-black text-black px-4 py-2 rounded-lg text-[11px] uppercase tracking-wider"><i class="fa-solid fa-signature"></i> Đăng nhập nghiệp vụ</button>`;
            } else {
                p.innerHTML = `<div class="flex items-center gap-2.5 bg-slate-900 border border-slate-800 p-1 pr-3 rounded-xl"><div class="bg-amber-500 text-black font-black p-1.5 rounded-lg text-xs"><i class="fa-solid fa-user-tie"></i></div><div class="text-left"><p class="font-black text-white text-[11px]">${activeUser.displayName}</p><p class="text-[9px] text-amber-500 font-bold uppercase font-mono tracking-wider">${activeUser.role}</p></div><button onclick="logout()" class="text-slate-500 hover:text-red-400 text-sm ml-2"><i class="fa-solid fa-power-off"></i></button></div>`;
            }
        }

        // KHỞI ĐỘNG KIỂM TRA SESSION VÀ ĐỒNG BỘ DỮ LIỆU KHI TẢI TRANG
        function init() {
            startClock();
            
            // Phục hồi session đăng nhập từ localStorage chống lỗi F5 thoát tài khoản
            let savedSession = localStorage.getItem('sessionUser');
            if(savedSession) {
                try {
                    let creds = JSON.parse(savedSession);
                    if (state.authorizedPersonnel[creds.username] && state.authorizedPersonnel[creds.username].password === creds.password) {
                        activeUser = state.authorizedPersonnel[creds.username];
                        applyUserRoleLayout();
                    }
                } catch(e) { localStorage.removeItem('sessionUser'); }
            } else {
                renderAuth(); renderAll();
            }

            setInterval(syncState, 3500);
        }
        window.onload = init;
    </script>
</body>
</html>
