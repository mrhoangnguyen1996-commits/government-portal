                        ${(activeUser.role === 'ADMIN') ? `<button onclick="sendAction('${app.id}', 'unarchive')" class="w-full bg-red-700 text-white font-black py-1 rounded text-[10px] uppercase hover:bg-red-600">Bác Đơn / Tái Thẩm</button>` : ''}
