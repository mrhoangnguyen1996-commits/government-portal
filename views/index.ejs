<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TRUNG TÂM QUỐC VỤ SỐ LIÊN THÔNG V6.0 - CYBERPUNK SIMULATOR</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Space+Grotesk:wght@400;500;600;700&display=swap');
        body { font-family: 'Space Grotesk', sans-serif; background-color: #02050e; color: #cbd5e1; }
        .font-mono-tech { font-family: 'Share Tech Mono', monospace; }
        
        /* PHÔI ẤN KÝ ĐIỆN TỬ NỔI KHỐI 3D ĐỘC QUYỀN */
        .stamp-box { position: relative; font-size: 11px; font-weight: 900; text-transform: uppercase; padding: 6px 14px; border-radius: 6px; border: 3px dashed; display: inline-block; text-align: center; letter-spacing: 1px; transform: rotate(-7deg) scale(1.05); text-shadow: 0 0 6px currentColor; background: rgba(0,0,0,0.3); box-shadow: 0 4px 10px rgba(0,0,0,0.5); animation: stampIn 0.22s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
        .stamp-approved { border-color: #10b981; color: #10b981; }
        .stamp-rejected { border-color: #ef4444; color: #ef4444; }
        .stamp-pending { border-color: #f59e0b; color: #f59e0b; }
        .stamp-forwarded { border-color: #3b82f6; color: #3b82f6; }
        .stamp-leader { border-color: #c084fc; color: #c084fc; border-style: double; border-width: 5px; }
        .stamp-archived { border-color: #64748b; color: #64748b; }
        @keyframes stampIn { 0% { transform: scale(2.5) rotate(-35deg); opacity: 0; } 100% { transform: scale(1.05) rotate(-7deg); opacity: 1; } }

        /* BIỂU MẪU PHÔI VĂN BẰNG PHẢN QUANG CYBERPUNK */
        .national-card { background: radial-gradient(circle at top left, #1e293b 0%, #0f172a 70%, #020617 100%); border: 2px solid #334155; position: relative; overflow: hidden; border-radius: 16px; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 20px 45px rgba(0,0,0,0.7); }
        .national-card:hover { transform: translateY(-6px) scale(1.01); border-color: #fbbf24; box-shadow: 0 0 35px rgba(251, 191, 36, 0.3); }
        .card-chip { width: 46px; height: 34px; background: linear-gradient(135deg, #fcd34d 0%, #d97706 50%, #78350f 100%); border-radius: 6px; border: 1px solid #b45309; }
        
        .marquee-container { width: 100%; overflow: hidden; white-space: nowrap; background: #060a16; border-top: 1px solid #111827; border-bottom: 1px solid #111827; }
        .marquee-content { display: inline-block; padding-left: 100%; animation: marquee 32s linear infinite; font-size: 13px; font-weight: 700; color: #f59e0b; }
        @keyframes marquee { 0% { transform: translate3d(0, 0, 0); } 100% { transform: translate3d(-100%, 0, 0); } }
        
        .sub-active { background: linear-gradient(90deg, #065f46 0%, #022c22 100%); border-color: #10b981; color: #fff; box-shadow: 0 0 15px rgba(16, 185, 129, 0.2); }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between">

    <div>
        <header class="bg-[#050814] border-b border-gray-800 px-6 py-4 flex flex-wrap justify-between items-center shadow-2xl relative">
            <div class="flex items-center space-x-4">
                <div class="relative flex items-center justify-center">
                    <div class="absolute inset-0 bg-cyan-500/20 blur-xl rounded-full animate-pulse"></div>
                    <div class="bg-gradient-to-br from-cyan-600 via-blue-600 to-indigo-600 p-3.5 rounded-2xl text-black border border-cyan-300 z-10">
                        <i class="fa-solid fa-building-columns text-2xl text-white"></i>
                    </div>
                </div>
                <div>
                    <span class="text-[10px] tracking-widest text-cyan-400 uppercase font-black font-mono-tech block">HỆ THỐNG GIẢ LẬP NHẬP VAI QUỐC VỤ CÔNG VỤ ROBLOX MÔ PHỎNG</span>
                    <h1 class="text-2xl font-black text-white tracking-tight flex items-center gap-2">TRUNG TÂM QUỐC VỤ SỐ LIÊN THÔNG <span class="text-xs font-mono bg-cyan-950 text-cyan-400 border border-cyan-800 px-2 py-0.5 rounded font-black">v6.0-DYNAMIC</span></h1>
                </div>
            </div>

            <div class="flex items-center space-x-3 text-xs mt-3 lg:mt-0">
                <div id="officer-alert-light" onclick="jumpToActiveNotification()" class="hidden bg-red-950 border border-red-500 px-3 py-2 rounded-xl flex items-center gap-2 animate-pulse cursor-pointer">
                    <span class="h-2 w-2 rounded-full bg-red-500 shadow-[0_0_10px_#ef4444]"></span>
                    <span class="text-red-400 font-black text-[11px] uppercase tracking-wider">🚨 HỒ SƠ CHUYỂN NGÀNH MỚI</span>
                </div>
                <div class="bg-[#0a0e1a] px-4 py-2 rounded-xl border border-gray-800 font-mono text-cyan-400 font-black tracking-widest text-sm" id="clock">00:00:00</div>
                <div class="bg-[#0a0e1a] px-3 py-2 rounded-xl border border-gray-800 flex items-center gap-2">
                    <span id="security-txt" class="font-black text-[11px] tracking-wider uppercase text-emerald-400"><%= state.securityLevel %></span>
                </div>
                <div id="auth-panel"></div>
            </div>
        </header>

        <div class="marquee-container py-2 flex items-center">
            <div class="bg-cyan-900 text-white font-black text-[9px] px-2 py-0.5 rounded uppercase tracking-wider mx-4 z-10 border border-cyan-500">TRỤC LIÊN THÔNG LÕI</div>
            <div class="marquee-content" id="live-marquee"><%= state.tickerMessage %></div>
        </div>

        <nav class="bg-[#050814]/95 border-b border-gray-800 px-6 py-1 flex flex-wrap gap-1 sticky top-0 z-40 backdrop-blur-md">
            <button onclick="tab('tab-news')" id="btn-tab-news" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-cyan-500 text-cyan-500 transition-all"><i class="fa-solid fa-scroll mr-1.5"></i> Trung Tâm Ấn Bản</button>
            <button onclick="tab('tab-id')" id="btn-tab-id" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-gray-400 hover:text-white transition-all"><i class="fa-solid fa-fingerprint mr-1.5"></i> Xác Minh Định Danh Gốc</button>
            <button onclick="tab('tab-cards')" id="btn-tab-cards" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-sky-400 hover:text-sky-300 transition-all"><i class="fa-solid fa-print mr-1.5"></i> Kết Xuất Phôi Đa Lớp</button>
            <button onclick="tab('tab-services')" id="btn-tab-services" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-purple-400 hover:text-purple-300 transition-all"><i class="fa-solid fa-file-invoice mr-1.5"></i> Nộp Đơn / Thủ Tục Trực Tuyến</button>
            <button onclick="tab('tab-officer')" id="btn-tab-officer" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-emerald-400 hover:text-emerald-300 hidden relative">
                <i class="fa-solid fa-briefcase mr-1.5"></i> Bàn Làm Việc Bộ Ngành 
                <span id="badge-count-app" class="absolute top-1.5 right-1.5 bg-red-600 text-white text-[9px] px-1.5 py-0.5 rounded-full font-black hidden">0</span>
            </button>
            <button onclick="tab('tab-admin')" id="btn-tab-admin" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-red-400 hover:text-red-300 hidden"><i class="fa-solid fa-building-shield mr-1.5"></i> Phòng Giám Sát Tối Cao</button>
        </nav>

        <main class="p-6 max-w-[1750px] w-full mx-auto space-y-6">
            
            <section id="tab-news" class="grid grid-cols-1 xl:grid-cols-4 gap-6">
                <div class="xl:col-span-2 space-y-4">
                    <h2 class="text-xs font-black text-gray-400 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-1.5"><i class="fa-solid fa-shield text-cyan-500"></i> Chỉ Thị Sắc Lệnh Điều Hành Quốc Gia</h2>
                    <div id="news-feed" class="space-y-3"></div>
                </div>
                <div class="space-y-4">
                    <h2 class="text-xs font-black text-red-400 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-1.5"><i class="fa-solid fa-mask text-red-500"></i> Hệ Thống Lệnh Truy Nã Toàn Quốc</h2>
                    <div id="wanted-feed" class="space-y-3"></div>
                </div>
                <div class="space-y-4">
                    <h2 class="text-xs font-black text-teal-400 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-1.5"><i class="fa-solid fa-robot text-teal-400"></i> Trợ Lý Số Hóa Tuệ Đức v6 (Core DB)</h2>
                    <div class="bg-[#0a0f24] border border-teal-900/60 p-4 flex flex-col justify-between h-[430px] shadow-2xl rounded-2xl">
                        <div id="bot-chat-flow" class="flex-1 overflow-y-auto space-y-3 pr-1 text-xs">
                            <div class="bg-teal-950/30 border border-teal-900/50 p-3 rounded-xl text-teal-300">
                                <b class="block text-[10px] text-teal-400 uppercase mb-1"><i class="fa-solid fa-server"></i> Hệ Thống Tuệ Đức v6.0</b>
                                Chào công dân, tôi đã đồng bộ dữ liệu thời gian thực. Hãy nhập mã hồ sơ (Ví dụ: <span class="text-white font-mono font-bold">HS-1001</span>) hoặc tên tài khoản để tôi bóc tách dữ liệu lý lịch tức thì!
                            </div>
                        </div>
                        <div class="pt-2 border-t border-gray-800 flex gap-2">
                            <input type="text" id="bot-input" placeholder="Hỏi mã hồ sơ, lý lịch cư dân hoặc quy trình..." class="flex-1 bg-gray-950 border border-gray-800 p-2.5 text-xs text-white rounded-xl focus:outline-none focus:border-teal-500 font-medium">
                            <button onclick="askAiBot()" class="bg-teal-600 hover:bg-teal-700 text-white font-black px-4 text-xs rounded-xl uppercase tracking-wider transition-all">Quét</button>
                        </div>
                    </div>
                </div>
            </section>

            <section id="tab-id" class="hidden max-w-4xl mx-auto space-y-4">
                <div class="bg-[#0a0f24] border border-gray-800 p-6 shadow-2xl max-w-2xl mx-auto rounded-2xl">
                    <h2 class="text-xs font-black text-center text-white uppercase tracking-widest mb-4 flex items-center justify-center gap-2"><i class="fa-solid fa-fingerprint text-cyan-500"></i> Cơ Quan Thẩm Định Hồ Sơ Định Danh Gốc Toàn Quốc</h2>
                    <div class="flex gap-2">
                        <input type="text" id="id-search" placeholder="Nhập tên tài khoản cư dân (Ví dụ: Nguyen_Manh_Hoang)..." class="flex-1 bg-gray-950 border border-gray-700 px-4 py-2.5 text-sm rounded-xl text-white font-mono focus:outline-none focus:border-cyan-500">
                        <button onclick="searchCitizen()" class="bg-gradient-to-r from-cyan-500 to-blue-600 text-white px-6 text-xs font-black uppercase rounded-xl tracking-widest transition-all shadow-md">Truy Quét</button>
                    </div>
                </div>
                <div id="id-result" class="max-w-2xl mx-auto"></div>
            </section>

            <section id="tab-cards" class="hidden max-w-6xl mx-auto space-y-6">
                <div class="bg-[#0a0f24] border border-gray-800 p-6 max-w-xl mx-auto rounded-2xl">
                    <h2 class="text-xs font-black text-center text-sky-400 uppercase tracking-widest mb-4 flex items-center justify-center gap-2"><i class="fa-solid fa-passport text-sky-500"></i> Trung Tâm Xuất Bản Phôi Văn Bằng & Căn Cước Số Hóa</h2>
                    <div class="flex gap-2">
                        <input type="text" id="card-search-input" placeholder="Nhập tài khoản cư dân để vẽ phôi..." class="flex-1 bg-gray-950 border border-gray-800 px-3 py-2.5 text-sm rounded-xl text-white font-mono focus:outline-none">
                        <button onclick="generateCitizenCards()" class="bg-sky-600 hover:bg-sky-700 text-white px-5 text-xs font-black uppercase rounded-xl tracking-wider shadow-md">Kết Xuất Phôi</button>
                    </div>
                </div>
                <div class="space-y-4">
                    <h3 class="text-xs font-black uppercase text-gray-400 tracking-widest flex items-center gap-2"><i class="fa-solid fa-id-badge text-sky-400"></i> Bản Vẽ Kỹ Thuật Bản Gốc Phôi Phát Quang Đa Sắc</h3>
                    <div id="cards-render-zone" class="grid grid-cols-1 md:grid-cols-2 gap-6 justify-center items-center">
                        <p class="text-center text-xs text-gray-600 col-span-2 py-12">Chưa thực hiện kết xuất bản vẽ phôi hành chính kịch bản.</p>
                    </div>
                </div>
                <div class="space-y-4">
                    <h3 class="text-xs font-black uppercase text-red-400 tracking-widest flex items-center gap-2"><i class="fa-solid fa-scale-balanced text-red-500"></i> Quyết Định Tư Pháp & Biên Bản Vi Phạm Kịch Bản Ghi Nhận</h3>
                    <div id="violation-render-zone" class="grid grid-cols-1 md:grid-cols-2 gap-6"></div>
                </div>
            </section>

            <section id="tab-services" class="hidden grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="bg-[#0a0f24] border border-gray-800 p-5 space-y-4 shadow-xl rounded-2xl">
                    <h3 class="text-xs font-black text-gray-300 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-2"><i class="fa-solid fa-file-import text-purple-400"></i> Khởi Tạo Hồ Sơ Trực Tuyến Thủ Tục Công</h3>
                    <form onsubmit="submitForm(event)" class="space-y-4 text-xs">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                            <div>
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Tên Tài Khoản Hệ Thống (Họ_Tên)</label>
                                <input type="text" id="app-sender" required placeholder="Nguyen_Manh_Hoang" class="w-full bg-gray-950 border border-gray-800 p-2.5 rounded-xl text-white font-mono focus:outline-none">
                            </div>
                            <div>
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Loại Giấy Tờ / Thủ Tục</label>
                                <select id="app-docType" class="w-full bg-gray-950 border border-gray-800 p-2.5 rounded-xl text-white font-bold text-cyan-400 focus:outline-none">
                                    <option value="CĂN CƯỚC CÔNG DÂN">Căn Cước Công Dân Gắn Chíp</option>
                                    <option value="GIẤY PHÉP SỬ DỤNG CÔNG CỤ HỖ TRỢ">Giấy Phép Sử Dụng Vũ Khí / CCHT</option>
                                    <option value="HỘ CHIẾU QUỐC TẾ">Hộ Chiếu Quốc Tế (Visa)</option>
                                    <option value="GIẤY PHÉP KINH DOANH DOANH NGHIỆP">Giấy Phép Doanh Nghiệp</option>
                                    <option value="ĐĂNG KÝ TẦN SỐ BỘ ĐÀM MÃ HÓA">Đăng Ký Tần Số Bộ Đàm</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Độ Khẩn Cấp</label>
                                <select id="app-priority" class="w-full bg-gray-950 border border-gray-800 p-2.5 rounded-xl text-white font-bold text-red-400 focus:outline-none">
                                    <option value="BÌNH THƯỜNG">Bình Thường</option>
                                    <option value="HỎA TỐC">Hỏa Tốc ⚡</option>
                                    <option value="THƯỢNG KHẨN">Thượng Khẩn Cấp 🚨</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Cơ Quan Tiếp Nhận Thẩm Định Bộ Ngành</label>
                            <select id="app-agency" class="w-full bg-gray-950 border border-gray-800 p-2.5 rounded-xl text-white font-bold text-sky-400 focus:outline-none">
                                <option value="CÔNG AN">BỘ CÔNG AN TOÀN QUỐC</option>
                                <option value="QUÂN ĐỘI">BỘ CHỈ HUY QUÂN SỰ TRƯỞNG</option>
                                <option value="TOÀ ÁN">TÒA ÁN NHÂN DÂN TỐI CAO</option>
                                <option value="THANH TRA">THANH TRA CHÍNH PHỦ</option>
                                <option value="CHÍNH PHỦ">VĂN PHÒNG CHÍNH PHỦ TỐI CAO</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Trình Bày Chi Tiết Yêu Cầu</label>
                            <textarea id="app-content" rows="4" required placeholder="Ghi rõ nội dung thuyết minh phục vụ kịch bản nhập vai..." class="w-full bg-gray-950 border border-gray-800 p-2.5 rounded-xl text-white focus:outline-none font-medium"></textarea>
                        </div>
                        <button type="submit" class="w-full bg-gradient-to-r from-purple-600 to-indigo-600 font-black text-white py-3 rounded-xl uppercase tracking-widest shadow-lg">Gửi Đơn Lên Trục Hệ Thống</button>
                    </form>
                </div>

                <div class="bg-[#0a0f24] border border-gray-800 p-5 flex flex-col h-full min-h-[480px] shadow-xl rounded-2xl">
                    <h3 class="text-xs font-black text-gray-300 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-1.5"><i class="fa-solid fa-satellite text-sky-400 animate-pulse"></i> Cổng Tra Cứu Tiến Độ & Kênh Đàm Thoại Tư Pháp Hai Chiều</h3>
                    <div class="flex gap-2 my-3">
                        <input type="text" id="track-id" placeholder="Nhập mã đơn thư (Ví dụ: HS-1001)..." class="flex-1 bg-gray-950 border border-gray-800 px-3 py-2 text-xs rounded-xl text-white font-mono focus:outline-none">
                        <button onclick="trackApplication()" class="bg-sky-600 hover:bg-sky-700 text-white px-5 text-xs font-black rounded-xl uppercase">Truy Vấn</button>
                    </div>
                    <div id="track-details" class="flex-1 flex flex-col justify-between hidden space-y-3"></div>
                    <div id="track-empty" class="text-center py-24 text-gray-500 text-xs flex-1 flex flex-col justify-center items-center"><i class="fa-solid fa-comment-dots text-4xl mb-3 text-gray-800"></i> Nhập chính xác mã đơn thư để mở khung đàm thoại tương tác trực tiếp.</div>
                </div>
            </section>

            <section id="tab-officer" class="hidden grid grid-cols-1 xl:grid-cols-4 gap-6">
                <div class="xl:col-span-1 bg-[#0a0f24] border border-gray-800 p-4 flex flex-col gap-2 shadow-2xl h-fit rounded-2xl">
                    <p class="text-[10px] font-black text-emerald-400 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-1.5"><i class="fa-solid fa-cubes"></i> Nghiệp Vụ Công Vụ Ban Ngành</p>
                    <button onclick="subtab('sub-app')" id="btn-sub-app" class="sub-active text-left px-4 py-3 text-xs font-black uppercase tracking-wider rounded-xl border border-gray-800 transition-all"><i class="fa-solid fa-folder-open mr-2"></i> 1. Tiếp Nhận & Thẩm Định Đơn</button>
                    <button onclick="subtab('sub-transfer')" id="btn-sub-transfer" class="text-left px-4 py-3 text-xs font-black uppercase tracking-wider rounded-xl border border-transparent text-gray-400 hover:text-white hover:bg-gray-900 transition-all"><i class="fa-solid fa-shuffle mr-2"></i> 2. Luân Chuyển Liên Ngành</button>
                    <button onclick="subtab('sub-licensing')" id="btn-sub-licensing" class="text-left px-4 py-3 text-xs font-black uppercase tracking-wider rounded-xl border border-transparent text-sky-400 hover:text-sky-300 hover:bg-gray-900 transition-all"><i class="fa-solid fa-stamp mr-2"></i> 3. Kho Cấp Phôi Độc Lập</button>
                    <button onclick="subtab('sub-vio')" id="btn-sub-vio" class="text-left px-4 py-3 text-xs font-black uppercase tracking-wider rounded-xl border border-transparent text-red-400 hover:text-red-300 hover:bg-gray-900 transition-all"><i class="fa-solid fa-gavel mr-2"></i> 4. Ký Quyết Định Xử Phạt</button>
                    <button onclick="subtab('sub-reg')" id="btn-sub-reg" class="text-left px-4 py-3 text-xs font-black uppercase tracking-wider rounded-xl border border-transparent text-teal-400 hover:text-teal-300 hover:bg-gray-900 transition-all"><i class="fa-solid fa-user-plus mr-2"></i> 5. Số Hóa Đăng Ký Cư Dân</button>
                    <button onclick="subtab('sub-rpt')" id="btn-sub-rpt" class="text-left px-4 py-3 text-xs font-black uppercase tracking-wider rounded-xl border border-transparent text-amber-400 hover:text-amber-300 hover:bg-gray-900 transition-all"><i class="fa-solid fa-clipboard-list mr-2"></i> 6. Báo Cáo Tiến Độ Ca Trực</button>
                </div>

                <div class="xl:col-span-2 space-y-5">
                    
                    <div id="sub-app" class="bg-[#050814] border border-gray-800 p-4 rounded-2xl shadow-xl">
                        <div class="flex justify-between items-center mb-3">
                            <h3 class="text-xs font-black text-emerald-400 uppercase tracking-wider flex items-center gap-2"><i class="fa-solid fa-inbox"></i> Các Đơn Thư Gửi Đến Bộ Phận Quản Lý</h3>
                            <span id="office-badge" class="text-[9px] font-mono font-bold bg-emerald-950 text-emerald-400 px-2.5 py-1 rounded-lg border border-emerald-800">Cơ Quan Tiếp Nhận</span>
                        </div>
                        <div class="overflow-x-auto text-xs">
                            <table class="w-full text-left">
                                <thead class="bg-gray-950 text-gray-400 font-bold uppercase text-[9px] tracking-widest border-b border-gray-800">
                                    <tr>
                                        <th class="p-3">Mã Hồ Sơ</th>
                                        <th class="p-3">Tài Khoản</th>
