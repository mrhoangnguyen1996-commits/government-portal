            setTimeout(() => {
                flow.innerHTML += `<div class="bg-teal-950/40 border border-teal-900/40 p-2.5 rounded-xl text-teal-300"><b class="block text-[10px] text-teal-400 uppercase"><i class="fa-solid fa-robot"></i> Tuệ Đức Quốc Vụ</b>${data.reply}</div>`;
