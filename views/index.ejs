    <script src="/socket.io/socket.io.js"></script>
    <script>
        // Khởi tạo kênh kết nối Realtime
        const socket = io();

        let state = {};
        let registry = {};
        let violations = {}; 
        let activeUser = null;
        let activeFileId = null;

        /* ENGINE SÓNG ÂM AUDIO-CONTEXT VẪN BẢO TOÀN ĐẦY ĐỦ */
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        function playTone(freq, type, duration, vol) {
            try {
                const osc = audioCtx.createOscillator();
                const gainNode = audioCtx.createGain();
                osc.type = type; osc.frequency.value = freq;
                gainNode.gain.setValueAtTime(vol, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.00001, audioCtx.currentTime + duration);
                osc.connect(gainNode); gainNode.connect(audioCtx.destination);
                osc.start(); osc.stop(audioCtx.currentTime + duration);
            } catch(e) {}
        }

        const soundClick = () => playTone(600, 'sine', 0.08, 0.1);
        const soundSuccess = () => { playTone(523.25, 'sine', 0.1, 0.15); setTimeout(() => playTone(659.25, 'sine', 0.15, 0.15), 80); };
        const soundAlert = () => { playTone(880, 'sawtooth', 0.15, 0.1); setTimeout(() => playTone(880, 'sawtooth', 0.15, 0.1), 200); };
        const soundStamp = () => { playTone(120, 'triangle', 0.2, 0.4); playTone(250, 'sawtooth', 0.08, 0.1); };

        document.addEventListener('click', (e) => {
            if(e.target.closest('button') || e.target.closest('nav button') || e.target.closest('select')) { soundClick(); }
        });

        function startClock() { setInterval(() => { document.getElementById('clock').innerText = new Date().toLocaleTimeString('vi-VN'); }, 1000); }

        /* ================= KÊNH LẮNG NGHE SỰ KIỆN REALTIME QUA SOCKET ================= */
        // 1. Lấy dữ liệu lần đầu tiên khi vừa kết nối
        socket.on('initData', (data) => {
            updateDataAndRender(data);
            checkAndRestoreSession();
        });

        // 2. Nhận cập nhật dữ liệu tự động từ Server tức thời (Dưới 0.1 giây) khi có bất kỳ ai thao tác
        socket.on('stateUpdate', (data) => {
            updateDataAndRender(data);
        });

        // 3. Nhận cảnh báo có đơn thư/hồ sơ mới nộp lên ngành
        socket.on('newApplicationAlert', (appInfo) => {
            if (activeUser) {
                if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ' || appInfo.agency === activeUser.agency) {
                    document.getElementById('officer-alert-light').classList.remove('hidden');
                    soundAlert(); // Phát âm thanh bíp báo động ngay tức khắc
                }
            }
        });

        // 4. Nhận sự kiện có tin nhắn tương tác 2 chiều mới
        socket.on('newChatMessage', (chatInfo) => {
            if (document.getElementById('track-id').value === chatInfo.fileId) {
                trackApplication(); // Tự động load lại khung chat của công dân ngay lập tức
            }
            if (activeFileId === chatInfo.fileId) {
                renderOfficerDesk(); // Tự động load lại khung chat của cán bộ ngay lập tức
            }
        });

        function updateDataAndRender(data) {
            state = data.systemState;
            registry = data.citizenIdentityRegistry;
            violations = data.criminalRecordsRegistry;
            
            if (activeUser) {
                activeUser = state.authorizedPersonnel[activeUser.username];
                renderAuth();
            }
            
            // Cập nhật số lượng huy hiệu thông báo
            if (activeUser) {
                let filtered = Object.values(state.applications).filter(a => {
                    if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ') return true;
                    return a.agency === activeUser.agency;
                });
                const badgeCount = document.getElementById('badge-count-app');
                if (filtered.length > 0) {
                    badgeCount.innerText = filtered.length;
                    badgeCount.classList.remove('hidden');
                } else {
                    badgeCount.classList.add('hidden');
                }
            }
            
            renderAll();
            
            // Nếu cán bộ đang mở 1 hồ sơ cụ thể, giữ trạng thái render bàn làm việc ổn định
            if (activeFileId) { renderOfficerDesk(); }
        }

        function checkAndRestoreSession() {
            let savedSession = localStorage.getItem('sessionUser');
            if(savedSession) {
                try {
                    let creds = JSON.parse(savedSession);
                    if (state.authorizedPersonnel[creds.username] && state.authorizedPersonnel[creds.username].password === creds.password) {
                        activeUser = state.authorizedPersonnel[creds.username];
                        applyUserRoleLayout();
                    }
                } catch(e) { localStorage.removeItem('sessionUser'); }
            } else {
                renderAuth();
            }
        }

        function jumpToActiveNotification() {
            tab('tab-officer');
            document.getElementById('officer-alert-light').classList.add('hidden');
        }

        function tab(id) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            document.getElementById(id).classList.remove('hidden');
            document.querySelectorAll('nav button').forEach(b => {
                b.classList.remove('border-amber-500', 'text-amber-500');
                b.classList.add('border-transparent', 'text-slate-400');
            });
            const btn = document.getElementById(`btn-${id}`);
            if(btn) {
                btn.classList.remove('border-transparent', 'text-slate-400');
                btn.classList.add('border-amber-500', 'text-amber-500');
            }
            if (id === 'tab-officer') { document.getElementById('officer-alert-light').classList.add('hidden'); }
            sessionStorage.setItem('activeTab', id);
        }

        async function submitViolationForm(e) {
            e.preventDefault();
            const username = document.getElementById('vio-user').value.trim();
