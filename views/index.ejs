                            <i class="fa-solid fa-user text-3xl mt-2"></i>
                            <div class="absolute bottom-0 w-full bg-amber-500/10 text-[7px] font-black text-center text-amber-400 py-0.5">ROBLOX RP</div>
                        </div>
                        <div class="flex-1 text-[11px] space-y-0.5">
                            <p class="font-mono text-amber-500 font-black text-[12px]">Số / No: <span class="text-white tracking-widest">${fixedID}</span></p>
                            <p class="text-slate-400 font-bold">Họ và tên: <span class="text-xs font-black text-white uppercase">${citizen.name}</span></p>
