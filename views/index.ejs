                        ${(activeUser.role === 'ADMIN') ? `<button onclick="sendAction('${app.id}', 'unarchive')" class="w-full bg-red-700 text-white font-black py-1.5 rounded text-[10px] uppercase hover:bg-red-600">Admin Quyền Lực: Tái Thẩm Phục Hồi Hồ Sơ</button>` : ''}
