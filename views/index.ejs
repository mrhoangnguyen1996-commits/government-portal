                        <p class="font-medium text-slate-400">Giấy phép sở hữu hệ thống: <span class="text-amber-400 font-bold block bg-black/40 p-2 rounded border border-slate-900 mt-1">${r.licenses.join(' — ')}</span></p>
                        <p class="text-emerald-400 font-black">Tình trạng tư pháp quốc gia: <span class="text-white font-bold bg-emerald-950 border border-emerald-800 px-2 py-0.5 rounded ml-1 uppercase text-[10px] tracking-wide">${r.status}</span></p>
                    </div>
                `;
            } else { resArea.innerHTML = `<p class="mt-4 text-center text-red-400 text-xs font-black"><i class="fa-solid fa-triangle-exclamation"></i> KHÔNG TÌM THẤY DỮ LIỆU ĐỊNH DANH TRÊN MÁY CHỦ.</p>`; }
        }

        function openLogin() { document.getElementById('login-modal').classList.remove('hidden'); }
        function closeLogin() { document.getElementById('login-modal').classList.add('hidden'); }
        
        function login() { 
            const u = document.getElementById('log-user').value; const p = document.getElementById('log-pass').value;
            if (state.authorizedPersonnel[u] && state.authorizedPersonnel[u].password === p) { 
                activeUser = state.authorizedPersonnel[u]; 
                localStorage.setItem('sessionUser', JSON.stringify({ username: u, password: p })); 
                closeLogin(); soundSuccess(); applyUserRoleLayout();
            } else { soundDecline(); alert("Sai chứng thư hoặc mã quyền lực hệ thống không khớp!"); } 
        }

        function applyUserRoleLayout() { 
            if(!activeUser) return;
            document.getElementById('btn-tab-officer').classList.remove('hidden'); 
            if(activeUser.role === 'ADMIN') document.getElementById('btn-tab-admin').classList.remove('hidden'); 
            
            // Phân quyền cho Tab lãnh đạo và ban hành sắc lệnh
            if(activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN') { 
                document.getElementById('btn-off-leaderzone').classList.remove('hidden'); 
            } else { 
                document.getElementById('btn-off-leaderzone').classList.add('hidden'); 
            } 
            renderAuth(); renderAll(); 
            let savedTab = sessionStorage.getItem('activeTab'); tab(savedTab || 'tab-officer');
        }

        function logout() { activeUser = null; activeFileId = null; localStorage.removeItem('sessionUser'); document.getElementById('btn-tab-officer').classList.add('hidden'); document.getElementById('btn-tab-admin').classList.add('hidden'); renderAuth(); tab('tab-news'); }
        
        function renderAuth() { 
            const p = document.getElementById('auth-panel');
            if(!activeUser) { p.innerHTML = `<button onclick="openLogin()" class="bg-gradient-to-r from-amber-400 to-amber-500 text-black px-5 py-2.5 rounded-lg text-[11px] uppercase font-black tracking-wider shadow-md hover:from-amber-300">Đăng Nhập Nghiệp Vụ Cán Bộ</button>`; } 
            else { p.innerHTML = `<div class="bg-slate-900 border border-slate-700 px-3 py-1.5 rounded-xl flex items-center gap-2 shadow-inner"><b class="text-white font-mono text-[11px]">${activeUser.displayName} [${activeUser.role}]</b><button onclick="logout()" class="text-red-400 hover:text-red-500 ml-2 cursor-pointer transition-colors"><i class="fa-solid fa-power-off"></i></button></div>`; } 
        }
        
        startClock();
    </script>
</body>
</html>
