        function editOfficer(username) {
            let u = state.authorizedPersonnel[username]; if(!u) return;
            tab('tab-admin'); adminSubTab('adm-accounts');
            document.getElementById('p-user').value = u.username;
            document.getElementById('p-user').readOnly = true;
            document.getElementById('p-pass').value = u.password;
            document.getElementById('p-name').value = u.displayName;
            document.getElementById('p-role').value = u.role;
            document.getElementById('p-agency').value = u.agency;
            document.getElementById('p-isEdit').value = "true";
            document.getElementById('form-provision-title').innerHTML = `<i class="fa-solid fa-user-gear text-sky-400"></i> Hiệu Chỉnh Chứng Thư Cán Bộ`;
            document.getElementById('btn-submit-provision').innerText = "Cập Nhật Thay Đổi Quyền Lực";
            document.getElementById('btn-cancel-edit').classList.remove('hidden');
        }

        function resetProvisionForm() {
            document.getElementById('p-user').value = ''; document.getElementById('p-user').readOnly = false;
            document.getElementById('p-pass').value = ''; document.getElementById('p-name').value = '';
            document.getElementById('p-isEdit').value = "false";
            document.getElementById('form-provision-title').innerHTML = `<i class="fa-solid fa-id-card-clip"></i> Cấp sắc lệnh nhân sự mới`;
