                <button onclick="closeLogin()" class="w-1/3 bg-slate-800 text-slate-400 py-2 rounded-lg uppercase font-black tracking-wider hover:bg-slate-700">Đóng</button>
                <button onclick="login()" class="w-2/3 bg-gradient-to-r from-amber-400 to-amber-500 text-black py-2 rounded-lg uppercase font-black tracking-wider hover:brightness-110">Xác Minh</button>
            </div>
