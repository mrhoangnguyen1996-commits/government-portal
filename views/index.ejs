<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CỔNG LIÊN THÔNG QUỐC GIA ULTRA CHÍNH PHỦ SỐ v3.0</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Space+Grotesk:wght@400;500;600;700&display=swap');
        body { font-family: 'Space Grotesk', sans-serif; background-color: #02040a; color: #e2e8f0; }
        .font-mono-tech { font-family: 'Share Tech Mono', monospace; }
        
        /* PHÔI ẤN KÝ PHÁT QUANG ĐA SẮC BIẾN THIÊN */
        .stamp-box { position: relative; font-size: 11px; font-weight: 900; text-transform: uppercase; padding: 6px 14px; border-radius: 6px; border: 3px dashed; display: inline-block; text-align: center; letter-spacing: 1px; transform: rotate(-8deg); text-shadow: 0 0 6px currentColor; box-shadow: inset 0 0 8px rgba(0,0,0,0.3); animation: stampAppear 0.2s ease-out forwards; }
        .stamp-approved { border-color: #10b981; color: #10b981; background: rgba(16, 185, 129, 0.1); }
        .stamp-rejected { border-color: #ef4444; color: #ef4444; background: rgba(239, 68, 68, 0.1); }
        .stamp-pending { border-color: #f59e0b; color: #f59e0b; background: rgba(245, 158, 11, 0.1); }
        .stamp-forwarded { border-color: #3b82f6; color: #3b82f6; background: rgba(59, 130, 246, 0.1); }
        .stamp-leader { border-color: #c084fc; color: #c084fc; background: rgba(192, 132, 252, 0.15); border-style: double; border-width: 5px; }
        .stamp-archived { border-color: #94a3b8; color: #94a3b8; background: rgba(148, 163, 184, 0.1); }
        @keyframes stampAppear { 0% { transform: scale(2.2) rotate(-25deg); opacity: 0; } 100% { transform: scale(1) rotate(-8deg); opacity: 1; } }

        /* PHÔI THẺ THÔNG MINH CHÍNH PHỦ SỐ ĐA LỚP */
        .national-card { background: linear-gradient(135deg, #0f172a 0%, #1e293b 40%, #020617 100%); border: 2px solid #334155; position: relative; overflow: hidden; box-shadow: 0 20px 45px rgba(0,0,0,0.8), inset 0 1px 1px rgba(255,255,255,0.1); border-radius: 14px; transition: all 0.25s ease; }
        .national-card:hover { transform: translateY(-5px); border-color: #f59e0b; box-shadow: 0 0 25px rgba(245, 158, 11, 0.2); }
        .card-chip { width: 44px; height: 32px; background: linear-gradient(135deg, #fbbf24 0%, #b45309 100%); border-radius: 6px; position: relative; border: 1px solid #d97706; }
        
        .marquee-container { width: 100%; overflow: hidden; white-space: nowrap; background: #070b16; border-top: 1px solid #111827; border-bottom: 1px solid #111827; }
        .marquee-content { display: inline-block; padding-left: 100%; animation: marquee 35s linear infinite; font-size: 13px; font-weight: 700; color: #f59e0b; }
        @keyframes marquee { 0% { transform: translate3d(0, 0, 0); } 100% { transform: translate3d(-100%, 0, 0); } }
        
        /* CÁN BỘ SUBTAB */
        .subtab-active { background-color: #064e3b; border-color: #10b981; color: #fff; }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between">

    <div>
        <header class="bg-[#070b14] border-b border-gray-900 px-6 py-4 flex flex-wrap justify-between items-center shadow-2xl relative">
            <div class="flex items-center space-x-4">
                <div class="relative flex items-center justify-center">
                    <div class="absolute inset-0 bg-amber-500/10 blur-xl rounded-full"></div>
                    <div class="bg-gradient-to-br from-red-600 via-amber-500 to-yellow-500 p-3 rounded-2xl text-black border border-amber-300 shadow-2xl z-10">
                        <i class="fa-solid fa-building-columns text-2xl text-white"></i>
                    </div>
                </div>
                <div>
                    <span class="text-[10px] tracking-widest text-amber-500 uppercase font-black font-mono-tech block">TRỤC LIÊN THÔNG QUỐC GIA CHÍNH PHỦ ĐIỆN TỬ</span>
                    <h1 class="text-2xl font-extrabold text-white tracking-tight flex items-center gap-2">TRUNG TÂM ĐIỀU HÀNH SỐ HÓA TỐI CAO <span class="text-xs font-mono bg-emerald-950 text-emerald-400 border border-emerald-800 px-2 py-0.5 rounded">v3.0-SPEED-CORE</span></h1>
                </div>
            </div>

            <div class="flex items-center space-x-3 text-xs mt-3 lg:mt-0">
                <div id="officer-alert-light" onclick="jumpToActiveNotification()" class="hidden bg-red-950 border border-red-500 px-3 py-1.5 rounded-xl flex items-center gap-2 animate-pulse cursor-pointer">
                    <span class="h-2 w-2 rounded-full bg-red-500"></span>
                    <span class="text-red-400 font-black text-[11px] uppercase tracking-wide">PHÁT HIỆN HỒ SƠ KHẨN TRÊN HỆ THỐNG</span>
                </div>
                <div class="bg-[#0b0f19] px-4 py-2 rounded-xl border border-gray-900 font-mono text-amber-400 font-black tracking-widest text-sm" id="clock">00:00:00</div>
                <div class="bg-[#0b0f19] px-3 py-2 rounded-xl border border-gray-900 flex items-center gap-2">
                    <span id="security-txt" class="font-black text-[11px] tracking-wider uppercase text-emerald-400"><%= state.securityLevel %></span>
                </div>
                <div id="auth-panel"></div>
            </div>
        </header>

        <div class="marquee-container py-2 flex items-center">
            <div class="bg-red-950 text-red-400 border border-red-800 font-black text-[10px] px-2.5 py-0.5 rounded uppercase tracking-wider mx-4 z-10">Thông báo lõi</div>
            <div class="marquee-content" id="live-marquee"><%= state.tickerMessage %></div>
        </div>

        <nav class="bg-[#070b14]/90 border-b border-gray-900 px-6 py-1 flex flex-wrap gap-1 sticky top-0 z-40 backdrop-blur-xl">
            <button onclick="tab('tab-news')" id="btn-tab-news" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-amber-500 text-amber-500 transition-all"><i class="fa-solid fa-newspaper mr-1.5"></i> Sắc lệnh quốc gia</button>
            <button onclick="tab('tab-id')" id="btn-tab-id" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-gray-400 hover:text-white transition-all"><i class="fa-solid fa-address-card mr-1.5"></i> Tra cứu định danh</button>
            <button onclick="tab('tab-cards')" id="btn-tab-cards" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-sky-400 hover:text-sky-300 transition-all"><i class="fa-solid fa-print mr-1.5"></i> Kết xuất phôi giấy tờ</button>
            <button onclick="tab('tab-services')" id="btn-tab-services" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-purple-400 hover:text-purple-300 transition-all"><i class="fa-solid fa-file-invoice mr-1.5"></i> Cổng nộp đơn/Khiếu nại</button>
            <button onclick="tab('tab-officer')" id="btn-tab-officer" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-emerald-400 hover:text-emerald-300 hidden relative">
                <i class="fa-solid fa-user-shield mr-1.5"></i> Bàn Làm Việc Bộ Ngành 
                <span id="badge-count-app" class="absolute top-1.5 right-1 bg-red-600 text-white text-[9px] px-1.5 rounded-full font-black hidden">0</span>
            </button>
            <button onclick="tab('tab-admin')" id="btn-tab-admin" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-red-400 hover:text-red-300 hidden"><i class="fa-solid fa-crown mr-1.5"></i> Phòng Giám Sát Tối Cao</button>
        </nav>

        <main class="p-6 max-w-[1700px] w-full mx-auto space-y-6">
            
            <section id="tab-news" class="grid grid-cols-1 xl:grid-cols-4 gap-6">
                <div class="xl:col-span-2 space-y-4">
                    <h2 class="text-xs font-black text-gray-400 uppercase tracking-widest border-b border-gray-900 pb-2"><i class="fa-solid fa-scroll text-amber-500 mr-1.5"></i> Văn bản quyết định điều hành</h2>
                    <div id="news-feed" class="space-y-3"></div>
                </div>
                <div class="space-y-4">
                    <h2 class="text-xs font-black text-red-400 uppercase tracking-widest border-b border-gray-900 pb-2"><i class="fa-solid fa-triangle-exclamation mr-1.5 animate-pulse"></i> Cơ sở dữ liệu đối tượng truy nã</h2>
                    <div id="wanted-feed" class="space-y-3"></div>
                </div>
                <div class="space-y-4">
                    <h2 class="text-xs font-black text-teal-400 uppercase tracking-widest border-b border-gray-900 pb-2"><i class="fa-solid fa-robot mr-1.5"></i> Trợ Lý Số Hóa Quốc Vụ (AI BOT)</h2>
                    <div class="bg-[#0b111e] border border-gray-800 p-4 rounded-2xl flex flex-col justify-between h-[420px] shadow-2xl">
                        <div id="bot-chat-flow" class="flex-1 overflow-y-auto space-y-3 pr-1 text-xs">
                            <div class="bg-teal-950/30 border border-teal-900/60 p-3 rounded-xl text-teal-300">
                                <b class="block text-[10px] text-teal-400 uppercase mb-1"><i class="fa-solid fa-robot"></i> Tuệ Đức Quốc Vụ v3.0</b>
                                Cổng trục liên thông chào công dân. Tôi đã nạp sẵn toàn bộ dữ liệu cấu trúc lõi năm 2026. Hãy gõ tên tài khoản kịch bản (Ví dụ: <span class="text-white font-mono">Nguyen_Mạnh_Hoang</span>) để tra cứu trạng thái lý lịch lõi hoặc hỏi về quy trình hành chính công công.
                            </div>
                        </div>
                        <div class="pt-2 border-t border-gray-800 flex gap-2">
                            <input type="text" id="bot-input" placeholder="Nhập câu hỏi hành chính hoặc tên công dân..." class="flex-1 bg-gray-950 border border-gray-700 p-2.5 text-xs text-white rounded-xl focus:outline-none">
                            <button onclick="askAiBot()" class="bg-teal-600 hover:bg-teal-700 text-white font-black px-4 text-xs rounded-xl uppercase tracking-wider">Hỏi</button>
                        </div>
                    </div>
                </div>
            </section>

            <section id="tab-id" class="hidden max-w-2xl mx-auto bg-[#070b14] border border-gray-900 p-6 rounded-2xl shadow-2xl">
                <h2 class="text-xs font-black text-center text-white uppercase tracking-widest mb-4"><i class="fa-solid fa-shield-halved text-amber-500 mr-1"></i> Hệ thống xác minh định danh cốt lõi quốc gia</h2>
                <div class="flex gap-2 mb-4">
                    <input type="text" id="id-search" placeholder="Nhập tên tài khoản cư dân định danh..." class="flex-1 bg-gray-950 border border-gray-800 px-3 py-2 text-sm rounded-xl text-white font-mono focus:outline-none">
                    <button onclick="searchCitizen()" class="bg-amber-500 hover:bg-amber-600 text-black px-5 text-xs font-black uppercase rounded-xl">Truy xuất dữ liệu</button>
                </div>
                <div id="id-result"></div>
            </section>

            <section id="tab-cards" class="hidden max-w-6xl mx-auto space-y-8">
                <div class="bg-[#070b14] border border-gray-900 p-6 rounded-2xl shadow-xl max-w-xl mx-auto">
                    <h2 class="text-xs font-black text-center text-sky-400 uppercase tracking-widest mb-4"><i class="fa-solid fa-id-card text-sky-500 mr-1"></i> Trình kết xuất bản vẽ phôi hành chính điện tử</h2>
                    <div class="flex gap-2">
                        <input type="text" id="card-search-input" placeholder="Nhập tài khoản cư dân (Ví dụ: Nguyen_Manh_Hoang)..." class="flex-1 bg-gray-950 border border-gray-800 px-3 py-2 text-sm rounded-xl text-white font-mono focus:outline-none">
                        <button onclick="generateCitizenCards()" class="bg-sky-600 hover:bg-sky-700 text-white px-5 text-xs font-black uppercase rounded-xl">Xuất Giấy Tờ</button>
                    </div>
                </div>
                <div class="space-y-4">
                    <h3 class="text-xs font-black uppercase text-gray-400 tracking-widest flex items-center gap-1.5"><i class="fa-solid fa-passport text-sky-400"></i> Phôi Căn Cước Công Dân Gắn Chíp & Văn Bằng Nghiệp Vụ</h3>
                    <div id="cards-render-zone" class="grid grid-cols-1 md:grid-cols-2 gap-6 justify-center items-center">
                        <p class="text-center text-xs text-gray-600 col-span-2 py-8">Vui lòng nhập tài khoản cư dân để trục đồng bộ kết xuất phôi đồ họa vector.</p>
                    </div>
                </div>
                <div class="space-y-4">
                    <h3 class="text-xs font-black uppercase text-red-400 tracking-widest flex items-center gap-1.5"><i class="fa-solid fa-gavel text-red-500"></i> Lý lịch tư pháp và biên bản xử phạt hình sự kịch bản</h3>
                    <div id="violation-render-zone" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <p class="text-center text-xs text-gray-600 col-span-2 py-4">Lý lịch trống.</p>
                    </div>
                </div>
            </section>

            <section id="tab-services" class="hidden grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="bg-[#070b14] border border-gray-900 p-5 rounded-2xl space-y-4 shadow-xl">
                    <h3 class="text-xs font-black text-gray-300 uppercase tracking-widest border-b border-gray-800 pb-2"><i class="fa-solid fa-file-pen text-amber-500 mr-1.5"></i> Khởi tạo hồ sơ hành chính số hóa</h3>
                    <form onsubmit="submitForm(event)" class="space-y-4 text-xs">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                            <div>
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Tên Tài Khoản Hệ Thống (Họ_Tên)</label>
                                <input type="text" id="app-sender" required placeholder="Nguyen_Manh_Hoang" class="w-full bg-gray-950 border border-gray-800 p-2.5 rounded-xl text-white font-mono focus:outline-none">
                            </div>
                            <div>
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Loại Giấy Tờ / Thủ Tục</label>
                                <select id="app-docType" class="w-full bg-gray-950 border border-gray-800 p-2.5 rounded-xl text-white font-bold text-amber-400 focus:outline-none">
                                    <option value="CĂN CƯỚC CÔNG DÂN">Căn Cước Công Dân Gắn Chíp</option>
                                    <option value="GIẤY PHÉP SỬ DỤNG CÔNG CỤ HỖ TRỢ">Giấy Phép Sử Dụng Vũ Khí / CCHT</option>
                                    <option value="HỘ CHIẾU QUỐC TẾ">Hộ Chiếu Quốc Tế (Visa)</option>
                                    <option value="GIẤY PHÉP KINH DOANH DOANH NGHIỆP">Giấy Phép Doanh Nghiệp</option>
                                    <option value="ĐĂNG KÝ SỬ DỤNG TẦN SỐ BỘ ĐÀM MÃ HÓA">Đăng Ký Tần Số Bộ Đàm Quốc Gia</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Mức Độ Khẩn</label>
                                <select id="app-priority" class="w-full bg-gray-950 border border-gray-800 p-2.5 rounded-xl text-white font-bold text-red-400 focus:outline-none">
                                    <option value="BÌNH THƯỜNG">Bình Thường</option>
                                    <option value="HỎA TỐC">Hỏa Tốc ⚡</option>
                                    <option value="THƯỢNG KHẨN">Thượng Khẩn Quốc Gia 🚨</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Cơ Quan Tiếp Nhận Thẩm Định</label>
                            <select id="app-agency" class="w-full bg-gray-950 border border-gray-800 p-2.5 rounded-xl text-white font-bold text-sky-400 focus:outline-none">
                                <option value="CHÍNH PHỦ">VĂN PHÒNG CHÍNH PHỦ TỐI CAO</option>
                                <option value="THANH TRA">THANH TRA CHÍNH PHỦ</option>
                                <option value="CÔNG AN">BỘ CÔNG AN QUỐC GIA</option>
                                <option value="QUÂN ĐỘI">BỘ CHỈ HUY QUÂN SỰ TRƯỞNG</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Trình Bày Nội Dung Giải Trình Kịch Bản Chi Tiết</label>
                            <textarea id="app-content" rows="4" required placeholder="Ghi rõ thông tin yêu cầu để Hội đồng thẩm định duyệt..." class="w-full bg-gray-950 border border-gray-800 p-2.5 rounded-xl text-white focus:outline-none"></textarea>
                        </div>
                        <button type="submit" class="w-full bg-gradient-to-r from-amber-500 to-amber-600 font-black text-black py-3 rounded-xl uppercase tracking-widest shadow-xl">Gửi Đơn Lên Trục Hệ Thống Quốc Gia</button>
                    </form>
                </div>

                <div class="bg-[#070b14] border border-gray-900 p-5 rounded-2xl flex flex-col h-full min-h-[480px] shadow-xl">
                    <h3 class="text-xs font-black text-gray-300 uppercase tracking-widest border-b border-gray-900 pb-2"><i class="fa-solid fa-satellite-dish text-sky-400 mr-1"></i> Cổng Tra Cứu Tiến Độ & Đàm Thoại Tư Pháp Hai Chiều</h3>
                    <div class="flex gap-2 my-3">
                        <input type="text" id="track-id" placeholder="Nhập mã đơn thư cần tra cứu (Ví dụ: HS-1001)..." class="flex-1 bg-gray-950 border border-gray-800 px-3 py-2 text-xs rounded-xl text-white font-mono focus:outline-none">
                        <button onclick="trackApplication()" class="bg-sky-600 hover:bg-sky-700 text-white px-5 text-xs font-black rounded-xl uppercase">Truy vấn đơn</button>
                    </div>
                    <div id="track-details" class="flex-1 flex flex-col justify-between hidden space-y-3"></div>
                    <div id="track-empty" class="text-center py-24 text-gray-600 text-xs flex-1 flex flex-col justify-center items-center"><i class="fa-solid fa-folder-open text-4xl mb-3 text-gray-800"></i> Nhập chính xác mã số đơn để mở khung đàm thoại và nhận kết quả trực tiếp từ cán bộ thụ lý.</div>
                </div>
            </section>

            <section id="tab-officer" class="hidden grid grid-cols-1 xl:grid-cols-4 gap-6">
                
                <div class="xl:col-span-1 bg-[#0b111e] border border-gray-800 p-4 rounded-2xl flex flex-col gap-2 shadow-2xl h-fit">
                    <p class="text-[10px] font-black text-amber-500 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-1"><i class="fa-solid fa-folder-tree"></i> Phân Hệ Nghiệp Vụ Công Vụ</p>
                    <button onclick="subtab('sub-app')" id="btn-sub-app" class="subtab-active text-left px-4 py-3 text-xs font-black uppercase tracking-wider rounded-xl border border-gray-800 transition-all"><i class="fa-solid fa-folder-open mr-2"></i> Tiếp Nhận & Thẩm Định Đơn</button>
                    <button onclick="subtab('sub-vio')" id="btn-sub-vio" class="text-left px-4 py-3 text-xs font-black uppercase tracking-wider rounded-xl border border-transparent text-gray-400 hover:text-white hover:bg-gray-900 transition-all"><i class="fa-solid fa-gavel mr-2"></i> Ký Biên Bản & Quyết Định Phạt</button>
                    <button onclick="subtab('sub-reg')" id="btn-sub-reg" class="text-left px-4 py-3 text-xs font-black uppercase tracking-wider rounded-xl border border-transparent text-gray-400 hover:text-white hover:bg-gray-900 transition-all"><i class="fa-solid fa-user-plus mr-2"></i> Số Hóa Đăng Ký Cư Dân</button>
                    <button onclick="subtab('sub-rpt')" id="btn-sub-rpt" class="text-left px-4 py-3 text-xs font-black uppercase tracking-wider rounded-xl border border-transparent text-gray-400 hover:text-white hover:bg-gray-900 transition-all"><i class="fa-solid fa-clipboard-list mr-2"></i> Trung Tâm Báo Cáo Ca Trực</button>
                </div>

                <div class="xl:col-span-2 space-y-5">
                    
                    <div id="sub-app" class="bg-[#070b14] border border-gray-800 p-4 rounded-2xl shadow-md">
                        <div class="flex justify-between items-center mb-3">
                            <h3 class="text-xs font-black text-emerald-400 uppercase tracking-wider"><i class="fa-solid fa-inbox mr-1"></i> Luồng hồ sơ chờ tiếp nhận tiếp quản</h3>
                            <span id="office-badge" class="text-[9px] font-mono font-bold bg-emerald-950 text-emerald-400 px-2 py-0.5 rounded border border-emerald-800">Cơ Quan Tiếp Nhận</span>
                        </div>
                        <div class="overflow-x-auto text-xs">
                            <table class="w-full text-left">
                                <thead class="bg-gray-950 text-gray-400 font-bold uppercase text-[9px] tracking-wider">
                                    <tr>
                                        <th class="p-3">Mã</th>
                                        <th class="p-3">Cư Dân</th>
                                        <th class="p-3">Thủ Tục</th>
                                        <th class="p-3">Độ Khẩn</th>
                                        <th class="p-3 text-right">Hành Động</th>
                                    </tr>
                                </thead>
                                <tbody id="officer-table" class="divide-y divide-gray-800"></tbody>
                            </table>
                        </div>
                    </div>

                    <div id="sub-vio" class="hidden bg-[#070b14] border border-gray-800 p-5 rounded-2xl space-y-4 shadow-xl">
                        <h3 class="text-xs font-black text-red-500 uppercase tracking-widest border-b border-gray-800 pb-2"><i class="fa-solid fa-signature"></i> Hệ thống ấn ký xử lý vi phạm pháp luật kịch bản</h3>
                        <form onsubmit="submitViolationForm(event)" class="grid grid-cols-1 md:grid-cols-2 gap-3 text-xs">
