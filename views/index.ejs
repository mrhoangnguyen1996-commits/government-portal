<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CỔNG THÔNG TIN ĐIỆN TỬ CHÍNH PHỦ - GIẢ LẬP ROLEPLAY</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Space+Grotesk:wght@400;500;600;700&display=swap');
        body { font-family: 'Space Grotesk', sans-serif; background-color: #05070f; color: #cbd5e1; }
        .font-mono-tech { font-family: 'Share Tech Mono', monospace; }
        
        .stamp-box { position: relative; font-size: 11px; font-weight: 800; text-transform: uppercase; padding: 5px 12px; border-radius: 4px; border: 2.5px dashed; display: inline-block; text-align: center; letter-spacing: 1px; transform: rotate(-6deg) scale(1.05); text-shadow: 0 0 4px currentColor; box-shadow: inset 0 0 6px rgba(0,0,0,0.2); animation: stampAppear 0.2s ease-out; }
        .stamp-approved { border-color: #10b981; color: #10b981; background: rgba(16, 185, 129, 0.08); }
        .stamp-rejected { border-color: #ef4444; color: #ef4444; background: rgba(239, 68, 68, 0.08); }
        .stamp-pending { border-color: #f59e0b; color: #f59e0b; background: rgba(245, 158, 11, 0.08); }
        .stamp-forwarded { border-color: #3b82f6; color: #3b82f6; background: rgba(59, 130, 246, 0.08); }
        .stamp-leader { border-color: #a855f7; color: #a855f7; background: rgba(168, 85, 247, 0.12); border-style: double; border-width: 4px; }
        .stamp-archived { border-color: #94a3b8; color: #94a3b8; background: rgba(148, 163, 184, 0.1); }

        @keyframes stampAppear { 0% { transform: scale(1.8) rotate(-20deg); opacity: 0; } 100% { transform: scale(1.05) rotate(-6deg); opacity: 1; } }
        
        .marquee-container { width: 100%; overflow: hidden; white-space: nowrap; background: #090d16; border-top: 1px solid #1e293b; border-bottom: 1px solid #1e293b; }
        .marquee-content { display: inline-block; padding-left: 100%; animation: marquee 35s linear infinite; font-size: 12px; font-weight: 600; color: #f59e0b; text-shadow: 0 0 6px rgba(245, 158, 11, 0.4); }
        @keyframes marquee { 0% { transform: translate3d(0, 0, 0); } 100% { transform: translate3d(-100%, 0, 0); } }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between">

    <div class="flex-1">
        <header class="bg-[#0a0f1d] border-b border-slate-800 px-6 py-3.5 flex flex-wrap justify-between items-center shadow-lg relative">
            <div class="flex items-center space-x-4">
                <div class="relative flex items-center justify-center">
                    <div class="absolute inset-0 bg-amber-500/20 blur-md rounded-full animate-pulse"></div>
                    <div class="bg-gradient-to-br from-amber-400 to-amber-600 p-2.5 rounded-xl text-black border border-amber-300 shadow-lg z-10">
                        <i class="fa-solid fa-building-columns text-2xl"></i>
                    </div>
                </div>
                <div>
                    <span class="text-[10px] tracking-widest text-amber-500 uppercase font-extrabold font-mono-tech">Roblox Gaming Roleplay Community Platform</span>
                    <h1 class="text-xl font-black text-white tracking-tight drop-shadow-sm flex items-center gap-2">CỔNG LIÊN THÔNG QUỐC GIA <span class="text-[11px] font-mono bg-slate-800 text-slate-400 px-1.5 py-0.5 rounded border border-slate-700">v5.0.0-PRO</span></h1>
                </div>
            </div>

            <div class="flex items-center space-x-4 text-xs">
                <div id="officer-alert-light" onclick="jumpToActiveNotification()" class="hidden bg-red-950 border border-red-500 px-3 py-1.5 rounded-lg flex items-center gap-2 animate-pulse cursor-pointer hover:bg-red-900 transition-all">
                    <span class="h-2 w-2 rounded-full bg-red-500 shadow-[0_0_10px_#ef4444]"></span>
                    <span id="alert-light-text" class="text-red-400 font-black text-[11px] tracking-wide uppercase">CÓ ĐƠN THƯ / TIN NHẮN MỚI</span>
                </div>
                <div class="bg-[#0f172a] px-3 py-1.5 rounded-lg border border-slate-800 font-mono text-amber-400 font-bold tracking-widest" id="clock">00:00:00</div>
                <div class="bg-[#0f172a] px-3 py-1.5 rounded-lg border border-slate-800 flex items-center gap-2">
                    <span id="security-txt" class="font-extrabold text-[11px] tracking-wider uppercase text-emerald-400"><%= state.securityLevel %></span>
                </div>
                <div id="auth-panel"></div>
            </div>
        </header>

        <div class="marquee-container py-2 flex items-center">
            <div class="bg-red-950 text-red-400 border border-red-900/60 font-black text-[9px] px-2 py-0.5 rounded uppercase tracking-wider mx-3 z-10">Thông báo khẩn</div>
            <div class="marquee-content" id="live-marquee"><%= state.tickerMessage %></div>
        </div>

        <nav class="bg-[#0a0f1d]/80 border-b border-slate-800 px-6 flex space-x-1.5 backdrop-blur-md">
            <button onclick="tab('tab-news')" id="btn-tab-news" class="px-4 py-3 text-xs font-black uppercase tracking-wider border-b-2 border-amber-500 text-amber-500 transition-all"><i class="fa-solid fa-newspaper mr-1"></i> Trung Tâm Ấn Bản</button>
            <button onclick="tab('tab-id')" id="btn-tab-id" class="px-4 py-3 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-slate-400 hover:text-white transition-all"><i class="fa-solid fa-address-card mr-1"></i> Tra cứu định danh</button>
            <button onclick="tab('tab-services')" id="btn-tab-services" class="px-4 py-3 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-slate-400 hover:text-white transition-all"><i class="fa-solid fa-file-invoice-dollar mr-1"></i> Nộp Đơn Thủ Tục / Khiếu Nại</button>
            <button onclick="tab('tab-officer')" id="btn-tab-officer" class="px-4 py-3 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-emerald-500 hover:text-emerald-400 hidden relative">
                <i class="fa-solid fa-user-shield mr-1"></i> Bàn Làm Việc Bộ Ngành 
                <span id="badge-count-app" class="absolute top-1.5 right-1 bg-red-600 text-white text-[9px] px-1 rounded-full font-black hidden">0</span>
            </button>
            <button onclick="tab('tab-admin')" id="btn-tab-admin" class="px-4 py-3 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-purple-400 hover:text-purple-300 hidden"><i class="fa-solid fa-crown mr-1"></i> Phòng Giám Sát Tối Cao</button>
        </nav>

        <main class="p-6 max-w-[1650px] w-full mx-auto space-y-6">
            
            <section id="tab-news" class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <div class="lg:col-span-2 space-y-4">
                    <h2 class="text-xs font-black text-slate-400 uppercase tracking-widest border-b border-slate-800 pb-2 flex items-center gap-2"><i class="fa-solid fa-scroll text-amber-500"></i> Văn Bản Chỉ Thị / Sắc Lệnh Quốc Gia</h2>
                    <div id="news-feed" class="space-y-3"></div>
                </div>
                <div class="space-y-4">
                    <h2 class="text-xs font-black text-red-400 uppercase tracking-widest border-b border-slate-800 pb-2 flex items-center gap-2"><i class="fa-solid fa-triangle-exclamation animate-pulse"></i> Cơ Sở Dữ Liệu Đối Tượng Truy Nã</h2>
                    <div id="wanted-feed" class="space-y-3"></div>
                </div>
            </section>

            <section id="tab-id" class="hidden max-w-2xl mx-auto bg-[#0a0f1d] border border-slate-800 p-6 rounded-2xl shadow-xl">
                <h2 class="text-xs font-black text-center text-white uppercase tracking-widest mb-4"><i class="fa-solid fa-shield-halved text-amber-500"></i> Tra Cứu Dữ Liệu Định Danh Cư Dân</h2>
                <div class="flex gap-2 mb-4">
                    <input type="text" id="id-search" placeholder="Nhập tên tài khoản cư dân (Ví dụ: Nguyen_Manh_Hoang)..." class="flex-1 bg-slate-900 border border-slate-700 px-3 py-2 text-sm rounded-lg text-white font-mono">
                    <button onclick="searchCitizen()" class="bg-amber-500 hover:bg-amber-600 text-black px-5 text-xs font-black uppercase rounded-lg">Truy xuất</button>
                </div>
                <div id="id-result"></div>
            </section>

            <section id="tab-services" class="hidden grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl space-y-4 shadow-lg">
                    <h3 class="text-xs font-black text-slate-300 uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-file-pen text-amber-500"></i> Khởi Tạo Hồ Sơ Hành Chính Điện Tử</h3>
                    <form onsubmit="submitForm(event)" class="space-y-3.5 text-xs">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            <div>
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Tên Tài Khoản Hệ Thống (Họ_Tên)</label>
                                <input type="text" id="app-sender" required placeholder="Nguyen_Manh_Hoang" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-mono">
                            </div>
                            <div>
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Loại Giấy Tờ / Thủ Tục</label>
                                <select id="app-docType" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-bold text-amber-400">
                                    <option value="CĂN CƯỚC CÔNG DÂN">Căn Cước Công Dân Gắn Chíp</option>
                                    <option value="GIẤY PHÉP SỬ DỤNG CÔNG CỤ HỖ TRỢ">Giấy Phép Sử Dụng Vũ Khí / Công Cụ Hỗ Trợ</option>
                                    <option value="HỘ CHIẾU QUỐC TẾ">Hộ Chiếu Quốc Tế (Visa)</option>
                                    <option value="GIẤY PHÉP KINH DOANH DOANH NGHIỆP">Giấy Phép Thành Lập Doanh Nghiệp</option>
                                    <option value="ĐĂNG KÝ KẾT HÔN / KHAI SINH">Đăng Ký Kết Hôn / Khai Sinh</option>
                                    <option value="ĐĂNG KÝ SỬ DỤNG TẦN SỐ BỘ ĐÀM MÃ HÓA">Đăng Ký Tần Số Bộ Đàm Mã Hóa Quốc Gia</option>
                                    <option value="GIẤY PHÉP VẬN TẢI LOGISTICS ĐƯỜNG BỘ">Giấy Phép Vận Tải Quốc Tế / Logistics</option>
                                    <option value="ĐƠN XIN GIA NHẬP LỰC LƯỢNG VŨ TRANG">Đơn Tuyển Dụng / Gia Nhập Lực Lượng Vũ Trang</option>
                                    <option value="BẰNG KHAI THÁC KHOÁNG SẢN & TÀI NGUYÊN">Giấy Phép Khai Thác Tài Nguyên Môi Trường</option>
                                    <option value="ĐƠN XIN TỔ CHỨC SỰ KIỆN QUẦN CHÚNG">Đơn Đăng Ký Tổ Chức Sự Kiện Nơi Công Cộng</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Cơ Quan Tiếp Nhận Thẩm Định</label>
                            <select id="app-agency" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-bold text-sky-400">
                                <option value="CHÍNH PHỦ">VĂN PHÒNG CHÍNH PHỦ TỐI CAO (Cơ quan phê duyệt tối cao)</option>
                                <option value="THANH TRA">THANH TRA CHÍNH PHỦ (Điều tra, giải quyết khiếu nại)</option>
                                <option value="CÔNG AN">BỘ CÔNG AN (Hồ sơ Căn cước, Giao thông, An ninh)</option>
                                <option value="QUÂN ĐỘI">BỘ CHỈ HUY QUÂN SỰ TRƯỞNG</option>
                                <option value="UBND PHƯỜNG">ỦY BAN NHÂN DÂN THÀNH PHỐ</option>
                                <option value="TOÀ ÁN">TÒA ÁN NHÂN DÂN TỐI CAO</option>
                                <option value="NGÂN HÀNG">NGÂN HÀNG TRUNG ƯƠNG QUỐC GIA</option>
                                <option value="BỆNH VIỆN">BỆNH VIỆN QUỐC GIA LIÊN THÔNG</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Trình Bày Nội Dung Chi Tiết</label>
                            <textarea id="app-content" rows="4" required placeholder="Ghi rõ thông tin yêu cầu giải quyết kịch bản nhập vai..." class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white focus:outline-none"></textarea>
                        </div>
                        <button type="submit" class="w-full bg-gradient-to-r from-amber-400 to-amber-500 font-black text-black py-3 rounded-lg uppercase tracking-widest shadow-lg">Gửi Đơn Lên Hệ Thống</button>
                    </form>
                </div>

                <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl flex flex-col h-full min-h-[480px] shadow-lg">
                    <h3 class="text-xs font-black text-slate-300 uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-satellite-dish text-sky-400 animate-pulse"></i> Cổng Tra Cứu Tiến Độ & Đàm Thoại Trực Tuyến</h3>
                    <div class="flex gap-2 my-3">
                        <input type="text" id="track-id" placeholder="Nhập mã đơn thư cần tra cứu (Ví dụ: HS-1001)..." class="flex-1 bg-slate-900 border border-slate-700 px-3 py-2 text-xs rounded-lg text-white font-mono focus:outline-none">
                        <button onclick="trackApplication()" class="bg-sky-600 hover:bg-sky-700 text-white px-5 text-xs font-black rounded-lg">Truy vấn đơn</button>
                    </div>
                    <div id="track-details" class="flex-1 flex flex-col justify-between hidden space-y-3"></div>
                    <div id="track-empty" class="text-center py-16 text-slate-500 text-xs flex-1 flex flex-col justify-center items-center"><i class="fa-solid fa-folder-open text-4xl mb-3 text-slate-700"></i> Nhập chính xác mã số đơn để tiến hành đàm thoại hoặc gửi khiếu nại lên bộ ban ngành cấp cao.</div>
                </div>
            </section>

            <section id="tab-officer" class="hidden grid grid-cols-1 xl:grid-cols-3 gap-6">
                <div class="xl:col-span-2 space-y-5">
                    
                    <div class="bg-[#0a0f1d] border border-slate-800 p-4 rounded-2xl shadow-md">
                        <div class="flex justify-between items-center mb-3">
                            <h3 class="text-xs font-black text-emerald-400 uppercase tracking-wider flex items-center gap-2"><i class="fa-solid fa-folder-closed"></i> Danh Sách Đơn Thư Thuộc Đơn Vị Quản Lý</h3>
                            <span id="office-badge" class="text-[10px] font-mono font-bold bg-emerald-950/60 text-emerald-400 px-2.5 py-1 rounded-lg border border-emerald-800">Cơ Quan Tiếp Nhận</span>
                        </div>
                        <div class="overflow-x-auto text-xs">
                            <table class="w-full text-left">
                                <thead class="bg-slate-900 text-slate-400 font-bold uppercase text-[9px] tracking-wider">
                                    <tr>
                                        <th class="p-3">Mã Đơn</th>
                                        <th class="p-3">Tài Khoản</th>
                                        <th class="p-3">Loại Giấy Tờ</th>
                                        <th class="p-3">Trạng Thái Xử Lý</th>
                                        <th class="p-3 text-right">Hành Động</th>
                                    </tr>
                                </thead>
                                <tbody id="officer-table" class="divide-y divide-slate-800"></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl space-y-3.5 shadow-lg">
                        <h3 class="text-xs font-black text-teal-400 uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-user-plus"></i> Nghiệp Vụ Số Hóa & Thiết Lập Hồ Sơ Dân Cư</h3>
                        <form onsubmit="registerResidentByOfficer(event)" class="grid grid-cols-1 md:grid-cols-3 gap-3 text-xs">
                            <div><label class="block text-gray-400 mb-1">Tài Khoản Cư Dân (Họ_Tên)</label><input type="text" id="res-user" required placeholder="Nguyen_Manh_Hoang" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white font-mono"></div>
                            <div><label class="block text-gray-400 mb-1">Họ Và Tên Khai Sinh</label><input type="text" id="res-name" required placeholder="Nguyễn Mạnh Hoàng" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white"></div>
                            <div><label class="block text-gray-400 mb-1">Ngày Sinh</label><input type="text" id="res-dob" required placeholder="18/05/1996" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white"></div>
                            <div><label class="block text-gray-400 mb-1">Giới Tính</label><select id="res-gender" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white font-bold"><option value="Nam">Nam</option><option value="Nữ">Nữ</option></select></div>
                            <div><label class="block text-gray-400 mb-1">Nguyên Quán</label><input type="text" id="res-pob" required placeholder="Lâm Đồng, Việt Nam" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white"></div>
                            <div><label class="block text-gray-400 mb-1">Nghề Nghiệp / Công Tác</label><input type="text" id="res-job" required placeholder="Chuyên Viên Cung Ứng Vật Tư" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white"></div>
                            <div class="md:col-span-2"><label class="block text-gray-400 mb-1">Giấy Phép Sở Hữu (Cách nhau bằng dấu phẩy)</label><input type="text" id="res-licenses" placeholder="Bằng Lái Xe Hạng B2, Giấy phép công cụ hỗ trợ" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white"></div>
                            <div>
                                <label class="block text-gray-400 mb-1">Tư Pháp Quốc Gia</label>
                                <select id="res-status" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white font-black text-emerald-400"><option value="Dân Cư Hợp Pháp - Lý Lịch Trong Sạch">Dân Cư Hợp Pháp - Lý Lịch Sạch</option><option value="Đang Thuộc Diện Theo Dõi Đặc Biệt">Diện Theo Dõi Đặc Biệt</option><option value="Đối Tượng Tình Nghi Hình Sự Khân Cấp">Đối Tượng Tình Nghi Hình Sự</option></select>
                            </div>
                            <button type="submit" class="md:col-span-3 bg-gradient-to-r from-teal-500 to-emerald-600 text-white font-black py-2.5 rounded-lg uppercase shadow-md">Lưu Thông Tin Lên Máy Chủ</button>
                        </form>
                    </div>

                    <div id="leader-publish-zone" class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl space-y-3.5 shadow-xl hidden">
                        <h3 class="text-xs font-black text-amber-500 uppercase tracking-widest border-b border-slate-800 pb-1.5 flex items-center gap-2"><i class="fa-solid fa-gavel text-xl"></i> Điều Hành Cấp Cao: Sắc Lệnh & Quản Lý Kho Lưu Trữ</h3>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 text-xs">
                            <div>
                                <label class="block text-gray-400 mb-1">Văn Bản Ban Hành</label>
                                <select id="pub-type" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white font-bold"><option value="QUYẾT ĐỊNH">QUYẾT ĐỊNH CHÍNH PHỦ</option><option value="THÔNG BÁO KHẨN">THÔNG BÁO KHẨN AN NINH</option><option value="TRUY NÃ">LỆNH TRUY NÃ BỊ CAN</option></select>
                            </div>
                            <div class="md:col-span-2"><label class="block text-gray-400 mb-1">Tiêu Đề Bản Tin / Tên Đối Tượng</label><input type="text" id="pub-title" placeholder="Nhập tên đối tượng hoặc tiêu đề nội dung..." class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white focus:outline-none"></div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 text-xs">
                            <div class="md:col-span-2"><label class="block text-gray-400 mb-1">Nội dung văn bản chi thị chi tiết</label><textarea id="pub-content" rows="2" placeholder="Nhập chi tiết lệnh..." class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white focus:outline-none"></textarea></div>
                            <div>
                                <label class="block text-gray-400 mb-1">Cập nhật bảng chữ chạy LED</label>
                                <div class="flex gap-1.5">
                                    <textarea id="pub-ticker" rows="2" placeholder="Nhập dòng chữ chạy..." class="flex-1 bg-slate-900 border border-slate-700 p-2 rounded-lg text-white text-[11px] focus:outline-none"></textarea>
                                    <button onclick="updateTicker()" class="bg-amber-500 text-black px-2.5 rounded-lg font-black text-[11px] uppercase">Lưu</button>
                                </div>
                            </div>
                        </div>
                        <button onclick="publishDocument()" class="w-full bg-gradient-to-r from-amber-500 to-amber-600 text-black text-xs font-black py-2.5 rounded-lg uppercase tracking-widest shadow-lg">Ký Phê Duyệt Phát Hành Ấn Bản</button>
                        
                        <div class="mt-4 pt-4 border-t border-slate-800">
                            <h4 class="text-[11px] font-black uppercase text-slate-400 mb-2"><i class="fa-solid fa-box-archive text-purple-400"></i> Kho Lưu Trữ Thuộc Ngành Bảo Mật (Click xem lại nội dung)</h4>
                            <div id="leader-archive-list" class="space-y-2 max-h-[160px] overflow-y-auto"></div>
                        </div>
                    </div>
                </div>

                <div class="bg-[#0a0f1d] border border-slate-800 p-4 rounded-2xl flex flex-col h-full min-h-[580px] shadow-lg">
                    <h3 class="text-xs font-black text-slate-300 uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-stamp text-emerald-400"></i> Phòng Nghiệp Vụ Thẩm Định & Đóng Dấu Số Hóa</h3>
                    <div id="officer-desk-active" class="flex-1 flex flex-col justify-between hidden mt-3 space-y-3.5"></div>
                    <div id="officer-desk-empty" class="text-center py-24 text-slate-500 text-xs flex-1 flex flex-col justify-center items-center"><i class="fa-solid fa-stamp text-4xl mb-3 text-slate-700"></i> Vui lòng lựa chọn hồ sơ từ danh sách để thẩm định công vụ.</div>
                </div>
            </section>

            <section id="tab-admin" class="hidden space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-xs font-mono-tech">
                    <div class="bg-[#0a0f1d] border border-slate-800 p-4 rounded-2xl flex justify-between items-center shadow-md">
                        <div><p class="text-slate-400 font-bold uppercase tracking-wider text-[11px]">Cán bộ quốc gia hoạt động</p><p id="st-staff" class="text-2xl font-black text-emerald-400 mt-1">0</p></div>
                        <div class="bg-emerald-950 p-2.5 rounded-xl border border-emerald-800 text-emerald-400"><i class="fa-solid fa-users-gear text-xl"></i></div>
                    </div>
                    <div class="bg-[#0a0f1d] border border-slate-800 p-4 rounded-2xl flex justify-between items-center shadow-md">
                        <div><p class="text-slate-400 font-bold uppercase tracking-wider text-[11px]">Trạng thái an ninh Quốc gia</p>
                            <select onchange="setSecurity(this.value)" id="adm-sec" class="bg-slate-900 border border-slate-700 rounded-lg p-1.5 mt-1.5 text-white font-black text-xs tracking-wide text-amber-500">
                                <option value="AN TOÀN">AN TOÀN / BÌNH THƯỜNG</option>
                                <option value="CAO ĐIỂM">CAO ĐIỂM TUẦN TRA ĐÊM</option>
                                <option value="KHẨN CẤP">TÌNH TRẠNG KHẨN CẤP QUỐC GIA</option>
                            </select>
                        </div>
                        <div class="bg-amber-950 p-2.5 rounded-xl border border-amber-900 text-amber-400"><i class="fa-solid fa-shield-cat text-xl"></i></div>
                    </div>
                    <div class="bg-[#0a0f1d] border border-slate-800 p-4 rounded-2xl flex justify-between items-center shadow-md">
                        <div><p class="text-slate-400 font-bold uppercase tracking-wider text-[11px]">Tổng số hồ sơ lưu kho quốc gia</p><p id="st-files" class="text-2xl font-black text-purple-400 mt-1">0</p></div>
                        <div class="bg-purple-950 p-2.5 rounded-xl border border-purple-900 text-purple-400"><i class="fa-solid fa-box-archive text-xl"></i></div>
                    </div>
                </div>

                <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl shadow-lg space-y-4">
                    <h3 class="text-xs font-black text-white uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-chart-column text-amber-500"></i> Quản Lý Phân Quyền, Chỉnh Sửa & Bãi Nhiệm Tài Khoản Cán Bộ</h3>
                    <div id="admin-analytics-list" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4"></div>
                </div>

                <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl shadow-lg space-y-3">
                    <h3 class="text-xs font-black text-white uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-vault text-purple-400"></i> Toàn Văn Kho Lưu Trữ Dữ Liệu Quốc Gia (Đặc quyền tối cao Admin)</h3>
                    <div id="admin-vault-list" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 text-xs"></div>
                </div>

                <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
                    <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl space-y-3.5 text-xs shadow-lg">
                        <h3 id="form-provision-title" class="text-xs font-black text-purple-400 uppercase tracking-wider border-b border-slate-800 pb-2"><i class="fa-solid fa-id-card-clip"></i> Thiết Lập / Phân Quyền Nhân Sự Quốc Gia</h3>
                        <form onsubmit="provisionAccount(event)" class="space-y-2.5">
                            <input type="hidden" id="p-isEdit" value="false">
                            <div class="grid grid-cols-2 gap-2">
                                <div><label class="text-gray-400 block mb-1">Tên Đăng Nhập</label><input type="text" id="p-user" required class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white font-mono"></div>
                                <div><label class="text-gray-400 block mb-1">Mật Mã</label><input type="text" id="p-pass" required class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white"></div>
                            </div>
                            <div><label class="text-gray-400 block mb-1">Họ Tên / Cấp Bậc Chức Danh</label><input type="text" id="p-name" required placeholder="Thượng Tá Nguyễn Văn B" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white"></div>
                            <div class="grid grid-cols-2 gap-2">
                                <div>
                                    <label class="text-gray-400 block mb-1">Quyền Hạn Hệ Thống</label>
                                    <select id="p-role" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white font-bold">
                                        <option value="CÁN BỘ">CÁN BỘ TIẾP NHẬN</option>
                                        <option value="LÃNH ĐẠO">LÃNH ĐẠO ĐƠN VỊ</option>
                                        <option value="THANH TRA">THANH TRA CHÍNH PHỦ</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="text-gray-400 block mb-1">Đơn Vị Ban Ngành</label>
                                    <select id="p-agency" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white font-bold">
                                        <option value="CÔNG AN">CÔNG AN</option>
                                        <option value="QUÂN ĐỘI">QUÂN ĐỘI</option>
                                        <option value="UBND PHƯỜNG">UBND PHƯỜNG</option>
                                        <option value="TOÀ ÁN">TOÀ ÁN</option>
                                        <option value="NGÂN HÀNG">NGÂN HÀNG</option>
                                        <option value="BỆNH VIỆN">BỆNH VIỆN</option>
                                        <option value="THANH TRA">THANH TRA CHÍNH PHỦ</option>
                                        <option value="CHÍNH PHỦ">VĂN PHÒNG CHÍNH PHỦ</option>
                                    </select>
                                </div>
                            </div>
                            <div class="flex gap-2">
                                <button type="button" id="btn-cancel-edit" onclick="resetProvisionForm()" class="bg-slate-800 text-slate-400 font-bold px-3 rounded-lg uppercase text-[11px] hidden">Hủy</button>
                                <button type="submit" id="btn-submit-provision" class="flex-1 bg-purple-600 text-white font-black py-2.5 rounded-lg uppercase shadow-md">Kích Hoạt Tài Khoản</button>
                            </div>
                        </form>
                    </div>

                    <div class="xl:col-span-2 bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl flex flex-col h-full shadow-lg">
                        <h3 class="text-xs font-black text-red-400 uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-terminal mr-1 text-xs animate-pulse"></i> Nhật Ký Hệ Thống Giả Lập Thời Gian Thực</h3>
                        <div id="admin-system-logs" class="flex-1 space-y-2 mt-3 font-mono text-[11px] overflow-y-auto max-h-[280px] bg-black/60 p-3 rounded-xl border border-slate-900 shadow-inner"></div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <footer class="mt-12 bg-[#060a14] border-t-2 border-red-900/60 py-6 px-6 text-center shadow-inner">
        <div class="max-w-4xl mx-auto space-y-2">
            <div class="flex justify-center items-center gap-2 text-red-500 font-black tracking-widest text-[11px] uppercase">
                <i class="fa-solid fa-triangle-exclamation animate-pulse"></i> CẢNH BÁO BẢO MẬT & ĐIỀU KHOẢN PHÁP LÝ NHẬP VAI <i class="fa-solid fa-triangle-exclamation animate-pulse"></i>
            </div>
            <p class="text-xs text-red-400/80 font-bold leading-relaxed tracking-wide uppercase">Đây là trang web giả lập không có thực, phục vụ độc quyền kịch bản tương tác nhập vai (Roleplay) giải trí trên Roblox.</p>
            <p class="text-[11px] text-slate-500 leading-relaxed font-medium">Mọi thông tin định danh cư dân, văn bản số hóa, quyết định xử lý, con dấu điện tử, khiếu nại tư pháp trên website này hoàn toàn là hư cấu do người chơi biên soạn, không có bất kỳ giá trị pháp lý thực tế nào đối với các cơ quan chức năng của nước Cộng hòa Xã hội Chủ nghĩa Việt Nam.</p>
            <div class="text-[10px] text-slate-600 font-mono pt-1">&copy; 2026 Gaming Simulator Project. Powered by Co-op Coding Sandbox. All rights reserved.</div>
        </div>
    </footer>

    <div id="login-modal" class="fixed inset-0 bg-black/90 backdrop-blur-md flex items-center justify-center hidden p-4 z-50">
        <div class="bg-[#0a0f1d] border border-slate-800 p-6 rounded-2xl max-w-sm w-full space-y-4 text-xs shadow-2xl relative">
            <div class="text-center space-y-1">
                <i class="fa-solid fa-key text-3xl text-amber-500 mb-1"></i>
                <h3 class="text-sm font-black text-white uppercase tracking-widest">Mã Hóa Chứng Thư Nghiệp Vụ</h3>
            </div>
            <div><label class="text-gray-400 block mb-1 font-bold">Mã Tài Khoản Định Danh</label><input type="text" id="log-user" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-mono focus:outline-none"></div>
            <div><label class="text-gray-400 block mb-1 font-bold">Mật Mã Hệ Thống</label><input type="password" id="log-pass" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white focus:outline-none"></div>
            <div class="flex gap-2 pt-2">
                <button onclick="closeLogin()" class="w-1/3 bg-slate-800 text-slate-400 py-2 rounded-lg uppercase font-black">Đóng</button>
                <button onclick="login()" class="w-2/3 bg-gradient-to-r from-amber-400 to-amber-500 text-black py-2 rounded-lg uppercase font-black">Xác Minh</button>
            </div>
        </div>
    </div>

    <script>
        let state = <%- JSON.stringify(state) %>;
        let registry = <%- JSON.stringify(registry) %>;
        let activeUser = null;
        let activeFileId = null;
        
        let lastAppCount = 0;
        let lastNotificationTargetId = null; // Lưu ID hồ sơ mới nhất để bấm chuông thông báo nhảy tới luôn

        function startClock() {
            setInterval(() => {
                document.getElementById('clock').innerText = new Date().toLocaleTimeString('vi-VN');
            }, 1000);
        }

        async function syncState() {
            const res = await fetch('/api/state');
            const data = await res.json();
            state = data.systemState;
            registry = data.citizenIdentityRegistry;
            
            // Đảm bảo sau khi F5, nếu session lưu activeUser vẫn tồn tại trên client thì map lại thông tin mới nhất từ server
            if (activeUser) {
                activeUser = state.authorizedPersonnel[activeUser.username];
                renderAuth();
            }
            
            checkRealtimeNotifications();
            renderAll();
        }

        // BẤM VÀO THÔNG BÁO TỰ ĐỘNG CHUYỂN TAB VÀ TRUY XUẤT THẨM ĐỊNH NGAY LẬP TỨC
        function jumpToActiveNotification() {
            if (!activeUser || !lastNotificationTargetId) return;
            tab('tab-officer');
            selectFile(lastNotificationTargetId);
            document.getElementById('officer-alert-light').classList.add('hidden');
        }

        // KIỂM TRA THÔNG BÁO THỜI GIAN THỰC THEO PHÂN QUYỀN ĐƠN VỊ
        function checkRealtimeNotifications() {
            if (!activeUser) {
                document.getElementById('officer-alert-light').classList.add('hidden');
                return;
            }

            // Lọc ra các đơn thư thuộc thẩm quyền của tài khoản đang đăng nhập
            let filtered = Object.values(state.applications).filter(a => {
                if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ') return true;
                return a.agency === activeUser.agency;
            });

            const alertBox = document.getElementById('officer-alert-light');
            const badgeCount = document.getElementById('badge-count-app');

            if (filtered.length > 0) {
                badgeCount.innerText = filtered.length;
                badgeCount.classList.remove('hidden');
                
                // Lấy ID hồ sơ mới nhất phục vụ tính năng click nhảy nhanh
                let latestApp = filtered[filtered.length - 1];
                lastNotificationTargetId = latestApp.id;
            } else {
                badgeCount.classList.add('hidden');
            }

            if (filtered.length > lastAppCount) {
                alertBox.classList.remove('hidden');
            }
            lastAppCount = filtered.length;
        }

        function tab(id) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            document.getElementById(id).classList.remove('hidden');
            document.querySelectorAll('nav border-b-2').forEach(b => b.className = b.className.replace('border-amber-500 text-amber-500', 'border-transparent text-slate-400'));
            
            document.querySelectorAll('nav button').forEach(b => {
                b.classList.remove('border-amber-500', 'text-amber-500');
                b.classList.add('border-transparent', 'text-slate-400');
            });
            const btn = document.getElementById(`btn-${id}`);
            if(btn) {
                btn.classList.remove('border-transparent', 'text-slate-400');
                btn.classList.add('border-amber-500', 'text-amber-500');
            }

            if (id === 'tab-officer') {
                document.getElementById('officer-alert-light').classList.add('hidden');
            }
            
            // Lưu tab hiện tại vào sessionStorage đề phòng F5 reload trang
            sessionStorage.setItem('activeTab', id);
        }

        function renderAll() {
            document.getElementById('live-marquee').innerText = state.tickerMessage;

            const feed = document.getElementById('news-feed');
            feed.innerHTML = '';
            state.announcements.forEach(a => {
                let deleteBtn = (activeUser && (activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN')) ? 
                    `<button onclick="deleteNews('${a.id}')" class="text-[10px] text-red-400 hover:underline font-bold"><i class="fa-solid fa-trash-can"></i> Gỡ</button>` : '';

                feed.innerHTML += `
                    <div class="bg-[#0a0f1d] border border-slate-800 p-4 rounded-xl relative shadow-md">
                        <div class="flex justify-between items-center"><span class="text-[9px] font-black text-amber-500 uppercase bg-amber-950 px-2 py-0.5 rounded border border-amber-800">${a.type}</span>${deleteBtn}</div>
                        <h4 class="text-sm font-black text-white mt-1.5">${a.title}</h4>
                        <p class="text-xs text-slate-400 whitespace-pre-wrap mt-1 leading-relaxed">${a.content}</p>
                        <div class="text-[10px] text-slate-500 mt-2 font-mono"><i class="fa-solid fa-stamp text-amber-600"></i> Ban hành hệ thống: ${a.timestamp}</div>
                    </div>
                `;
            });

            const wanted = document.getElementById('wanted-feed');
            wanted.innerHTML = '';
            state.criminalWantedList.forEach(c => {
                wanted.innerHTML += `
                    <div class="bg-red-950/10 border border-red-900/50 p-3 rounded-xl relative overflow-hidden">
                        <p class="text-xs text-red-400 font-black"><i class="fa-solid fa-bullseye animate-pulse"></i> TRUY NÃ: @${c.name}</p>
                        <p class="text-xs text-slate-300 mt-0.5">Tội danh: ${c.crime}</p>
                        <p class="text-xs text-yellow-500 font-extrabold mt-1.5 font-mono">Bounty: ${c.bounty} - [${c.date}]</p>
                    </div>
                `;
            });

            // GIAO DIỆN BÀN LÀM VIỆC CÓ PHÂN QUYỀN BẢO MẬT BỘ NGÀNH CHẶT CHẼ
            if (activeUser) {
                document.getElementById('office-badge').innerText = `ĐƠN VỊ CHỦ QUẢN: [${activeUser.agency}] — CÁN BỘ THẨM ĐỊNH: ${activeUser.displayName} [${activeUser.role}]`;
                const tbody = document.getElementById('officer-table');
                tbody.innerHTML = '';
                
                // Gộp chung cả đơn đang hoạt động để Cán bộ thẩm duyệt
                Object.values(state.applications).forEach(app => {
                    // PHÂN QUYỀN XEM HỒ SƠ: Chỉ đơn vị nhận đơn, hoặc ADMIN, hoặc THANH TRA CHÍNH PHỦ mới được nhìn thấy hồ sơ!
                    if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ' || app.agency === activeUser.agency) {
                        tbody.innerHTML += `
                            <tr class="hover:bg-slate-900/60 border-b border-slate-800 text-xs transition-all">
                                <td class="p-3 font-black font-mono text-amber-500">${app.id}</td>
                                <td class="p-3 font-medium">@${app.sender}</td>
                                <td class="p-3"><span class="bg-slate-800 text-slate-300 px-2 py-0.5 rounded border border-slate-700 text-[10px] font-bold">${app.docType}</span></td>
                                <td class="p-3 font-black"><span class="text-amber-400">${app.status}</span></td>
                                <td class="p-3 text-right"><button onclick="selectFile('${app.id}')" class="bg-emerald-600 hover:bg-emerald-700 font-bold text-white px-3 py-1 rounded-md text-[11px]">Thẩm Định / Xem</button></td>
                            </tr>
                        `;
                    }
                });

                // KHO LƯU TRỮ DÀNH CHO LÃNH ĐẠO / CHÍNH PHỦ XEM LẠI VÀ KHÔI PHỤC TRẢ LẠI
                const leadArch = document.getElementById('leader-archive-list');
                if(leadArch) {
                    leadArch.innerHTML = '';
                    Object.values(state.archivedApplications).forEach(ar => {
                        if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ' || ar.agency === activeUser.agency) {
                            leadArch.innerHTML += `
                                <div class="bg-slate-900 p-2 rounded-lg border border-slate-800 flex justify-between items-center text-[11px]">
                                    <div><b class="text-purple-400 font-mono">${ar.id}</b> - @${ar.sender} (${ar.docType})</div>
                                    <button onclick="selectFile('${ar.id}')" class="text-[10px] bg-purple-900 text-white px-2 py-0.5 rounded hover:bg-purple-800 font-bold">Mở xem lại</button>
                                </div>
                            `;
                        }
                    });
                }
            }

            document.getElementById('st-staff').innerText = Object.keys(state.authorizedPersonnel).length - 1;
            document.getElementById('st-files').innerText = Object.keys(state.archivedApplications).length;
            
            const logBox = document.getElementById('admin-system-logs');
            if(logBox) {
                logBox.innerHTML = '';
                state.systemLogs.forEach(l => {
                    logBox.innerHTML += `<div class="py-1 border-b border-slate-900"><span class="text-amber-400 font-bold">[${l.time}]</span> <span class="text-slate-300">${l.text}</span></div>`;
                });
            }

            // KHO LƯU TRỮ QUỐC GIA CỦA PHÒNG GIÁM SÁT TOÀN QUỐC (ADMIN)
            const adminVault = document.getElementById('admin-vault-list');
            if(adminVault) {
                adminVault.innerHTML = '';
                Object.values(state.archivedApplications).forEach(ar => {
                    adminVault.innerHTML += `
                        <div class="bg-slate-900/90 border border-slate-800 p-3 rounded-xl flex justify-between items-start">
                            <div>
                                <p class="font-mono font-black text-purple-400">${ar.id}</p>
                                <p class="text-slate-300 mt-0.5">Chủ quản cư dân: <b>@${ar.sender}</b></p>
                                <span class="text-[10px] bg-slate-950 text-amber-500 px-1 py-0.5 rounded font-mono">${ar.docType}</span>
                            </div>
                            <button onclick="selectFile('${ar.id}')" class="text-[10px] bg-purple-600 text-white font-black px-2 py-1 rounded hover:bg-purple-700 uppercase">Mở xem lại</button>
                        </div>
                    `;
                });
            }

            const analytics = document.getElementById('admin-analytics-list');
            analytics.innerHTML = '';
            Object.values(state.authorizedPersonnel).forEach(u => {
                if (u.username !== 'admin') {
                    let totalRatings = u.positiveRatings + u.negativeRatings;
                    let positivePercentage = totalRatings > 0 ? Math.round((u.positiveRatings / totalRatings) * 100) : 0;
                    
                    analytics.innerHTML += `
                        <div class="bg-slate-900/80 p-3.5 rounded-xl border border-slate-800 text-xs space-y-2">
                            <div class="flex justify-between font-black text-white border-b border-slate-800 pb-1.5">
                                <span>${u.displayName} <span class="text-slate-500 font-mono text-[10px]">(@${u.username})</span></span>
                                <span class="text-purple-400 text-[10px] uppercase bg-purple-950 px-1.5 rounded border border-purple-800">${u.agency} - ${u.role}</span>
                            </div>
                            <div class="text-[11px] text-slate-400 font-mono">Mật khẩu số hóa: <span class="text-amber-400">${u.password}</span></div>
                            <div class="flex justify-between text-[11px] text-slate-400 font-mono"><span>Tín nhiệm phục vụ: <b class="text-emerald-400">${positivePercentage}%</b></span><span>👍${u.positiveRatings} | 👎${u.negativeRatings}</span></div>
                            <div class="flex gap-2 pt-1 border-t border-slate-800/60">
                                <button onclick="editOfficer('${u.username}')" class="flex-1 bg-sky-600 hover:bg-sky-700 text-white font-bold py-1 rounded text-[10px] uppercase"><i class="fa-solid fa-user-gear"></i> Phân Quyền / Sửa</button>
                                <button onclick="deleteOfficer('${u.username}')" class="bg-red-600 hover:bg-red-700 text-white font-bold px-2 py-1 rounded text-[10px] uppercase"><i class="fa-solid fa-trash"></i> Xóa</button>
                            </div>
                        </div>
                    `;
                }
            });
        }

        function editOfficer(username) {
            let u = state.authorizedPersonnel[username];
            if(!u) return;
            document.getElementById('p-user').value = u.username;
            document.getElementById('p-user').readOnly = true;
            document.getElementById('p-pass').value = u.password;
            document.getElementById('p-name').value = u.displayName;
            document.getElementById('p-role').value = u.role;
            document.getElementById('p-agency').value = u.agency;
            document.getElementById('p-isEdit').value = "true";
            
            document.getElementById('form-provision-title').innerHTML = `<i class="fa-solid fa-user-gear text-sky-400"></i> Hiệu chỉnh & Phân Quyền Cán Bộ`;
