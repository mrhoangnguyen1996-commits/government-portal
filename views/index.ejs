                        <button onclick="citizenChat('${app.id}')" class="bg-amber-500 font-black text-black px-4 text-xs rounded-xl uppercase">Gửi</button>
                    </div>
                </div>
            `;
            setTimeout(() => { const el = document.getElementById('citizen-chat-flow'); if (el) el.scrollTop = el.scrollHeight; }, 50);
