        async function submitForm(e) {
            e.preventDefault();
            const sender = document.getElementById('app-sender').value.trim();
            const docType = document.getElementById('app-docType').value;
            const agency = document.getElementById('app-agency').value;
            const content = document.getElementById('app-content').value.trim();
            const res = await fetch('/api/applications/submit', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sender, agency, docType, content }) });
            const data = await res.json();
            document.getElementById('app-content').value = '';
            document.getElementById('track-id').value = data.id;
            soundSuccess(); trackApplication();
        }

        // ĐÀM THOẠI HÀI LÒNG TỰ ĐỘNG CHUYỂN GIAO LÃNH ĐẠO KÝ PHÊ DUYỆT HOÀN TOÀN TỰ ĐỘNG
        function trackApplication() {
            const id = document.getElementById('track-id').value.trim();
            const area = document.getElementById('track-details'); const empty = document.getElementById('track-empty');
            let app = state.applications[id] || state.archivedApplications[id];
            if (!app) { area.classList.add('hidden'); empty.classList.remove('hidden'); return; }
            empty.classList.add('hidden'); area.classList.remove('hidden');

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-slate-900/90 p-2.5 rounded border border-slate-800 text-[11px]"><p class="text-[9px] font-black text-gray-500">${l.sender} • ${l.time}</p><p class="text-white mt-0.5">${l.msg}</p></div>`;
            });

            let satBlock = '';
            if ((app.status === 'Đã Phê Duyệt' || app.status === 'Bị Bác Bỏ') && !app.satisfaction) {
                satBlock = `
                    <div class="space-y-2 p-3 bg-slate-950 border border-slate-800 rounded-xl text-center">
                        <p class="text-[10px] text-slate-400 font-bold uppercase">Xác thực kết quả phục vụ công vụ của Bộ ngành</p>
                        <div class="flex gap-2 justify-center">
                            <button onclick="acceptAndLockApplication('${id}', 'HÀI LÒNG')" class="bg-emerald-600 text-white font-black px-4 py-1.5 rounded text-[10px] uppercase shadow-sm hover:bg-emerald-500">Đồng ý kết quả & Đóng hồ sơ 👍</button>
                            <button onclick="sendAction('${id}', 'satisfaction', 'KHIẾU NẠI CẤP CAO')" class="bg-red-600 text-white font-black px-4 py-1.5 rounded text-[10px] uppercase shadow-sm hover:bg-red-500">🚨 ĐƠN KHIẾU NẠI KHẨN 🚨</button>
                        </div>
                    </div>
                `;
            } else if (app.satisfaction) {
                satBlock = `<div class="text-center text-[10px] font-black uppercase text-amber-500 bg-slate-950 p-2.5 rounded-lg border border-slate-800 tracking-wider">Mức độ phản hồi dân cư: [${app.satisfaction}]</div>`;
            }

            area.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3 max-h-[320px] pr-1">
                    <div class="bg-slate-950 p-3 rounded-xl border border-slate-800 flex justify-between items-center shadow-md">
                        <div><p class="font-black text-amber-500 text-xs">${app.id} [${app.docType}]</p><p class="text-[9px] text-slate-500 font-mono mt-0.5">Đơn vị thụ lý: ${app.agency}</p></div>
                        <div class="stamp-box ${app.stamp}">${app.status}</div>
                    </div>
                    <div class="space-y-2" id="citizen-chat-flow">${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-slate-800 space-y-2">
                    ${satBlock}
                    <div class="flex gap-2">
                        <input type="text" id="citizen-chat-msg" placeholder="Nhập văn bản đàm thoại trực tuyến..." class="flex-1 bg-slate-900 border border-slate-700 p-2.5 text-xs text-white rounded-lg focus:outline-none">
                        <button onclick="citizenChat('${app.id}')" class="bg-amber-500 font-black text-black px-5 text-xs rounded-lg uppercase transition-colors hover:bg-amber-600">Gửi</button>
                    </div>
                </div>
            `;
            setTimeout(() => { const el = document.getElementById('citizen-chat-flow'); if (el) el.scrollTop = el.scrollHeight; }, 50);
        }

        async function acceptAndLockApplication(id, status) {
            soundSuccess();
            // Đóng hồ sơ, tự động chuyển giao lên cấp Lãnh đạo cao ban ngành xem xét ký đóng kho vĩnh viễn
            await fetch('/api/applications/action', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id, action: 'satisfaction', status: 'HÀI LÒNG' })
            });
            await fetch('/api/applications/action', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id, action: 'to_leader', officerName: "Hệ thống tự động liên thông" })
            });
            trackApplication();
            alert(`Hồ sơ đã được công dân đồng thuận đóng tự động và chuyển thẳng lên cấp Lãnh Đạo đơn vị ký niêm phong đóng kho!`);
        }

