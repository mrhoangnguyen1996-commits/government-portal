    <script>
        let state = <%- JSON.stringify(state) %>;
        let registry = <%- JSON.stringify(registry) %>;
        let activeUser = null;
        let activeFileId = null;
        let totalAppsSnapshot = 0; // Lưu số lượng đơn để theo dõi thông báo mới
        let totalLogsLengthSnapshot = {}; // Đếm số dòng chat để nhận biết tin nhắn mới

        function startClock() {
            setInterval(() => {
                document.getElementById('clock').innerText = new Date().toLocaleTimeString('vi-VN');
            }, 1000);
        }

        async function syncState() {
            const res = await fetch('/api/state');
            const data = await res.json();
            state = data.systemState;
            registry = data.citizenIdentityRegistry;
            
            checkNewAlertsNotifications();
            renderAll();
        }

        // KIỂM TRA ĐƠN THƯ HOẶC TIN NHẮN MỚI CỦA CÔNG DÂN GỬI ĐẾN ĐỂ BẬT ĐÈN NHẤP NHÁY
        function checkNewAlertsNotifications() {
            if (!activeUser) {
                document.getElementById('officer-alert-light').classList.add('hidden');
                return;
            }

            let currentAgencyApps = Object.values(state.applications).filter(a => a.agency === activeUser.agency || activeUser.role === 'ADMIN');
            let currentAppCount = currentAgencyApps.length;
            
            // 1. Cảnh báo số lượng đơn thư thay đổi hoặc tăng
            let hasNewMsg = false;
            
            // 2. Cảnh báo nếu có hội thoại chat mới từ công dân
            currentAgencyApps.forEach(app => {
                let lastLog = app.logs[app.logs.length - 1];
                if (lastLog && lastLog.sender.includes('Công Dân')) {
                    // Nếu dòng cuối cùng là của Công dân và số lượng log tăng lên so với snapshot cũ
                    if (!totalLogsLengthSnapshot[app.id] || app.logs.length > totalLogsLengthSnapshot[app.id]) {
                        hasNewMsg = true;
                    }
                }
                // Cập nhật snapshot chiều dài hội thoại ẩn
                totalLogsLengthSnapshot[app.id] = app.logs.length;
            });

            const alertBox = document.getElementById('officer-alert-light');
            const alertText = document.getElementById('alert-light-text');
            const badgeCount = document.getElementById('badge-count-app');

            if (currentAppCount > 0) {
                badgeCount.innerText = currentAppCount;
                badgeCount.classList.remove('hidden');
            } else {
                badgeCount.classList.add('hidden');
            }

            if (currentAppCount > totalAppsSnapshot || hasNewMsg) {
                alertBox.classList.remove('hidden');
                alertText.innerText = hasNewMsg ? "CÓ TIN NHẮN MỚI TỪ CÔNG DÂN" : "CÓ HỒ SƠ MỚI CHỜ DUYỆT";
            }
            
            totalAppsSnapshot = currentAppCount;
        }

        function tab(id) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            document.getElementById(id).classList.remove('hidden');
            document.querySelectorAll('nav button').forEach(b => b.className = b.className.replace('border-amber-500 text-amber-500', 'border-transparent text-slate-400'));
            const btn = document.getElementById(`btn-${id}`);
            if(btn) btn.className = btn.className.replace('border-transparent text-slate-400', 'border-amber-500 text-amber-500');

            // Tắt đèn cảnh báo khi Cán bộ đã click vào bàn làm việc để kiểm tra đơn
            if (id === 'tab-officer') {
                document.getElementById('officer-alert-light').classList.add('hidden');
            }
        }

        function renderAll() {
            document.getElementById('live-marquee').innerText = state.tickerMessage;

            const feed = document.getElementById('news-feed');
            feed.innerHTML = '';
            state.announcements.forEach(a => {
                let deleteBtn = (activeUser && (activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN')) ? 
                    `<button onclick="deleteNews('${a.id}')" class="text-[10px] text-red-400 hover:underline font-bold"><i class="fa-solid fa-trash-can"></i> Gỡ văn bản</button>` : '';

                feed.innerHTML += `
                    <div class="bg-[#0a0f1d] border border-slate-800 p-4 rounded-xl relative shadow-md">
                        <div class="flex justify-between items-center"><span class="text-[9px] font-black text-amber-500 uppercase bg-amber-950/60 border border-amber-800 px-2 py-0.5 rounded">${a.type}</span>${deleteBtn}</div>
                        <h4 class="text-sm font-black text-white mt-1.5">${a.title}</h4>
                        <p class="text-xs text-slate-400 whitespace-pre-wrap mt-1 leading-relaxed">${a.content}</p>
                        <div class="text-[10px] text-slate-500 mt-2 font-mono flex items-center gap-1"><i class="fa-solid fa-stamp text-amber-600"></i> Khắc dấu ban hành quốc gia: ${a.timestamp}</div>
                    </div>
                `;
            });

            const wanted = document.getElementById('wanted-feed');
            wanted.innerHTML = '';
            state.criminalWantedList.forEach(c => {
                wanted.innerHTML += `
                    <div class="bg-red-950/10 border border-red-900/50 p-3 rounded-xl shadow-inner relative overflow-hidden">
                        <div class="absolute right-[-15px] bottom-[-5px] text-red-800/10 text-4xl font-black uppercase tracking-tighter">WANTED</div>
                        <p class="text-xs text-red-400 font-black"><i class="fa-solid fa-bullseye animate-pulse"></i> TRUY NÃ: @${c.name}</p>
                        <p class="text-xs text-slate-300 mt-0.5">Tội danh: ${c.crime}</p>
                        <p class="text-xs text-yellow-500 font-extrabold mt-1.5 font-mono">Bounty: ${c.bounty}</p>
                    </div>
                `;
            });

            if (activeUser) {
                document.getElementById('office-badge').innerText = `BAN TIẾP NHẬN: BỘ [${activeUser.agency}] — CHỨC DANH: ${activeUser.displayName} [${activeUser.role}]`;
                const tbody = document.getElementById('officer-table');
                tbody.innerHTML = '';
                
                Object.values(state.applications).forEach(app => {
                    if (app.agency === activeUser.agency || activeUser.role === 'ADMIN') {
                        tbody.innerHTML += `
                            <tr class="hover:bg-slate-900/60 border-b border-slate-800 text-xs transition-all">
                                <td class="p-3 font-black font-mono text-amber-500">${app.id}</td>
                                <td class="p-3 font-medium">@${app.sender}</td>
                                <td class="p-3"><span class="bg-slate-800 text-slate-300 px-2 py-0.5 rounded border border-slate-700 text-[10px] font-bold">${app.docType}</span></td>
                                <td class="p-3 font-black text-slate-400">${app.status}</td>
                                <td class="p-3 text-right"><button onclick="selectFile('${app.id}')" class="bg-emerald-600 hover:bg-emerald-700 font-bold text-white px-3 py-1 rounded-md text-[11px]">Thẩm Định</button></td>
                            </tr>
                        `;
                    }
                });

                const leadArch = document.getElementById('leader-archive-list');
                if(leadArch) {
                    leadArch.innerHTML = '';
                    Object.values(state.archivedApplications).forEach(ar => {
                        if (ar.agency === activeUser.agency || activeUser.role === 'ADMIN') {
                            leadArch.innerHTML += `
                                <div class="bg-slate-900 p-2 rounded-lg border border-slate-800 flex justify-between items-center text-[11px]">
                                    <div><b class="text-purple-400 font-mono">${ar.id}</b> - Cư dân: @${ar.sender} (${ar.docType})</div>
                                    <button onclick="selectFile('${ar.id}')" class="text-[10px] bg-purple-950 text-purple-300 border border-purple-800 px-2 py-0.5 rounded hover:bg-purple-900 font-bold">Mở xem lại</button>
                                </div>
                            `;
                        }
                    });
                }
            }

            document.getElementById('st-staff').innerText = Object.keys(state.authorizedPersonnel).length - 1;
            document.getElementById('st-files').innerText = Object.keys(state.archivedApplications).length;
            
            const logBox = document.getElementById('admin-system-logs');
            if(logBox) {
                logBox.innerHTML = '';
                state.systemLogs.forEach(l => {
                    logBox.innerHTML += `<div class="py-1 border-b border-slate-900/60"><span class="text-amber-500 font-bold">[${l.time}]</span> <span class="text-slate-300">${l.text}</span></div>`;
                });
            }

            const adminVault = document.getElementById('admin-vault-list');
            if(adminVault) {
                adminVault.innerHTML = '';
                Object.values(state.archivedApplications).forEach(ar => {
                    adminVault.innerHTML += `
                        <div class="bg-slate-900/90 border border-slate-800 p-3 rounded-xl flex justify-between items-start">
                            <div>
                                <p class="font-mono font-black text-purple-400">${ar.id}</p>
                                <p class="text-slate-300 mt-0.5">Chủ quản: <b>@${ar.sender}</b></p>
                                <span class="text-[10px] bg-slate-950 text-amber-500 px-1 py-0.5 rounded font-mono">${ar.docType}</span>
                            </div>
                            <button onclick="selectFile('${ar.id}')" class="text-[10px] bg-purple-600 text-white font-black px-2 py-1 rounded hover:bg-purple-700 uppercase">Mở xem lại</button>
                        </div>
                    `;
                });
            }

            // ADMIN ĐỘC QUYỀN SỬA, PHÂN QUYỀN VÀ XÓA TÀI KHOẢN CÁN BỘ
            const analytics = document.getElementById('admin-analytics-list');
            analytics.innerHTML = '';
            Object.values(state.authorizedPersonnel).forEach(u => {
                if (u.username !== 'admin') {
                    let totalRatings = u.positiveRatings + u.negativeRatings;
                    let positivePercentage = totalRatings > 0 ? Math.round((u.positiveRatings / totalRatings) * 100) : 0;
                    
                    analytics.innerHTML += `
                        <div class="bg-slate-900/80 p-3.5 rounded-xl border border-slate-800 text-xs space-y-2">
                            <div class="flex justify-between font-black text-white border-b border-slate-800 pb-1.5">
                                <span>${u.displayName} <span class="text-slate-500 font-mono text-[10px]">(@${u.username})</span></span>
                                <span class="text-purple-400 text-[10px] uppercase bg-purple-950 px-1.5 rounded border border-purple-800">${u.agency} - ${u.role}</span>
                            </div>
                            <div class="text-[11px] text-slate-400 font-mono">Khóa mật khẩu: <span class="text-amber-400">${u.password}</span></div>
                            <div class="flex justify-between text-[11px] text-slate-400 font-mono"><span>Tín nhiệm: <b class="text-emerald-400">${positivePercentage}%</b></span><span>👍${u.positiveRatings} | 👎${u.negativeRatings}</span></div>
                            
                            <div class="flex gap-2 pt-1 border-t border-slate-800/60">
                                <button onclick="editOfficer('${u.username}')" class="flex-1 bg-sky-600 hover:bg-sky-700 text-white font-bold py-1 rounded text-[10px] uppercase"><i class="fa-solid fa-user-gear"></i> Chỉnh sửa/Phân quyền</button>
                                <button onclick="deleteOfficer('${u.username}')" class="bg-red-600 hover:bg-red-700 text-white font-bold px-2 py-1 rounded text-[10px] uppercase"><i class="fa-solid fa-trash"></i> Xóa</button>
                            </div>
                        </div>
                    `;
                }
            });
        }

        // ĐIỀU CHỈNH ĐIỀU HƯỚNG FORM SỬA NHÂN SỰ
        function editOfficer(username) {
            let u = state.authorizedPersonnel[username];
            if(!u) return;
            document.getElementById('p-user').value = u.username;
            document.getElementById('p-user').readOnly = true; // Không cho sửa username gốc
            document.getElementById('p-pass').value = u.password;
            document.getElementById('p-name').value = u.displayName;
            document.getElementById('p-role').value = u.role;
            document.getElementById('p-agency').value = u.agency;
            document.getElementById('p-isEdit').value = "true";
            
            document.getElementById('form-provision-title').innerHTML = `<i class="fa-solid fa-user-gear text-sky-400"></i> Hiệu chỉnh & Phân Quyền Cán Bộ`;
            document.getElementById('btn-submit-provision').innerText = "Cập Nhật Thay Đổi";
            document.getElementById('btn-cancel-edit').classList.remove('hidden');
        }

        function resetProvisionForm() {
            document.getElementById('p-user').value = '';
            document.getElementById('p-user').readOnly = false;
            document.getElementById('p-pass').value = '';
            document.getElementById('p-name').value = '';
            document.getElementById('p-isEdit').value = "false";
            
            document.getElementById('form-provision-title').innerHTML = `<i class="fa-solid fa-id-card-clip"></i> Cấp Chứng Thư / Tạo Nhân Sự Mới`;
            document.getElementById('btn-submit-provision').innerText = "Kích Hoạt Nhân Sự";
            document.getElementById('btn-cancel-edit').classList.add('hidden');
        }

        async function deleteOfficer(username) {
            if(!confirm(`Bạn có chắc chắn muốn bãi nhiệm và xóa tài khoản [${username}] khỏi máy chủ quốc gia?`)) return;
            await fetch('/api/officer/delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username })
            });
            await syncState();
        }

        async function registerResidentByOfficer(e) {
            e.preventDefault();
            const username = document.getElementById('res-user').value.trim();
            const name = document.getElementById('res-name').value.trim();
            const dob = document.getElementById('res-dob').value.trim();
            const gender = document.getElementById('res-gender').value;
            const pob = document.getElementById('res-pob').value.trim();
            const job = document.getElementById('res-job').value.trim();
            const licenses = document.getElementById('res-licenses').value.trim();
            const status = document.getElementById('res-status').value;

            await fetch('/api/resident/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, name, dob, gender, pob, job, licenses, status, officerName: activeUser.displayName })
            });
            
            document.getElementById('res-user').value = '';
            document.getElementById('res-name').value = '';
            document.getElementById('res-dob').value = '';
            document.getElementById('res-pob').value = '';
            document.getElementById('res-job').value = '';
            document.getElementById('res-licenses').value = '';
            
            alert(`Đã nhập liệu định danh cư dân @${username} thành công!`);
            await syncState();
        }

        async function submitForm(e) {
            e.preventDefault();
            const sender = document.getElementById('app-sender').value.trim();
            const docType = document.getElementById('app-docType').value;
            const agency = document.getElementById('app-agency').value;
            const content = document.getElementById('app-content').value.trim();

            const res = await fetch('/api/applications/submit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ sender, agency, docType, content })
            });
            const data = await res.json();
            document.getElementById('app-content').value = '';
            document.getElementById('track-id').value = data.id;
            await syncState();
            trackApplication();
        }

        function trackApplication() {
            const id = document.getElementById('track-id').value.trim();
            const area = document.getElementById('track-details');
            const empty = document.getElementById('track-empty');

            let app = state.applications[id] || state.archivedApplications[id];

            if (!app) {
                area.classList.add('hidden'); empty.classList.remove('hidden');
                return;
            }
            empty.classList.add('hidden'); area.classList.remove('hidden');

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-slate-900 p-2 rounded-lg border border-slate-800 text-[11px]"><p class="text-[9px] font-bold text-gray-400">${l.sender} • ${l.time}</p><p class="text-white mt-0.5">${l.msg}</p></div>`;
            });

            let satBlock = '';
            if ((app.status === 'Đã Phê Duyệt' || app.status === 'Bị Bác Bỏ') && !app.satisfaction) {
                satBlock = `
                    <div class="flex gap-2 justify-center py-2 bg-slate-900/60 border border-slate-800 rounded-xl">
                        <button onclick="sendAction('${id}', 'satisfaction', 'HÀI LÒNG')" class="bg-emerald-600 text-white font-black px-4 py-1 rounded text-[10px] uppercase">Hài Lòng 👍</button>
                        <button onclick="sendAction('${id}', 'satisfaction', 'KHIẾU NẠI')" class="bg-red-600 text-white font-black px-4 py-1 rounded text-[10px] uppercase">Khiếu Nại Kém 👎</button>
                    </div>
                `;
            } else if (app.satisfaction) {
                satBlock = `<div class="text-center text-[10px] font-black uppercase text-amber-500 bg-slate-900 p-2 rounded-lg border border-slate-800 tracking-wider">Đánh giá hiệu suất: [${app.satisfaction}]</div>`;
            }

            area.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3 max-h-[300px] pr-1">
                    <div class="bg-slate-900 p-3 rounded-xl border border-slate-800 flex justify-between items-center shadow-md">
                        <div>
                            <p class="font-black text-amber-500">${app.id} [${app.docType}]</p>
                            <p class="text-[11px] text-slate-300 mt-1">Nội dung: "${app.content}"</p>
                        </div>
                        <div class="stamp-box ${app.stamp}">${app.status}</div>
                    </div>
                    <div class="space-y-2"><p class="text-[10px] uppercase font-black text-slate-400 tracking-wider">Tiến Độ Xử Lý & Đối Thoại Số Hóa:</p>${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-slate-800 space-y-2">
                    ${satBlock}
                    <div class="flex gap-2">
                        <input type="text" id="citizen-chat-msg" placeholder="Phản hồi câu hỏi gửi cán bộ..." class="flex-1 bg-slate-900 border border-slate-700 p-2 text-xs text-white rounded-lg focus:outline-none">
                        <button onclick="citizenChat('${app.id}')" class="bg-amber-500 font-black text-black px-4 text-xs rounded-lg uppercase">Gửi</button>
                    </div>
                </div>
            `;
        }

        async function citizenChat(id) {
            const msg = document.getElementById('citizen-chat-msg').value.trim();
            if (!msg) return;
            await fetch('/api/applications/action', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id, action: 'chat', msg, officerName: `Công Dân (@${(state.applications[id] || state.archivedApplications[id]).sender})` })
            });
            await syncState();
            trackApplication();
        }

        function selectFile(id) {
            activeFileId = id;
            document.getElementById('officer-desk-empty').classList.add('hidden');
            const desk = document.getElementById('officer-desk-active');
            desk.classList.remove('hidden');
            
            // Nếu bấm xem từ tab nghiệp vụ thì tự động tắt thông báo cảnh báo nhấp nháy đi
            document.getElementById('officer-alert-light').classList.add('hidden');
            renderOfficerDesk();
        }

        function renderOfficerDesk() {
            let app = state.applications[activeFileId] || state.archivedApplications[activeFileId];
            const desk = document.getElementById('officer-desk-active');

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-slate-900 p-2 rounded border border-slate-800 text-[11px]"><p class="text-[9px] font-bold text-gray-400">${l.sender} • ${l.time}</p><p class="text-white mt-0.5">${l.msg}</p></div>`;
            });

            let residentProfileHtml = '';
            if (registry[app.sender]) {
                let r = registry[app.sender];
                residentProfileHtml = `
                    <div class="bg-amber-500/5 border border-amber-500/20 p-3 rounded-xl text-[11px] text-slate-300 space-y-1 relative">
                        <p class="text-amber-500 font-black uppercase text-[9px] tracking-wider"><i class="fa-solid fa-server"></i> Định danh cư dân hệ thống gốc:</p>
                        <p>Họ tên: <b class="text-white">${r.name}</b> | Sinh: <b>${r.dob}</b> | Giới tính: <b>${r.gender}</b></p>
                        <p>Nơi sinh: ${r.pob} | Nghề nghiệp: ${r.job}</p>
                        <p class="text-[10px] text-slate-400">Giấy tờ, chứng chỉ: <span class="text-amber-400">${r.licenses.join(', ')}</span></p>
                        <p class="text-emerald-400 font-black">Tư pháp: ${r.status}</p>
                    </div>
                `;
            } else {
                residentProfileHtml = `<div class="bg-red-950/20 border border-red-900/40 p-2.5 text-[10px] text-red-400 text-center rounded-xl font-bold">CẢNH BÁO: Cư dân chưa được định danh hành chính.</div>`;
            }

            let actionsHtml = '';
            // Cho phép hiển thị nút thao tác nếu hồ sơ chưa bị đóng hẳn hoàn toàn vào lưu trữ
            if (state.applications[activeFileId]) {
                let forwardLeaderBtn = (activeUser.role === 'CÁN BỘ' && app.status !== 'Đã Phê Duyệt' && app.status !== 'Bị Bác Bỏ') ? 
                    `<button onclick="sendAction('${app.id}', 'to_leader')" class="w-full bg-purple-600 hover:bg-purple-700 text-white font-black py-1.5 rounded-lg text-[11px] uppercase shadow-md"><i class="fa-solid fa-paper-plane"></i> Trình Lên Lãnh Đạo Ký</button>` : '';

                let archiveBtn = '';
                if (app.satisfaction) {
                    archiveBtn = `<button onclick="sendAction('${app.id}', 'archive')" class="w-full bg-gradient-to-r from-purple-600 to-indigo-600 text-white font-black py-2 rounded-lg text-[11px] uppercase tracking-wide shadow-md"><i class="fa-solid fa-box-archive"></i> Đóng Hồ Sơ & Chuyển Lưu Trữ Quốc Gia</button>`;
                }

                actionsHtml = `
                    <div class="grid grid-cols-2 gap-2">
                        <button onclick="sendAction('${app.id}', 'status', 'Đã Phê Duyệt', 'stamp-approved')" class="bg-emerald-600 hover:bg-emerald-700 text-white font-black py-1.5 rounded-lg text-[11px] uppercase">Phê Duyệt Đóng Dấu</button>
                        <button onclick="sendAction('${app.id}', 'status', 'Bị Bác Bỏ', 'stamp-rejected')" class="bg-red-600 hover:bg-red-700 text-white font-black py-1.5 rounded-lg text-[11px] uppercase">Bác Bỏ Đơn Thư</button>
                    </div>
                    ${forwardLeaderBtn}
                    ${archiveBtn}
                    <div>
                        <select onchange="sendAction('${app.id}', 'forward', '', '', this.value)" class="w-full bg-slate-900 border border-slate-700 p-1.5 text-[11px] text-white rounded-lg font-bold">
                            <option value="">-- Điều chuyển liên ngành --</option>
                            <option value="CÔNG AN">BỘ CÔNG AN</option>
                            <option value="QUÂN ĐỘI">BỘ CHỈ HUY QUÂN SỰ</option>
                            <option value="UBND PHƯỜNG">ỦY BAN NHÂN DÂN</option>
                            <option value="TOÀ ÁN">TÒA ÁN NHÂN DÂN</option>
                            <option value="NGÂN HÀNG">NGÂN HÀNG TRUNG ƯƠNG</option>
                            <option value="BỆNH VIỆN">BỆNH VIỆN LIÊN THÔNG</option>
                        </select>
                    </div>
                `;
            } else {
                // Nếu lấy ra từ Kho lưu trữ
                actionsHtml = `<div class="bg-purple-950/40 text-purple-400 p-2.5 rounded-xl border border-purple-800 text-center font-bold uppercase text-[10px] tracking-wider"><i class="fa-solid fa-box-archive"></i> Hồ sơ đang mở xem lại từ Kho lưu trữ Quốc Gia</div>`;
            }

            desk.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3.5 max-h-[350px] pr-1">
                    <div class="bg-slate-900 p-2.5 rounded-xl border border-slate-800 text-[11px] relative">
                        <div class="absolute top-2 right-2 stamp-box ${app.stamp}">${app.status}</div>
                        <p class="font-black text-amber-500">HỒ SƠ SỐ: ${app.id}</p>
                        <p class="text-slate-300 font-bold mt-1">Yêu cầu thủ tục: <span class="text-white">${app.docType}</span></p>
                        <p class="text-slate-400 italic mt-0.5">" ${app.content} "</p>
                    </div>
                    ${residentProfileHtml}
                    <div class="space-y-2 font-bold text-[9px] text-slate-400 uppercase tracking-wider">Lịch sử thẩm định đối thoại: ${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-slate-800 space-y-2">
                    ${actionsHtml}
                    <div class="flex gap-2">
                        <input type="text" id="officer-chat-msg" placeholder="Nhập câu hỏi, chỉ thị yêu cầu cư dân..." class="flex-1 bg-slate-900 border border-slate-700 p-2 text-xs text-white rounded-lg focus:outline-none">
                        <button onclick="officerChat()" class="bg-emerald-600 font-black text-white px-4 text-xs rounded-lg uppercase">Gửi</button>
                    </div>
                </div>
            `;
        }

        async function officerChat() {
            const msg = document.getElementById('officer-chat-msg').value.trim();
            if (!msg) return;
            await fetch('/api/applications/action', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: activeFileId, action: 'chat', msg, officerName: `${activeUser.displayName} (${activeUser.agency})` })
            });
            await syncState();
            renderOfficerDesk();
        }

        async function sendAction(id, action, status = '', stamp = '', targetAgency = '') {
            await fetch('/api/applications/action', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id, action, status, stamp, targetAgency, officerName: activeUser ? activeUser.displayName : 'Hệ thống Trực ban' })
            });
            await syncState();
            if (activeFileId === id) {
                if (action === 'forward' || action === 'to_leader' || action === 'archive') { 
                    activeFileId = null; 
                    document.getElementById('officer-desk-active').classList.add('hidden'); 
                    document.getElementById('officer-desk-empty').classList.remove('hidden'); 
                } else { 
                    renderOfficerDesk(); 
                }
            }
            if (document.getElementById('track-id').value === id) { trackApplication(); }
        }

        async function publishDocument() {
            const type = document.getElementById('pub-type').value;
            const title = document.getElementById('pub-title').value.trim();
            const content = document.getElementById('pub-content').value.trim();
            if(!title || !content) return;
            await fetch('/api/national/publish', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ type, title, content, author: activeUser.displayName }) });
            document.getElementById('pub-title').value = ''; document.getElementById('pub-content').value = '';
            await syncState();
        }

        async function updateTicker() {
            const msg = document.getElementById('pub-ticker').value.trim();
            if(!msg) return;
            await fetch('/api/national/ticker', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }) });
            document.getElementById('pub-ticker').value = '';
            await syncState();
        }

        async function deleteNews(id) {
            await fetch('/api/national/delete-announcement', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
            await syncState();
        }

        async function setSecurity(level) {
            await fetch('/api/national/security', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ level }) });
            await syncState();
        }

        async function provisionAccount(e) {
            e.preventDefault();
            const username = document.getElementById('p-user').value.trim();
            const password = document.getElementById('p-pass').value;
            const displayName = document.getElementById('p-name').value.trim();
            const role = document.getElementById('p-role').value;
            const agency = document.getElementById('p-agency').value;
            const isEdit = document.getElementById('p-isEdit').value === "true";

            await fetch('/api/officer/save', { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify({ username, password, displayName, role, agency, isEdit }) 
            });
            resetProvisionForm();
            await syncState();
        }

        function searchCitizen() {
            const q = document.getElementById('id-search').value.trim();
            const resArea = document.getElementById('id-result');
            if (registry[q]) {
                let r = registry[q];
                resArea.innerHTML = `
                    <div class="mt-4 p-4 bg-slate-900 border border-slate-700 rounded-xl text-xs space-y-2 shadow-inner">
                        <p class="text-sm font-black text-amber-500 border-b border-slate-800 pb-1">${r.name}</p>
                        <p>Ngày sinh: <b>${r.dob}</b> | Giới tính: <b>${r.gender}</b></p>
                        <p>Nơi sinh quản lý: <b>${r.pob}</b></p>
                        <p>Công tác chuyên môn: <b>${r.job}</b></p>
                        <p class="text-amber-400 font-bold">Giấy chứng nhận được cấp phép: ${r.licenses.join(' — ')}</p>
                        <p class="text-emerald-400 font-black">Tình trạng dân sự: ${r.status}</p>
                    </div>
                `;
            } else {
                resArea.innerHTML = `<p class="mt-4 text-center text-red-400 text-xs font-black">KHÔNG TÌM THẤY DỮ LIỆU ĐỊNH DANH TRÊN MÁY CHỦ.</p>`;
            }
        }

        function openLogin() { document.getElementById('login-modal').classList.remove('hidden'); }
        function closeLogin() { document.getElementById('login-modal').classList.add('hidden'); }
        
        function login() {
            const u = document.getElementById('log-user').value;
            const p = document.getElementById('log-pass').value;

            if (state.authorizedPersonnel[u] && state.authorizedPersonnel[u].password === p) {
                activeUser = state.authorizedPersonnel[u];
                closeLogin();
                document.getElementById('btn-tab-officer').classList.remove('hidden');
                if(activeUser.role === 'ADMIN') document.getElementById('btn-tab-admin').classList.remove('hidden');
                
                if(activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN') {
                    document.getElementById('leader-publish-zone').classList.remove('hidden');
                } else {
                    document.getElementById('leader-publish-zone').classList.add('hidden');
                }

                renderAuth(); renderAll(); tab('tab-officer');
            } else {
                alert("Mã bảo mật chứng thư nghiệp vụ sai!");
            }
        }

        function logout() {
            activeUser = null; activeFileId = null;
            document.getElementById('btn-tab-officer').classList.add('hidden');
            document.getElementById('btn-tab-admin').classList.add('hidden');
            document.getElementById('leader-publish-zone').classList.add('hidden');
            document.getElementById('officer-desk-active').classList.add('hidden');
            document.getElementById('officer-desk-empty').classList.remove('hidden');
            renderAuth(); renderAll(); tab('tab-news');
        }

        function renderAuth() {
            const p = document.getElementById('auth-panel');
            if(!activeUser) {
                p.innerHTML = `<button onclick="openLogin()" class="bg-gradient-to-r from-amber-400 to-amber-500 font-black text-black px-4 py-2 rounded-lg text-[11px] uppercase tracking-wider shadow-md"><i class="fa-solid fa-signature"></i> Đăng nhập nghiệp vụ</button>`;
            } else {
                p.innerHTML = `<div class="flex items-center gap-2.5 bg-slate-900/60 border border-slate-800 p-1 pr-3 rounded-xl"><div class="bg-amber-500 text-black font-black p-1.5 rounded-lg text-xs"><i class="fa-solid fa-user-tie"></i></div><div class="text-left"><p class="font-black text-white text-[11px]">${activeUser.displayName}</p><p class="text-[9px] text-amber-500 font-bold uppercase font-mono tracking-wider">${activeUser.role}</p></div><button onclick="logout()" class="text-slate-500 hover:text-red-400 text-sm ml-2"><i class="fa-solid fa-power-off"></i></button></div>`;
            }
        }

        function init() {
            startClock(); renderAuth(); renderAll();
            setInterval(syncState, 4000);
        }
        window.onload = init;
    </script>
</body>
</html>
