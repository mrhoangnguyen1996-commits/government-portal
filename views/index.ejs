        async function setSecurity(level) { await fetch('/api/national/security', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ level }) }); }
        
        async function provisionAccount(e) { 
            e.preventDefault(); const username = document.getElementById('p-user').value.trim(); const password = document.getElementById('p-pass').value; const displayName = document.getElementById('p-name').value.trim(); const role = document.getElementById('p-role').value; const agency = document.getElementById('p-agency').value; const isEdit = document.getElementById('p-isEdit').value === "true"; 
            await fetch('/api/officer/save', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, password, displayName, role, agency, isEdit }) });
            resetProvisionForm(); soundSuccess(); 
        }

        function searchCitizen() {
            const q = document.getElementById('id-search').value.trim(); const resArea = document.getElementById('id-result');
            if (registry[q]) {
                let r = registry[q]; soundSuccess();
                resArea.innerHTML = `
                    <div class="mt-4 p-4 bg-slate-900 border border-slate-700 rounded-xl text-xs space-y-2">
                        <p class="text-sm font-black text-amber-500 border-b border-slate-800 pb-1 uppercase">${r.name}</p>
                        <p>Giấy phép sở hữu hành chính: <span class="text-amber-400 font-bold font-mono">${r.licenses.join(' — ')}</span></p>
                        <p class="text-emerald-400 font-black">Tư pháp kịch bản: ${r.status}</p>
                    </div>
                `;
            } else { resArea.innerHTML = `<p class="mt-4 text-center text-red-400 text-xs font-black">KHÔNG TÌM THẤY DỮ LIỆU ĐỊNH DANH SỐ TRÊN MÁY CHỦ.</p>`; }
        }

        function openLogin() { document.getElementById('login-modal').classList.remove('hidden'); }
        function closeLogin() { document.getElementById('login-modal').classList.add('hidden'); }
        function login() { 
            const u = document.getElementById('log-user').value; const p = document.getElementById('log-pass').value;
            if (state.authorizedPersonnel[u] && state.authorizedPersonnel[u].password === p) { 
                activeUser = state.authorizedPersonnel[u]; localStorage.setItem('sessionUser', JSON.stringify({ username: u, password: p })); closeLogin(); soundSuccess(); applyUserRoleLayout();
            } else { alert("Sai chứng thư định danh cán bộ!"); } 
        }

        function applyUserRoleLayout() { 
            if(!activeUser) return;
            document.getElementById('btn-tab-officer').classList.remove('hidden'); 
            if(activeUser.role === 'ADMIN') document.getElementById('btn-tab-admin').classList.remove('hidden'); 
            renderAuth(); renderAll(); 
            let savedTab = sessionStorage.getItem('activeTab'); tab(savedTab || 'tab-officer');
        }

        function logout() { activeUser = null; activeFileId = null; localStorage.removeItem('sessionUser'); document.getElementById('btn-tab-officer').classList.add('hidden'); document.getElementById('btn-tab-admin').classList.add('hidden'); renderAuth(); tab('tab-news'); }
        function renderAuth() { const p = document.getElementById('auth-panel'); if(!activeUser) { p.innerHTML = `<button onclick="openLogin()" class="bg-amber-500 text-black px-4 py-2 rounded-lg text-[11px] uppercase font-black tracking-wider shadow-md">Đăng nhập nghiệp vụ</button>`; } else { p.innerHTML = `<div class="bg-slate-900 border border-slate-800 p-1.5 text-xs rounded-xl flex items-center gap-2"><b class="text-white">${activeUser.displayName}</b><button onclick="logout()" class="text-red-400 ml-2 cursor-pointer"><i class="fa-solid fa-power-off"></i></button></div>`; } }
        
        startClock();
    </script>
</body>
</html>
