                });
            } else {
                vioHtml = `<p class="text-center text-xs text-emerald-400 font-bold col-span-2 py-6"><i class="fa-solid fa-circle-check"></i> TRONG SẠCH - CƯ DÂN KHÔNG CÓ TIỀN ÁN TIỀN SỰ HOẶC BIÊN BẢN VI PHẠM TƯ PHÁP.</p>`;
            }
            vioZone.innerHTML = vioHtml;
        }

