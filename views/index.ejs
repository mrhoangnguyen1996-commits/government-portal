<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CỔNG THÔNG TIN ĐIỆN TỬ LIÊN THÔNG QUỐC GIA - GIẢ LẬP ROLEPLAY v7.5.0</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Space+Grotesk:wght@300;400;500;600;700&display=swap');
        body { font-family: 'Space Grotesk', sans-serif; background-color: #040814; color: #cbd5e1; overflow-x: hidden; }
        .font-mono-tech { font-family: 'Share Tech Mono', monospace; }
        
        /* Hiệu ứng con dấu nghiệp vụ cơ mật v7.5 */
        .stamp-box { position: relative; font-size: 10px; font-weight: 900; text-transform: uppercase; padding: 5px 12px; border-radius: 4px; border: 2.5px dashed; display: inline-block; text-align: center; letter-spacing: 1.5px; transform: rotate(-5deg) scale(1.02); text-shadow: 0 0 6px currentColor; box-shadow: inset 0 0 8px rgba(0,0,0,0.3); animation: stampAppear 0.22s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .stamp-approved { border-color: #10b981; color: #10b981; background: rgba(16, 185, 129, 0.08); }
        .stamp-rejected { border-color: #ef4444; color: #ef4444; background: rgba(239, 68, 68, 0.08); }
        .stamp-pending { border-color: #f59e0b; color: #f59e0b; background: rgba(245, 158, 11, 0.08); }
        .stamp-forwarded { border-color: #3b82f6; color: #3b82f6; background: rgba(59, 130, 246, 0.08); }
        .stamp-leader { border-color: #a855f7; color: #a855f7; background: rgba(168, 85, 247, 0.12); border-style: double; border-width: 4px; }
        .stamp-archived { border-color: #94a3b8; color: #94a3b8; background: rgba(148, 163, 184, 0.1); }

        @keyframes stampAppear { 0% { transform: scale(2.8) rotate(-40deg); opacity: 0; filter: blur(4px); } 100% { transform: scale(1.02) rotate(-5deg); opacity: 1; filter: blur(0); } }
        
        .marquee-container { width: 100%; overflow: hidden; white-space: nowrap; background: #060a17; border-top: 1px solid #1e293b; border-bottom: 1px solid #1e293b; }
        .marquee-content { display: inline-block; padding-left: 100%; animation: marquee 38s linear infinite; font-size: 12px; font-weight: 600; color: #f59e0b; text-shadow: 0 0 6px rgba(245, 158, 11, 0.4); }
        @keyframes marquee { 0% { transform: translate3d(0, 0, 0); } 100% { transform: translate3d(-100%, 0, 0); } }

        .national-card { background: linear-gradient(135deg, #0f172a 0%, #020612 100%); border: 2px solid #334155; position: relative; overflow: hidden; box-shadow: 0 15px 35px rgba(0,0,0,0.6), inset 0 1px 1px rgba(255,255,255,0.05); transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        .national-card:hover { transform: translateY(-5px); border-color: #fbbf24; box-shadow: 0 20px 40px rgba(251,191,36,0.15); }
        .card-chip { width: 40px; height: 30px; background: linear-gradient(135deg, #fbbf24 0%, #d97706 100%); border-radius: 5px; position: relative; border: 1px solid #f59e0b; }
        .card-chip::after { content: ''; position: absolute; inset: 4px; border: 1px solid rgba(0,0,0,0.2); border-radius: 2px; }

        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #040814; }
        ::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 8px; }
        ::-webkit-scrollbar-thumb:hover { background: #334155; }
        
        .subtab-btn.active { background-color: #1e293b; color: #f59e0b; border-color: #f59e0b; box-shadow: 0 0 10px rgba(245,158,11,0.15); }
        .glow-red { animation: glowRed 1.5s infinite alternate; }
        @keyframes glowRed { 0% { border-color: #ef4444; box-shadow: 0 0 4px rgba(239,68,68,0.3); } 100% { border-color: #991b1b; box-shadow: 0 0 15px rgba(239,68,68,0.5); } }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between">

    <div class="flex-1">
        <header class="bg-[#050b14] border-b border-slate-800 px-6 py-4 flex flex-wrap justify-between items-center shadow-2xl relative">
            <div class="flex items-center space-x-4">
                <div class="relative flex items-center justify-center">
                    <div class="absolute inset-0 bg-amber-500/20 blur-lg rounded-full animate-pulse"></div>
                    <div class="bg-gradient-to-br from-amber-400 to-amber-600 p-3 rounded-xl text-black border border-amber-300 shadow-xl z-10">
                        <i class="fa-solid fa-building-columns text-2xl"></i>
                    </div>
                </div>
                <div>
                    <span class="text-[10px] tracking-widest text-amber-500 uppercase font-black font-mono-tech block">Roblox Gaming Roleplay Community Platform</span>
                    <h1 class="text-xl font-black text-white tracking-tight flex items-center gap-2">CỔNG LIÊN THÔNG QUỐC GIA <span class="text-[11px] font-mono bg-slate-900 text-amber-400 px-2 py-0.5 rounded border border-slate-700">v7.5.0-PREMIUM ULTRA</span></h1>
                </div>
            </div>

            <div class="flex items-center space-x-4 text-xs mt-4 lg:mt-0">
                <div id="officer-alert-light" onclick="jumpToActiveNotification()" class="hidden bg-red-950 border border-red-500 px-3 py-2 rounded-lg flex items-center gap-2 animate-pulse cursor-pointer hover:bg-red-900 transition-all shadow-[0_0_15px_#ef4444]">
                    <span class="h-2 w-2 rounded-full bg-red-500 shadow-[0_0_10px_#ef4444]"></span>
                    <span class="text-red-400 font-black text-[11px] tracking-wide uppercase">CÓ TÍN HIỆU ĐƠN THƯ / BIÊN BẢN LIÊN NGÀNH MỚI</span>
                </div>
                <div class="bg-[#090d16] px-4 py-2 rounded-lg border border-slate-800 font-mono text-amber-400 font-black tracking-widest text-sm shadow-inner" id="clock">00:00:00</div>
                <div class="bg-[#090d16] px-3 py-2 rounded-lg border border-slate-800 flex items-center gap-2">
                    <span id="security-txt" class="font-black text-[11px] tracking-wider uppercase text-emerald-400"><%= state.securityLevel %></span>
                </div>
                <div id="auth-panel"></div>
            </div>
        </header>

        <div class="marquee-container py-2 flex items-center">
            <div class="bg-red-950 text-red-400 border border-red-900 font-black text-[9px] px-2.5 py-0.5 rounded uppercase tracking-wider mx-4 z-10 shadow-md">Thông báo cơ mật</div>
            <div class="marquee-content" id="live-marquee"><%= state.tickerMessage %></div>
        </div>

        <nav class="bg-[#050b14]/90 border-b border-slate-800 px-6 flex flex-wrap space-x-1 backdrop-blur-md sticky top-0 z-40 shadow-md">
            <button onclick="tab('tab-news')" id="btn-tab-news" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-amber-500 text-amber-500 transition-all"><i class="fa-solid fa-newspaper mr-1.5"></i> Trung Tâm Ấn Bản</button>
            <button onclick="tab('tab-id')" id="btn-tab-id" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-slate-400 hover:text-white transition-all"><i class="fa-solid fa-address-card mr-1.5"></i> Tra cứu định danh</button>
            <button onclick="tab('tab-cards')" id="btn-tab-cards" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-sky-400 hover:text-sky-300 transition-all"><i class="fa-solid fa-id-badge mr-1.5"></i> Thẩm Tra Văn Bằng & Vi Phạm</button>
            <button onclick="tab('tab-services')" id="btn-tab-services" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-slate-400 hover:text-white transition-all"><i class="fa-solid fa-file-invoice-dollar mr-1.5"></i> Khởi tạo hồ sơ đa dạng</button>
            <button onclick="tab('tab-officer')" id="btn-tab-officer" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-emerald-500 hover:text-emerald-400 hidden relative">
                <i class="fa-solid fa-user-shield mr-1.5"></i> Bàn Làm Việc Bộ Ngành 
                <span id="badge-count-app" class="absolute top-2 right-1.5 bg-red-600 text-white text-[9px] px-1.5 rounded-full font-black hidden">0</span>
            </button>
            <button onclick="tab('tab-admin')" id="btn-tab-admin" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-purple-400 hover:text-purple-300 hidden"><i class="fa-solid fa-crown mr-1.5"></i> Phòng Giám Sát Tối Cao</button>
        </nav>

        <main class="p-6 max-w-[1700px] w-full mx-auto space-y-6">
            
            <section id="tab-news" class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <div class="lg:col-span-2 space-y-4">
                    <h2 class="text-xs font-black text-slate-400 uppercase tracking-widest border-b border-slate-800 pb-2 flex items-center gap-2"><i class="fa-solid fa-scroll text-amber-500"></i> Văn Bản Chỉ Thị / Sắc Lệnh Quốc Gia ban hành</h2>
                    <div id="news-feed" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
                </div>
                <div class="space-y-4">
                    <h2 class="text-xs font-black text-red-400 uppercase tracking-widest border-b border-slate-800 pb-2 flex items-center gap-2"><i class="fa-solid fa-triangle-exclamation animate-pulse"></i> Danh Sách Đối Tượng Truy Nã Khẩn Cấp</h2>
                    <div id="wanted-feed" class="space-y-3"></div>
                </div>
            </section>

            <section id="tab-id" class="hidden max-w-2xl mx-auto bg-[#0a0f1d] border border-slate-800 p-6 rounded-2xl shadow-xl">
                <h2 class="text-xs font-black text-center text-white uppercase tracking-widest mb-4"><i class="fa-solid fa-shield-halved text-amber-500"></i> Tra Cứu Dữ Liệu Định Danh Cư Dân Toàn Quốc</h2>
                <div class="flex gap-2 mb-4">
                    <input type="text" id="id-search" placeholder="Nhập tên tài khoản cư dân..." class="flex-1 bg-slate-900 border border-slate-700 px-4 py-2 text-sm rounded-lg text-white font-mono focus:outline-none">
                    <button onclick="searchCitizen()" class="bg-amber-500 hover:bg-amber-600 text-black px-5 text-xs font-black uppercase rounded-lg transition-colors">Truy xuất</button>
                </div>
                <div id="id-result"></div>
            </section>

            <section id="tab-cards" class="hidden max-w-6xl mx-auto space-y-8">
                <div class="bg-[#0a0f1d] border border-slate-800 p-6 rounded-2xl shadow-xl max-w-xl mx-auto">
                    <h2 class="text-xs font-black text-center text-sky-400 uppercase tracking-widest mb-4"><i class="fa-solid fa-id-card text-sky-500"></i> Hệ Thống Đồ Họa Kết Xuất Giấy Tờ Thông Minh</h2>
                    <div class="flex gap-2">
                        <input type="text" id="card-search-input" placeholder="Nhập tài khoản cư dân (Ví dụ: Nguyen_Manh_Hoang)..." class="flex-1 bg-slate-900 border border-slate-700 px-4 py-2 text-sm rounded-lg text-white font-mono focus:outline-none">
                        <button onclick="generateCitizenCards()" class="bg-sky-600 hover:bg-sky-700 text-white px-5 text-xs font-black uppercase rounded-lg transition-colors">Kết xuất đồ họa</button>
                    </div>
                </div>

                <div class="space-y-4">
                    <h3 class="text-xs font-black uppercase text-slate-400 tracking-wider flex items-center gap-1.5"><i class="fa-solid fa-passport text-sky-400"></i> Đồ Họa Phôi Thẻ & Giấy Phép Nghiệp Vụ Gốc</h3>
                    <div id="cards-render-zone" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <p class="text-center text-xs text-slate-500 col-span-2 py-8">Vui lòng nhập tài khoản công dân để truy xuất phôi thẻ chuyên nghiệp.</p>
                    </div>
                </div>

                <div class="space-y-4">
                    <h3 class="text-xs font-black uppercase text-red-400 tracking-wider flex items-center gap-2"><i class="fa-solid fa-gavel text-red-500"></i> Nhật Ký Quyết Định Tư Pháp & Biên Bản Vi Phạm Lưu Kho Quốc Gia</h3>
                    <div id="violation-render-zone" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <p class="text-center text-xs text-slate-500 col-span-2 py-4">Chưa có dữ liệu lịch sử lý lịch tư pháp được tải lên.</p>
                    </div>
                </div>
            </section>

            <section id="tab-services" class="hidden grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl space-y-4 shadow-lg">
                    <h3 class="text-xs font-black text-slate-300 uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-file-pen text-amber-500"></i> Khởi Tạo Hồ Sơ Hành Chính Điện Tử Đa Ngành</h3>
                    <form onsubmit="submitForm(event)" class="space-y-4 text-xs">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            <div>
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Tên Tài Khoản Hệ Thống (Họ_Tên)</label>
                                <input type="text" id="app-sender" required placeholder="Nguyen_Manh_Hoang" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-mono focus:outline-none">
                            </div>
                            <div>
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Loại Giấy Tờ / Thủ Tục Thẩm Định</label>
                                <select id="app-docType" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-bold text-amber-400 focus:outline-none">
                                    <option value="CĂN CƯỚC CÔNG DÂN">Căn Cước Công Dân Gắn Chíp Điện Tử</option>
                                    <option value="BẰNG LÁI XE HẠNG B2">Bằng Lái Xe Ô Tô Hạng B2 Quốc Gia</option>
                                    <option value="BẰNG LÁI XE TẢI HẠNG C">Bằng Lái Xe Tải Nặng Hạng C</option>
                                    <option value="GIẤY PHÉP SỬ DỤNG CÔNG CỤ HỖ TRỢ">Giấy Phép Sử Dụng Vũ Khí & Công Cụ Hỗ Trợ</option>
                                    <option value="CHỨNG NHẬN LỰC LƯỢNG VŨ TRANG">Chứng Nhận Gia Nhập Lực Lượng Vũ Trang QĐND</option>
                                    <option value="THÈ NGÀNH CÔNG CHỨC">Thẻ Ngành Công Chức / Chứng Thư Bổ Nhiệm Tư Pháp</option>
                                    <option value="HỘ CHIẾU QUỐC TẾ">Hộ Chiếu Quốc Tế Toàn Cầu Liên Thông (Visa)</option>
                                    <option value="GIẤY PHÉP KINH DOANH DOANH NGHIỆP">Giấy Phép Thành Lập Doanh Nghiệp & Đầu Tư Tổng Thầu</option>
                                    <option value="ĐĂNG KÝ SỬ DỤNG TẦN SỐ BỘ ĐÀM">Đăng Ký Tần Số Bộ Đàm Mã Hóa Quốc Gia</option>
                                    <option value="ĐƠN XIN TỔ CHỨC SỰ KIỆN QUẦN CHÚNG">Đơn Xin Cấp Phép Tổ Chức Sự Kiện Nơi Công Cộng</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Cơ Quan Ban Ngành Tiếp Nhận</label>
                            <select id="app-agency" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-bold text-sky-400 focus:outline-none">
                                <option value="CHÍNH PHỦ">VĂN PHÒNG CHÍNH PHỦ TỐI CAO</option>
                                <option value="THANH TRA">THANH TRA CHÍNH PHỦ ỦY BAN</option>
                                <option value="CÔNG AN">BỘ CÔNG AN CHÍNH QUY</option>
                                <option value="QUÂN ĐỘI">BỘ CHỈ HUY QUÂN SỰ ĐẠI QUỐC PHÒNG</option>
                                <option value="UBND PHƯỜNG">ỦY BAN NHÂN DÂN THÀNH PHỐ THỦ PHỦ</option>
                                <option value="TOÀ ÁN">TÒA ÁN NHÂN DÂN TỐI CAO</option>
                                <option value="NGÂN HÀNG">NGÂN HÀNG TRUNG ƯƠNG QUỐC GIA</option>
                                <option value="BỆNH VIỆN">BỆNH VIỆN LIÊN THÔNG QUỐC TẾ</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Trình Bày Nội Dung Chi Tiết Nghiệp Vụ Kịch Bản</label>
                            <textarea id="app-content" rows="4" required placeholder="Ghi rõ thông tin yêu cầu giải quyết kịch bản nhập vai..." class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white focus:outline-none"></textarea>
                        </div>
                        <button type="submit" class="w-full bg-gradient-to-r from-amber-400 to-amber-500 font-black text-black py-3 rounded-lg uppercase tracking-widest shadow-lg transition-transform hover:scale-[1.01]">Gửi Đơn Thư Lên Hệ Thống</button>
                    </form>
                </div>

                <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl flex flex-col h-full min-h-[480px] shadow-lg">
                    <h3 class="text-xs font-black text-slate-300 uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-satellite-dish text-sky-400 animate-pulse"></i> Cổng Tra Cứu Tiến Độ & Đàm Thoại Trực Tuyến Realtime (Không delay)</h3>
                    <div class="flex gap-2 my-3">
                        <input type="text" id="track-id" placeholder="Nhập mã đơn thư cần tra cứu (Ví dụ: HS-1001)..." class="flex-1 bg-slate-900 border border-slate-700 px-3 py-2 text-xs rounded-lg text-white font-mono focus:outline-none">
                        <button onclick="trackApplication()" class="bg-sky-600 hover:bg-sky-700 text-white px-5 text-xs font-black rounded-lg transition-colors">Truy vấn</button>
                    </div>
                    <div id="track-details" class="flex-1 flex flex-col justify-between hidden space-y-3"></div>
                    <div id="track-empty" class="text-center py-20 text-slate-500 text-xs flex-1 flex flex-col justify-center items-center"><i class="fa-solid fa-folder-open text-4xl mb-3 text-slate-700"></i> Nhập chính xác mã đơn để tiến hành đàm thoại, cung cấp chứng cứ và gửi phản hồi đóng hồ sơ liên thông.</div>
                </div>
            </section>

            <section id="tab-officer" class="hidden grid grid-cols-1 xl:grid-cols-3 gap-6">
                <div class="xl:col-span-2 space-y-5">
                    
                    <div class="bg-[#0b111e] border border-slate-700 p-1.5 rounded-xl flex flex-wrap gap-1 shadow-md">
                        <button onclick="subTab('off-apps')" id="btn-off-apps" class="subtab-btn px-4 py-2 text-[11px] font-black uppercase border border-slate-700 text-slate-400 rounded-md transition-all"><i class="fa-solid fa-inbox mr-1"></i> Hồ sơ ban ngành</button>
                        <button onclick="subTab('off-cccd')" id="btn-off-cccd" class="subtab-btn px-4 py-2 text-[11px] font-black uppercase border border-slate-700 text-slate-400 rounded-md transition-all"><i class="fa-solid fa-address-card mr-1"></i> Cấp Căn Cước Công Dân (CCCD)</button>
                        <button onclick="subTab('off-docs')" id="btn-off-docs" class="subtab-btn px-4 py-2 text-[11px] font-black uppercase border border-slate-700 text-slate-400 rounded-md transition-all"><i class="fa-solid fa-id-badge mr-1"></i> Cấp Văn Bằng / Giấy Phép / Thẻ Ngành</button>
                        <button onclick="subTab('off-gavel')" id="btn-off-gavel" class="subtab-btn px-4 py-2 text-[11px] font-black uppercase border border-slate-700 text-slate-400 rounded-md transition-all"><i class="fa-solid fa-gavel mr-1"></i> Lập Quyết Định Xử Phạt</button>
                        <button onclick="subTab('off-leader')" id="btn-off-leader" class="subtab-btn px-4 py-2 text-[11px] font-black uppercase border border-purple-800 text-purple-400 rounded-md transition-all hidden"><i class="fa-solid fa-crown mr-1"></i> Phân Hệ Lãnh Đạo Cao Cấp</button>
                    </div>

                    <div id="subtab-off-apps" class="bg-[#0a0f1d] border border-slate-800 p-4 rounded-xl shadow-md">
                        <div class="flex justify-between items-center mb-3 border-b border-slate-800 pb-2">
                            <h3 class="text-xs font-black text-emerald-400 uppercase tracking-wider flex items-center gap-2"><i class="fa-solid fa-folder-closed"></i> Thẩm định danh sách đơn thư liên thông</h3>
                            <span id="office-badge" class="text-[10px] font-mono font-bold bg-emerald-950 text-emerald-400 px-2 py-0.5 rounded border border-emerald-800">Cơ quan tiếp nhận</span>
                        </div>
                        <div class="overflow-x-auto text-xs">
                            <table class="w-full text-left">
                                <thead class="bg-slate-900 text-slate-400 font-bold uppercase text-[9px] tracking-wider">
                                    <tr>
                                        <th class="p-3">Mã Đơn</th>
                                        <th class="p-3">Tài Khoản</th>
                                        <th class="p-3">Loại Giấy Tờ</th>
                                        <th class="p-3">Trạng Thái</th>
                                        <th class="p-3 text-right">Hành Động</th>
                                    </tr>
                                </thead>
                                <tbody id="officer-table" class="divide-y divide-slate-800"></tbody>
                            </table>
                        </div>
                    </div>

                    <div id="subtab-off-cccd" class="hidden bg-[#0a0f1d] border border-slate-800 p-5 rounded-xl space-y-4 shadow-lg">
