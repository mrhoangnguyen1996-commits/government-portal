        async function askAiBot() {
            const msg = document.getElementById('bot-input').value.trim();
            if(!msg) return;
            const flow = document.getElementById('bot-chat-flow');
            flow.innerHTML += `<div class="bg-gray-800 p-2.5 rounded-xl text-gray-200 text-right"><span class="font-bold block text-[10px] text-gray-400">Công Dân</span>${msg}</div>`;
            document.getElementById('bot-input').value = '';
            
            const res = await fetch('/api/bot/chat', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }) });
            const data = await res.json();
            
            setTimeout(() => {
                flow.innerHTML += `<div class="bg-teal-950/40 border border-teal-900/40 p-2.5 rounded-xl text-teal-300 animate-fade-in"><span class="font-black text-[10px] text-teal-400 block"><i class="fa-solid fa-robot"></i> Tuệ Đức Quốc Vụ</span>${data.reply}</div>`;
                flow.scrollTop = flow.scrollHeight; playTone(440, 'sine', 0.08, 0.05);
            }, 300);
        }

