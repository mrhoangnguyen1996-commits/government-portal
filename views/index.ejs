            <div class="flex gap-2 pt-2">
                <button onclick="closeLogin()" class="w-1/3 bg-slate-800 text-slate-400 py-2 rounded-lg uppercase font-black">Đóng</button>
                <button onclick="login()" class="w-2/3 bg-gradient-to-r from-amber-400 to-amber-500 text-black py-2 rounded-lg uppercase font-black">Xác Minh</button>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();

        let state = {};
        let registry = {};
        let violations = {}; 
        let activeUser = null;
        let activeFileId = null;

        /* ENGINE SÓNG ÂM AUDIO-CONTEXT */
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        function playTone(freq, type, duration, vol) {
            try {
                const osc = audioCtx.createOscillator();
                const gainNode = audioCtx.createGain();
                osc.type = type; osc.frequency.value = freq;
                gainNode.gain.setValueAtTime(vol, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.00001, audioCtx.currentTime + duration);
                osc.connect(gainNode); gainNode.connect(audioCtx.destination);
                osc.start(); osc.stop(audioCtx.currentTime + duration);
            } catch(e) {}
        }

        const soundClick = () => playTone(600, 'sine', 0.08, 0.1);
        const soundSuccess = () => { playTone(523.25, 'sine', 0.1, 0.15); setTimeout(() => playTone(659.25, 'sine', 0.15, 0.15), 80); };
        const soundAlert = () => { playTone(880, 'sawtooth', 0.15, 0.1); setTimeout(() => playTone(880, 'sawtooth', 0.15, 0.1), 200); };
        const soundStamp = () => { playTone(120, 'triangle', 0.2, 0.4); playTone(250, 'sawtooth', 0.08, 0.1); };

        function startClock() { setInterval(() => { document.getElementById('clock').innerText = new Date().toLocaleTimeString('vi-VN'); }, 1000); }

        // MẠNG LƯỚI LẮNG NGHE REALTIME KHÔNG CHẬM TRỄ
        socket.on('initData', (data) => { updateDataAndRender(data); checkAndRestoreSession(); });
        socket.on('stateUpdate', (data) => { updateDataAndRender(data); });
        socket.on('newApplicationAlert', (appInfo) => {
            if (activeUser && (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ' || appInfo.agency === activeUser.agency)) {
                document.getElementById('officer-alert-light').classList.remove('hidden');
                soundAlert();
            }
        });
        socket.on('newChatMessage', (chatInfo) => {
            if (document.getElementById('track-id').value === chatInfo.fileId) { trackApplication(); }
            if (activeFileId === chatInfo.fileId) { renderOfficerDesk(); }
        });

        function updateDataAndRender(data) {
            state = data.systemState; registry = data.citizenIdentityRegistry; violations = data.criminalRecordsRegistry;
            if (activeUser) { activeUser = state.authorizedPersonnel[activeUser.username]; renderAuth(); }
            renderAll();
            if (activeFileId) { renderOfficerDesk(); }
        }

        function checkAndRestoreSession() {
            let savedSession = localStorage.getItem('sessionUser');
            if(savedSession) {
                try {
                    let creds = JSON.parse(savedSession);
                    if (state.authorizedPersonnel[creds.username] && state.authorizedPersonnel[creds.username].password === creds.password) {
                        activeUser = state.authorizedPersonnel[creds.username];
                        applyUserRoleLayout();
                    }
                } catch(e) {}
            } else { renderAuth(); }
        }

        function jumpToActiveNotification() { tab('tab-officer'); document.getElementById('officer-alert-light').classList.add('hidden'); }

        function tab(id) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            document.getElementById(id).classList.remove('hidden');
            document.querySelectorAll('nav button').forEach(b => {
                b.classList.remove('border-amber-500', 'text-amber-500'); b.classList.add('border-transparent', 'text-slate-400');
            });
            const btn = document.getElementById(`btn-${id}`);
            if(btn) { btn.classList.remove('border-transparent', 'text-slate-400'); btn.classList.add('border-amber-500', 'text-amber-500'); }
            if (id === 'tab-officer') { document.getElementById('officer-alert-light').classList.add('hidden'); }
            sessionStorage.setItem('activeTab', id);
        }

        // CHUYỂN ĐỔI TAB CON TRONG BÀN LÀM VIỆC CÁN BỘ KHÔNG BỊ TRÙNG LẶP RỐI MẮT
        function subOfficeTab(targetSubId) {
            ['sub-desk-apps', 'sub-desk-violations', 'sub-desk-residents', 'sub-desk-commands'].forEach(id => {
                document.getElementById(id).classList.add('hidden');
            });
            document.getElementById(targetSubId).classList.remove('hidden');

            ['btn-sub-apps', 'btn-sub-violations', 'btn-sub-residents', 'btn-sub-commands'].forEach(btnId => {
                document.getElementById(btnId).className = "px-4 py-2 text-[11px] font-black uppercase tracking-wider rounded-lg bg-slate-900 text-slate-400 hover:text-white transition-all";
            });
            const activeBtnMap = { 'sub-desk-apps': 'btn-sub-apps', 'sub-desk-violations': 'btn-sub-violations', 'sub-desk-residents': 'btn-sub-residents', 'sub-desk-commands': 'btn-sub-commands' };
            document.getElementById(activeBtnMap[targetSubId]).className = "px-4 py-2 text-[11px] font-black uppercase tracking-wider rounded-lg bg-emerald-600 text-white transition-all";
        }

        async function submitViolationForm(e) {
            e.preventDefault();
            const username = document.getElementById('vio-user').value.trim();
            const type = document.getElementById('vio-type').value;
            const lawClause = document.getElementById('vio-clause').value.trim();
            const fine = document.getElementById('vio-fine').value.trim() || "0 VND";
            const status = document.getElementById('vio-status').value;

            await fetch('/api/resident/violation', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, type, lawClause, fine, status, officerName: activeUser.displayName })
            });

            document.getElementById('vio-user').value = '';
            document.getElementById('vio-clause').value = '';
            document.getElementById('vio-fine').value = '';
            soundStamp();
            alert(`Biên bản xử phạt tư pháp đã ban hành thành công lên máy chủ!`);
        }

