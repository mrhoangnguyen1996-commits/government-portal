<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CỔNG THÔNG TIN ĐIỆN TỬ CHÍNH PHỦ - GIẢ LẬP ROLEPLAY</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Space+Grotesk:wght@400;500;600;700&display=swap');
        body { font-family: 'Space Grotesk', sans-serif; background-color: #05070f; color: #cbd5e1; }
        .font-mono-tech { font-family: 'Share Tech Mono', monospace; }
        
        .stamp-box { position: relative; font-size: 11px; font-weight: 800; text-transform: uppercase; padding: 5px 12px; border-radius: 4px; border: 2.5px dashed; display: inline-block; text-align: center; letter-spacing: 1px; transform: rotate(-6deg) scale(1.05); text-shadow: 0 0 4px currentColor; box-shadow: inset 0 0 6px rgba(0,0,0,0.2); animation: stampAppear 0.2s ease-out; }
        .stamp-approved { border-color: #10b981; color: #10b981; background: rgba(16, 185, 129, 0.08); }
        .stamp-rejected { border-color: #ef4444; color: #ef4444; background: rgba(239, 68, 68, 0.08); }
        .stamp-pending { border-color: #f59e0b; color: #f59e0b; background: rgba(245, 158, 11, 0.08); }
        .stamp-forwarded { border-color: #3b82f6; color: #3b82f6; background: rgba(59, 130, 246, 0.08); }
        .stamp-leader { border-color: #a855f7; color: #a855f7; background: rgba(168, 85, 247, 0.12); border-style: double; border-width: 4px; }
        .stamp-archived { border-color: #94a3b8; color: #94a3b8; background: rgba(148, 163, 184, 0.1); }

        @keyframes stampAppear { 0% { transform: scale(1.8) rotate(-20deg); opacity: 0; } 100% { transform: scale(1.05) rotate(-6deg); opacity: 1; } }
        
        .marquee-container { width: 100%; overflow: hidden; white-space: nowrap; background: #090d16; border-top: 1px solid #1e293b; border-bottom: 1px solid #1e293b; }
        .marquee-content { display: inline-block; padding-left: 100%; animation: marquee 35s linear infinite; font-size: 12px; font-weight: 600; color: #f59e0b; text-shadow: 0 0 6px rgba(245, 158, 11, 0.4); }
        @keyframes marquee { 0% { transform: translate3d(0, 0, 0); } 100% { transform: translate3d(-100%, 0, 0); } }

        .national-card {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            border: 2px solid #334155;
            position: relative;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(0,0,0,0.6), inset 0 1px 1px rgba(255,255,255,0.1);
            transition: transform 0.3s ease;
        }
        .national-card:hover { transform: translateY(-4px); }
        .card-chip {
            width: 38px; height: 28px;
            background: linear-gradient(135deg, #fbbf24 0%, #d97706 100%);
            border-radius: 4px;
            position: relative;
            border: 1px solid #f59e0b;
        }
        .card-chip::after {
            content: ''; position: absolute; inset: 4px;
            border: 1px solid rgba(0,0,0,0.2); border-radius: 2px;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between">

    <div class="flex-1">
        <header class="bg-[#0a0f1d] border-b border-slate-800 px-6 py-3.5 flex flex-wrap justify-between items-center shadow-lg relative">
            <div class="flex items-center space-x-4">
                <div class="relative flex items-center justify-center">
                    <div class="absolute inset-0 bg-amber-500/20 blur-md rounded-full animate-pulse"></div>
                    <div class="bg-gradient-to-br from-amber-400 to-amber-600 p-2.5 rounded-xl text-black border border-amber-300 shadow-lg z-10">
                        <i class="fa-solid fa-building-columns text-2xl"></i>
                    </div>
                </div>
                <div>
                    <span class="text-[10px] tracking-widest text-amber-500 uppercase font-extrabold font-mono-tech">Roblox Gaming Roleplay Community Platform</span>
                    <h1 class="text-xl font-black text-white tracking-tight drop-shadow-sm flex items-center gap-2">CỔNG LIÊN THÔNG QUỐC GIA <span class="text-[11px] font-mono bg-slate-800 text-slate-400 px-1.5 py-0.5 rounded border border-slate-700">v6.0.0-REALTIME</span></h1>
                </div>
            </div>

            <div class="flex items-center space-x-4 text-xs">
                <div id="officer-alert-light" onclick="jumpToActiveNotification()" class="hidden bg-red-950 border border-red-500 px-3 py-1.5 rounded-lg flex items-center gap-2 animate-pulse cursor-pointer hover:bg-red-900 transition-all">
                    <span class="h-2 w-2 rounded-full bg-red-500 shadow-[0_0_10px_#ef4444]"></span>
                    <span id="alert-light-text" class="text-red-400 font-black text-[11px] tracking-wide uppercase">CÓ ĐƠN THƯ / TIN NHẮN MỚI TỨC THÌ</span>
                </div>
                <div class="bg-[#0f172a] px-3 py-1.5 rounded-lg border border-slate-800 font-mono text-amber-400 font-bold tracking-widest" id="clock">00:00:00</div>
                <div class="bg-[#0f172a] px-3 py-1.5 rounded-lg border border-slate-800 flex items-center gap-2">
                    <span id="security-txt" class="font-extrabold text-[11px] tracking-wider uppercase text-emerald-400"><%= state.securityLevel %></span>
                </div>
                <div id="auth-panel"></div>
            </div>
        </header>

        <div class="marquee-container py-2 flex items-center">
            <div class="bg-red-950 text-red-400 border border-red-900/60 font-black text-[9px] px-2 py-0.5 rounded uppercase tracking-wider mx-3 z-10">Thông báo khẩn</div>
            <div class="marquee-content" id="live-marquee"><%= state.tickerMessage %></div>
        </div>

        <nav class="bg-[#0a0f1d]/80 border-b border-slate-800 px-6 flex space-x-1.5 backdrop-blur-md">
            <button onclick="tab('tab-news')" id="btn-tab-news" class="px-4 py-3 text-xs font-black uppercase tracking-wider border-b-2 border-amber-500 text-amber-500 transition-all"><i class="fa-solid fa-newspaper mr-1"></i> Trung Tâm Ấn Bản</button>
            <button onclick="tab('tab-id')" id="btn-tab-id" class="px-4 py-3 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-slate-400 hover:text-white transition-all"><i class="fa-solid fa-address-card mr-1"></i> Tra cứu định danh</button>
            <button onclick="tab('tab-cards')" id="btn-tab-cards" class="px-4 py-3 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-sky-400 hover:text-sky-300 transition-all"><i class="fa-solid fa-id-badge mr-1"></i> Thẩm Tra Văn Bằng & Vi Phạm</button>
            <button onclick="tab('tab-services')" id="btn-tab-services" class="px-4 py-3 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-slate-400 hover:text-white transition-all"><i class="fa-solid fa-file-invoice-dollar mr-1"></i> Nộp Đơn Thủ Tục / Khiếu Nại</button>
            <button onclick="tab('tab-officer')" id="btn-tab-officer" class="px-4 py-3 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-emerald-500 hover:text-emerald-400 hidden relative">
                <i class="fa-solid fa-user-shield mr-1"></i> Bàn Làm Việc Bộ Ngành 
                <span id="badge-count-app" class="absolute top-1.5 right-1 bg-red-600 text-white text-[9px] px-1 rounded-full font-black hidden">0</span>
            </button>
            <button onclick="tab('tab-admin')" id="btn-tab-admin" class="px-4 py-3 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-purple-400 hover:text-purple-300 hidden"><i class="fa-solid fa-crown mr-1"></i> Phòng Giám Sát Tối Cao</button>
        </nav>

        <main class="p-6 max-w-[1650px] w-full mx-auto space-y-6">
            
            <section id="tab-news" class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <div class="lg:col-span-2 space-y-4">
                    <h2 class="text-xs font-black text-slate-400 uppercase tracking-widest border-b border-slate-800 pb-2 flex items-center gap-2"><i class="fa-solid fa-scroll text-amber-500"></i> Văn Bản Chỉ Thị / Sắc Lệnh Quốc Gia</h2>
                    <div id="news-feed" class="space-y-3"></div>
                </div>
                <div class="space-y-4">
                    <h2 class="text-xs font-black text-red-400 uppercase tracking-widest border-b border-slate-800 pb-2 flex items-center gap-2"><i class="fa-solid fa-triangle-exclamation animate-pulse"></i> Cơ Sở Dữ Liệu Đối Tượng Truy Nã</h2>
                    <div id="wanted-feed" class="space-y-3"></div>
                </div>
            </section>

            <section id="tab-id" class="hidden max-w-2xl mx-auto bg-[#0a0f1d] border border-slate-800 p-6 rounded-2xl shadow-xl">
                <h2 class="text-xs font-black text-center text-white uppercase tracking-widest mb-4"><i class="fa-solid fa-shield-halved text-amber-500"></i> Tra Cứu Dữ Liệu Định Danh Cư Dân</h2>
                <div class="flex gap-2 mb-4">
                    <input type="text" id="id-search" placeholder="Nhập tên tài khoản cư dân..." class="flex-1 bg-slate-900 border border-slate-700 px-3 py-2 text-sm rounded-lg text-white font-mono">
                    <button onclick="searchCitizen()" class="bg-amber-500 hover:bg-amber-600 text-black px-5 text-xs font-black uppercase rounded-lg">Truy xuất</button>
                </div>
                <div id="id-result"></div>
            </section>

            <section id="tab-cards" class="hidden max-w-6xl mx-auto space-y-8">
                <div class="bg-[#0a0f1d] border border-slate-800 p-6 rounded-2xl shadow-xl max-w-xl mx-auto">
                    <h2 class="text-xs font-black text-center text-sky-400 uppercase tracking-widest mb-4"><i class="fa-solid fa-id-card text-sky-500"></i> Hệ Thống Xuất Đồ Họa Căn Cước & Chứng Chỉ Quốc Gia</h2>
                    <div class="flex gap-2">
                        <input type="text" id="card-search-input" placeholder="Nhập tài khoản cư dân (Ví dụ: Nguyen_Manh_Hoang)..." class="flex-1 bg-slate-900 border border-slate-700 px-3 py-2 text-sm rounded-lg text-white font-mono">
                        <button onclick="generateCitizenCards()" class="bg-sky-600 hover:bg-sky-700 text-white px-5 text-xs font-black uppercase rounded-lg">Truy Xuất Giấy Tờ</button>
                    </div>
                </div>

                <div class="space-y-4">
                    <h3 class="text-xs font-black uppercase text-slate-400 tracking-wider flex items-center gap-1.5"><i class="fa-solid fa-passport text-sky-400"></i> Đồ Họa Thẻ Hành Chính Gốc</h3>
                    <div id="cards-render-zone" class="grid grid-cols-1 md:grid-cols-2 gap-6 justify-center items-center">
                        <p class="text-center text-xs text-slate-500 col-span-2 py-8">Nhập tài khoản cư dân để kết xuất hình ảnh thẻ thông minh.</p>
                    </div>
                </div>

                <div class="space-y-4">
                    <h3 class="text-xs font-black uppercase text-red-400 tracking-wider flex items-center gap-2"><i class="fa-solid fa-gavel text-red-500"></i> Tra Cứu Lịch Sử Vi Phạm & Quyết Định Tư Pháp</h3>
                    <div id="violation-render-zone" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <p class="text-center text-xs text-slate-500 col-span-2 py-4">Nhập tài khoản công dân để kiểm tra lý lịch tư pháp.</p>
                    </div>
                </div>
            </section>

            <section id="tab-services" class="hidden grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl space-y-4 shadow-lg">
                    <h3 class="text-xs font-black text-slate-300 uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-file-pen text-amber-500"></i> Khởi Tạo Hồ Sơ Hành Chính Điện Tử</h3>
                    <form onsubmit="submitForm(event)" class="space-y-3.5 text-xs">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            <div>
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Tên Tài Khoản Hệ Thống (Họ_Tên)</label>
                                <input type="text" id="app-sender" required placeholder="Nguyen_Manh_Hoang" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-mono">
                            </div>
                            <div>
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Loại Giấy Tờ / Thủ Tục</label>
                                <select id="app-docType" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-bold text-amber-400">
                                    <option value="CĂN CƯỚC CÔNG DÂN">Căn Cước Công Dân Gắn Chíp</option>
                                    <option value="GIẤY PHÉP SỬ DỤNG CÔNG CỤ HỖ TRỢ">Giấy Phép Sử Dụng Vũ Khí / Công Cụ Hỗ Trợ</option>
                                    <option value="HỘ CHIẾU QUỐC TẾ">Hộ Chiếu Quốc Tế (Visa)</option>
                                    <option value="GIẤY PHÉP KINH DOANH DOANH NGHIỆP">Giấy Phép Thành Lập Doanh Nghiệp</option>
                                    <option value="ĐĂNG KÝ KẾT HÔN / KHAI SINH">Đăng Ký Kết Hôn / Khai Sinh</option>
                                    <option value="ĐĂNG KÝ SỬ DỤNG TẦN SỐ BỘ ĐÀM MÃ HÓA">Đăng Ký Tần Số Bộ Đàm Mã Hóa Quốc Gia</option>
                                    <option value="GIẤY PHÉP VẬN TẢI LOGISTICS ĐƯỜNG BỘ">Giấy Phép Vận Tải Quốc Tế / Logistics</option>
                                    <option value="ĐƠN XIN GIA NHẬP LỰC LƯỢNG VŨ TRANG">Đơn Tuyển Dụng / Gia Nhập Lực Lượng Vũ Trang</option>
                                    <option value="BẰNG KHAI THÁC KHOÁNG SẢN & TÀI NGUYÊN">Giấy Phép Khai Thác Tài Nguyên Môi Trường</option>
                                    <option value="ĐƠN XIN TỔ CHỨC SỰ KIỆN QUẦN CHÚNG">Đơn Đăng Ký Tổ Chức Sự Kiện Nơi Công Cộng</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Cơ Quan Tiếp Nhận Thẩm Định</label>
                            <select id="app-agency" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-bold text-sky-400">
                                <option value="CHÍNH PHỦ">VĂN PHÒNG CHÍNH PHỦ TỐI CAO</option>
                                <option value="THANH TRA">THANH TRA CHÍNH PHỦ</option>
                                <option value="CÔNG AN">BỘ CÔNG AN</option>
                                <option value="QUÂN ĐỘI">BỘ CHỈ HUY QUÂN SỰ TRƯỞNG</option>
                                <option value="UBND PHƯỜNG">ỦY BAN NHÂN DÂN THÀNH PHỐ</option>
                                <option value="TOÀ ÁN">TÒA ÁN NHÂN DÂN TỐI CAO</option>
                                <option value="NGÂN HÀNG">NGÂN HÀNG TRUNG ƯƠNG QUỐC GIA</option>
                                <option value="BỆNH VIỆN">BỆNH VIỆN QUỐC GIA LIÊN THÔNG</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Trình Bày Nội Dung Chi Tiết</label>
                            <textarea id="app-content" rows="4" required placeholder="Ghi rõ thông tin yêu cầu giải quyết kịch bản nhập vai..." class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white focus:outline-none"></textarea>
                        </div>
                        <button type="submit" class="w-full bg-gradient-to-r from-amber-400 to-amber-500 font-black text-black py-3 rounded-lg uppercase tracking-widest shadow-lg">Gửi Đơn Lên Hệ Thống</button>
                    </form>
                </div>

                <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl flex flex-col h-full min-h-[480px] shadow-lg">
                    <h3 class="text-xs font-black text-slate-300 uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-satellite-dish text-sky-400 animate-pulse"></i> Cổng Tra Cứu Tiến Độ & Đàm Thoại Trực Tuyến</h3>
                    <div class="flex gap-2 my-3">
                        <input type="text" id="track-id" placeholder="Nhập mã đơn thư cần tra cứu (Ví dụ: HS-1001)..." class="flex-1 bg-slate-900 border border-slate-700 px-3 py-2 text-xs rounded-lg text-white font-mono focus:outline-none">
                        <button onclick="trackApplication()" class="bg-sky-600 hover:bg-sky-700 text-white px-5 text-xs font-black rounded-lg">Truy vấn đơn</button>
                    </div>
                    <div id="track-details" class="flex-1 flex flex-col justify-between hidden space-y-3"></div>
                    <div id="track-empty" class="text-center py-16 text-slate-500 text-xs flex-1 flex flex-col justify-center items-center"><i class="fa-solid fa-folder-open text-4xl mb-3 text-slate-700"></i> Nhập chính xác mã số đơn để tiến hành đàm thoại gửi bằng chứng kịch bản trực tiếp.</div>
                </div>
            </section>

            <section id="tab-officer" class="hidden grid grid-cols-1 xl:grid-cols-3 gap-6">
                <div class="xl:col-span-2 space-y-5">
                    
                    <div class="bg-[#0a0f1d] border border-slate-800 p-4 rounded-2xl shadow-md">
                        <div class="flex justify-between items-center mb-3">
                            <h3 class="text-xs font-black text-emerald-400 uppercase tracking-wider flex items-center gap-2"><i class="fa-solid fa-folder-closed"></i> Danh Sách Đơn Thư Thuộc Đơn Vị Quản Lý</h3>
                            <span id="office-badge" class="text-[10px] font-mono font-bold bg-emerald-950/60 text-emerald-400 px-2.5 py-1 rounded-lg border border-emerald-800">Cơ Quan Tiếp Nhận</span>
                        </div>
                        <div class="overflow-x-auto text-xs">
                            <table class="w-full text-left">
                                <thead class="bg-slate-900 text-slate-400 font-bold uppercase text-[9px] tracking-wider">
                                    <tr>
                                        <th class="p-3">Mã Đơn</th>
                                        <th class="p-3">Tài Khoản</th>
                                        <th class="p-3">Loại Giấy Tờ</th>
                                        <th class="p-3">Trạng Thái Xử Lý</th>
                                        <th class="p-3 text-right">Hành Động</th>
                                    </tr>
                                </thead>
                                <tbody id="officer-table" class="divide-y divide-slate-800"></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl space-y-3.5 shadow-lg">
                        <h3 class="text-xs font-black text-red-500 uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-gavel"></i> Hệ Thống Lập Biên Bản & Quyết Định Xử Phạt Vi Phạm</h3>
                        <form onsubmit="submitViolationForm(event)" class="grid grid-cols-1 md:grid-cols-2 gap-3 text-xs">
                            <div>
                                <label class="block text-gray-400 mb-1 font-bold">Tài Khoản Cư Dân Vi Phạm (Họ_Tên)</label>
                                <input type="text" id="vio-user" required placeholder="Nguyen_Manh_Hoang" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white font-mono">
                            </div>
                            <div>
                                <label class="block text-gray-400 mb-1 font-bold">Phân Loại Hành Vi</label>
                                <select id="vio-type" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white font-bold text-amber-400">
                                    <option value="VI PHẠM GIAO THÔNG">Vi Phạm Luật Giao Thông Đường Bộ</option>
                                    <option value="VI PHẠM HÀNH CHÍNH">Vi Phạm Hành Chính / Sai Quy Trình</option>
                                    <option value="VI PHẠM LUẬT AN NINH">Vi Phạm Quy Định An Ninh / Quốc Phòng</option>
                                    <option value="SỬ DỤNG VŨ KHÍ TRÁI PHÉP">Sử Dụng Công Cụ Hỗ Trợ Trái Phép</option>
                                </select>
                            </div>
                            <div class="md:col-span-2">
                                <label class="block text-gray-400 mb-1 font-bold">Chi Tiết Luật Áp Dụng & Nội Dung Hành Vi</label>
                                <input type="text" id="vio-clause" required placeholder="Ví dụ: Điều 5 Nghị định 100 - Điểu khiển phương tiện chạy quá tốc độ kịch bản..." class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white">
                            </div>
                            <div>
                                <label class="block text-gray-400 mb-1 font-bold">Khung Số Tiền Phạt (Nếu có)</label>
                                <input type="text" id="vio-fine" placeholder="5,000,000 VND" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white font-mono">
                            </div>
                            <div>
                                <label class="block text-gray-400 mb-1 font-bold">Hình Thức Biện Pháp & Trạng Thái</label>
                                <select id="vio-status" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white font-black text-red-400">
                                    <option value="Đang Chờ Nộp Phạt">Đang Chờ Nộp Phạt Dân Sự</option>
                                    <option value="Quyết Định Thành Công - Đã Nộp Phạt">Quyết Định Thành Công - Đã Nộp Phạt</option>
                                    <option value="Đình Chỉ Xử Lý - Tước Giấy Phép Tạm Thời">Đình Chỉ Xử Lý - Tước Giấy Phép Tạm Thời</option>
                                    <option value="Tịch Thu Phương Tiện / Giam Giữ Tư Pháp">Tịch Thu Phương Tiện / Giam Giữ Tư Pháp</option>
                                </select>
                            </div>
