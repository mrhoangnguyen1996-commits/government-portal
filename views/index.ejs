            <div class="flex gap-2 pt-2"><button onclick="closeLogin()" class="w-1/3 bg-gray-800 text-gray-400 py-2.5 rounded-xl uppercase font-black">Hủy</button><button onclick="login()" class="w-2/3 bg-gradient-to-r from-amber-500 to-amber-600 text-black py-2.5 rounded-xl uppercase font-black">Xác Thực Lõi</button></div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();

        let state = {}; let registry = {}; let violations = {}; 
        let activeUser = null; let activeFileId = null;

        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        function playTone(freq, type, duration, vol) {
            try {
                const osc = audioCtx.createOscillator(); const gainNode = audioCtx.createGain();
                osc.type = type; osc.frequency.value = freq;
                gainNode.gain.setValueAtTime(vol, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.00001, audioCtx.currentTime + duration);
                osc.connect(gainNode); gainNode.connect(audioCtx.destination);
                osc.start(); osc.stop(audioCtx.currentTime + duration);
            } catch(e) {}
        }

        const soundClick = () => playTone(650, 'sine', 0.06, 0.08);
        const soundSuccess = () => { playTone(523.25, 'sine', 0.1, 0.12); setTimeout(() => playTone(659.25, 'sine', 0.12, 0.12), 60); };
        const soundAlert = () => { playTone(987.77, 'sawtooth', 0.18, 0.08); setTimeout(() => playTone(987.77, 'sawtooth', 0.18, 0.08), 180); };
        const soundStamp = () => { playTone(115, 'triangle', 0.22, 0.45); playTone(230, 'sawtooth', 0.06, 0.12); };

        document.addEventListener('click', (e) => {
            if(e.target.closest('button') || e.target.closest('nav button') || e.target.closest('select')) { soundClick(); }
        });
        
        function startClock() { setInterval(() => { document.getElementById('clock').innerText = new Date().toLocaleTimeString('vi-VN'); }, 1000); }

        socket.on('initData', (data) => { updateDataAndRender(data); checkAndRestoreSession(); });
        socket.on('stateUpdate', (data) => { updateDataAndRender(data); });
        socket.on('newApplicationAlert', (appInfo) => {
            if (activeUser && (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ' || appInfo.agency === activeUser.agency)) {
                document.getElementById('officer-alert-light').classList.remove('hidden'); soundAlert();
                // Rung lắc nhẹ màn hình tạo tính khẩn cấp kịch bản nhập vai
                document.body.style.transform = "translateX(2px)"; setTimeout(()=>document.body.style.transform="none", 50);
            }
        });
        socket.on('newChatMessage', (chatInfo) => {
            if (document.getElementById('track-id').value === chatInfo.fileId) trackApplication();
            if (activeFileId === chatInfo.fileId) renderOfficerDesk();
        });

        function updateDataAndRender(data) {
            state = data.systemState; registry = data.citizenIdentityRegistry; violations = data.criminalRecordsRegistry;
            if (activeUser) activeUser = state.authorizedPersonnel[activeUser.username];
            
            if (activeUser) {
                let filtered = Object.values(state.applications).filter(a => {
                    if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ') return true;
                    return a.agency === activeUser.agency;
                });
                const badgeCount = document.getElementById('badge-count-app');
                if (filtered.length > 0) { badgeCount.innerText = filtered.length; badgeCount.classList.remove('hidden'); } 
                else { badgeCount.classList.add('hidden'); }
            }
            renderAll();
            if (activeFileId) renderOfficerDesk();
        }

        function checkAndRestoreSession() {
            let savedSession = localStorage.getItem('sessionUser');
            if(savedSession) {
                try {
                    let creds = JSON.parse(savedSession);
                    if (state.authorizedPersonnel[creds.username] && state.authorizedPersonnel[creds.username].password === creds.password) {
                        activeUser = state.authorizedPersonnel[creds.username]; applyUserRoleLayout();
                    }
                } catch(e) { localStorage.removeItem('sessionUser'); }
            } else { renderAuth(); }
        }

        function jumpToActiveNotification() { tab('tab-officer'); document.getElementById('officer-alert-light').classList.add('hidden'); }

        function tab(id) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            document.getElementById(id).classList.remove('hidden');
            document.querySelectorAll('nav button').forEach(b => { b.classList.remove('border-amber-500', 'text-amber-500'); b.classList.add('border-transparent', 'text-gray-400'); });
            const btn = document.getElementById(`btn-${id}`);
            if(btn) { btn.classList.remove('border-transparent', 'text-gray-400'); btn.classList.add('border-amber-500', 'text-amber-500'); }
            if (id === 'tab-officer') { document.getElementById('officer-alert-light').classList.add('hidden'); subtab('sub-app'); }
            sessionStorage.setItem('activeTab', id);
        }

        function subtab(subId) {
            document.getElementById('sub-app').classList.add('hidden');
            document.getElementById('sub-transfer').classList.add('hidden');
            document.getElementById('sub-licensing').classList.add('hidden');
            document.getElementById('sub-vio').classList.add('hidden');
            document.getElementById('sub-rpt').classList.add('hidden');
            document.getElementById(subId).classList.remove('hidden');
            
            document.querySelectorAll('[id^="btn-sub-"]').forEach(btn => {
                btn.classList.remove('sub-active'); btn.classList.add('border-transparent', 'text-gray-400');
            });
            document.getElementById(`btn-${subId}`).classList.add('sub-active');
        }

        /* CHAT AI BOT THÔNG MINH TRA CỨU ĐỘNG DB GỐC */
        async function askAiBot() {
            const msg = document.getElementById('bot-input').value.trim(); if(!msg) return;
            const flow = document.getElementById('bot-chat-flow');
            flow.innerHTML += `<div class="bg-gray-800 p-2.5 rounded-xl text-right text-gray-200 shadow-sm"><span class="text-[9px] block text-gray-500 font-bold">Cư Dân</span>${msg}</div>`;
            document.getElementById('bot-input').value = '';
            
            const res = await fetch('/api/bot/chat', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }) });
            const data = await res.json();
            
            setTimeout(() => {
                flow.innerHTML += `<div class="bg-teal-950/40 border border-teal-900/40 p-2.5 rounded-xl text-teal-300 shadow-inner"><b class="block text-[10px] text-teal-400 uppercase"><i class="fa-solid fa-robot"></i> Tuệ Đức v4</b>${data.reply}</div>`;
                flow.scrollTop = flow.scrollHeight; playTone(450, 'sine', 0.05, 0.04);
            }, 150);
        }

        /* GỬI BÁO CÁO CA TRỰC */
        async function submitShiftReport(e) {
            e.preventDefault();
            const content = document.getElementById('rpt-content').value.trim();
            await fetch('/api/officer/report', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ officer: activeUser.displayName, agency: activeUser.agency, content }) });
            document.getElementById('rpt-content').value = ''; soundSuccess();
            alert('Nhật ký báo cáo trực ban đã được đóng mã bảo mật chuyển thẳng lên Chỉ Huy!');
        }

        async function actionShiftReport(id, status) {
            const feedback = prompt("Nhập ý kiến chỉ đạo phê duyệt quyết định hạ xuống ca trực:"); if(feedback===null) return;
            await fetch('/api/officer/report-action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, status, feedback }) });
            soundStamp();
        }

        /* CẤP PHÔI VĂN BẰNG ĐỘC LẬP TỪ BÀN LÀM VIỆC */
        async function submitLicensingForm(e) {
            e.preventDefault();
            const username = document.getElementById('lic-user').value.trim();
            const license = document.getElementById('lic-type').value;
            const res = await fetch('/api/resident/add-license', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, license, officerName: activeUser.displayName }) });
            if(res.ok) {
                document.getElementById('lic-user').value = ''; soundSuccess();
                alert(`Cấp phôi văn bằng chứng chỉ [${license}] thành công lên hệ thống dữ liệu quốc gia!`);
            } else { alert("Tài khoản cư dân không tồn tại trên hệ thống dữ liệu!"); }
        }

        async function submitViolationForm(e) {
            e.preventDefault();
            const username = document.getElementById('vio-user').value.trim(); const type = document.getElementById('vio-type').value; const lawClause = document.getElementById('vio-clause').value.trim(); const fine = document.getElementById('vio-fine').value.trim() || "0 VND"; const status = document.getElementById('vio-status').value;
            await fetch('/api/resident/violation', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, type, lawClause, fine, status, officerName: activeUser.displayName }) });
            document.getElementById('vio-user').value = ''; document.getElementById('vio-clause').value = ''; document.getElementById('vio-fine').value = '';
            soundStamp(); alert(`Đã đóng ấn ký quyết định xử phạt vi phạm tư pháp kịch bản thành công!`);
        }

        /* ĐIỀU CHUYỂN LIÊN NGÀNH HỒ SƠ VƯỢT THẨM QUYỀN */
        async function executeForwardApplication() {
            if(!activeFileId) { alert("Vui lòng mở xem một hồ sơ cụ thể trước khi thực hiện điều chuyển luồng!"); return; }
            const targetAgency = document.getElementById('transfer-target-agency').value;
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: activeFileId, action: 'forward', targetAgency, officerName: activeUser.displayName, officerRole: activeUser.role }) });
            soundStamp(); alert(`Đã thực hiện sắc lệnh điều chuyển hồ sơ ${activeFileId} liên ngành sang đơn vị bộ phận [${targetAgency}] xử lý.`);
        }

        function generateCitizenCards() {
            const username = document.getElementById('card-search-input').value.trim();
            const zone = document.getElementById('cards-render-zone'); const vioZone = document.getElementById('violation-render-zone');
            if(!registry[username]) {
                zone.innerHTML = `<p class="text-center text-xs text-red-500 font-bold col-span-2 py-6 bg-red-950/20 border border-red-900/30 rounded-xl">⚠️ KHÔNG TÌM THẤY PHÔI GIẤY TỜ KHỞI TẠO CHO CƯ DÂN TRÊN TRỤC DB.</p>`;
                vioZone.innerHTML = ''; return;
            }
            const citizen = registry[username]; soundSuccess();
            
            zone.innerHTML = `
                <div class="national-card w-full max-w-md p-6 text-gray-100 font-sans space-y-4 border-amber-500/30">
                    <div class="flex justify-between items-start border-b border-amber-500/20 pb-2.5">
                        <div>
                            <h4 class="text-[11px] font-black tracking-wider text-amber-400 uppercase">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</h4>
                            <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest mt-0.5">CĂN CƯỚC CÔNG DÂN / CITIZEN IDENTITY</p>
                        </div>
                        <i class="fa-solid fa-star text-amber-400 text-xl animate-pulse"></i>
                    </div>
                    <div class="flex gap-4 items-center">
                        <div class="w-22 h-28 bg-gray-950 border border-gray-800 flex flex-col items-center justify-center rounded-2xl text-gray-700 relative overflow-hidden shadow-inner">
                            <i class="fa-solid fa-user text-5xl mt-4 text-gray-800"></i>
                            <div class="absolute bottom-0 w-full bg-amber-500/20 text-[8px] font-mono font-black text-center text-amber-400 py-1 border-t border-amber-500/20">ROBLOX RP</div>
                        </div>
                        <div class="flex-1 text-[11px] space-y-1.5">
                            <p class="font-mono text-amber-400 font-black text-xs">Số / No: <span class="text-white tracking-widest">0680${1000 + Math.floor(Math.random() * 9000)}</span></p>
                            <p class="text-gray-400 font-bold">Họ và tên: <span class="text-sm font-black text-white uppercase block">${citizen.name}</span></p>
                            <p class="text-gray-400 font-bold">Ngày sinh: <span class="text-white font-mono">${citizen.dob}</span> | Giới tính: <span class="text-white block md:inline">${citizen.gender}</span></p>
                            <p class="text-gray-400 font-bold">Nguyên quán: <span class="text-white text-[10px] block">${citizen.pob}</span></p>
                        </div>
                    </div>
                    <div class="flex justify-between items-center pt-2.5 border-t border-gray-800">
                        <div class="card-chip"></div>
                        <span class="text-[9px] font-black bg-emerald-950 text-emerald-400 border border-emerald-900/60 px-2.5 py-0.5 rounded-lg uppercase tracking-wider">${citizen.status}</span>
                    </div>
                </div>
            `;
            
            citizen.licenses.forEach(lic => {
                zone.innerHTML += `
                    <div class="national-card w-full max-w-md p-5 border-emerald-500/30 text-gray-100 font-sans space-y-3 shadow-2xl">
                        <div class="flex justify-between items-center border-b border-emerald-500/20 pb-1.5"><span class="text-[9px] font-black font-mono tracking-widest text-emerald-400 uppercase"><i class="fa-solid fa-shield mr-1"></i> GIẤY PHÉP ĐIỆN TỬ BAN NGÀNH QUỐC GIA</span></div>
                        <p class="text-[10px] text-gray-400 font-bold">Chủ sở hữu văn bằng danh vị: <span class="text-white font-black block text-xs uppercase mt-0.5">${citizen.name}</span></p>
                        <div class="p-3 bg-black/50 border border-gray-800 rounded-xl shadow-inner"><p class="text-xs font-black text-amber-400 flex items-center gap-2"><i class="fa-solid fa-certificate text-emerald-500 text-sm"></i> ${lic}</p></div>
                    </div>
                `;
            });

            let vioHtml = '';
            if (violations[username] && violations[username].length > 0) {
                violations[username].forEach(v => {
                    vioHtml += `
                        <div class="border border-red-900/60 bg-red-950/10 p-4 rounded-xl space-y-2 shadow-lg animate-fade-in">
                            <div class="flex justify-between items-center border-b border-red-900/40 pb-2"><span class="text-xs font-black text-red-500 font-mono">BIÊN BẢN HÌNH PHẠT: ${v.id}</span><span class="text-[10px] bg-red-950 text-red-400 font-mono px-2 py-0.5 rounded border border-red-900">${v.date}</span></div>
                            <div class="text-[11px] space-y-1">
                                <p class="text-gray-400 font-bold">Cơ quan ban hành: <span class="text-white font-black">${v.type}</span></p>
                                <p class="text-gray-400 font-bold">Nội dung luật áp dụng: <span class="text-amber-500 font-medium block mt-0.5 bg-black/40 p-1.5 rounded border border-gray-800">${v.lawClause}</span></p>
                                <p class="text-gray-400 font-bold">Khung xử phạt kinh tế: <b class="text-yellow-500 font-mono text-xs">${v.fine}</b></p>
                            </div>
                            <div class="pt-2 border-t border-red-900/20"><span class="text-[11px] font-black uppercase text-center text-white tracking-widest bg-red-900 border border-red-700 py-1 rounded block shadow-md">Tình trạng xử lý: [${v.status}]</span></div>
                        </div>
                    `;
                });
            } else { vioHtml = `<p class="text-center text-xs text-emerald-400 font-bold col-span-2 py-6 bg-emerald-950/10 border border-emerald-900/30 rounded-xl"><i class="fa-solid fa-circle-check"></i> LÝ LỊCH TƯ PHÁP TRONG SẠCH - CHƯA PHÁT HIỆN TIỀN ÁN TIỀN SỰ.</p>`; }
            vioZone.innerHTML = vioHtml;
        }

        function renderAll() {
            if(!state.announcements) return;
            document.getElementById('live-marquee').innerText = state.tickerMessage;
            document.getElementById('security-txt').innerText = state.securityLevel;
            
            const feed = document.getElementById('news-feed'); feed.innerHTML = '';
            state.announcements.forEach(a => {
                feed.innerHTML += `
                    <div class="bg-[#0b111e] border border-gray-800 p-4 rounded-xl shadow-md">
                        <span class="text-[9px] font-black text-amber-500 uppercase bg-amber-950 px-2 py-0.5 rounded border border-amber-800">${a.type}</span>
                        <h4 class="text-sm font-black text-white mt-1.5">${a.title}</h4>
                        <p class="text-xs text-gray-400 whitespace-pre-wrap mt-1 leading-relaxed font-medium">${a.content}</p>
                    </div>
                `;
            });

            const wanted = document.getElementById('wanted-feed'); wanted.innerHTML = '';
            state.criminalWantedList.forEach(c => {
                wanted.innerHTML += `<div class="bg-red-950/20 border border-red-900/50 p-3 rounded-xl shadow"><p class="text-xs text-red-400 font-black"><i class="fa-solid fa-bullseye animate-pulse"></i> TRUY NÃ: @${c.name}</p><p class="text-xs text-gray-300 mt-0.5 font-medium">Tội danh: ${c.crime}</p></div>`;
            });

            if (activeUser) {
                const tbody = document.getElementById('officer-table'); tbody.innerHTML = '';
                Object.values(state.applications).forEach(app => {
                    if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ' || app.agency === activeUser.agency) {
                        tbody.innerHTML += `
                            <tr class="hover:bg-gray-900/40 border-b border-gray-800 text-xs transition-all">
                                <td class="p-3 font-black font-mono text-amber-500">${app.id}</td>
                                <td class="p-3 font-bold">@${app.sender}</td>
                                <td class="p-3"><span class="bg-gray-800 text-gray-300 px-2 py-0.5 rounded text-[10px] font-bold border border-gray-700">${app.docType}</span></td>
                                <td class="p-3 font-black"><span class="text-red-400 text-[10px] bg-red-950/40 border border-red-900/60 px-1.5 py-0.5 rounded font-mono">${app.priority}</span></td>
                                <td class="p-3 font-black text-amber-400">${app.status}</td>
                                <td class="p-3 text-right"><button onclick="selectFile('${app.id}')" class="bg-emerald-600 hover:bg-emerald-700 font-black text-white px-3 py-1 rounded-lg text-[11px] shadow transition-all">Thẩm Định</button></td>
                            </tr>
                        `;
                    }
                });

                const rptFeed = document.getElementById('shift-reports-feed');
                if(rptFeed) {
                    rptFeed.innerHTML = '';
                    state.shiftReports.forEach(r => {
                        let isLead = (activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN');
                        let actionBtns = (isLead && r.status === 'CHỜ PHÊ DUYỆT') ? `
                            <div class="flex gap-1 mt-2">
                                <button onclick="actionShiftReport('${r.id}', 'ĐÃ PHÊ DUYỆT')" class="bg-emerald-600 text-white font-black text-[9px] px-2.5 py-1 rounded-lg">Phê Duyệt Chuẩn ✅</button>
                                <button onclick="actionShiftReport('${r.id}', 'KỶ LUẬT NHẮC NHỞ')" class="bg-red-600 text-white font-black text-[9px] px-2.5 py-1 rounded-lg animate-pulse">Kỷ Luật Nhắc Nhở 🚨</button>
                            </div>
                        ` : '';
                        rptFeed.innerHTML += `
                            <div class="bg-gray-950 p-2.5 rounded-xl border border-gray-800 text-[11px] space-y-1">
                                <div class="flex justify-between text-gray-400 font-mono text-[10px]"><span>Ca trực: ${r.officer} [${r.agency}]</span> <b class="text-amber-500">${r.status}</b></div>
                                <p class="text-white bg-black/20 p-2 rounded border border-gray-900 font-medium">${r.content}</p>
                                ${r.feedback ? `<p class="text-teal-400 text-[10px] font-bold">Chỉ đạo Thượng cấp: ${r.feedback}</p>` : ''}
                                ${actionBtns}
                            </div>
                        `;
                    });
                }
            }

            document.getElementById('st-staff').innerText = Object.keys(state.authorizedPersonnel).length - 1;
            document.getElementById('st-files').innerText = Object.keys(state.archivedApplications).length;
            
            const logBox = document.getElementById('admin-system-logs');
            if(logBox) {
                logBox.innerHTML = '';
                state.systemLogs.forEach(l => {
                    logBox.innerHTML += `<div class="py-1 border-b border-gray-900"><span class="text-amber-400 font-bold">[${l.time}]</span> <span class="text-gray-300 font-medium">${l.text}</span></div>`;
                });
            }

            const analytics = document.getElementById('admin-analytics-list');
            if (analytics) {
                analytics.innerHTML = '';
                Object.values(state.authorizedPersonnel).forEach(u => {
                    if (u.username !== 'admin') {
                        analytics.innerHTML += `
                            <div class="bg-gray-950/80 p-3.5 rounded-xl border border-gray-800 text-xs space-y-2 shadow-md">
                                <div class="flex justify-between font-black text-white border-b border-gray-800 pb-1.5"><span>${u.displayName}</span><span class="text-purple-400 text-[10px] uppercase bg-purple-950 px-2 py-0.5 rounded border border-purple-800">${u.role}</span></div>
                                <div class="text-[11px] text-gray-400 font-mono">Đơn vị công vụ: <b class="text-sky-400">${u.agency}</b></div>
                                <div class="flex gap-2 pt-1 border-t border-gray-800/60"><button onclick="editOfficer('${u.username}')" class="flex-1 bg-sky-600 text-white font-bold py-1 rounded text-[10px] uppercase">Sửa</button><button onclick="deleteOfficer('${u.username}')" class="bg-red-600 text-white font-bold px-2 py-1 rounded text-[10px] uppercase">Tước Quyền</button></div>
                            </div>
                        `;
                    }
                });
            }
        }

        function editOfficer(username) {
            let u = state.authorizedPersonnel[username]; if(!u) return;
            document.getElementById('p-user').value = u.username; document.getElementById('p-user').readOnly = true;
            document.getElementById('p-pass').value = u.password; document.getElementById('p-name').value = u.displayName;
            document.getElementById('p-role').value = u.role; document.getElementById('p-agency').value = u.agency;
            document.getElementById('p-isEdit').value = "true";
            document.getElementById('form-provision-title').innerHTML = `<i class="fa-solid fa-user-gear text-sky-400"></i> Hiệu chỉnh chứng thư công vụ`;
            document.getElementById('btn-submit-provision').innerText = "Cập Nhật Quyết Định";
            document.getElementById('btn-cancel-edit').classList.remove('hidden');
        }

        function resetProvisionForm() {
            document.getElementById('p-user').value = ''; document.getElementById('p-user').readOnly = false;
            document.getElementById('p-pass').value = ''; document.getElementById('p-name').value = '';
            document.getElementById('p-isEdit').value = "false";
            document.getElementById('form-provision-title').innerHTML = `<i class="fa-solid fa-id-card-clip"></i> Thiết Lập / Phân Quyền Nhân Sự`;
            document.getElementById('btn-submit-provision').innerText = "Kích Hoạt Chứng Thư";
            document.getElementById('btn-cancel-edit').classList.add('hidden');
        }

        async function deleteOfficer(username) {
            if(!confirm(`Bãi nhiệm tước quyền vĩnh viễn tài khoản [${username}]?`)) return;
            await fetch('/api/officer/delete', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username }) });
        }

        async function registerResidentByOfficer(e) {
            e.preventDefault();
            const username = document.getElementById('res-user').value.trim(); const name = document.getElementById('res-name').value.trim(); const dob = document.getElementById('res-dob').value.trim(); const gender = document.getElementById('res-gender').value; const pob = document.getElementById('res-pob').value.trim(); const job = document.getElementById('res-job').value.trim(); const licenses = document.getElementById('res-licenses').value.trim(); const status = document.getElementById('res-status').value;
            await fetch('/api/resident/register', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, name, dob, gender, pob, job, licenses, status, officerName: activeUser.displayName }) });
            document.getElementById('res-user').value = ''; document.getElementById('res-name').value = ''; document.getElementById('res-dob').value = ''; document.getElementById('res-pob').value = ''; document.getElementById('res-job').value = ''; document.getElementById('res-licenses').value = '';
            soundSuccess(); alert(`Định danh thành công cư dân kịch bản!`);
        }

        async function submitForm(e) {
            e.preventDefault();
            const sender = document.getElementById('app-sender').value.trim(); const docType = document.getElementById('app-docType').value; const priority = document.getElementById('app-priority').value; const agency = document.getElementById('app-agency').value; const content = document.getElementById('app-content').value.trim();
            const res = await fetch('/api/applications/submit', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sender, agency, docType, content, priority }) });
            const data = await res.json();
            document.getElementById('app-content').value = ''; document.getElementById('track-id').value = data.id;
            soundSuccess(); trackApplication();
        }

        function trackApplication() {
            const id = document.getElementById('track-id').value.trim(); const area = document.getElementById('track-details'); const empty = document.getElementById('track-empty');
            let app = state.applications[id] || state.archivedApplications[id];
            if (!app) { area.classList.add('hidden'); empty.classList.remove('hidden'); return; }
            empty.classList.add('hidden'); area.classList.remove('hidden');

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-gray-950 p-2.5 rounded border border-gray-900 text-[11px] font-medium"><p class="text-[9px] font-bold text-gray-500">${l.sender} • ${l.time}</p><p class="text-white mt-0.5">${l.msg}</p></div>`;
            });
            let satBlock = '';
            if ((app.status === 'Đã Phê Duyệt' || app.status === 'Bị Bác Bỏ') && !app.satisfaction) {
                satBlock = `
                    <div class="space-y-1.5 p-2 bg-gray-950 border border-gray-900 rounded-xl flex gap-2 justify-center">
                        <button onclick="sendAction('${id}', 'satisfaction', 'HÀI LÒNG')" class="bg-emerald-600 text-white font-black px-4 py-1.5 rounded-lg text-[10px] uppercase">Hài Lòng 👍</button>
                        <button onclick="sendAction('${id}', 'satisfaction', 'KHIẾU NẠI CẤP CAO')" class="bg-red-600 text-white font-black px-4 py-1.5 rounded-lg text-[10px] uppercase animate-pulse">🚨 KHIẾU NẠI KHẨN 🚨</button>
                    </div>
                `;
            } else if (app.satisfaction) {
                satBlock = `<div class="text-center text-[10px] font-black uppercase text-amber-500 bg-gray-950 p-2 rounded-xl border border-gray-900">Phản hồi chất lượng: [${app.satisfaction}]</div>`;
            }

            area.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3 max-h-[300px] pr-1">
                    <div class="bg-gray-950 p-3 rounded-xl border border-gray-900 flex justify-between items-center shadow-md">
                        <div><p class="font-black text-amber-500">${app.id} [${app.docType}]</p><span class="text-[9px] font-mono text-gray-500 block">Độ khẩn: ${app.priority}</span></div>
                        <div class="stamp-box ${app.stamp}">${app.status}</div>
                    </div>
                    <div class="space-y-2" id="citizen-chat-flow">${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-slate-800 space-y-2">
                    ${satBlock}
                    <div class="flex gap-2">
                        <input type="text" id="citizen-chat-msg" placeholder="Phản hồi tin nhắn..." class="flex-1 bg-gray-950 border border-gray-800 p-2 text-xs text-white rounded-xl focus:outline-none">
                        <button onclick="citizenChat('${app.id}')" class="bg-amber-500 font-black text-black px-4 text-xs rounded-xl uppercase">Gửi</button>
                    </div>
                </div>
            `;
            setTimeout(() => { const el = document.getElementById('citizen-chat-flow'); if (el) el.scrollTop = el.scrollHeight; }, 50);
        }

        async function citizenChat(id) {
            const msg = document.getElementById('citizen-chat-msg').value.trim(); if (!msg) return;
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action: 'chat', msg, officerName: `Công Dân (@${(state.applications[id] || state.archivedApplications[id]).sender})` }) });
            document.getElementById('citizen-chat-msg').value = '';
        }

        function selectFile(id) { activeFileId = id; document.getElementById('officer-desk-empty').classList.add('hidden'); document.getElementById('officer-desk-active').classList.remove('hidden'); renderOfficerDesk(); }

        /* PHƠI BÀY TOÀN BỘ LÝ LỊCH CƯ DÂN NGAY TRÊN KHUNG TIẾP NHẬN ĐƠN */
        function renderOfficerDesk() {
            let app = state.applications[activeFileId] || state.archivedApplications[activeFileId]; if(!app) return;
            const desk = document.getElementById('officer-desk-active');

            // Quét tìm thông tin cư dân thụ hưởng đơn thư ngay lập tức
            let citizenInfoHtml = `<p class="text-red-400 text-[10px] font-bold"><i class="fa-solid fa-triangle-exclamation"></i> Không tìm thấy định danh cư dân này trên DB hệ thống liên thông.</p>`;
            if (registry[app.sender]) {
                let c = registry[app.sender];
                let v = criminalRecordsRegistry[app.sender] || [];
                citizenInfoHtml = `
                    <div class="bg-black/40 border border-gray-800 p-3 rounded-xl text-[11px] space-y-1.5 text-gray-300 font-medium">
                        <p class="text-xs font-black text-amber-400 border-b border-gray-900 pb-1 flex justify-between"><span><i class="fa-solid fa-address-card"></i> ${c.name}</span> <span class="text-gray-500 font-mono">Dob: ${c.dob}</span></p>
                        <p>Nguyên quán: <b class="text-white">${c.pob}</b> | Nghề nghiệp: <b class="text-white">${c.job}</b></p>
                        <p>Giấy phép sở hữu: <span class="text-sky-400 font-bold font-mono">${c.licenses.join(' — ') || 'Trống'}</span></p>
                        <p class="flex justify-between font-bold"><span>Tư pháp: <b class="text-emerald-400">${c.status}</b></span> <span>Tiền án vi phạm: <b class="text-red-500 font-mono">${v.length}</b></span></p>
                    </div>
                `;
            }

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-gray-950 p-2 rounded border border-gray-900 text-[11px]"><p class="text-[9px] text-gray-500 font-bold">${l.sender} • ${l.time}</p><p class="text-white mt-0.5 font-medium">${l.msg}</p></div>`;
            });
            let actionsHtml = '';
            if (state.applications[activeFileId]) {
                if (app.status === 'Đang Chờ Tiếp Nhận') {
                    actionsHtml = `<button onclick="sendAction('${app.id}', 'claim_packet')" class="w-full bg-gradient-to-r from-sky-500 to-blue-600 text-white font-black py-2.5 rounded-xl text-xs uppercase shadow-md tracking-wider">Thụ Lý Tiếp Nhận Đơn Thư</button>`;
                } else {
                    let isLead = (activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN');
                    actionsHtml = `
                        <div class="grid grid-cols-2 gap-2">
                            ${isLead ? `
                                <button onclick="sendAction('${app.id}', 'status', 'Đã Phê Duyệt', 'stamp-approved')" class="bg-emerald-600 text-white font-black py-1.5 rounded-xl text-[10px] uppercase shadow">Phê Duyệt</button>
                                <button onclick="sendAction('${app.id}', 'status', 'Bị Bác Bỏ', 'stamp-rejected')" class="bg-red-600 text-white font-black py-1.5 rounded-xl text-[10px] uppercase shadow">Bác Bỏ</button>
                            ` : `
                                <button onclick="sendAction('${app.id}', 'status', 'Trình Duyệt Sắc Lệnh', 'stamp-leader')" class="bg-amber-600 text-black font-black py-1.5 col-span-2 rounded-xl text-[10px] uppercase shadow">Trình Tấu Thượng Cấp</button>
                            `}
                        </div>
                        ${isLead ? `<button onclick="sendAction('${app.id}', 'archive')" class="w-full bg-purple-600 text-white font-black py-1.5 rounded-xl text-[10px] uppercase tracking-wide">Đóng Niêm Phong Vào Kho</button>` : ''}
                    `;
                }
            } else { actionsHtml = `<div class="text-center text-[10px] text-purple-400 font-bold uppercase bg-purple-950/20 p-2.5 rounded-xl border border-purple-900/40">🔒 Bản ghi đã lưu kho bảo mật quốc gia</div>`; }

            desk.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3.5 max-h-[380px] pr-1">
                    <div class="bg-gray-950 p-2.5 rounded-xl border border-gray-900 text-[11px] relative shadow-inner">
                        <div class="absolute top-2 right-2 stamp-box ${app.stamp}">${app.status}</div>
                        <p class="font-black text-amber-500 font-mono">MÃ ĐƠN: ${app.id} [${app.docType}]</p>
                        <p class="text-gray-400 italic mt-1 bg-black/30 p-2 rounded border border-gray-900 font-medium">"${app.content}"</p>
                    </div>
                    <p class="text-[10px] font-black text-sky-400 uppercase tracking-wider flex items-center gap-1"><i class="fa-solid fa-wand-magic-sparkles"></i> Phơi lý lịch liên thông tự động của cư dân:</p>
                    ${citizenInfoHtml}
                    <div class="space-y-2" id="officer-chat-flow">${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-gray-800 space-y-2">
                    ${actionsHtml}
                    <div class="flex gap-2">
                        <input type="text" id="officer-chat-msg" placeholder="Chỉ thị gửi công dân..." class="flex-1 bg-gray-950 border border-gray-800 p-2 text-xs text-white rounded-xl focus:outline-none">
                        <button onclick="officerChat()" class="bg-emerald-600 font-black text-white px-4 text-xs rounded-xl uppercase">Gửi</button>
                    </div>
                </div>
            `;
            setTimeout(() => { const el = document.getElementById('officer-chat-flow'); if (el) el.scrollTop = el.scrollHeight; }, 50);
        }

        async function officerChat() {
            const msg = document.getElementById('officer-chat-msg').value.trim(); if (!msg) return;
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: activeFileId, action: 'chat', msg, officerName: `${activeUser.displayName} (${activeUser.agency})` }) });
            document.getElementById('officer-chat-msg').value = '';
        }

        async function sendAction(id, action, status = '', stamp = '', targetAgency = '') {
            if(action === 'status' || action === 'claim_packet' || action === 'archive') soundStamp();
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action, status, stamp, targetAgency, officerName: activeUser ? activeUser.displayName : 'Hệ thống', officerRole: activeUser ? activeUser.role : 'Hệ thống' }) });
        }

        async function publishDocument() {
            const type = document.getElementById('pub-type').value; const title = document.getElementById('pub-title').value.trim(); const content = document.getElementById('pub-content').value.trim(); if(!title || !content) return;
            await fetch('/api/national/publish', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ type, title, content, author: activeUser.displayName }) });
            document.getElementById('pub-title').value = ''; document.getElementById('pub-content').value = ''; soundSuccess();
        }

        async function updateTicker() {
            const msg = document.getElementById('pub-ticker').value.trim(); if(!msg) return;
            await fetch('/api/national/ticker', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }) });
            document.getElementById('pub-ticker').value = ''; soundSuccess();
        }

        async function deleteNews(id) { await fetch('/api/national/delete-announcement', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) }); }
        async function setSecurity(level) { await fetch('/api/national/security', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ level }) }); }
        async function provisionAccount(e) { e.preventDefault(); const username = document.getElementById('p-user').value.trim(); const password = document.getElementById('p-pass').value; const displayName = document.getElementById('p-name').value.trim(); const role = document.getElementById('p-role').value; const agency = document.getElementById('p-agency').value; const isEdit = document.getElementById('p-isEdit').value === "true"; await fetch('/api/officer/save', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, password, displayName, role, agency, isEdit }) }); resetProvisionForm(); soundSuccess(); }

        /* HIỆU CHỈNH TAB TRA CỨU ĐỊNH DANH CƯ DÂN CHUYÊN NGHIỆP */
        function searchCitizen() {
            const q = document.getElementById('id-search').value.trim(); const resArea = document.getElementById('id-result');
            if (registry[q]) {
                let r = registry[q]; let v = criminalRecordsRegistry[q] || []; soundSuccess();
                resArea.innerHTML = `
                    <div class="cyber-panel p-5 text-xs space-y-3 shadow-2xl border-amber-500/30">
                        <div class="flex justify-between items-center border-b border-gray-800 pb-2"><p class="text-base font-black text-amber-400 uppercase tracking-wide flex items-center gap-1.5"><i class="fa-solid fa-passport"></i> Căn cước gốc: ${r.name}</p><span class="bg-emerald-950 text-emerald-400 font-bold px-2 py-0.5 rounded border border-emerald-800 font-mono text-[10px]">LÕI ĐỒNG BỘ MẠNG</span></div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-2 text-gray-300 font-medium">
                            <p>Ngày sinh: <span class="text-white font-mono">${r.dob}</span> | Giới tính: <span class="text-white">${r.gender}</span></p>
                            <p>Nguyên quán công tác: <span class="text-white">${r.pob}</span></p>
                            <p>Nghề nghiệp chức danh: <span class="text-white">${r.job}</span></p>
                            <p>Hồ sơ tư pháp: <span class="text-emerald-400 font-bold">${r.status}</span></p>
                        </div>
                        <div class="p-3 bg-black/40 border border-gray-800 rounded-xl"><p class="text-[11px] font-bold text-gray-400 mb-1">Mã chứng chỉ nghiệp vụ đang sở hữu:</p><p class="text-sky-400 font-black font-mono tracking-wide">${r.licenses.join(' — ') || 'Chưa cấp phôi'}</p></div>
                        <div class="p-3 bg-red-950/10 border border-red-900/30 rounded-xl"><p class="text-[11px] font-bold text-red-400 mb-1">Nhật ký vi phạm xử lý dân sự kịch bản (${v.length}):</p><p class="text-gray-400 font-mono">${v.map(item=>`[${item.id}] ${item.type} - Phạt: ${item.fine}`).join('<br>') || 'Lý lịch hoàn toàn trong sạch'}</p></div>
                    </div>
                `;
            } else { resArea.innerHTML = `<p class="text-center text-red-400 text-xs font-black bg-red-950/20 border border-red-900/40 p-4 rounded-xl">⚠️ SAI LỖI CẤU TRÚC: KHÔNG TÌM THẤY TÀI KHOẢN TRÊN MÁY CHỦ QUỐC GIA.</p>`; }
        }

        function openLogin() { document.getElementById('login-modal').classList.remove('hidden'); }
        function closeLogin() { document.getElementById('login-modal').classList.add('hidden'); }
        function login() { const u = document.getElementById('log-user').value; const p = document.getElementById('log-pass').value; if (state.authorizedPersonnel[u] && state.authorizedPersonnel[u].password === p) { activeUser = state.authorizedPersonnel[u]; localStorage.setItem('sessionUser', JSON.stringify({ username: u, password: p })); closeLogin(); soundSuccess(); applyUserRoleLayout(); } else { alert("Mật mã chứng thư nghiệp vụ sai!"); } }
        function applyUserRoleLayout() { if(!activeUser) return; document.getElementById('btn-tab-officer').classList.remove('hidden'); if(activeUser.role === 'ADMIN') document.getElementById('btn-tab-admin').classList.remove('hidden'); if(activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ') { document.getElementById('leader-publish-zone').classList.remove('hidden'); } else { document.getElementById('leader-publish-zone').classList.add('hidden'); } renderAuth(); renderAll(); let savedTab = sessionStorage.getItem('activeTab'); tab(savedTab || 'tab-officer'); }
        function logout() { activeUser = null; activeFileId = null; localStorage.removeItem('sessionUser'); document.getElementById('btn-tab-officer').classList.add('hidden'); document.getElementById('btn-tab-admin').classList.add('hidden'); renderAuth(); tab('tab-news'); }
        function renderAuth() { const p = document.getElementById('auth-panel'); if(!activeUser) { p.innerHTML = `<button onclick="openLogin()" class="bg-amber-500 text-black px-4 py-2 rounded-xl text-[11px] uppercase font-black tracking-wider shadow">Đăng Nhập Nghiệp Vụ</button>`; } else { p.innerHTML = `<div class="bg-gray-950 border border-gray-800 p-1.5 text-xs rounded-xl flex items-center gap-2 shadow-inner"><b class="text-white">${activeUser.displayName}</b><button onclick="logout()" class="text-red-400 ml-2"><i class="fa-solid fa-power-off"></i></button></div>`; } }
        
        startClock();
    </script>
</body>
</html>
