<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CỔNG THÔNG TIN ĐIỆN TỬ CHÍNH PHỦ - GIẢ LẬP ROLEPLAY</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Space+Grotesk:wght@400;500;600;700&display=swap');
        body { font-family: 'Space Grotesk', sans-serif; background-color: #05070f; color: #cbd5e1; }
        .font-mono-tech { font-family: 'Share Tech Mono', monospace; }
        
        .stamp-box { position: relative; font-size: 11px; font-weight: 800; text-transform: uppercase; padding: 5px 12px; border-radius: 4px; border: 2.5px dashed; display: inline-block; text-align: center; letter-spacing: 1px; transform: rotate(-6deg) scale(1.05); text-shadow: 0 0 4px currentColor; box-shadow: inset 0 0 6px rgba(0,0,0,0.2); animation: stampAppear 0.2s ease-out; }
        .stamp-approved { border-color: #10b981; color: #10b981; background: rgba(16, 185, 129, 0.08); }
        .stamp-rejected { border-color: #ef4444; color: #ef4444; background: rgba(239, 68, 68, 0.08); }
        .stamp-pending { border-color: #f59e0b; color: #f59e0b; background: rgba(245, 158, 11, 0.08); }
        .stamp-forwarded { border-color: #3b82f6; color: #3b82f6; background: rgba(59, 130, 246, 0.08); }
        .stamp-leader { border-color: #a855f7; color: #a855f7; background: rgba(168, 85, 247, 0.12); border-style: double; border-width: 4px; }
        .stamp-archived { border-color: #94a3b8; color: #94a3b8; background: rgba(148, 163, 184, 0.1); }

        @keyframes stampAppear { 0% { transform: scale(1.8) rotate(-20deg); opacity: 0; } 100% { transform: scale(1.05) rotate(-6deg); opacity: 1; } }
        
        .marquee-container { width: 100%; overflow: hidden; white-space: nowrap; background: #090d16; border-top: 1px solid #1e293b; border-bottom: 1px solid #1e293b; }
        .marquee-content { display: inline-block; padding-left: 100%; animation: marquee 35s linear infinite; font-size: 12px; font-weight: 600; color: #f59e0b; text-shadow: 0 0 6px rgba(245, 158, 11, 0.4); }
        @keyframes marquee { 0% { transform: translate3d(0, 0, 0); } 100% { transform: translate3d(-100%, 0, 0); } }
        .bar-chart-fill { height: 100%; transition: width 0.6s ease; border-radius: 3px; }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between">

    <div class="flex-1">
        <header class="bg-[#0a0f1d] border-b border-slate-800 px-6 py-3.5 flex flex-wrap justify-between items-center shadow-lg relative">
            <div class="flex items-center space-x-4">
                <div class="relative flex items-center justify-center">
                    <div class="absolute inset-0 bg-amber-500/20 blur-md rounded-full animate-pulse"></div>
                    <div class="bg-gradient-to-br from-amber-400 to-amber-600 p-2.5 rounded-xl text-black border border-amber-300 shadow-lg z-10">
                        <i class="fa-solid fa-building-columns text-2xl"></i>
                    </div>
                    <div class="absolute -bottom-1 -right-1 bg-red-600 text-[8px] font-black text-white px-1 rounded-md border border-black animate-bounce">RP</div>
                </div>
                <div>
                    <span class="text-[10px] tracking-widest text-amber-500 uppercase font-extrabold font-mono-tech">Roblox Gaming Roleplay Community Platform</span>
                    <h1 class="text-xl font-black text-white tracking-tight drop-shadow-sm flex items-center gap-2">CỔNG LIÊN THÔNG GIẢ LẬP <span class="text-[11px] font-mono bg-slate-800 text-slate-400 px-1.5 py-0.5 rounded border border-slate-700">v4.5.0-RP</span></h1>
                </div>
            </div>

            <div class="flex items-center space-x-4 text-xs">
                <div id="officer-alert-light" class="hidden bg-red-950/80 border border-red-500 px-3 py-1.5 rounded-lg flex items-center gap-2 animate-pulse">
                    <span class="h-2 w-2 rounded-full bg-red-500 shadow-[0_0_10px_#ef4444]"></span>
                    <span id="alert-light-text" class="text-red-400 font-black text-[11px] tracking-wide uppercase">CÓ ĐƠN THƯ/TIN NHẮN MỚI</span>
                </div>
                <div class="bg-[#0f172a] px-3 py-1.5 rounded-lg border border-slate-800 font-mono text-amber-400 font-bold tracking-widest shadow-inner shadow-black" id="clock">00:00:00</div>
                <div class="bg-[#0f172a] px-3 py-1.5 rounded-lg border border-slate-800 flex items-center gap-2">
                    <span class="h-2 w-2 rounded-full bg-emerald-500 animate-ping"></span>
                    <span id="security-txt" class="font-extrabold text-[11px] tracking-wider uppercase text-emerald-400"><%= state.securityLevel %></span>
                </div>
                <div id="auth-panel"></div>
            </div>
        </header>

        <div class="marquee-container py-2 flex items-center">
            <div class="bg-red-950 text-red-400 border border-red-900/60 font-black text-[9px] px-2 py-0.5 rounded uppercase tracking-wider mx-3 z-10 shadow-md">Thông báo khẩn</div>
            <div class="marquee-content" id="live-marquee"><%= state.tickerMessage %></div>
        </div>

        <nav class="bg-[#0a0f1d]/80 border-b border-slate-800/80 px-6 flex space-x-1.5 backdrop-blur-md">
            <button onclick="tab('tab-news')" id="btn-tab-news" class="px-4 py-3 text-xs font-black uppercase tracking-wider border-b-2 border-amber-500 text-amber-500 transition-all"><i class="fa-solid fa-newspaper mr-1"></i> Trung Tâm Ấn Bản</button>
            <button onclick="tab('tab-id')" id="btn-tab-id" class="px-4 py-3 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-slate-400 hover:text-white transition-all"><i class="fa-solid fa-address-card mr-1"></i> Tra cứu định danh</button>
            <button onclick="tab('tab-services')" id="btn-tab-services" class="px-4 py-3 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-slate-400 hover:text-white transition-all"><i class="fa-solid fa-file-invoice-dollar mr-1"></i> Nộp Đơn Thủ Tục</button>
            <button onclick="tab('tab-officer')" id="btn-tab-officer" class="px-4 py-3 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-emerald-500 hover:text-emerald-400 hidden relative">
                <i class="fa-solid fa-user-shield mr-1"></i> Bàn Làm Việc Bộ Ngành 
                <span id="badge-count-app" class="absolute top-1.5 right-1 bg-red-600 text-white text-[9px] px-1 rounded-full font-black hidden">0</span>
            </button>
            <button onclick="tab('tab-admin')" id="btn-tab-admin" class="px-4 py-3 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-purple-400 hover:text-purple-300 hidden"><i class="fa-solid fa-crown mr-1"></i> Phòng Giám Sát Tối Cao</button>
        </nav>

        <main class="p-6 max-w-[1650px] w-full mx-auto space-y-6">
            
            <section id="tab-news" class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <div class="lg:col-span-2 space-y-4">
                    <h2 class="text-xs font-black text-slate-400 uppercase tracking-widest border-b border-slate-800 pb-2 flex items-center gap-2"><i class="fa-solid fa-scroll text-amber-500"></i> Văn Bản Chỉ Thị / Sắc Lệnh Từ Bộ Chỉ Huy</h2>
                    <div id="news-feed" class="space-y-3"></div>
                </div>
                <div class="space-y-4">
                    <h2 class="text-xs font-black text-red-400 uppercase tracking-widest border-b border-slate-800 pb-2 flex items-center gap-2"><i class="fa-solid fa-triangle-exclamation animate-pulse"></i> Cơ Sở Dữ Liệu Đối Tượng Truy Nã Quốc Gia</h2>
                    <div id="wanted-feed" class="space-y-3"></div>
                </div>
            </section>

            <section id="tab-id" class="hidden max-w-2xl mx-auto bg-[#0a0f1d] border border-slate-800 p-6 rounded-2xl shadow-xl">
                <h2 class="text-xs font-black text-center text-white uppercase tracking-widest mb-4"><i class="fa-solid fa-shield-halved text-amber-500"></i> Cơ Sở Dữ Liệu Căn Cước Dân Sự Quốc Gia</h2>
                <div class="flex gap-2 mb-4">
                    <input type="text" id="id-search" placeholder="Nhập tên tài khoản cư dân (Ví dụ: Nguyen_Manh_Hoang)..." class="flex-1 bg-slate-900 border border-slate-700 px-3 py-2 text-sm rounded-lg text-white focus:outline-none focus:border-amber-500 font-mono">
                    <button onclick="searchCitizen()" class="bg-amber-500 hover:bg-amber-600 text-black px-5 text-xs font-black uppercase rounded-lg transition-all">Truy xuất dữ liệu</button>
                </div>
                <div id="id-result"></div>
            </section>

            <section id="tab-services" class="hidden grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl space-y-4 shadow-lg">
                    <h3 class="text-xs font-black text-slate-300 uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-file-pen text-amber-500"></i> Tạo Hồ Sơ Trực Tuyến Đa Dạng</h3>
                    <form onsubmit="submitForm(event)" class="space-y-3.5 text-xs">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            <div>
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Tên Tài Khoản Hệ Thống (Họ_Tên)</label>
                                <input type="text" id="app-sender" required placeholder="Nguyen_Manh_Hoang" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-mono">
                            </div>
                            <div>
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Loại Giấy Tờ / Thủ Tục Đăng Ký</label>
                                <select id="app-docType" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-bold text-amber-400">
                                    <option value="CĂN CƯỚC CÔNG DÂN">Căn Cước Công Dân Gắn Chíp (Làm mới/Cấp đổi)</option>
                                    <option value="GIẤY PHÉP SỬ DỤNG CÔNG CỤ HỖ TRỢ">Giấy Phép Sử Dụng Vũ Khí / Công Cụ Hỗ Trợ</option>
                                    <option value="HỘ CHIẾU QUỐC TẾ">Hộ Chiếu Quốc Tế (Visa Xuất Nhập Cảnh)</option>
                                    <option value="GIẤY PHÉP KINH DOANH DOANH NGHIỆP">Giấy Phép Thành Lập / Kinh Doanh Doanh Nghiệp</option>
                                    <option value="ĐĂNG KÝ KẾT HÔN / KHAI SINH">Đăng Ký Kết Hôn / Giấy Khai Sinh Cư Dân</option>
                                    <option value="CHỨNG CHỈ HÀNH NGHỀ CHUYÊN MÔN">Chứng Chỉ Hành Nghề Chuyên Môn Đặc Chủng</option>
                                    <option value="ĐĂNG KÝ SỬ DỤNG TẦN SỐ BỘ ĐÀM MÃ HÓA">Đăng Ký Sử Dụng Tần Số Bộ Đàm Mã Hóa Quốc Gia</option>
                                    <option value="GIẤY PHÉP VẬN TẢI LOGISTICS ĐƯỜNG BỘ">Giấy Phép Vận Tải Quốc Tế / Logistics Đường Bộ</option>
                                    <option value="ĐƠN XIN GIA NHẬP LỰC LƯỢNG VŨ TRANG">Đơn Tuyển Dụng / Gia Nhập Lực Lượng Vũ Trang</option>
                                    <option value="BẰNG KHAI THÁC KHOÁNG SẢN & TÀI NGUYÊN">Giấy Phép Khai Thác Tài Nguyên Môi Trường</option>
                                    <option value="ĐƠN XIN TỔ CHỨC SỰ KIỆN QUẦN CHÚNG">Đơn Đăng Ký Tổ Chức Sự Kiện Nơi Công Cộng</option>
                                    <option value="HỒ SƠ KHÁM SỨC KHỎE TƯ PHÁP">Hồ Sơ Chứng Nhận Y Tế & Sức Khỏe Tư Pháp</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Cơ Quan Tiếp Nhận Thẩm Định</label>
                            <select id="app-agency" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-bold">
                                <option value="CÔNG AN">BỘ CÔNG AN (Hồ sơ Căn cước, Giao thông, An ninh)</option>
                                <option value="QUÂN ĐỘI">BỘ CHỈ HUY QUÂN SỰ TRƯỞNG</option>
                                <option value="UBND PHƯỜNG">ỦY BAN NHÂN DÂN CẤP PHƯỜNG / THÀNH PHỐ</option>
                                <option value="TOÀ ÁN">TÒA ÁN NHÂN DÂN TỐI CAO</option>
                                <option value="NGÂN HÀNG">NGÂN HÀNG TRUNG ƯƠNG QUỐC GIA</option>
                                <option value="BỆNH VIỆN">BỆNH VIỆN QUỐC GIA LIÊN THÔNG</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Trình Bày Nội Dung Chi Tiết Lý Do Gửi Đơn</label>
                            <textarea id="app-content" rows="4" required placeholder="Ghi rõ thông tin yêu cầu giải quyết..." class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white focus:border-amber-500 focus:outline-none"></textarea>
                        </div>
                        <button type="submit" class="w-full bg-gradient-to-r from-amber-400 to-amber-500 font-black text-black py-3 rounded-lg uppercase tracking-widest hover:brightness-110 shadow-lg">Gửi Hồ Sơ Lên Hệ Thống Quốc Gia</button>
                    </form>
                </div>

                <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl flex flex-col h-full min-h-[480px] shadow-lg">
                    <h3 class="text-xs font-black text-slate-300 uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-satellite-dish text-sky-400 animate-pulse"></i> Kiểm Tra Tiến Độ & Đàm Thoại Trực Tuyến</h3>
                    <div class="flex gap-2 my-3">
                        <input type="text" id="track-id" placeholder="Nhập mã đơn thư cần tra cứu (Ví dụ: HS-1001)..." class="flex-1 bg-slate-900 border border-slate-700 px-3 py-2 text-xs rounded-lg text-white font-mono focus:outline-none">
                        <button onclick="trackApplication()" class="bg-sky-600 hover:bg-sky-700 text-white px-5 text-xs font-black rounded-lg transition-all">Truy vấn đơn</button>
                    </div>
                    <div id="track-details" class="flex-1 flex flex-col justify-between hidden space-y-3"></div>
                    <div id="track-empty" class="text-center py-16 text-slate-500 text-xs flex-1 flex flex-col justify-center items-center"><i class="fa-solid fa-folder-open text-4xl mb-3 text-slate-700"></i> Nhập chính xác mã số đơn hành chính của bạn để mở luồng đàm thoại với cán bộ nghiệp vụ trực ban.</div>
                </div>
            </section>

            <section id="tab-officer" class="hidden grid grid-cols-1 xl:grid-cols-3 gap-6">
                <div class="xl:col-span-2 space-y-5">
                    
                    <div class="bg-[#0a0f1d] border border-slate-800 p-4 rounded-2xl shadow-md">
                        <div class="flex justify-between items-center mb-3">
                            <h3 class="text-xs font-black text-emerald-400 uppercase tracking-wider flex items-center gap-2"><i class="fa-solid fa-folder-closed"></i> Hồ Sơ Hành Chính Chờ Duyệt Lĩnh Vực</h3>
                            <span id="office-badge" class="text-[10px] font-mono font-bold bg-emerald-950/60 text-emerald-400 px-2.5 py-1 rounded-lg border border-emerald-800">Cơ Quan Tiếp Nhận</span>
                        </div>
                        <div class="overflow-x-auto text-xs">
                            <table class="w-full text-left">
                                <thead class="bg-slate-900 text-slate-400 font-bold uppercase text-[9px] tracking-wider">
                                    <tr>
                                        <th class="p-3">Mã Hồ Sơ</th>
                                        <th class="p-3">Tài Khoản</th>
                                        <th class="p-3">Loại Giấy Tờ</th>
                                        <th class="p-3">Trạng Thái</th>
                                        <th class="p-3 text-right">Hành Động</th>
                                    </tr>
                                </thead>
                                <tbody id="officer-table" class="divide-y divide-slate-800"></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl space-y-3.5 shadow-lg">
                        <h3 class="text-xs font-black text-teal-400 uppercase tracking-widest border-b border-slate-800 pb-2 flex items-center gap-2"><i class="fa-solid fa-user-plus"></i> Nghiệp Vụ Cán Bộ: Số Hóa & Khai Sinh Dữ Liệu Định Danh Cư Dân</h3>
                        <form onsubmit="registerResidentByOfficer(event)" class="grid grid-cols-1 md:grid-cols-3 gap-3 text-xs">
                            <div>
                                <label class="block text-gray-400 mb-1">Tài Khoản Định Danh (Họ_Tên)</label>
                                <input type="text" id="res-user" required placeholder="Nguyen_Manh_Hoang" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white font-mono">
                            </div>
                            <div>
                                <label class="block text-gray-400 mb-1">Họ Và Tên Khai Sinh</label>
                                <input type="text" id="res-name" required placeholder="Nguyễn Mạnh Hoàng" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white">
                            </div>
                            <div>
                                <label class="block text-gray-400 mb-1">Ngày Tháng Năm Sinh</label>
                                <input type="text" id="res-dob" required placeholder="18/05/1996" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white">
                            </div>
                            <div>
                                <label class="block text-gray-400 mb-1">Giới Tính</label>
                                <select id="res-gender" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white font-bold">
                                    <option value="Nam">Nam</option>
                                    <option value="Nữ">Nữ</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-gray-400 mb-1">Nguyên Quán / Nơi Sinh</label>
                                <input type="text" id="res-pob" required placeholder="Lâm Đồng, Việt Nam" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white">
                            </div>
                            <div>
                                <label class="block text-gray-400 mb-1">Nghề Nghiệp / Công Tác</label>
                                <input type="text" id="res-job" required placeholder="Chuyên Viên Cung Ứng Vật Tư" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white">
                            </div>
                            <div class="md:col-span-2">
                                <label class="block text-gray-400 mb-1">Giấy Phép / Chứng Chỉ Sở Hữu (Cách nhau bằng dấu phẩy)</label>
                                <input type="text" id="res-licenses" placeholder="Bằng Lái Xe Hạng B2, Giấy phép công cụ hỗ trợ" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white">
                            </div>
                            <div>
                                <label class="block text-gray-400 mb-1">Tình Trạng Tư Pháp Quốc Gia</label>
                                <select id="res-status" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white font-black text-emerald-400">
                                    <option value="Dân Cư Hợp Pháp - Lý Lịch Trong Sạch">Dân Cư Hợp Pháp - Lý Lịch Sạch</option>
                                    <option value="Đang Thuộc Diện Theo Dõi Đặc Biệt">Diện Theo Dõi Đặc Biệt</option>
                                    <option value="Đối Tượng Tình Nghi Hình Sự Khẩn Cấp">Đối Tượng Tình Nghi Hình Sự</option>
                                </select>
                            </div>
                            <button type="submit" class="md:col-span-3 bg-gradient-to-r from-teal-500 to-emerald-600 text-white font-black py-2.5 rounded-lg uppercase tracking-wider hover:brightness-110 shadow-md transition-all">Lưu Thông Tin Vào Máy Chủ Quốc Gia</button>
                        </form>
                    </div>

                    <div id="leader-publish-zone" class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl space-y-3.5 shadow-xl hidden">
                        <h3 class="text-xs font-black text-amber-500 uppercase tracking-widest border-b border-slate-800 pb-1.5 flex items-center gap-2"><i class="fa-solid fa-gavel text-xl"></i> Quyền Hạn Lãnh Đạo Cao Cấp: Chỉ Huy Hệ Thống Toàn Quốc</h3>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 text-xs">
                            <div>
                                <label class="block text-gray-400 mb-1">Loại Hình Văn Bản</label>
                                <select id="pub-type" class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white font-bold">
                                    <option value="QUYẾT ĐỊNH">QUYẾT ĐỊNH BAN HÀNH SẮC LỆNH</option>
                                    <option value="THÔNG BÁO KHẨN">THÔNG BÁO KHẨN CẤP AN NINH</option>
                                    <option value="TRUY NÃ">LỆNH TRUY NÃ BỊ CAN HÌNH SỰ</option>
                                </select>
                            </div>
                            <div class="md:col-span-2">
                                <label class="block text-gray-400 mb-1">Tiêu Đề Văn Bản / Họ Tên Đối Tượng Bị Truy Nã</label>
                                <input type="text" id="pub-title" placeholder="Nhập tên đối tượng hoặc tiêu đề nội dung..." class="w-full bg-slate-900 border border-slate-700 p-2 rounded-lg text-white focus:outline-none">
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 text-xs">
                            <div class="md:col-span-2">
                                <label class="block text-gray-400 mb-1">Nội dung văn bản chỉ thị chi tiết</label>
