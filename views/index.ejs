                <div class="pt-2 border-t border-slate-800 space-y-2">
                    ${actionsHtml}
                    <div class="flex gap-2">
                        <input type="text" id="officer-chat-msg" placeholder="Nhập câu hỏi, chỉ thị gửi công dân..." class="flex-1 bg-slate-900 border border-slate-700 p-2 text-xs text-white rounded-lg focus:outline-none">
                        <button onclick="officerChat()" class="bg-emerald-600 font-black text-white px-4 text-xs rounded-lg uppercase">Gửi</button>
                    </div>
                </div>
            `;
            setTimeout(() => { const el = document.getElementById('officer-chat-flow'); if (el) el.scrollTop = el.scrollHeight; }, 50);
        }

        function trackApplication() {
            const id = document.getElementById('track-id').value.trim();
            const area = document.getElementById('track-details'); const empty = document.getElementById('track-empty');
            let app = state.applications[id] || state.archivedApplications[id];
            if (!app) { area.classList.add('hidden'); empty.classList.remove('hidden'); return; }
            empty.classList.add('hidden'); area.classList.remove('hidden');

            let chatHtml = ''; app.logs.forEach(l => { chatHtml += `<div class="bg-slate-900 p-2 rounded border border-slate-800 text-[11px]"><p class="text-[9px] font-bold text-gray-500">${l.sender} • ${l.time}</p><p class="text-white mt-0.5">${l.msg}</p></div>`; });
            area.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3 max-h-[300px] pr-1">
                    <div class="bg-slate-900 p-3 rounded-xl border border-slate-800 flex justify-between items-center shadow-md">
                        <div><p class="font-black text-amber-500">${app.id} [${app.docType}]</p></div>
                        <div class="stamp-box ${app.stamp}">${app.status}</div>
                    </div>
                    <div class="space-y-2" id="citizen-chat-flow">${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-slate-800 space-y-2">
                    <div class="flex gap-2">
                        <input type="text" id="citizen-chat-msg" placeholder="Phản hồi câu hỏi kịch bản..." class="flex-1 bg-slate-900 border border-slate-700 p-2 text-xs text-white rounded-lg focus:outline-none">
                        <button onclick="citizenChat('${app.id}')" class="bg-amber-500 font-black text-black px-4 text-xs rounded-lg uppercase">Gửi</button>
                    </div>
                </div>
            `;
        }

        async function citizenChat(id) { const msg = document.getElementById('citizen-chat-msg').value.trim(); if (!msg) return; await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action: 'chat', msg, officerName: `Công Dân (@${(state.applications[id] || state.archivedApplications[id]).sender})` }) }); document.getElementById('citizen-chat-msg').value = ''; }
        async function publishDocument() { const type = document.getElementById('pub-type').value; const title = document.getElementById('pub-title').value.trim(); const content = document.getElementById('pub-content').value.trim(); if(!title || !content) return; await fetch('/api/national/publish', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ type, title, content, author: activeUser.displayName }) }); document.getElementById('pub-title').value = ''; document.getElementById('pub-content').value = ''; soundSuccess(); }
        async function updateTicker() { const msg = document.getElementById('pub-ticker').value.trim(); if(!msg) return; await fetch('/api/national/ticker', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }) }); document.getElementById('pub-ticker').value = ''; soundSuccess(); }
        async function deleteNews(id) { await fetch('/api/national/delete-announcement', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) }); }
        async function setSecurity(level) { await fetch('/api/national/security', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ level }) }); }
        async function provisionAccount(e) { e.preventDefault(); const username = document.getElementById('p-user').value.trim(); const password = document.getElementById('p-pass').value; const displayName = document.getElementById('p-name').value.trim(); const role = document.getElementById('p-role').value; const agency = document.getElementById('p-agency').value; const isEdit = document.getElementById('p-isEdit').value; await fetch('/api/officer/save', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, password, displayName, role, agency, isEdit }) }); resetProvisionForm(); soundSuccess(); }
        function openLogin() { document.getElementById('login-modal').classList.remove('hidden'); }
        function closeLogin() { document.getElementById('login-modal').classList.add('hidden'); }
        function login() { const u = document.getElementById('log-user').value; const p = document.getElementById('log-pass').value; if (state.authorizedPersonnel[u] && state.authorizedPersonnel[u].password === p) { activeUser = state.authorizedPersonnel[u]; localStorage.setItem('sessionUser', JSON.stringify({ username: u, password: p })); closeLogin(); soundSuccess(); applyUserRoleLayout(); } else { alert("Mật mã sai!"); } }
        
        function applyUserRoleLayout() {
            if(!activeUser) return;
            document.getElementById('btn-tab-officer').classList.remove('hidden');
            if(activeUser.role === 'ADMIN') document.getElementById('btn-tab-admin').classList.remove('hidden');
            if(activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ') {
                document.getElementById('leader-publish-zone').classList.remove('hidden'); document.getElementById('leader-notice-block').classList.add('hidden');
            } else {
                document.getElementById('leader-publish-zone').classList.add('hidden'); document.getElementById('leader-notice-block').classList.remove('hidden');
            }
            renderAuth(); renderAll(); let savedTab = sessionStorage.getItem('activeTab'); tab(savedTab || 'tab-officer');
        }
        function logout() { activeUser = null; activeFileId = null; localStorage.removeItem('sessionUser'); document.getElementById('btn-tab-officer').classList.add('hidden'); document.getElementById('btn-tab-admin').classList.add('hidden'); renderAuth(); tab('tab-news'); }
        function renderAuth() { const p = document.getElementById('auth-panel'); if(!activeUser) { p.innerHTML = `<button onclick="openLogin()" class="bg-amber-500 text-black px-4 py-2 rounded-lg text-[11px] uppercase font-black">Đăng nhập nghiệp vụ</button>`; } else { p.innerHTML = `<div class="bg-slate-900 border p-1 text-xs rounded-xl flex items-center gap-2"><b class="text-white">${activeUser.displayName}</b><button onclick="logout()" class="text-red-400 ml-2"><i class="fa-solid fa-power-off"></i></button></div>`; } }
        
        startClock();
    </script>
</body>
</html>
