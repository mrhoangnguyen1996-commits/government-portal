            // KHO LƯU TRỮ QUỐC GIA TẠI PHÒNG GIÁM SÁT TỐI CAO - BẤM CHUỘT MỞ XEM CHI TIẾT HỒ SƠ TỨC THÌ
            const adminVault = document.getElementById('admin-vault-list');
