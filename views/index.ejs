            <p class="text-[11px] text-red-400/90 font-medium leading-relaxed uppercase tracking-wide max-w-4xl mx-auto">
                CẢNH BÁO CHÍNH THỨC: ĐÂY LÀ TRANG WEB GIẢ LẬP HOÀN TOÀN KHÔNG CÓ THỰC ĐƯỢC PHÁT TRIỂN PHỤC VỤ ĐỘC QUYỀN CHO MỤC ĐÍCH ĐỒNG BỘ KỊCH BẢN TƯƠNG TÁC NHẬP VAI (ROLEPLAY) GIẢI TRÍ TRÊN NỀN TẢNG ROBLOX GAMING. CHÚNG TÔI KHÔNG ĐẠI DIỆN, KHÔNG LIÊN KẾT VÀ KHÔNG SỞ HỮU BẤT KỲ THẨM QUYỀN NÀO CỦA CƠ QUAN CHỨC NĂNG CÓ THỰC NGOÀI ĐỜI THỰC. TOÀN BỘ DANH TÁNH, SỐ CĂN CƯỚC, BIÊN BẢN XỬ PHẠT VÀ TIỀN TỆ TRÊN HỆ THỐNG CHỈ CÓ GIÁ TRỊ TRONG PHẠM VI TRÒ CHƠI. NGHIÊM CẤM MỌI HÀNH VI SỬ DỤNG HÌNH ẢNH CỦA TRANG WEB NÀY ĐỂ THỰC HIỆN CÁC HÀNH VI LỪA ĐẢO HOẶC MẠO DANH CƠ QUAN CÔNG QUYỀN NGOÀI THỰC TẾ. NGƯỜI VI PHẠM TỰ CHỊU TRÁCH NHIỆM HOÀN TOÀN TRƯỚC PHÁP LUẬT VIỆT NAM.
            </p>
            <div class="text-[10px] text-slate-600 font-mono pt-2 border-t border-slate-900">&copy; 2026 National Cyber Gaming Simulator Project. Toàn bộ kịch bản được bảo lưu trên Sandbox Cloud.</div>
        </div>
    </footer>

    <div id="login-modal" class="fixed inset-0 bg-black/95 backdrop-blur-md flex items-center justify-center hidden p-4 z-50">
        <div class="bg-[#0a0f1d] border-2 border-slate-700 p-7 rounded-2xl max-w-sm w-full space-y-4 text-xs shadow-2xl relative">
            <div class="text-center space-y-1">
                <i class="fa-solid fa-key text-4xl text-amber-500 mb-1 animate-pulse"></i>
                <h3 class="text-sm font-black text-white uppercase tracking-widest">Mã Hóa Chứng Thư Nghiệp Vụ</h3>
                <p class="text-[10px] text-slate-500 font-mono">Yêu cầu xác thực tài khoản phân hệ liên thông quốc gia</p>
            </div>
            <div><label class="text-gray-400 block mb-1.5 font-bold uppercase">Mã định danh cán bộ</label><input type="text" id="log-user" class="w-full bg-slate-900 border border-slate-700 p-3 rounded-lg text-white font-mono focus:outline-none focus:border-amber-500"></div>
            <div><label class="text-gray-400 block mb-1.5 font-bold uppercase">Mật mã bảo mật hệ thống</label><input type="password" id="log-pass" class="w-full bg-slate-900 border border-slate-700 p-3 rounded-lg text-white focus:outline-none focus:border-amber-500"></div>
            <div class="flex gap-2 pt-2">
                <button onclick="closeLogin()" class="w-1/3 bg-slate-800 text-slate-400 py-2.5 rounded-lg uppercase font-black tracking-wider transition-colors hover:bg-slate-700">Đóng</button>
                <button onclick="login()" class="w-2/3 bg-gradient-to-r from-amber-400 to-amber-500 text-black py-2.5 rounded-lg uppercase font-black tracking-wider transition-all hover:from-amber-300">Xác Minh Nghiệp Vụ</button>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        let state = {};
        let registry = {};
        let violations = {}; 
        let activeUser = null;
        let activeFileId = null;

        // KIẾN TRÚC SÓNG ÂM ĐA TẦN SỐ CHUYÊN NGHIỆP v7.0
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        function playTone(freq, type, duration, vol) {
            try {
                const osc = audioCtx.createOscillator();
                const gainNode = audioCtx.createGain();
                osc.type = type; osc.frequency.value = freq;
                gainNode.gain.setValueAtTime(vol, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.00001, audioCtx.currentTime + duration);
                osc.connect(gainNode); gainNode.connect(audioCtx.destination);
                osc.start(); osc.stop(audioCtx.currentTime + duration);
            } catch(e) {}
        }

        const soundClick = () => playTone(580, 'sine', 0.07, 0.1);
        const soundSuccess = () => { playTone(523.25, 'sine', 0.1, 0.15); setTimeout(() => playTone(659.25, 'sine', 0.12, 0.15), 60); };
        const soundAlert = () => { playTone(987.77, 'sawtooth', 0.2, 0.12); setTimeout(() => playTone(987.77, 'sawtooth', 0.2, 0.12), 180); };
        const soundStamp = () => { playTone(90, 'triangle', 0.25, 0.5); playTone(220, 'sawtooth', 0.09, 0.15); };
        const soundDecline = () => { playTone(220, 'sawtooth', 0.3, 0.2); };

        document.addEventListener('click', (e) => {
            if(e.target.closest('button') || e.target.closest('nav button') || e.target.closest('select')) { soundClick(); }
        });

        function startClock() { 
            setInterval(() => { 
                document.getElementById('clock').innerText = new Date().toLocaleTimeString('vi-VN'); 
            }, 1000);
        }

        // ĐIỀU PHỐI TAB CON
        function subTab(id) {
            document.querySelectorAll('[id^="subtab-off-"]').forEach(s => s.classList.add('hidden'));
            document.getElementById(`subtab-${id}`).classList.remove('hidden');
            document.querySelectorAll('.subtab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById(`btn-${id}`).classList.add('active');
        }

        function adminSubTab(id) {
            document.querySelectorAll('[id^="subtab-adm-"]').forEach(s => s.classList.add('hidden'));
            document.getElementById(`subtab-${id}`).classList.remove('hidden');
        }

        // LẮNG NGHE ĐỒNG BỘ DỮ LIỆU TỪ MÁY CHỦ SỐ TỨC THỜI < 0.1S
        socket.on('initData', (data) => { updateDataAndRender(data); checkAndRestoreSession(); });
        socket.on('stateUpdate', (data) => { updateDataAndRender(data); });
        
        socket.on('newApplicationAlert', (appInfo) => {
            if (activeUser) {
                if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ' || appInfo.agency === activeUser.agency) {
                    document.getElementById('officer-alert-light').classList.remove('hidden');
                    soundAlert();
                }
            }
        });

        socket.on('newChatMessage', (chatInfo) => {
            if (document.getElementById('track-id').value === chatInfo.fileId) trackApplication();
            if (activeFileId === chatInfo.fileId) renderOfficerDesk();
        });

        function updateDataAndRender(data) {
            state = data.systemState;
            registry = data.citizenIdentityRegistry;
            violations = data.criminalRecordsRegistry;
            if (activeUser) activeUser = state.authorizedPersonnel[activeUser.username];
            
            if (activeUser) {
                let filtered = Object.values(state.applications).filter(a => {
                    if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ') return true;
                    return a.agency === activeUser.agency;
                });
                const badgeCount = document.getElementById('badge-count-app');
                if (filtered.length > 0) {
                    badgeCount.innerText = filtered.length;
                    badgeCount.classList.remove('hidden');
                } else {
                    badgeCount.classList.add('hidden');
                }
            }
            renderAll();
            if (activeFileId) renderOfficerDesk();
        }

        function checkAndRestoreSession() {
            let savedSession = localStorage.getItem('sessionUser');
            if(savedSession) {
                try {
                    let creds = JSON.parse(savedSession);
                    if (state.authorizedPersonnel[creds.username] && state.authorizedPersonnel[creds.username].password === creds.password) {
                        activeUser = state.authorizedPersonnel[creds.username];
                        applyUserRoleLayout();
                    }
                } catch(e) { localStorage.removeItem('sessionUser'); }
            } else { renderAuth(); }
        }

        function jumpToActiveNotification() { tab('tab-officer'); subTab('off-applications'); document.getElementById('officer-alert-light').classList.add('hidden'); }

        function tab(id) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            document.getElementById(id).classList.remove('hidden');
            document.querySelectorAll('nav button').forEach(b => {
                b.classList.remove('border-amber-500', 'text-amber-500');
                b.classList.add('border-transparent', 'text-slate-400');
            });
            const btn = document.getElementById(`btn-${id}`);
            if(btn) btn.classList.add('border-amber-500', 'text-amber-500');
            if (id === 'tab-officer') {
                document.getElementById('officer-alert-light').classList.add('hidden');
                if(activeUser && (activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN')) {
                    document.getElementById('btn-off-leaderzone').classList.remove('hidden');
                }
                subTab('off-applications');
            }
            if (id === 'tab-admin') adminSubTab('adm-stats');
            sessionStorage.setItem('activeTab', id);
        }

        // LUỒNG XỬ LÝ VI PHẠM TỰ ĐỘNG ĐÓNG KHÓA VÀO KHO QUỐC GIA
        async function submitViolationForm(e) {
            e.preventDefault();
            const username = document.getElementById('vio-user').value.trim();
            const type = document.getElementById('vio-type').value;
            const lawClause = document.getElementById('vio-clause').value.trim();
            const fine = document.getElementById('vio-fine').value.trim() || "0 VND";
            const status = document.getElementById('vio-status').value;

            await fetch('/api/resident/violation', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, type, lawClause, fine, status, officerName: activeUser.displayName })
            });

            // Tự động đồng bộ biên bản thành một hồ sơ lưu kho lưu trữ quốc gia để mở xem lại
            if(status === 'Quyết Định Thành Công - Đã Nộp Phạt' || status === 'Tịch Thu Phương Tiện / Giam Giữ Tư Pháp') {
                await fetch('/api/applications/submit', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ sender: username, agency: activeUser.agency, docType: "QUYẾT ĐỊNH TƯ PHÁP XỬ PHẠT", content: `Biên bản xử lý số hiệu hành vi: ${lawClause}. Khung hình phạt: ${fine}. Trạng thái kết xuất: ${status}. Người ký ban hành: ${activeUser.displayName}` })
                });
            }

            document.getElementById('vio-user').value = '';
            document.getElementById('vio-clause').value = '';
            document.getElementById('vio-fine').value = '';
            soundStamp();
            alert(`Sắc lệnh xử phạt tư pháp khởi tạo thành công & Đã tự động đồng bộ chuyển giao Kho Lưu Trữ Quốc Gia!`);
        }

        // TRUY XUẤT ĐỒ HỌA PHÔI CĂN CƯỚC VÀ CÁC LOẠI BẰNG CẤP ĐA DẠNG NGHIỆP VỤ (KHÔNG RANDOM KHI F5)
        function generateCitizenCards() {
            const username = document.getElementById('card-search-input').value.trim();
            const zone = document.getElementById('cards-render-zone');
            const vioZone = document.getElementById('violation-render-zone');
            if(!registry[username]) {
                zone.innerHTML = `<p class="text-center text-xs text-red-500 col-span-2 py-6 font-black"><i class="fa-solid fa-circle-exclamation mr-1"></i> KHÔNG TÌM THẤY DỮ LIỆU ĐỊNH DANH TRÊN TOÀN QUỐC.</p>`;
                vioZone.innerHTML = `<p class="text-center text-xs text-slate-600 col-span-2">Không có dữ liệu lý lịch tư pháp tư pháp.</p>`;
                return;
            }
            const citizen = registry[username];
            soundSuccess();
            
            // Mã căn cước dựa trên chuỗi tên cố định không bị thay đổi khi bấm F5
            let seedCode = 0; for (let i = 0; i < username.length; i++) { seedCode += username.charCodeAt(i); }
            let fixId = 68000000 + (seedCode * 123) % 899999;

            let cardCcTmpl = `
                <div class="national-card w-full p-6 rounded-2xl border-l-4 border-amber-500 text-slate-100 font-sans space-y-4">
                    <div class="flex justify-between items-start border-b border-amber-500/30 pb-2">
                        <div>
                            <h4 class="text-[11px] font-black tracking-wider text-amber-400 uppercase">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</h4>
                            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">CĂN CƯỚC CÔNG DÂN / CITIZEN IDENTITY CARD</p>
                        </div>
                        <i class="fa-solid fa-star text-amber-400 text-lg shadow-sm"></i>
                    </div>
                    <div class="flex gap-4 items-center">
                        <div class="w-24 h-28 bg-slate-900 border border-slate-700 flex flex-col items-center justify-center rounded-xl text-slate-600 relative overflow-hidden shadow-inner">
                            <i class="fa-solid fa-user text-5xl mt-4 text-slate-500"></i>
                            <div class="absolute bottom-0 w-full bg-amber-500 text-[8px] font-mono font-black text-center text-black py-0.5">ẢNH SỐ HÓA</div>
                        </div>
                        <div class="flex-1 text-[11px] space-y-1.5">
                            <p class="font-mono text-amber-500 font-bold text-xs">Số / ID: <span class="text-white tracking-widest font-black">${fixId}</span></p>
                            <p class="text-slate-400 font-bold">Họ và tên: <span class="text-sm font-black text-white uppercase">${citizen.name}</span></p>
                            <p class="text-slate-400 font-bold">Ngày sinh: <span class="text-white font-mono">${citizen.dob}</span></p>
                            <p class="text-slate-400 font-bold">Giới tính: <span class="text-white">${citizen.gender}</span></p>
                            <p class="text-slate-400 font-bold">Nguyên quán: <span class="text-white">${citizen.pob}</span></p>
                            <p class="text-slate-400 font-bold">Công tác: <span class="text-white font-mono">${citizen.job}</span></p>
                        </div>
                    </div>
                    <div class="flex justify-between items-center pt-2 border-t border-slate-800">
                        <div class="card-chip shadow-md"></div>
                        <div class="text-right"><span class="text-[9px] font-black bg-emerald-950 text-emerald-400 border border-emerald-800/60 px-2.5 py-1 rounded uppercase tracking-wider">${citizen.status}</span></div>
                    </div>
                </div>
            `;

            let cardLicensesHtml = '';
            citizen.licenses.forEach(lic => {
                let isWeapon = lic.includes("Vũ Khí") || lic.includes("Công Cụ Hỗ Trợ") || lic.includes("Lực Lượng Vũ Trang");
                let isThẻNgành = lic.includes("Công Chức") || lic.includes("Thẻ Ngành");
                let borderTheme = isWeapon ? 'border-l-4 border-red-500' : (isThẻNgành ? 'border-l-4 border-purple-500' : 'border-l-4 border-sky-500');
                let badgeIcon = isWeapon ? 'fa-gun text-red-500' : (isThẻNgành ? 'fa-user-shield text-purple-400' : 'fa-id-card text-sky-400');

                cardLicensesHtml += `
                    <div class="national-card w-full p-6 rounded-2xl ${borderTheme} text-slate-100 font-sans space-y-3">
                        <div class="flex justify-between items-center border-b border-slate-800 pb-1.5">
                            <span class="text-[9px] font-black font-mono tracking-widest text-slate-400 uppercase"><i class="fa-solid fa-shield mr-1"></i> CHỨNG CHỈ / VĂN BẰNG ĐIỆN TỬ BAN NGÀNH</span>
                            <i class="fa-solid ${badgeIcon} text-sm"></i>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[11px] text-slate-400 font-bold">Chủ quyền văn bằng: <span class="text-white font-black uppercase text-xs">${citizen.name}</span></p>
                            <p class="text-[10px] text-slate-500 font-mono">Định danh máy chủ: @${username}</p>
                        </div>
                        <div class="p-3 bg-black/50 border border-slate-800 rounded-xl shadow-inner">
                            <p class="text-xs font-black text-amber-400 uppercase tracking-wide flex items-center gap-2"><i class="fa-solid fa-circle-check text-emerald-500"></i> ${lic}</p>
                        </div>
                    </div>
                `;
            });
            zone.innerHTML = cardCcTmpl + cardLicensesHtml;

            let vioHtml = '';
            if (violations[username] && violations[username].length > 0) {
                violations[username].forEach(v => {
                    vioHtml += `
                        <div class="border-2 border-red-900/60 bg-red-950/10 p-5 rounded-xl relative space-y-3 shadow-xl">
                            <div class="flex justify-between items-center border-b border-red-900/40 pb-2">
                                <span class="text-xs font-black text-red-500 font-mono"><i class="fa-solid fa-gavel mr-1"></i> QUYẾT ĐỊNH XỬ PHẠT SỐ HỆ THỐNG: ${v.id}</span>
                                <span class="text-[10px] bg-red-950 text-red-400 font-mono px-2 py-0.5 rounded border border-red-800">${v.date}</span>
                            </div>
                            <div class="text-[11px] space-y-1.5">
                                <p class="text-slate-400 font-bold">Cơ quan ban hành tư pháp: <span class="text-white font-black">${v.type}</span></p>
                                <p class="text-slate-400 font-bold">Nội dung bộ luật áp dụng: <span class="text-amber-500 font-medium">${v.lawClause}</span></p>
                                <p class="text-slate-400 font-bold">Khung xử phạt dân sự: <b class="text-yellow-500 font-mono text-xs">${v.fine}</b></p>
                                <p class="text-slate-400 font-bold">Cán bộ ký lập quyết định: <span class="text-slate-300 italic font-bold">${v.officer}</span></p>
                            </div>
                            <div class="pt-2 border-t border-red-900/20">
                                <span class="text-[11px] font-black uppercase text-center text-white tracking-widest bg-red-900/80 border border-red-700 px-3 py-1.5 rounded block shadow-sm">Quy trình tiến độ: [${v.status}]</span>
                            </div>
                        </div>
                    `;
                });
            } else {
                vioHtml = `<p class="text-center text-xs text-emerald-400 font-bold col-span-2 py-8"><i class="fa-solid fa-circle-check text-xl block mb-2"></i> LÝ LỊCH TƯ PHÁP TRONG SẠCH - DÂN CƯ CHƯA CÓ TIỀN ÁN TIỀN SỰ TRÊN HỆ THỐNG.</p>`;
            }
            vioZone.innerHTML = vioHtml;
        }

        function renderAll() {
            if(!state.announcements) return;
            document.getElementById('live-marquee').innerText = state.tickerMessage;
            document.getElementById('security-txt').innerText = state.securityLevel;
            
            const feed = document.getElementById('news-feed'); feed.innerHTML = '';
            state.announcements.forEach(a => {
                let deleteBtn = (activeUser && (activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN')) ? 
                    `<button onclick="deleteNews('${a.id}')" class="text-[10px] text-red-400 hover:underline font-bold"><i class="fa-solid fa-trash-can"></i> Gỡ ấn bản</button>` : '';
                feed.innerHTML += `
                    <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-xl relative shadow-md space-y-2">
                        <div class="flex justify-between items-center"><span class="text-[9px] font-black text-amber-500 uppercase bg-amber-950 px-2 py-0.5 rounded border border-amber-800 tracking-wider">${a.type}</span>${deleteBtn}</div>
                        <h4 class="text-sm font-black text-white">${a.title}</h4>
                        <p class="text-xs text-slate-400 whitespace-pre-wrap leading-relaxed">${a.content}</p>
                        <div class="text-[10px] text-slate-500 font-mono pt-1 border-t border-slate-900">Ban hành: ${a.timestamp}</div>
                    </div>
                `;
            });

            const wanted = document.getElementById('wanted-feed'); wanted.innerHTML = '';
            state.criminalWantedList.forEach(c => {
                wanted.innerHTML += `
                    <div class="bg-red-950/10 border border-red-900/50 p-4 rounded-xl relative overflow-hidden glow-border-red">
                        <p class="text-xs text-red-400 font-black flex items-center gap-1.5"><i class="fa-solid fa-bullseye animate-pulse"></i> LỆNH TRUY NÃ: @${c.name}</p>
                        <p class="text-xs text-slate-300 mt-1 font-bold">Tội danh truy tố: <span class="text-red-300 font-normal">${c.crime}</span></p>
                        <p class="text-xs text-yellow-500 font-black mt-1.5 font-mono">Bounty Quỹ Thưởng: ${c.bounty}</p>
                    </div>
                `;
            });

            if (activeUser) {
                document.getElementById('office-badge').innerText = `ĐƠN VỊ CHỦ QUẢN: [${activeUser.agency}] — CÁN BỘ TIẾP NHẬN: ${activeUser.displayName} [${activeUser.role}]`;
                const tbody = document.getElementById('officer-table'); tbody.innerHTML = '';
                Object.values(state.applications).forEach(app => {
                    if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ' || app.agency === activeUser.agency) {
                        tbody.innerHTML += `
                            <tr class="hover:bg-slate-900/80 border-b border-slate-800 text-xs transition-all">
                                <td class="p-3 font-black font-mono text-amber-500">${app.id}</td>
                                <td class="p-3 font-bold text-slate-300">@${app.sender}</td>
                                <td class="p-3"><span class="bg-slate-800 text-slate-300 px-2 py-0.5 rounded text-[10px] font-black">${app.docType}</span></td>
                                <td class="p-3 font-black"><span class="text-amber-400">${app.status}</span></td>
                                <td class="p-3 text-right"><button onclick="selectFile('${app.id}')" class="bg-emerald-600 font-black text-white px-3 py-1.5 rounded-md text-[11px] shadow-sm hover:bg-emerald-500 transition-colors">Thẩm Định / Khảo Sát</button></td>
                            </tr>
                        `;
                    }
                });

                const leadArch = document.getElementById('leader-archive-list');
                if(leadArch) {
                    leadArch.innerHTML = '';
                    Object.values(state.archivedApplications).forEach(ar => {
                        if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ' || ar.agency === activeUser.agency) {
                            leadArch.innerHTML += `
                                <div class="bg-slate-900 p-2.5 rounded-lg border border-slate-800 flex justify-between items-center text-[11px]">
                                    <div><b class="text-purple-400 font-mono">${ar.id}</b> - @${ar.sender} <span class="text-slate-500">(${ar.docType})</span></div>
