        }

        async function sendAction(id, action, status = '', stamp = '', targetAgency = '') {
            if(action === 'status' || action === 'claim_packet' || action === 'archive') soundStamp();
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action, status, stamp, targetAgency, officerName: activeUser ? activeUser.displayName : 'Hệ thống', officerRole: activeUser ? activeUser.role : 'Hệ thống' }) });
        }

        async function publishDocument() {
            const type = document.getElementById('pub-type').value;
            const title = document.getElementById('pub-title').value.trim(); const content = document.getElementById('pub-content').value.trim(); if(!title || !content) return;
            await fetch('/api/national/publish', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ type, title, content, author: activeUser.displayName }) });
            document.getElementById('pub-title').value = ''; document.getElementById('pub-content').value = ''; soundSuccess();
        }

        async function updateTicker() {
            const msg = document.getElementById('pub-ticker').value.trim();
            if(!msg) return;
            await fetch('/api/national/ticker', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }) });
            document.getElementById('pub-ticker').value = ''; soundSuccess();
        }

        async function deleteNews(id) { await fetch('/api/national/delete-announcement', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) }); }
        async function setSecurity(level) { await fetch('/api/national/security', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ level }) }); }
        
        async function provisionAccount(e) {
            e.preventDefault(); const username = document.getElementById('p-user').value.trim(); const password = document.getElementById('p-pass').value; const displayName = document.getElementById('p-name').value.trim(); const role = document.getElementById('p-role').value; const agency = document.getElementById('p-agency').value;
            await fetch('/api/officer/save', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, password, displayName, role, agency }) });
            resetProvisionForm(); soundSuccess();
        }

        // SỬA LỖI TRA CỨU ĐỊNH DANH THÔNG MINH KHÔNG PHÂN BIỆT KÝ TỰ HOA THƯỜNG
        function searchCitizen() {
            const q = document.getElementById('id-search').value.trim().toLowerCase(); 
            const resArea = document.getElementById('id-result');
            if (registry[q]) {
                let r = registry[q]; let v = criminalRecordsRegistry[q] || []; soundSuccess();
                resArea.innerHTML = `
                    <div class="bg-[#0a0f24] border border-gray-800 p-5 text-xs space-y-3 rounded-2xl shadow-2xl text-left">
                        <div class="flex justify-between items-center border-b border-gray-800 pb-2"><p class="text-base font-black text-amber-400 uppercase flex items-center gap-1.5"><i class="fa-solid fa-passport"></i> Định Danh Cư Dân: ${r.name}</p></div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-2 text-gray-300 font-medium">
                            <p>Ngày sinh: <span class="text-white font-mono">${r.dob}</span> | Giới tính: <span class="text-white">${r.gender}</span></p>
                            <p>Nguyên quán: <span class="text-white">${r.pob}</span></p>
                            <p>Nghề nghiệp: <span class="text-white">${r.job}</span></p>
                            <p>Số định danh cá nhân: <span class="text-yellow-400 font-mono font-bold">${r.cccdNumber}</span></p>
                            <p>Lý lịch quốc gia: <span class="text-emerald-400 font-bold">${r.status}</span></p>
                        </div>
                        <div class="p-3 bg-black/40 border border-gray-800 rounded-xl"><p class="text-[11px] font-bold text-gray-400 mb-1">Mã văn bằng / Giấy phép sở hữu:</p><p class="text-sky-400 font-black font-mono tracking-wide">${r.licenses.join(' — ') || 'Chưa cấp phôi mộc'}</p></div>
                    </div>
                `;
            } else { resArea.innerHTML = `<p class="text-center text-red-400 text-xs font-black bg-red-950/20 border border-red-900/40 p-4 rounded-xl">⚠️ KHÔNG TÌM THẤY DỮ LIỆU ĐỊNH DANH TRÊN MÁY CHỦ SỐ HÓA TRUNG ƯƠNG.</p>`; }
        }

        function openLogin() { document.getElementById('login-modal').classList.remove('hidden'); }
        function closeLogin() { document.getElementById('login-modal').classList.add('hidden'); }
        function login() {
            const u = document.getElementById('log-user').value; const p = document.getElementById('log-pass').value;
            if (state.authorizedPersonnel[u] && state.authorizedPersonnel[u].password === p) {
                activeUser = state.authorizedPersonnel[u]; localStorage.setItem('sessionUser', JSON.stringify({ username: u, password: p })); closeLogin(); soundSuccess(); applyUserRoleLayout();
            } else { alert("Sai chứng thư nghiệp vụ!"); }
        }
        function applyUserRoleLayout() {
            if(!activeUser) return;
            document.getElementById('btn-tab-officer').classList.remove('hidden');
            if(activeUser.role === 'ADMIN') document.getElementById('btn-tab-admin').classList.remove('hidden');
            if(activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'VĂN PHÒNG CHÍNH PHỦ') { document.getElementById('leader-publish-zone').classList.remove('hidden'); }
            else { document.getElementById('leader-publish-zone').classList.add('hidden'); }
            renderAuth(); renderAll(); let savedTab = sessionStorage.getItem('activeTab'); tab(savedTab || 'tab-officer');
        }
        function logout() { activeUser = null; activeFileId = null; localStorage.removeItem('sessionUser'); document.getElementById('btn-tab-officer').classList.add('hidden'); document.getElementById('btn-tab-admin').classList.add('hidden'); renderAuth(); tab('tab-news'); }
        function renderAuth() {
            const p = document.getElementById('auth-panel');
            if(!activeUser) { p.innerHTML = `<button onclick="openLogin()" class="bg-amber-500 text-black px-4 py-2 rounded-xl text-[11px] uppercase font-black">Đăng nhập nghiệp vụ</button>`; }
            else { p.innerHTML = `<div class="bg-gray-950 border border-gray-800 p-1.5 text-xs rounded-xl flex items-center gap-2 shadow-inner"><b class="text-white">${activeUser.displayName}</b><button onclick="logout()" class="text-red-400 ml-2"><i class="fa-solid fa-power-off"></i></button></div>`; }
        }
        
        startClock();
    </script>
