    <div id="login-modal" class="fixed inset-0 bg-black/90 backdrop-blur-md flex items-center justify-center hidden p-4 z-50">
        <div class="bg-[#0a0f1d] border border-slate-800 p-6 rounded-2xl max-w-sm w-full space-y-4 text-xs shadow-2xl relative">
            <div class="text-center space-y-1">
                <i class="fa-solid fa-key text-3xl text-amber-500 mb-1"></i>
                <h3 class="text-sm font-black text-white uppercase tracking-widest">Mã Hóa Chứng Thư Nghiệp Vụ cán bộ</h3>
            </div>
            <div><label class="text-gray-400 block mb-1 font-bold uppercase">Mã Tài Khoản Định Danh</label><input type="text" id="log-user" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-mono focus:outline-none"></div>
            <div><label class="text-gray-400 block mb-1 font-bold uppercase">Mật Mã Hệ Thống</label><input type="password" id="log-pass" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white focus:outline-none"></div>
            <div class="flex gap-2 pt-2">
                <button onclick="closeLogin()" class="w-1/3 bg-slate-800 text-slate-400 py-2 rounded-lg uppercase font-black">Đóng</button>
                <button onclick="login()" class="w-2/3 bg-gradient-to-r from-amber-400 to-amber-500 text-black py-2 rounded-lg uppercase font-black">Xác Minh Nghiệp Vụ</button>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        let state = {}; let registry = {}; let violations = {}; 
        let activeUser = null; let activeFileId = null;

        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        function playTone(freq, type, duration, vol) {
            try {
                const osc = audioCtx.createOscillator(); const gainNode = audioCtx.createGain();
                osc.type = type; osc.frequency.value = freq;
                gainNode.gain.setValueAtTime(vol, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.00001, audioCtx.currentTime + duration);
                osc.connect(gainNode); gainNode.connect(audioCtx.destination);
                osc.start(); osc.stop(audioCtx.currentTime + duration);
            } catch(e) {}
        }

        const soundClick = () => playTone(540, 'sine', 0.05, 0.1);
        const soundSuccess = () => { playTone(523.25, 'sine', 0.07, 0.12); setTimeout(() => playTone(659.25, 'sine', 0.1, 0.12), 60); };
        const soundAlert = () => { playTone(920, 'sawtooth', 0.15, 0.07); setTimeout(() => playTone(920, 'sawtooth', 0.15, 0.07), 150); };
        const soundStamp = () => { playTone(110, 'triangle', 0.2, 0.4); playTone(260, 'sawtooth', 0.07, 0.15); };

        document.addEventListener('click', (e) => {
            if(e.target.closest('button') || e.target.closest('nav button') || e.target.closest('select')) { soundClick(); }
        });

        function startClock() { 
            setInterval(() => { 
                document.getElementById('clock').innerText = new Date().toLocaleTimeString('vi-VN'); 
                drawAdminChart();
            }, 1000); 
        }

        function subTab(id) {
            document.querySelectorAll('[id^="subtab-off-"]').forEach(s => s.classList.add('hidden'));
            document.getElementById(`subtab-${id}`).classList.remove('hidden');
            document.querySelectorAll('.subtab-btn').forEach(b => b.classList.remove('active'));
            if(document.getElementById(`btn-${id}`)) document.getElementById(`btn-${id}`).classList.add('active');
        }

        function adminSubTab(id) {
            document.querySelectorAll('[id^="subtab-adm-"]').forEach(s => s.classList.add('hidden'));
            document.getElementById(`subtab-${id}`).classList.remove('hidden');
        }

        /* BIỂU ĐỒ SỐ CANVAS ĐỘNG ADMIN */
        function drawAdminChart() {
            const canvas = document.getElementById('adminDynamicChart'); if (!canvas) return;
            const ctx = canvas.getContext('2d'); ctx.clearRect(0, 0, canvas.width, canvas.height);
            let activeApps = Object.keys(state.applications || {}).length;
            let archivedApps = Object.keys(state.archivedApplications || {}).length;
            let staffCount = Object.keys(state.authorizedPersonnel || {}).length - 1;

            let b1 = Math.max(10, Math.min(90, activeApps * 12));
            let b2 = Math.max(10, Math.min(90, archivedApps * 12));
            let b3 = Math.max(10, Math.min(90, staffCount * 12));

            ctx.fillStyle = '#1e293b'; ctx.fillRect(25, 100, 45, -b1);
            ctx.fillStyle = '#f59e0b'; ctx.font = '9px monospace'; ctx.fillText(activeApps, 40, 95 - b1);

            ctx.fillStyle = '#a855f7'; ctx.fillRect(110, 100, 45, -b2);
            ctx.fillStyle = '#c084fc'; ctx.fillText(archivedApps, 125, 95 - b2);

            ctx.fillStyle = '#10b981'; ctx.fillRect(195, 100, 45, -b3);
            ctx.fillStyle = '#34d399'; ctx.fillText(staffCount, 210, 95 - b3);

            ctx.fillStyle = '#64748b'; ctx.font = '8px sans-serif';
            ctx.fillText('Đơn Đang Chờ', 18, 115); ctx.fillText('Hồ Sơ Lưu Kho', 105, 115); ctx.fillText('Tổng Nhân Sự', 190, 115);
        }

        socket.on('initData', (data) => { updateDataAndRender(data); checkAndRestoreSession(); });
        socket.on('stateUpdate', (data) => { updateDataAndRender(data); });
        
        socket.on('newApplicationAlert', (appInfo) => {
            if (activeUser && (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ' || appInfo.agency === activeUser.agency)) {
                document.getElementById('officer-alert-light').classList.remove('hidden'); soundAlert();
            }
        });

        socket.on('newChatMessage', (chatInfo) => {
            if (document.getElementById('track-id').value === chatInfo.fileId) trackApplication();
            if (activeFileId === chatInfo.fileId) renderOfficerDesk();
        });

        function updateDataAndRender(data) {
            state = data.systemState; registry = data.citizenIdentityRegistry; violations = data.criminalRecordsRegistry;
            if (activeUser) activeUser = state.authorizedPersonnel[activeUser.username];
            
            if (activeUser) {
                let filtered = Object.values(state.applications).filter(a => {
                    if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ') return true;
                    return a.agency === activeUser.agency;
                });
                const badgeCount = document.getElementById('badge-count-app');
                if (filtered.length > 0) { badgeCount.innerText = filtered.length; badgeCount.classList.remove('hidden'); } 
                else { badgeCount.classList.add('hidden'); }
            }
            renderAll(); if (activeFileId) renderOfficerDesk();
        }

        function checkAndRestoreSession() {
            let savedSession = localStorage.getItem('sessionUser');
            if(savedSession) {
                try {
                    let creds = JSON.parse(savedSession);
                    if (state.authorizedPersonnel[creds.username] && state.authorizedPersonnel[creds.username].password === creds.password) {
                        activeUser = state.authorizedPersonnel[creds.username]; applyUserRoleLayout();
                    }
                } catch(e) { localStorage.removeItem('sessionUser'); }
            } else { renderAuth(); }
        }

        function jumpToActiveNotification() { tab('tab-officer'); subTab('off-apps'); document.getElementById('officer-alert-light').classList.add('hidden'); }

        function tab(id) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            document.getElementById(id).classList.remove('hidden');
            document.querySelectorAll('nav button').forEach(b => { b.classList.remove('border-amber-500', 'text-amber-500'); b.classList.add('border-transparent', 'text-slate-400'); });
            const btn = document.getElementById(`btn-${id}`); if(btn) btn.classList.add('border-amber-500', 'text-amber-500');
            if (id === 'tab-officer') {
                document.getElementById('officer-alert-light').classList.add('hidden');
                if(activeUser && (activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN')) document.getElementById('btn-off-leader').classList.remove('hidden');
                subTab('off-apps');
            }
            if (id === 'tab-admin') adminSubTab('adm-stats');
            sessionStorage.setItem('activeTab', id);
        }

        async function submitViolationForm(e) {
            e.preventDefault();
            const username = document.getElementById('vio-user').value.trim(); const type = document.getElementById('vio-type').value;
            const lawClause = document.getElementById('vio-clause').value.trim(); const fine = document.getElementById('vio-fine').value.trim() || "0 VND";
            const status = document.getElementById('vio-status').value;

            await fetch('/api/resident/violation', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, type, lawClause, fine, status, officerName: activeUser.displayName })
            });

            document.getElementById('vio-user').value = ''; document.getElementById('vio-clause').value = ''; document.getElementById('vio-fine').value = '';
            soundStamp(); alert(`Đã dập phôi ban hành biên bản xử lý vi phạm liên thông!`);
        }

        async function registerResidentByOfficer(e, mode) {
            e.preventDefault();
            let username, name, dob, gender, pob, job, licenses, status;
            if (mode === 'cccd') {
                username = document.getElementById('cccd-user').value.trim(); name = document.getElementById('cccd-name').value.trim();
                dob = document.getElementById('cccd-dob').value.trim(); gender = document.getElementById('cccd-gender').value;
                pob = document.getElementById('cccd-pob').value.trim(); job = document.getElementById('cccd-job').value.trim();
                licenses = "Căn Cước Công Dân Gắn Chíp Điện Tử Số Hóa"; status = document.getElementById('cccd-status').value;
            } else {
                username = document.getElementById('doc-user').value.trim();
                const selectedLicense = document.getElementById('doc-license-type').value;
                if (!citizenIdentityRegistry[username]) { alert("Cư dân chưa có thẻ Căn Cước gốc!"); return; }
                let currentRes = citizenIdentityRegistry[username];
                name = currentRes.name; dob = currentRes.dob; gender = currentRes.gender; pob = currentRes.pob; job = currentRes.job; status = currentRes.status;
                let existingLicenses = currentRes.licenses || [];
                if (!existingLicenses.includes(selectedLicense)) existingLicenses.push(selectedLicense);
                licenses = existingLicenses.join(', ');
            }

            await fetch('/api/resident/register', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, name, dob, gender, pob, job, licenses, status, officerName: activeUser.displayName }) });
            if (mode === 'cccd') {
                document.getElementById('cccd-user').value = ''; document.getElementById('cccd-name').value = ''; document.getElementById('cccd-dob').value = ''; document.getElementById('cccd-pob').value = ''; document.getElementById('cccd-job').value = '';
            } else { document.getElementById('doc-user').value = ''; }
            soundSuccess(); alert(`Phê chuẩn dập phôi chứng thư thành công lên cổng liên thông!`);
        }

        // BĂM SỐ THEO TÊN CỐ ĐỊNH - KHÔNG BỊ RANDOM KHI F5
        function buildCccdTemplate(username, citizen) {
            let seedVal = 0; for (let i = 0; i < username.length; i++) { seedVal += username.charCodeAt(i); }
            let constantCccdId = 12000000 + (seedVal * 4321) % 8999999;
            return `
                <div class="hologram-card w-full max-w-md p-5 rounded-2xl border-l-4 border-amber-500 text-slate-100 font-sans space-y-4 relative">
                    <div class="flex justify-between items-start border-b border-amber-500/30 pb-2">
                        <div>
                            <h4 class="text-[9px] font-black tracking-wider text-amber-400 uppercase">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</h4>
                            <p class="text-[8px] font-bold text-slate-400 uppercase tracking-widest">CĂN CƯỚC CÔNG DÂN / CITIZEN IDENTITY CARD</p>
                        </div>
                        <i class="fa-solid fa-star text-amber-400 text-sm"></i>
                    </div>
                    <div class="flex gap-4 items-center">
                        <div class="w-16 h-20 bg-slate-900 border border-slate-700 flex flex-col items-center justify-center rounded-lg text-slate-600 relative overflow-hidden">
                            <i class="fa-solid fa-user text-3xl mt-2 text-slate-400"></i>
                            <div class="absolute bottom-0 w-full bg-amber-500 text-[7px] font-mono font-black text-center text-black py-0.5">ROBLOX RP</div>
                        </div>
                        <div class="flex-1 text-[11px] space-y-0.5">
                            <p class="font-mono text-amber-500 font-bold text-xs">Số / ID: <span class="text-white tracking-wider font-black">${constantCccdId}</span></p>
                            <p class="text-slate-400 font-bold">Họ và tên: <span class="text-xs font-black text-white uppercase">${citizen.name}</span></p>
                            <p class="text-slate-400 font-bold">Ngày sinh: <span class="text-white font-mono">${citizen.dob}</span></p>
                            <p class="text-slate-400 font-bold">Giới tính: <span class="text-white">${citizen.gender}</span></p>
                            <p class="text-slate-400 font-bold">Nguyên quán: <span class="text-white">${citizen.pob}</span></p>
                        </div>
                    </div>
                    <div class="red-seal-mộc">BỘ CÔNG AN<br>ĐÃ CHỨNG THỰC</div>
                </div>
            `;
        }

        function searchCitizen() {
            const q = document.getElementById('id-search').value.trim(); const resArea = document.getElementById('id-result');
            if (registry[q]) {
                soundSuccess(); resArea.innerHTML = buildCccdTemplate(q, registry[q]);
            } else { resArea.innerHTML = `<p class="mt-4 text-center text-red-400 text-xs font-black">KHÔNG TÌM THẤY DỮ LIỆU ĐỊNH DANH CƯ DÂN TRÊN TOÀN QUỐC.</p>`; }
        }

        function generateCitizenCards() {
            const username = document.getElementById('card-search-input').value.trim();
            const zone = document.getElementById('cards-render-zone'); const vioZone = document.getElementById('violation-render-zone');
            if(!registry[username]) {
                zone.innerHTML = `<p class="text-center text-xs text-red-400 col-span-2 py-6 font-black">KHÔNG TÌM THẤY DỮ LIỆU ĐỊNH DANH.</p>`; return;
            }
            const citizen = registry[username]; soundSuccess();
            zone.innerHTML = buildCccdTemplate(username, citizen);

            citizen.licenses.forEach(lic => {
                if(lic.includes("Căn Cước")) return;
                let isWeapon = lic.includes("Vũ Khí");
                let isMil = lic.includes("Vũ Trang") || lic.includes("Công An");
                let sideColor = isWeapon ? 'border-l-4 border-red-500' : (isMil ? 'border-l-4 border-purple-500' : 'border-l-4 border-sky-500');
                let sealName = isWeapon ? "BỘ QUỐC PHÒNG" : (isMil ? "CỤC QUÂN PHÁP" : "SỞ GIAO THÔNG");

                zone.innerHTML += `
                    <div class="hologram-card w-full p-5 rounded-2xl ${sideColor} text-slate-100 font-sans space-y-3 relative">
                        <p class="text-[8px] font-black tracking-widest text-slate-400 uppercase"><i class="fa-solid fa-shield mr-1"></i> GIẤY PHÉP CHỨNG CHỈ QUỐC GIA BAN HÀNH</p>
                        <p class="text-[11px] text-slate-400 font-bold">Người sở hữu: <span class="text-white font-black uppercase">${citizen.name}</span></p>
                        <div class="p-2 bg-black/40 border border-slate-800 rounded-xl"><p class="text-xs font-black text-amber-400 uppercase">${lic}</p></div>
                        <div class="red-seal-mộc">${sealName}<br>QUỐC GIA</div>
                    </div>
                `;
            });

            let vioHtml = '';
            let vList = violations[username] || [];
            if (vList.length > 0) {
                vList.forEach(v => {
                    vioHtml += `
                        <div class="border-2 border-red-900/60 bg-red-950/10 p-4 rounded-xl relative space-y-2">
                            <p class="text-xs font-black text-red-500 font-mono">BIÊN BẢN SỐ: ${v.id}</p>
                            <p class="text-xs text-slate-300">Cơ quan lập: <b>${v.type}</b> | Điều luật: ${v.lawClause}</p>
                            <p class="text-xs text-yellow-500 font-bold">Hình phạt: ${v.fine} | Cán bộ: ${v.officer}</p>
                            <span class="text-[10px] font-black uppercase text-white bg-red-900 px-2 py-0.5 rounded block text-center">Tiến độ luồng: [${v.status}]</span>
                        </div>
                    `;
                });
            } else { vioHtml = `<p class="text-center text-xs text-emerald-400 font-bold col-span-2 py-6">LÝ LỊCH TƯ PHÁP TRONG SẠCH.</p>`; }
            vioZone.innerHTML = vioHtml;
        }

        // ĐÀM THOẠI TRỰC TUYẾN 2 CHIỀU KHÔNG DELAY & KÝ BIÊN BẢN CỦA CÔNG DÂN
        function trackApplication() {
            const id = document.getElementById('track-id').value.trim();
            const area = document.getElementById('track-details'); const empty = document.getElementById('track-empty');
            let app = state.applications[id] || state.archivedApplications[id];
            if (!app) { area.classList.add('hidden'); empty.classList.remove('hidden'); return; }
            empty.classList.add('hidden'); area.classList.remove('hidden');

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-slate-900 p-2 rounded text-[11px]"><p class="text-[9px] font-bold text-gray-500">${l.sender} • ${l.time}</p><p class="text-white mt-0.5">${l.msg}</p></div>`;
            });

            let signBlock = '';
            if (app.status === 'Chờ Công Dân Ký' && !app.citizenSigned) {
                signBlock = `
                    <div class="p-2.5 bg-red-950/20 border border-red-900 rounded-xl text-center space-y-2">
                        <p class="text-[10px] text-red-400 font-black uppercase">Yêu cầu người vi phạm / Người nộp xác thực chữ ký tên</p>
                        <div class="flex gap-2 justify-center">
                            <button onclick="signApplication('${id}', 'citizen_sign')" class="bg-emerald-600 text-white font-black px-4 py-1.5 rounded text-[10px] uppercase">Đồng Ý Ký Tên Biên Bản ✓</button>
                            <button onclick="signApplication('${id}', 'citizen_reject_sign')" class="bg-red-600 text-white font-black px-4 py-1.5 rounded text-[10px] uppercase">Từ Chối Ký (Khiếu Nại) 🚨</button>
                        </div>
                    </div>
                `;
            }

            let satBlock = '';
            if ((app.status === 'Đã Phê Duyệt') && !app.satisfaction) {
                satBlock = `<button onclick="sendAction('${id}', 'satisfaction', 'HÀI LÒNG')" class="w-full bg-emerald-600 text-white font-black py-1.5 rounded text-[10px] uppercase">Đánh giá hài lòng kết quả 👍</button>`;
            }

            area.innerHTML = `
                <div class="flex-1 flex flex-col justify-between h-full">
                    <div class="overflow-y-auto space-y-2.5 max-h-[250px] pr-1">
                        <div class="bg-slate-900 p-2.5 rounded-xl border border-slate-800 flex justify-between items-center">
                            <div><p class="font-black text-amber-500 text-xs">${app.id}</p><p class="text-[9px] text-slate-400 uppercase">${app.docType}</p></div>
                            <div class="stamp-box ${app.stamp}">${app.status}</div>
                        </div>
                        <div class="space-y-1.5" id="citizen-chat-flow">${chatHtml}</div>
                    </div>
                    <div class="pt-2 border-t border-slate-800 space-y-2">
                        ${signBlock} ${satBlock}
                        <div class="flex gap-2">
                            <input type="text" id="citizen-chat-msg" placeholder="Nhập tin nhắn..." class="flex-1 bg-slate-900 border border-slate-700 p-2 text-xs text-white rounded-lg focus:outline-none">
                            <button onclick="citizenChat('${app.id}')" class="bg-amber-500 font-black text-black px-4 text-xs rounded-lg uppercase">Gửi</button>
                        </div>
                    </div>
                </div>
            `;
            setTimeout(() => { const el = document.getElementById('citizen-chat-flow'); if (el) el.scrollTop = el.scrollHeight; }, 10);
        }

        async function signApplication(id, actionType) {
            soundStamp();
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action: actionType }) });
            trackApplication();
        }

        async function citizenChat(id) {
            const msg = document.getElementById('citizen-chat-msg').value.trim(); if (!msg) return;
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action: 'chat', msg, officerName: `Công Dân (@${(state.applications[id] || state.archivedApplications[id]).sender})` }) });
            document.getElementById('citizen-chat-msg').value = '';
        }

        function selectFile(id) { activeFileId = id; document.getElementById('officer-desk-empty').classList.add('hidden'); document.getElementById('officer-desk-active').classList.remove('hidden'); renderOfficerDesk(); }

        // BÀN LÀM VIỆC NGHIỆP VỤ CAN BỘ CHUYÊN NGHIỆP
        function renderOfficerDesk() {
            let app = state.applications[activeFileId] || state.archivedApplications[activeFileId]; if(!app) return;
            const desk = document.getElementById('officer-desk-active');

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-slate-900 p-2 rounded border border-slate-800 text-[11px]"><p class="text-[9px] text-gray-400">${l.sender} • ${l.time}</p><p class="text-white mt-0.5">${l.msg}</p></div>`;
            });

            let actionsHtml = '';
            let signStatusBox = `<div class="grid grid-cols-3 gap-1.5 text-center text-[8px] font-black uppercase font-mono tracking-wider p-1 bg-slate-950 rounded border border-slate-800 my-1">
                <div class="${app.citizenSigned ? 'text-emerald-400':'text-red-500'}">Công dân: ${app.citizenSigned ? 'Đã ký':'Chờ'}</div>
                <div class="${app.officerSigned ? 'text-emerald-400':'text-red-500'}">Cán bộ: ${app.officerSigned ? 'Đã ký':'Chờ'}</div>
                <div class="${app.leaderSigned ? 'text-emerald-400':'text-red-500'}">Lãnh đạo: ${app.leaderSigned ? 'Đã ký':'Chờ'}</div>
            </div>`;

            if (state.applications[activeFileId]) {
                if (app.status === 'Đang Chờ Tiếp Nhận') {
                    actionsHtml = `<button onclick="sendAction('${app.id}', 'claim_packet')" class="w-full bg-sky-600 text-white font-black py-2 rounded-lg text-xs uppercase">Tiếp Nhận Phụ Trách Thẩm Định</button>`;
                } else {
                    if(activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN') {
                        actionsHtml = `
                            <div class="grid grid-cols-2 gap-2">
                                <button onclick="sendAction('${app.id}', 'status', 'Đã Phê Duyệt', 'stamp-approved')" class="bg-emerald-600 text-white font-black py-1.5 rounded text-[10px] uppercase">Lãnh Đạo Ký Phê Duyệt</button>
                                <button onclick="sendAction('${app.id}', 'status', 'Bị Bác Bỏ', 'stamp-rejected')" class="bg-red-600 text-white font-black py-1.5 rounded text-[10px] uppercase">Bác Bỏ Đơn</button>
                            </div>
                            <button onclick="archiveWithCheck('${app.id}', '${activeUser.role}')" class="w-full bg-purple-600 text-white font-black py-1.5 rounded text-[11px] uppercase mt-1">Đóng & Niêm Phong Lưu Kho Quốc Gia</button>
                        `;
                    } else {
                        actionsHtml = `
                            <button onclick="sendAction('${app.id}', 'to_leader')" class="w-full bg-gradient-to-r from-amber-500 to-purple-600 text-black font-black py-1.5 rounded text-[11px] uppercase">Trình Lên Cấp Lãnh Đạo Ký Duyệt</button>
                            <div class="p-1.5 bg-slate-950 border border-slate-800 rounded mt-1 text-[11px]">
                                <select id="forward-target-agency" class="bg-slate-900 text-white border p-1 text-[11px] w-full mb-1"><option value="CÔNG AN">CÔNG AN</option><option value="QUÂN ĐỘI">QUÂN ĐỘI</option></select>
                                <button onclick="forwardAppAction('${app.id}')" class="w-full bg-sky-600 text-white py-1 rounded font-black text-[10px] uppercase">Chuyển luồng ban ngành</button>
                            </div>
                        `;
                    }
                }
            } else {
                actionsHtml = `<div class="text-center text-[10px] text-purple-400 font-bold bg-purple-950/20 p-2 rounded border border-purple-900 uppercase">Hồ sơ đã niêm phong lưu kho bảo mật tối cao</div>
                ${(activeUser.role === 'ADMIN') ? `<button onclick="sendAction('${app.id}', 'unarchive')" class="w-full bg-red-700 text-white font-black py-1 rounded text-[10px] uppercase mt-1">Admin Quyền Lực: Tái Thẩm</button>`:''}`;
            }

            desk.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3 max-h-[350px] pr-1">
                    <div class="bg-slate-900 p-2.5 rounded-xl border border-slate-800 text-[11px] relative">
                        <div class="absolute top-2 right-2 stamp-box ${app.stamp}">${app.status}</div>
                        <p class="font-black text-amber-500">MÃ HỒ SƠ: ${app.id}</p>
                        <p class="text-slate-400 italic mt-1 font-bold">"${app.content}"</p>
                        ${signStatusBox}
                    </div>
                    <div class="space-y-1.5" id="officer-chat-flow">${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-slate-800 space-y-2">
                    ${actionsHtml}
                    <div class="flex gap-2">
                        <input type="text" id="officer-chat-msg" placeholder="Chỉ thị..." class="flex-1 bg-slate-900 border border-slate-700 p-2 text-xs text-white rounded-lg focus:outline-none">
                        <button onclick="officerChat()" class="bg-emerald-600 font-black text-white px-4 text-xs rounded-lg uppercase">Gửi</button>
                    </div>
                </div>
            `;
            setTimeout(() => { const el = document.getElementById('officer-chat-flow'); if (el) el.scrollTop = el.scrollHeight; }, 10);
        }

        async function archiveWithCheck(id, role) {
            let app = state.applications[id];
            if (role !== 'ADMIN' && (!app.citizenSigned || !app.officerSigned || !app.leaderSigned)) {
                alert("Không thể đóng hồ sơ! Quy trình yêu cầu nghiêm ngặt phải thu thập đủ 3 chữ ký số điện tử của (Công dân, Cán bộ lập và Lãnh đạo phê duyệt).");
                return;
            }
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action: 'archive', officerName: activeUser.displayName, officerRole: role }) });
            activeFileId = null; document.getElementById('officer-desk-active').innerHTML = '';
            alert("Niêm phong hồ sơ thành công vào kho quốc gia!");
        }

        async function forwardAppAction(id) {
            const targetAgency = document.getElementById('forward-target-agency').value; soundStamp();
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action: 'forward', targetAgency, officerName: activeUser.displayName }) });
            activeFileId = null; selectFile(id);
        }

        async function officerChat() {
            const msg = document.getElementById('officer-chat-msg').value.trim(); if (!msg) return;
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: activeFileId, action: 'chat', msg, officerName: `${activeUser.displayName} (${activeUser.agency})` }) });
            document.getElementById('officer-chat-msg').value = '';
        }

        async function sendAction(id, action, status = '', stamp = '', targetAgency = '') {
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action, status, stamp, targetAgency, officerName: activeUser ? activeUser.displayName : 'Hệ thống', officerRole: activeUser ? activeUser.role : 'Hệ thống' }) });
        }

        async function publishDocument() {
            const type = document.getElementById('pub-type').value; const title = document.getElementById('pub-title').value.trim(); const content = document.getElementById('pub-content').value.trim();
            if(!title || !content) return;
            await fetch('/api/national/publish', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ type, title, content, author: activeUser.displayName }) });
            document.getElementById('pub-title').value = ''; document.getElementById('pub-content').value = ''; soundSuccess();
        }

        async function updateTicker() {
            const msg = document.getElementById('pub-ticker').value.trim(); if(!msg) return;
            await fetch('/api/national/ticker', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }) });
            document.getElementById('pub-ticker').value = ''; soundSuccess();
        }

        async function deleteNews(id) { await fetch('/api/national/delete-announcement', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) }); }
        async function setSecurity(level) { await fetch('/api/national/security', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ level }) }); }
        async function provisionAccount(e) { 
            e.preventDefault(); const username = document.getElementById('p-user').value.trim(); const password = document.getElementById('p-pass').value; const displayName = document.getElementById('p-name').value.trim(); const role = document.getElementById('p-role').value; const agency = document.getElementById('p-agency').value;
            await fetch('/api/officer/save', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, password, displayName, role, agency }) });
            resetProvisionForm(); soundSuccess(); 
        }

        function openLogin() { document.getElementById('login-modal').classList.remove('hidden'); }
        function closeLogin() { document.getElementById('login-modal').classList.add('hidden'); }
        function login() { 
            const u = document.getElementById('log-user').value; const p = document.getElementById('log-pass').value;
            if (state.authorizedPersonnel[u] && state.authorizedPersonnel[u].password === p) { 
                activeUser = state.authorizedPersonnel[u]; localStorage.setItem('sessionUser', JSON.stringify({ username: u, password: p })); closeLogin(); soundSuccess(); applyUserRoleLayout();
            } else { alert("Sai chứng thư nghiệp vụ!"); } 
        }

        function applyUserRoleLayout() { 
            if(!activeUser) return;
            document.getElementById('btn-tab-officer').classList.remove('hidden'); 
            if(activeUser.role === 'ADMIN') document.getElementById('btn-tab-admin').classList.remove('hidden'); 
            renderAuth(); renderAll(); 
            let savedTab = sessionStorage.getItem('activeTab'); tab(savedTab || 'tab-officer');
        }

        function logout() { activeUser = null; activeFileId = null; localStorage.removeItem('sessionUser'); document.getElementById('btn-tab-officer').classList.add('hidden'); document.getElementById('btn-tab-admin').classList.add('hidden'); renderAuth(); tab('tab-news'); }
        function renderAuth() { const p = document.getElementById('auth-panel'); if(!activeUser) { p.innerHTML = `<button onclick="openLogin()" class="bg-amber-500 text-black px-4 py-2 rounded-lg text-[11px] uppercase font-black">Đăng nhập nghiệp vụ</button>`; } else { p.innerHTML = `<div class="bg-slate-900 border p-1.5 text-xs rounded-xl flex items-center gap-2"><b class="text-white">${activeUser.displayName}</b><button onclick="logout()" class="text-red-400 ml-2 cursor-pointer"><i class="fa-solid fa-power-off"></i></button></div>`; } }
        
        startClock();
    </script>
</body>
</html>
