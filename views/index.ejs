    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();

        let state = {};
        let registry = {};
        let violations = {}; 
        let activeUser = null;
        let activeFileId = null;

        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        function playTone(freq, type, duration, vol) {
            try {
                const osc = audioCtx.createOscillator();
                const gainNode = audioCtx.createGain();
                osc.type = type; osc.frequency.value = freq;
                gainNode.gain.setValueAtTime(vol, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.00001, audioCtx.currentTime + duration);
                osc.connect(gainNode); gainNode.connect(audioCtx.destination);
                osc.start(); osc.stop(audioCtx.currentTime + duration);
            } catch(e) {}
        }

        const soundClick = () => playTone(600, 'sine', 0.08, 0.1);
        const soundSuccess = () => { playTone(523.25, 'sine', 0.1, 0.15); setTimeout(() => playTone(659.25, 'sine', 0.15, 0.15), 80); };
        const soundAlert = () => { playTone(880, 'sawtooth', 0.15, 0.1); setTimeout(() => playTone(880, 'sawtooth', 0.15, 0.1), 200); };
        const soundStamp = () => { playTone(120, 'triangle', 0.18, 0.4); playTone(240, 'sawtooth', 0.08, 0.1); };

        function startClock() { setInterval(() => { document.getElementById('clock').innerText = new Date().toLocaleTimeString('vi-VN'); }, 1000); }

        socket.on('initData', (data) => { updateDataAndRender(data); checkAndRestoreSession(); });
        socket.on('stateUpdate', (data) => { updateDataAndRender(data); });
        socket.on('newApplicationAlert', (appInfo) => {
            if (activeUser && (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ' || appInfo.agency === activeUser.agency)) {
                document.getElementById('officer-alert-light').classList.remove('hidden');
                soundAlert();
            }
        });
        socket.on('newChatMessage', (chatInfo) => {
            if (document.getElementById('track-id').value === chatInfo.fileId) { trackApplication(); }
            if (activeFileId === chatInfo.fileId) { renderOfficerDesk(); }
        });

        function updateDataAndRender(data) {
            state = data.systemState; registry = data.citizenIdentityRegistry; violations = data.criminalRecordsRegistry;
            if (activeUser) { activeUser = state.authorizedPersonnel[activeUser.username]; renderAuth(); }
            renderAll();
            if (activeFileId) { renderOfficerDesk(); }
        }

        function checkAndRestoreSession() {
            let savedSession = localStorage.getItem('sessionUser');
            if(savedSession) {
                try {
                    let creds = JSON.parse(savedSession);
                    if (state.authorizedPersonnel[creds.username] && state.authorizedPersonnel[creds.username].password === creds.password) {
                        activeUser = state.authorizedPersonnel[creds.username];
                        applyUserRoleLayout();
                    }
                } catch(e) {}
            } else { renderAuth(); }
        }

        function jumpToActiveNotification() { tab('tab-officer'); document.getElementById('officer-alert-light').classList.add('hidden'); }

        function tab(id) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            document.getElementById(id).classList.remove('hidden');
            document.querySelectorAll('nav border-b-2').forEach(b => b.classList.replace('border-amber-500', 'border-transparent'));
            sessionStorage.setItem('activeTab', id);
        }

        // ĐIỀU HƯỚNG CÁC TAB NHỎ TRONG BÀN LÀM VIỆC CÁN BỘ CỰC KỲ CHUYÊN NGHIỆP
        function subOfficeTab(targetSubId) {
            // Ẩn toàn bộ các tab nghiệp vụ nhỏ
            ['sub-desk-apps', 'sub-desk-violations', 'sub-desk-residents', 'sub-desk-commands'].forEach(id => {
                document.getElementById(id).classList.add('hidden');
            });
            // Hiện đúng tab cán bộ chỉ định
            document.getElementById(targetSubId).classList.remove('hidden');

            // Đổi màu nút bấm
            ['btn-sub-apps', 'btn-sub-violations', 'btn-sub-residents', 'btn-sub-commands'].forEach(btnId => {
                document.getElementById(btnId).className = "px-4 py-2 text-[11px] font-black uppercase tracking-wider rounded-lg bg-slate-900 text-slate-400 hover:text-white transition-all";
            });
            const activeBtnMap = { 'sub-desk-apps': 'btn-sub-apps', 'sub-desk-violations': 'btn-sub-violations', 'sub-desk-residents': 'btn-sub-residents', 'sub-desk-commands': 'btn-sub-commands' };
            document.getElementById(activeBtnMap[targetSubId]).className = "px-4 py-2 text-[11px] font-black uppercase tracking-wider rounded-lg bg-emerald-600 text-white transition-all";
        }

        function generateCitizenCards() {
            const username = document.getElementById('card-search-input').value.trim();
            const zone = document.getElementById('cards-render-zone');
            const vioZone = document.getElementById('violation-render-zone');
            
            if(!registry[username]) {
                zone.innerHTML = `<p class="text-center text-xs text-red-400 col-span-2 py-4 font-black">KHÔNG CÓ DỮ LIỆU ĐỊNH DANH.</p>`;
                vioZone.innerHTML = `<p class="text-center text-xs text-slate-600 col-span-2">Không có lịch sử vi phạm.</p>`;
                return;
            }
            const citizen = registry[username]; soundSuccess();
            
            // Render thẻ chip
            zone.innerHTML = `
                <div class="national-card w-full max-w-md p-4 rounded-xl border-amber-500/30 text-slate-100 font-sans space-y-3">
                    <p class="text-[9px] font-bold text-amber-400 uppercase tracking-wider">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</p>
                    <div class="flex gap-3 items-center">
                        <div class="w-16 h-20 bg-slate-800 rounded flex flex-col items-center justify-center text-slate-500 text-3xl font-black">ID</div>
                        <div class="flex-1 text-[11px] space-y-0.5">
                            <p class="text-sm font-black text-white uppercase">${citizen.name}</p>
                            <p class="text-slate-400">Ngày sinh: <span class="text-white">${citizen.dob}</span></p>
                            <p class="text-slate-400">Nghề nghiệp: <span class="text-white">${citizen.job}</span></p>
                            <p class="text-emerald-400 font-black">${citizen.status}</p>
                        </div>
                    </div>
                    <div class="flex justify-between items-center pt-2 border-t border-slate-800">
                        <div class="card-chip"></div>
                        <p class="text-[10px] text-slate-400 font-mono">BẰNG CẤP: ${citizen.licenses.join(', ')}</p>
                    </div>
                </div>
            `;

            // Lập lịch sử vi phạm hình ảnh
            let vioHtml = '';
            if (violations[username] && violations[username].length > 0) {
                violations[username].forEach(v => {
                    vioHtml += `
                        <div class="border-2 border-red-900/40 bg-red-950/10 p-3 rounded-xl space-y-2 text-xs">
                            <p class="font-black text-red-500 font-mono">QUYẾT ĐỊNH XỬ PHẠT SỐ: ${v.id} [${v.date}]</p>
                            <p class="text-slate-300">Nội dung hành vi: <b>${v.lawClause}</b></p>
                            <p class="text-yellow-500 font-black">Khung phạt hành chính: ${v.fine} | Cán bộ lập: ${v.officer}</p>
                            <span class="bg-red-900 text-white font-black px-2 py-0.5 rounded text-[10px] block text-center uppercase">Hình thức: ${v.status}</span>
                        </div>
                    `;
                });
            } else {
                vioHtml = `<p class="text-center text-xs text-emerald-400 font-bold col-span-2 py-4"><i class="fa-solid fa-circle-check"></i> CÔNG DÂN LÝ LỊCH SẠCH - CHƯA PHÁT HIỆN LỊCH SỬ VI PHẠM PHÁP LUẬT TƯ PHÁP.</p>`;
            }
            vioZone.innerHTML = vioHtml;
        }

        function renderAll() {
            if(!state.announcements) return;
            document.getElementById('live-marquee').innerText = state.tickerMessage;
            
            const feed = document.getElementById('news-feed'); feed.innerHTML = '';
            state.announcements.forEach(a => {
                let deleteBtn = (activeUser && (activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN')) ? `<button onclick="deleteNews('${a.id}')" class="text-[10px] text-red-400 font-bold">Xóa</button>` : '';
                feed.innerHTML += `<div class="bg-[#0a0f1d] border border-slate-800 p-3 rounded-xl flex justify-between items-start"><div><span class="text-[9px] font-black text-amber-500 bg-amber-950 px-1.5 py-0.5 rounded uppercase">${a.type}</span><h4 class="text-sm font-black text-white mt-1">${a.title}</h4><p class="text-xs text-slate-400 mt-0.5">${a.content}</p></div>${deleteBtn}</div>`;
            });

            const wanted = document.getElementById('wanted-feed'); wanted.innerHTML = '';
            state.criminalWantedList.forEach(c => {
                wanted.innerHTML += `<div class="bg-red-950/10 border border-red-900/40 p-2.5 rounded-xl text-xs"><p class="font-black text-red-400"><i class="fa-solid fa-bullseye"></i> TRUY NÃ: @${c.name}</p><p class="text-slate-300">${c.crime}</p></div>`;
            });
            
            if (activeUser) {
                const tbody = document.getElementById('officer-table'); tbody.innerHTML = '';
                Object.values(state.applications).forEach(app => {
                    if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ' || app.agency === activeUser.agency) {
                        tbody.innerHTML += `
                            <tr class="hover:bg-slate-900/40 border-b border-slate-800 text-xs">
                                <td class="p-3 font-mono text-amber-500 font-bold">${app.id}</td>
                                <td class="p-3 font-medium">@${app.sender}</td>
                                <td class="p-3"><span class="bg-slate-800 text-slate-300 px-2 py-0.5 rounded text-[10px]">${app.docType}</span></td>
                                <td class="p-3 font-black text-amber-400">${app.status}</td>
                                <td class="p-3 text-right"><button onclick="selectFile('${app.id}')" class="bg-emerald-600 text-white font-bold px-3 py-1 rounded text-[11px]">Duyệt / Xem Lịch Sử</button></td>
                            </tr>
                        `;
                    }
                });
            }

            document.getElementById('st-staff').innerText = Object.keys(state.authorizedPersonnel).length - 1;
            document.getElementById('st-files').innerText = Object.keys(state.archivedApplications).length;
            
            // KHO LƯU TRỮ QUỐC GIA TẠI TAB GIÁM SÁT - BÊN TRONG CÓ NÚT BẤM MỞ XEM CHI TIẾT ĐƠN THƯ NGAY LẬP TỨC
            const adminVault = document.getElementById('admin-vault-list');
            if(adminVault) {
                adminVault.innerHTML = '';
                Object.values(state.archivedApplications).forEach(ar => {
                    adminVault.innerHTML += `
                        <div class="bg-slate-900/90 border border-slate-800 p-3 rounded-xl flex justify-between items-center">
                            <div>
                                <p class="font-mono font-black text-purple-400">${ar.id}</p>
                                <p class="text-slate-300 mt-0.5">Cư dân nộp: <b>@${ar.sender}</b></p>
                                <span class="text-[10px] bg-purple-950 text-purple-400 border border-purple-800/40 px-1 rounded font-bold">${ar.docType}</span>
                            </div>
                            <button onclick="selectFile('${ar.id}')" class="text-[10px] bg-purple-600 text-white font-black px-2 py-1 rounded hover:bg-purple-700 uppercase">Mở Xem Dữ Liệu</button>
                        </div>
                    `;
                });
            }

            const analytics = document.getElementById('admin-analytics-list');
            if (analytics) {
                analytics.innerHTML = '';
                Object.values(state.authorizedPersonnel).forEach(u => {
                    if (u.username !== 'admin') {
                        analytics.innerHTML += `
                            <div class="bg-slate-900/80 p-3 rounded-xl border border-slate-800 text-xs">
                                <div class="flex justify-between font-black text-white"><span>${u.displayName}</span><span class="text-purple-400 text-[10px]">${u.role}</span></div>
                                <div class="text-[11px] text-slate-400 mt-1">Mật khẩu số hóa: <span class="text-amber-400 font-mono">${u.password}</span></div>
                                <div class="flex gap-2 mt-2 pt-2 border-t border-slate-800/60">
                                    <button onclick="editOfficer('${u.username}')" class="flex-1 bg-sky-600 text-white font-bold py-1 rounded text-[10px]">SỬA</button>
                                    <button onclick="deleteOfficer('${u.username}')" class="bg-red-600 text-white font-bold px-2 py-1 rounded text-[10px]">XÓA</button>
                                </div>
                            </div>
                        `;
                    }
                });
            }
        }

        function selectFile(id) {
            activeFileId = id;
            document.getElementById('officer-desk-empty').classList.add('hidden');
            document.getElementById('officer-desk-active').classList.remove('hidden');
            renderOfficerDesk();
        }

        /* ================= TÍNH NĂNG ĐẮT GIÁ: TRUY XUẤT TOÀN BỘ THÔNG TIN CƯ DÂN NGAY TRONG LUỒNG DUYỆT HỒ SƠ ================= */
        function renderOfficerDesk() {
            let app = state.applications[activeFileId] || state.archivedApplications[activeFileId];
            if(!app) return;
            const desk = document.getElementById('officer-desk-active');

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-slate-900 p-2 rounded border border-slate-800 text-[11px]"><p class="text-[9px] text-gray-500">${l.sender} • ${l.time}</p><p class="text-white mt-0.5">${l.msg}</p></div>`;
            });

            // Tự động tra cứu tất cả thông tin của công dân nộp đơn thư này
            let autoSearchCitizenHtml = '';
            const cUser = app.sender;
            if (registry[cUser]) {
                let citizenData = registry[cUser];
                let vioCount = (violations[cUser]) ? violations[cUser].length : 0;
                
                autoSearchCitizenHtml = `
                    <div class="p-3 bg-slate-900 border border-slate-800 rounded-xl space-y-1.5 text-[11px] text-slate-300">
                        <p class="text-[10px] font-black uppercase text-sky-400 border-b border-slate-800 pb-1"><i class="fa-solid fa-folder-open"></i> Tra Cứu Nhanh Lý Lịch Cư Dân</p>
                        <p>Họ tên khai sinh: <b class="text-white font-sans uppercase">${citizenData.name}</b></p>
                        <p>Ngày sinh: <b>${citizenData.dob}</b> | Giới tính: <b>${citizenData.gender}</b></p>
                        <p>Nghề nghiệp: <b>${citizenData.job}</b></p>
                        <p>Chứng chỉ cấp phát: <span class="text-amber-400 font-bold">${citizenData.licenses.join(', ')}</span></p>
                        <p class="text-red-400 font-bold">Số lần vi phạm tư pháp: <span class="bg-red-950 px-1.5 rounded text-white border border-red-700">${vioCount} lần</span></p>
                        <p class="text-emerald-400 font-black">Diện tư pháp dân sự: ${citizenData.status}</p>
                    </div>
                `;
            } else {
                autoSearchCitizenHtml = `
                    <div class="p-2 bg-red-950/20 border border-red-900/40 rounded-xl text-[10px] text-red-400 text-center font-bold">
                        ⚠️ CẢNH BÁO: TÀI KHOẢN CƯ DÂN CHƯA ĐƯỢC ĐĂNG KÝ ĐỊNH DANH TRÊN MÁY CHỦ QUỐC GIA.
                    </div>
                `;
            }

            let actionsHtml = '';
            if (state.applications[activeFileId]) {
                if (app.status === 'Đang Chờ Tiếp Nhận') {
                    actionsHtml = `<button onclick="sendAction('${app.id}', 'claim_packet')" class="w-full bg-gradient-to-r from-sky-500 to-blue-600 text-white font-black py-2 rounded-lg text-xs uppercase">Tiếp Nhận Phụ Trách Hồ Sơ</button>`;
                } else {
                    actionsHtml = `
                        <div class="grid grid-cols-2 gap-2">
                            <button onclick="sendAction('${app.id}', 'status', 'Đã Phê Duyệt', 'stamp-approved')" class="bg-emerald-600 text-white font-black py-1.5 rounded-lg text-[11px] uppercase">Phê Duyệt Ký Dấu</button>
                            <button onclick="sendAction('${app.id}', 'status', 'Bị Bác Bỏ', 'stamp-rejected')" class="bg-red-600 text-white font-black py-1.5 rounded-lg text-[11px] uppercase">Bác Bỏ Đơn Thư</button>
                        </div>
                        <button onclick="sendAction('${app.id}', 'archive')" class="w-full bg-purple-600 text-white font-black py-1.5 rounded-lg text-[11px] uppercase">Đóng Dấu & Khóa Lưu Kho</button>
                    `;
                }
            } else {
                actionsHtml = `<div class="text-center text-[10px] text-purple-400 font-bold bg-purple-950/20 p-2 border border-purple-800/40 rounded-lg">🗄️ HỒ SƠ LƯU TRỮ - ĐANG ĐƯỢC NIÊM PHONG TRONG KHO</div>`;
            }

            desk.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3.5 max-h-[380px] pr-1">
                    <div class="bg-slate-900 p-2.5 rounded-xl border border-slate-800 text-[11px] relative">
                        <div class="absolute top-2 right-2 stamp-box ${app.stamp}">${app.status}</div>
                        <p class="font-black text-amber-500">MÃ SỐ ĐƠN: ${app.id}</p>
                        <p class="text-slate-300 font-bold mt-1">Yêu cầu thủ tục: <span class="text-white">${app.docType}</span></p>
                        <p class="text-slate-400 italic mt-0.5">"${app.content}"</p>
                    </div>
                    
                    ${autoSearchCitizenHtml}
                    
                    <div class="space-y-2" id="officer-chat-flow"><p class="text-[9px] uppercase font-bold text-slate-500">Hội thoại kịch bản:</p>${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-slate-800 space-y-2">
                    ${actionsHtml}
                    <div class="flex gap-2">
                        <input type="text" id="officer-chat-msg" placeholder="Nhập tin nhắn..." class="flex-1 bg-slate-900 border border-slate-700 p-2 text-xs text-white rounded-lg focus:outline-none">
                        <button onclick="officerChat()" class="bg-emerald-600 font-black text-white px-4 text-xs rounded-lg uppercase">Gửi</button>
                    </div>
                </div>
            `;
            
            setTimeout(() => { const el = document.getElementById('officer-chat-flow'); if (el) el.scrollTop = el.scrollHeight; }, 50);
        }

        async function officerChat() {
            const msg = document.getElementById('officer-chat-msg').value.trim(); if (!msg) return;
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: activeFileId, action: 'chat', msg, officerName: `${activeUser.displayName} (${activeUser.agency})` }) });
            document.getElementById('officer-chat-msg').value = '';
        }

        async function sendAction(id, action, status = '', stamp = '', targetAgency = '') {
            if(action === 'status' || action === 'claim_packet' || action === 'archive') { soundStamp(); }
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action, status, stamp, targetAgency, officerName: activeUser ? activeUser.displayName : 'Hệ thống', officerRole: activeUser ? activeUser.role : 'Hệ thống' }) });
        }

        async function publishDocument() {
            const type = document.getElementById('pub-type').value; const title = document.getElementById('pub-title').value.trim(); const content = document.getElementById('pub-content').value.trim();
            if(!title || !content) return;
            await fetch('/api/national/publish', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ type, title, content, author: activeUser.displayName }) });
            document.getElementById('pub-title').value = ''; document.getElementById('pub-content').value = ''; soundSuccess();
        }

        async function updateTicker() {
            const msg = document.getElementById('pub-ticker').value.trim(); if(!msg) return;
            await fetch('/api/national/ticker', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }) });
            document.getElementById('pub-ticker').value = ''; soundSuccess();
        }

        async function deleteNews(id) { await fetch('/api/national/delete-announcement', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) }); }
        async function setSecurity(level) { await fetch('/api/national/security', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ level }) }); }
        async function provisionAccount(e) { e.preventDefault(); const username = document.getElementById('p-user').value.trim(); const password = document.getElementById('p-pass').value; const displayName = document.getElementById('p-name').value.trim(); const role = document.getElementById('p-role').value; const agency = document.getElementById('p-agency').value; const isEdit = document.getElementById('p-isEdit').value === "true"; await fetch('/api/officer/save', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, password, displayName, role, agency, isEdit }) }); resetProvisionForm(); soundSuccess(); }

        function searchCitizen() {
            const q = document.getElementById('id-search').value.trim(); const resArea = document.getElementById('id-result');
            if (registry[q]) {
                let r = registry[q]; soundSuccess();
                resArea.innerHTML = `
                    <div class="mt-4 p-4 bg-slate-900 border border-slate-700 rounded-xl text-xs space-y-1">
                        <p class="text-sm font-black text-amber-500 border-b border-slate-800 pb-1">${r.name}</p>
                        <p>Bằng cấp/Giấy chứng nhận: <span class="text-amber-400 font-bold">${r.licenses.join(' — ')}</span></p>
                        <p class="text-emerald-400 font-black">Lý lịch: ${r.status}</p>
                    </div>
                `;
            } else { resArea.innerHTML = `<p class="mt-4 text-center text-red-400 text-xs font-black">KHÔNG TÌM THẤY DỮ LIỆU CƯ DÂN TRÊN MÁY CHỦ.</p>`; }
        }

        function openLogin() { document.getElementById('login-modal').classList.remove('hidden'); }
        function closeLogin() { document.getElementById('login-modal').classList.add('hidden'); }
        function login() { const u = document.getElementById('log-user').value; const p = document.getElementById('log-pass').value; if (state.authorizedPersonnel[u] && state.authorizedPersonnel[u].password === p) { activeUser = state.authorizedPersonnel[u]; localStorage.setItem('sessionUser', JSON.stringify({ username: u, password: p })); closeLogin(); soundSuccess(); applyUserRoleLayout(); } else { alert("Mật mã sai!"); } }
        
        function applyUserRoleLayout() {
            if(!activeUser) return;
            document.getElementById('btn-tab-officer').classList.remove('hidden');
            if(activeUser.role === 'ADMIN') document.getElementById('btn-tab-admin').classList.remove('hidden');
            
            if(activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ') {
                document.getElementById('leader-publish-zone').classList.remove('hidden');
                document.getElementById('leader-notice-block').classList.add('hidden');
            } else {
                document.getElementById('leader-publish-zone').classList.add('hidden');
                document.getElementById('leader-notice-block').classList.remove('hidden');
            }
            renderAuth(); renderAll(); let savedTab = sessionStorage.getItem('activeTab'); tab(savedTab || 'tab-officer');
        }
        
        function logout() { activeUser = null; activeFileId = null; localStorage.removeItem('sessionUser'); document.getElementById('btn-tab-officer').classList.add('hidden'); document.getElementById('btn-tab-admin').classList.add('hidden'); renderAuth(); tab('tab-news'); }
        function renderAuth() { const p = document.getElementById('auth-panel'); if(!activeUser) { p.innerHTML = `<button onclick="openLogin()" class="bg-amber-500 text-black px-4 py-2 rounded-lg text-[11px] uppercase font-black">Đăng nhập nghiệp vụ</button>`; } else { p.innerHTML = `<div class="bg-slate-900 border p-1 text-xs rounded-xl flex items-center gap-2"><b class="text-white">${activeUser.displayName}</b><button onclick="logout()" class="text-red-400 ml-2"><i class="fa-solid fa-power-off"></i></button></div>`; } }
        
        startClock();
    </script>
</body>
</html>
