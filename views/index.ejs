        function renderAll() {
            if(!state.announcements) return;
            document.getElementById('live-marquee').innerText = state.tickerMessage;
            document.getElementById('security-txt').innerText = state.securityLevel;
            
            const feed = document.getElementById('news-feed'); feed.innerHTML = '';
            state.announcements.forEach(a => {
                let deleteBtn = (activeUser && (activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN')) ? `<button onclick="deleteNews('${a.id}')" class="text-[10px] text-red-400 font-bold hover:underline">Gỡ bản tin</button>` : '';
                feed.innerHTML += `<div class="bg-[#0a0f1d] border border-slate-800 p-3.5 rounded-xl flex justify-between items-start shadow-sm"><div><span class="text-[9px] font-black text-amber-500 bg-amber-950 px-1.5 py-0.5 rounded border border-amber-800">${a.type}</span><h4 class="text-sm font-black text-white mt-1">${a.title}</h4><p class="text-xs text-slate-400 mt-0.5 leading-relaxed">${a.content}</p></div>${deleteBtn}</div>`;
            });

            const wanted = document.getElementById('wanted-feed'); wanted.innerHTML = '';
            state.criminalWantedList.forEach(c => {
                wanted.innerHTML += `
                    <div class="bg-red-950/10 border border-red-900/40 p-3 rounded-xl text-xs">
                        <p class="font-black text-red-400 flex items-center gap-1"><i class="fa-solid fa-bullseye"></i> TRUY NÃ QUỐC GIA: @${c.name}</p>
                        <p class="text-slate-300 mt-1">Hành vi phạm tội: ${c.crime}</p>
                    </div>
                `;
            });
            
            if (activeUser) {
                const tbody = document.getElementById('officer-table'); tbody.innerHTML = '';
                Object.values(state.applications).forEach(app => {
                    if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ' || app.agency === activeUser.agency) {
                        tbody.innerHTML += `
                            <tr class="hover:bg-slate-900/60 border-b border-slate-800 text-xs">
                                <td class="p-3 font-black font-mono text-amber-500">${app.id}</td>
                                <td class="p-3 font-medium">@${app.sender}</td>
                                <td class="p-3"><span class="bg-slate-800 text-slate-300 px-2 py-0.5 rounded text-[10px] font-bold">${app.docType}</span></td>
                                <td class="p-3 font-black text-amber-400">${app.status}</td>
                                <td class="p-3 text-right"><button onclick="selectFile('${app.id}')" class="bg-emerald-600 hover:bg-emerald-700 font-bold text-white px-3 py-1 rounded text-[11px]">Mở Thẩm Định Tư Pháp</button></td>
                            </tr>
                        `;
                    }
                });
            }

            document.getElementById('st-staff').innerText = Object.keys(state.authorizedPersonnel).length - 1;
            document.getElementById('st-files').innerText = Object.keys(state.archivedApplications).length;
            
            // ADMIN TAB LƯU TRỮ QUỐC GIA: XEM CHI TIẾT 100% ĐƠN THƯ KHÔNG BỊ KHÓA
            const adminVault = document.getElementById('admin-vault-list');
            if(adminVault) {
                adminVault.innerHTML = '';
                Object.values(state.archivedApplications).forEach(ar => {
                    adminVault.innerHTML += `
                        <div class="bg-slate-900/90 border border-slate-800 p-3 rounded-xl flex justify-between items-center">
                            <div>
                                <p class="font-mono font-black text-purple-400">${ar.id}</p>
                                <p class="text-slate-300 text-[11px]">Chủ sở hữu: <b>@${ar.sender}</b></p>
                                <span class="text-[9px] bg-purple-950 text-purple-400 border border-purple-800/40 px-1 rounded font-bold">${ar.docType}</span>
                            </div>
                            <button onclick="selectFile('${ar.id}')" class="text-[10px] bg-purple-600 text-white font-black px-2 py-1 rounded hover:bg-purple-700 uppercase">Xem Nội Dung Chi Tiết</button>
                        </div>
                    `;
                });
            }

            // PHÂN HỆ THANG ĐIỂM KPI VÀ HIỆU SUẤT CÁN BỘ
            const analytics = document.getElementById('admin-analytics-list');
            if (analytics) {
                analytics.innerHTML = '';
                Object.values(state.authorizedPersonnel).forEach(u => {
                    if (u.username !== 'admin') {
                        let totalRatings = u.positiveRatings + u.negativeRatings;
                        let kpiScore = Math.max(0, (u.processedCount * 10) + (u.positiveRatings * 5) - (u.negativeRatings * 10));
                        
                        analytics.innerHTML += `
                            <div class="bg-slate-900/80 p-3.5 rounded-xl border border-slate-800 text-xs space-y-2">
                                <div class="flex justify-between font-black text-white border-b border-slate-800 pb-1.5">
                                    <span>${u.displayName} <span class="text-slate-500 font-mono text-[10px]">(@${u.username})</span></span>
                                    <span class="text-purple-400 text-[10px] uppercase bg-purple-950 px-1.5 rounded">${u.agency} - ${u.role}</span>
                                </div>
                                <div class="text-[11px] text-slate-400 font-mono grid grid-cols-2 gap-1 bg-black/30 p-2 rounded-lg">
                                    <div>Mật khẩu: <span class="text-amber-400">${u.password}</span></div>
                                    <div>Đã xử lý: <b class="text-white">${u.processedCount} hồ sơ</b></div>
                                    <div>Đánh giá: <span class="text-emerald-400">👍${u.positiveRatings}</span> / <span class="text-red-400">👎${u.negativeRatings}</span></div>
                                    <div class="text-right">KPI: <b class="text-yellow-400 font-mono text-xs">${kpiScore}đ</b></div>
                                </div>
                                <div class="flex gap-2 pt-1">
                                    <button onclick="editOfficer('${u.username}')" class="flex-1 bg-sky-600 hover:bg-sky-700 text-white font-bold py-1 rounded text-[10px] uppercase"><i class="fa-solid fa-user-gear"></i> Chỉnh Sửa Acc</button>
                                    <button onclick="deleteOfficer('${u.username}')" class="bg-red-600 hover:bg-red-700 text-white font-bold px-2 py-1 rounded text-[10px] uppercase"><i class="fa-solid fa-trash"></i> Xóa</button>
                                </div>
                            </div>
                        `;
                    }
                });
            }

            // BIỂU ĐỒ HOẠT ĐỘNG PHẦN TRĂM SỐ HÓA PHÒNG GIÁM SÁT
            const chartZone = document.getElementById('admin-chart-zone');
            if(chartZone) {
                let totalApps = Object.keys(state.applications).length;
                let totalArchived = Object.keys(state.archivedApplications).length;
                let totalSum = totalApps + totalArchived || 1;
                let pApps = Math.round((totalApps / totalSum) * 100);
                let pArchived = Math.round((totalArchived / totalSum) * 100);
                
                chartZone.innerHTML = `
                    <p class="text-slate-400 font-bold text-[10px] uppercase">Biểu đồ cơ cấu lưu trữ dữ liệu quốc gia:</p>
                    <div class="space-y-1">
                        <p class="flex justify-between"><span>Hồ sơ đang xử lý (${totalApps})</span><b>${pApps}%</b></p>
                        <div class="w-full bg-slate-900 h-2.5 rounded-full overflow-hidden border border-slate-800"><div class="bg-amber-500 h-full" style="width: ${pApps}%"></div></div>
                    </div>
                    <div class="space-y-1">
                        <p class="flex justify-between"><span>Hồ sơ đã lưu kho (${totalArchived})</span><b>${pArchived}%</b></p>
                        <div class="w-full bg-slate-900 h-2.5 rounded-full overflow-hidden border border-slate-800"><div class="bg-purple-600 h-full" style="width: ${pArchived}%"></div></div>
                    </div>
