            }
            const citizen = registry[username]; soundSuccess();
            const fixedID = "06802600" + hashCodeCCCD(username); // Số căn cước cố định tuyệt đối theo tên tài khoản

            // Thẻ Căn Cước Số Hóa
            let ccHtml = `
