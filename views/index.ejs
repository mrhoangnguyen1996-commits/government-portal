<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Hệ Thống Quản Lý Quốc Gia - Roleplay</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #0d1117;
            color: #c9d1d9;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            transition: all 0.5s ease;
        }
        .card {
            background-color: #161b22;
            border: 1px solid #30363d;
            color: #c9d1d9;
            margin-bottom: 15px;
            position: relative;
            overflow: hidden;
        }
        .card-header {
            background-color: #21262d;
            border-bottom: 1px solid #30363d;
            font-weight: bold;
        }
        .nav-tabs .nav-link {
            color: #58a6ff;
            border: none;
        }
        .nav-tabs .nav-link.active {
            background-color: #161b22;
            color: #ffffff;
            border: 1px solid #30363d;
            border-bottom: none;
        }
        /* ===== HIỆU ỨNG ĐẶC BIỆT (ANIMATIONS) ===== */
        @keyframes redAlertPulse {
            0% { box-shadow: inset 0 0 40px rgba(255, 0, 0, 0.3); background-color: #150505; }
            50% { box-shadow: inset 0 0 120px rgba(255, 0, 0, 0.7); background-color: #300505; }
            100% { box-shadow: inset 0 0 40px rgba(255, 0, 0, 0.3); background-color: #150505; }
        }
        .red-alert-active {
            animation: redAlertPulse 1.6s infinite !important;
        }
        .glitch-text {
            text-shadow: 2px 2px #ff0000, -2px -2px #00ffff;
            animation: glitch 0.4s infinite;
        }
        @keyframes glitch {
            0% { transform: translate(0) }
            20% { transform: translate(-1px, 1px) }
            40% { transform: translate(-1px, -1px) }
            60% { transform: translate(1px, 1px) }
            80% { transform: translate(1px, -1px) }
            100% { transform: translate(0) }
        }
        .stamp-animated {
            position: absolute;
            top: 25%; right: 8%;
            border: 4px double #ff4d4d;
            color: #ff4d4d;
            font-weight: 900; font-size: 26px;
            padding: 4px 12px; transform: rotate(-15deg);
            border-radius: 4px; font-family: 'Courier New', monospace;
            text-transform: uppercase; background: rgba(0,0,0,0.15);
            animation: slamStamp 0.25s ease-out forwards;
        }
        @keyframes slamStamp {
            0% { transform: scale(5) rotate(-35deg); opacity: 0; }
            80% { transform: scale(0.95) rotate(-10deg); opacity: 1; }
            100% { transform: scale(1) rotate(-15deg); opacity: 1; filter: drop-shadow(0 0 6px rgba(255,0,0,0.4)); }
        }
        @keyframes screenShake {
            0%, 100% { transform: translate(0, 0); }
            20% { transform: translate(-2px, 1px); }
            40% { transform: translate(2px, -1px); }
            60% { transform: translate(-1px, -2px); }
            80% { transform: translate(2px, 2px); }
        }
        .shake-element { animation: screenShake 0.15s ease-in-out; }
    </style>
</head>
<body>

    <canvas id="matrix-bg" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -1; opacity: 0.03; pointer-events: none;"></canvas>

    <audio id="snd-click" src="https://assets.mixkit.co/active_storage/sfx/2568/2568-84.wav" preload="auto"></audio>
    <audio id="snd-stamp" src="https://assets.mixkit.co/active_storage/sfx/2019/2019-84.wav" preload="auto"></audio>
    <audio id="snd-warn" src="https://assets.mixkit.co/active_storage/sfx/911/911-84.wav" preload="auto"></audio>
    <audio id="snd-key" src="https://assets.mixkit.co/active_storage/sfx/2539/2539-84.wav" preload="auto"></audio>

    <div class="container-fluid p-4">
        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary">
            <div>
                <h1 id="system-title" class="fw-bold text-success">TRUNG TÂM ĐIỀU HÀNH QUỐC GIA</h1>
                <p class="text-muted m-0">Hệ thống xử lý hành chính trực tuyến liên thông Bộ Ngành</p>
            </div>
            <div class="text-end">
                <span class="badge bg-secondary p-2 mb-1">Cấp độ an ninh:</span>
                <div id="security-badge" class="h5 fw-bold text-info"><%= securityLevel %></div>
            </div>
        </div>

        <div class="alert alert-dark p-2 mb-4 overflow-hidden" style="white-space: nowrap; background-color: #161b22; border-color: #30363d;">
            <marquee behavior="scroll" direction="left" class="text-warning fw-bold"><%= tickerMessage %></marquee>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header text-danger">⚙️ TRẠM ĐIỀU KHIỂN AN NINH TỐI CAO</div>
                    <div class="card-body">
                        <label class="form-label small">Thay đổi trạng thái quốc gia:</label>
                        <select id="select-security" class="form-select bg-dark text-white border-secondary mb-3">
                            <option value="AN TOÀN" <%= securityLevel==='AN TOÀN'?'selected':'' %>>🟢 Mức 1: AN TOÀN TOÀN DIỆN</option>
                            <option value="NGUY HIỂM CAO" <%= securityLevel==='NGUY HIỂM CAO'?'selected':'' %>>🟡 Mức 2: NGUY HIỂM CAO</option>
                            <option value="BÁO ĐỘNG ĐỎ" <%= securityLevel==='BÁO ĐỘNG ĐỎ'?'selected':'' %>>🔴 Mức 3: BÁO ĐỘNG ĐỎ TOÀN QUỐC</option>
                        </select>
                        <button onclick="changeSecurity()" class="btn btn-danger w-100 fw-bold">KÍCH HOẠT LỆNH</button>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header text-success">📟 NHẬT KÝ LỆNH ĐIỆN TỬ VĂN PHÒNG</div>
                    <div id="log-box" class="card-body small style-scrollbar" style="max-height: 300px; overflow-y: auto; font-family: monospace; background-color: #090d13;">
                        <% systemLogs.forEach(function(log) { %>
                            <div class="mb-1"><span class="text-muted">[<%= log.time %>]</span> <span class="log-text text-light"><%= log.text %></span></div>
                        <% }); %>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <ul class="nav nav-tabs card-header-tabs" id="docTabs">
                            <li class="nav-link active" style="cursor: pointer;">📂 Hồ Sơ Đang Chờ Xử Lý</li>
                        </ul>
                    </div>
                    <div class="card-body">
                        <div id="application-list">
                            <% Object.keys(applications).forEach(function(id) { let app = applications[id]; %>
                                <div id="card-<%= app.id %>" class="card card-body mb-3 border-secondary">
                                    <h5 class="text-info fw-bold"><%= app.id %> | <%= app.docType %></h5>
                                    <p class="small m-1"><strong>Người gửi:</strong> @<%= app.sender %> | <strong>Cơ quan đích:</strong> <%= app.agency %></p>
                                    <p class="bg-dark p-2 rounded text-light my-2 border border-secondary"><%= app.content %></p>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="badge bg-warning text-dark"><%= app.status %></span>
                                        <div>
                                            <button onclick="approveDocument('<%= app.id %>')" class="btn btn-sm btn-success me-2">✔ Phê Duyệt</button>
                                            <button onclick="rejectDocument('<%= app.id %>')" class="btn btn-sm btn-danger">❌ Bác Bỏ</button>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Phát âm thanh
        function playSnd(type) {
            const s = document.getElementById(`snd-${type}`);
            if(s) { s.currentTime = 0; s.play().catch(()=>{}); }
        }

        // Tự động gán âm thanh khi bấm nút/gõ phím
        document.querySelectorAll('button, select').forEach(b => b.addEventListener('click', () => playSnd('click')));
        document.querySelectorAll('input, textarea').forEach(i => i.addEventListener('input', () => playSnd('key')));

        // Hiệu ứng Báo Động Đỏ toàn màn hình
        function applySecurityVisuals(lvl) {
            const b = document.body;
            const t = document.getElementById('system-title');
            const badge = document.getElementById('security-badge');
            badge.innerText = lvl;

            if (lvl === "BÁO ĐỘNG ĐỎ" || lvl === "NGUY HIỂM CAO") {
                b.classList.add('red-alert-active');
                if(t) t.classList.add('glitch-text');
                playSnd('warn');
            } else {
                b.classList.remove('red-alert-active');
                if(t) t.classList.remove('glitch-text');
            }
        }

        // Gửi lệnh đổi mức an ninh lên Server
        function changeSecurity() {
            const lvl = document.getElementById('select-security').value;
            fetch('/api/national/security', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ level: lvl })
            }).then(() => {
                applySecurityVisuals(lvl);
                location.reload();
            });
        }

        // Hiệu ứng dập dấu mộc và rung chuyển hồ sơ
        function executeStampEffect(id, text, color) {
            const card = document.getElementById(`card-${id}`);
            if(!card) return;

            const st = document.createElement('div');
            st.className = 'stamp-animated';
            st.style.borderColor = color;
            st.style.color = color;
            st.innerText = text;

            card.appendChild(st);
            playSnd('amp'); // Tiếng bộp đóng dấu
            card.classList.add('shake-element');
            setTimeout(() => card.classList.remove('shake-element'), 150);
        }

        // Hàm Phê Duyệt Hồ Sơ
        function approveDocument(id) {
            executeStampEffect(id, 'ĐÃ PHÊ DUYỆT', '#00ff00');
            setTimeout(() => {
                fetch('/api/applications/action', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ id, action: 'status', status: 'Chấp Thuận Hợp Pháp', stamp: 'stamp-approved', officerName: 'Lãnh Đạo Tối Cao', officerRole: 'ADMIN' })
                }).then(() => location.reload());
            }, 600);
        }

        // Hàm Từ Chối Hồ Sơ
        function rejectDocument(id) {
            executeStampEffect(id, 'BỊ BÁC BỎ', '#ff3333');
            setTimeout(() => {
                fetch('/api/applications/action', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ id, action: 'status', status: 'Bị Từ Chối', stamp: 'stamp-rejected', officerName: 'Lãnh Đạo Tối Cao', officerRole: 'ADMIN' })
                }).then(() => location.reload());
            }, 600);
        }

        // Khởi chạy nền ma trận mờ
        const canvas = document.getElementById('matrix-bg');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth; canvas.height = window.innerHeight;
        const letters = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ☣️⚡'.split('');
        const fontSize = 14; const columns = canvas.width / fontSize;
        const drops = Array(Math.floor(columns)).fill(1);
        
        function drawMatrix() {
            ctx.fillStyle = 'rgba(13, 17, 23, 0.05)'; ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#0f0'; ctx.font = fontSize + 'px monospace';
            for(let i=0; i<drops.length; i++) {
                const text = letters[Math.floor(Math.random()*letters.length)];
                ctx.fillText(text, i*fontSize, drops[i]*fontSize);
                if(drops[i]*fontSize > canvas.height && Math.random() > 0.975) drops[i] = 0;
                drops[i]++;
            }
        }
        setInterval(drawMatrix, 33);

        // Chạy kiểm tra đồ họa an ninh ngay khi load trang
        applySecurityVisuals("<%= securityLevel %>");
    </script>
</body>
</html>
