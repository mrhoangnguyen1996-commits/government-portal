        function trackApplication() {
            const id = document.getElementById('track-id').value.trim();
            const area = document.getElementById('track-details');
            const empty = document.getElementById('track-empty');
            let app = state.applications[id] || state.archivedApplications[id];
            if (!app) { area.classList.add('hidden'); empty.classList.remove('hidden'); return; }
            empty.classList.add('hidden'); area.classList.remove('hidden');

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-gray-950 p-2.5 rounded-xl border border-gray-800 text-[11px]"><p class="text-[9px] font-bold text-gray-500">${l.sender} • ${l.time}</p><p class="text-white mt-0.5 font-medium">${l.msg}</p></div>`;
            });
            let satBlock = '';
            if ((app.status === 'Đã Phê Duyệt' || app.status === 'Bị Bác Bỏ') && !app.satisfaction) {
                satBlock = `<div class="space-y-2 p-2 bg-gray-950 border border-gray-800 rounded-xl flex gap-2 justify-center"><button onclick="sendAction('${id}', 'satisfaction', 'HÀI LÒNG')" class="bg-emerald-600 text-white font-black px-4 py-1.5 rounded-lg text-[10px] uppercase shadow">Hài Lòng 👍</button><button onclick="sendAction('${id}', 'satisfaction', 'KHIẾU NẠI CẤP CAO')" class="bg-red-600 text-white font-black px-4 py-1.5 rounded-lg text-[10px] uppercase shadow animate-pulse">🚨 KHIẾU NẠI KHẨN 🚨</button></div>`;
            } else if (app.satisfaction) {
                satBlock = `<div class="text-center text-[10px] font-black uppercase text-amber-500 bg-gray-950 p-2 rounded-xl border border-gray-800">ĐÁNH GIÁ CHẤT LƯỢNG CÔNG VỤ: [${app.satisfaction}]</div>`;
            }

            area.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3 max-h-[300px] pr-1">
                    <div class="bg-gray-950 p-3 rounded-xl border border-gray-800 flex justify-between items-center shadow-inner">
                        <div><p class="font-black text-amber-400">${app.id} [${app.docType}]</p><p class="text-[9px] font-mono text-gray-500">Mức độ khẩn: ${app.priority}</p></div>
                        <div class="stamp-box ${app.stamp}">${app.status}</div>
                    </div>
                    <div class="space-y-2" id="citizen-chat-flow">${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-gray-800 space-y-2">
                    ${satBlock}
                    <div class="flex gap-2">
                        <input type="text" id="citizen-chat-msg" placeholder="Nhập bằng chứng kịch bản hoặc văn bản đối thoại trực tiếp..." class="flex-1 bg-gray-950 border border-gray-700 p-2 text-xs text-white rounded-xl focus:outline-none">
                        <button onclick="citizenChat('${app.id}')" class="bg-amber-500 hover:bg-amber-600 font-black text-black px-5 text-xs rounded-xl uppercase tracking-wider transition-all">Gửi</button>
                    </div>
                </div>
            `;
            setTimeout(() => { const el = document.getElementById('citizen-chat-flow'); if(el) el.scrollTop = el.scrollHeight; }, 60);
        }

        async function citizenChat(id) {
            const msg = document.getElementById('citizen-chat-msg').value.trim(); if (!msg) return;
            let target = state.applications[id] || state.archivedApplications[id];
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action: 'chat', msg, officerName: `Công Dân (@${target.sender})` }) });
            document.getElementById('citizen-chat-msg').value = '';
        }

        function selectFile(id) { activeFileId = id; document.getElementById('officer-desk-empty').classList.add('hidden'); document.getElementById('officer-desk-active').classList.remove('hidden'); renderOfficerDesk(); }

        function renderOfficerDesk() {
            let app = state.applications[activeFileId] || state.archivedApplications[activeFileId]; if(!app) return;
            const desk = document.getElementById('officer-desk-active');

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-gray-950 p-2 rounded-xl border border-gray-800 text-[11px]"><p class="text-[9px] text-gray-500">${l.sender} • ${l.time}</p><p class="text-white mt-0.5 font-medium">${l.msg}</p></div>`;
            });
            let actionsHtml = '';
            if (state.applications[activeFileId]) {
                if (app.status === 'Đang Chờ Tiếp Nhận') {
                    actionsHtml = `<button onclick="sendAction('${app.id}', 'claim_packet')" class="w-full bg-gradient-to-r from-sky-500 to-blue-600 text-white font-black py-2.5 rounded-xl text-xs uppercase shadow-md tracking-wider">Thụ Lý Phân Phối Hồ Sơ</button>`;
                } else {
                    // PHÂN QUYỀN 4 CẤP: CHUYÊN VIÊN, LÃNH ĐẠO VÀ THANH TRA TRONG QUY TRÌNH HỒ SƠ
                    let lanhDaoBlock = (activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN') ? `
                        <div class="grid grid-cols-2 gap-2">
                            <button onclick="sendAction('${app.id}', 'status', 'Đã Phê Duyệt', 'stamp-approved')" class="bg-emerald-600 hover:bg-emerald-700 text-white font-black py-2 rounded-xl text-[10px] uppercase shadow transition-all">Ấn Approved</button>
                            <button onclick="sendAction('${app.id}', 'status', 'Bị Bác Bỏ', 'stamp-rejected')" class="bg-red-600 hover:bg-red-700 text-white font-black py-2 rounded-xl text-[10px] uppercase shadow transition-all">Bác Bỏ Từ Chối</button>
                        </div>
                        <button onclick="sendAction('${app.id}', 'archive')" class="w-full bg-purple-700 hover:bg-purple-800 text-white font-black py-2 rounded-xl text-[10px] uppercase tracking-wider shadow shadow-purple-900 transition-all">Ký Lưu Kho Quốc Gia</button>
                    ` : `<button onclick="sendAction('${app.id}', 'to_leader')" class="w-full bg-amber-600 hover:bg-amber-700 text-black font-black py-2 rounded-xl text-[10px] uppercase tracking-wider shadow">Trình Tấu Thượng Cấp Phê Duyệt</button>`;
                    
                    let thanhTraBlock = (activeUser.role === 'THANH TRA' || activeUser.role === 'ADMIN') ? `
                        <button onclick="sendAction('${app.id}', 'investigate')" class="w-full bg-red-950 hover:bg-red-900 border border-red-700 text-red-400 font-black py-2 rounded-xl text-[10px] uppercase tracking-widest shadow animate-pulse">Lệnh Thanh Tra Đóng Băng Hồ Sơ</button>
                    ` : '';

                    actionsHtml = `<div class="space-y-1.5">${lanhDaoBlock}${thanhTraBlock}</div>`;
                }
            } else {
                actionsHtml = (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA') ? 
                    `<button onclick="sendAction('${app.id}', 'unarchive')" class="w-full bg-yellow-600 font-black text-black py-2 rounded-xl text-xs uppercase tracking-wider">Sắc Lệnh Phục Hồi Hồ Sơ Từ Kho</button>` : 
                    `<div class="text-center text-[10px] text-purple-400 font-black uppercase bg-purple-950/40 p-2.5 rounded-xl border border-purple-900/40">🔒 Hồ sơ đã niêm phong lưu kho bảo mật lõi</div>`;
            }

            desk.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3.5 max-h-[350px] pr-1">
                    <div class="bg-gray-950 p-3 rounded-xl border border-gray-800 text-[11px] relative shadow-inner">
                        <div class="absolute top-2 right-2 stamp-box ${app.stamp}">${app.status}</div>
                        <p class="font-black text-amber-400">MÃ SỐ ĐƠN: ${app.id}</p>
                        <p class="text-gray-400 italic mt-2 bg-black/40 p-2 rounded-xl border border-gray-900 font-medium">"${app.content}"</p>
                    </div>
                    <div class="space-y-2" id="officer-chat-flow">${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-gray-800 space-y-2">
                    ${actionsHtml}
                    <div class="flex gap-2">
                        <input type="text" id="officer-chat-msg" placeholder="Nhập chỉ thị điều hành gửi công dân..." class="flex-1 bg-gray-950 border border-gray-700 p-2 text-xs text-white rounded-xl focus:outline-none">
                        <button onclick="officerChat()" class="bg-emerald-600 hover:bg-emerald-700 font-black text-white px-4 text-xs rounded-xl uppercase transition-all">Gửi</button>
                    </div>
                </div>
            `;
            setTimeout(() => { const el = document.getElementById('officer-chat-flow'); if(el) el.scrollTop = el.scrollHeight; }, 60);
        }

        async function officerChat() {
            const msg = document.getElementById('officer-chat-msg').value.trim(); if (!msg) return;
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: activeFileId, action: 'chat', msg, officerName: `${activeUser.displayName} (${activeUser.agency})` }) });
            document.getElementById('officer-chat-msg').value = '';
        }

        async function sendAction(id, action, status = '', stamp = '', targetAgency = '') {
            if(action==='status' || action==='claim_packet' || action==='archive' || action==='investigate') soundStamp();
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action, status, stamp, targetAgency, officerName: activeUser ? activeUser.displayName : 'Hệ thống', officerRole: activeUser ? activeUser.role : 'Hệ thống' }) });
        }

        async function publishDocument() {
            const type = document.getElementById('pub-type').value; const title = document.getElementById('pub-title').value.trim(); const content = document.getElementById('pub-content').value.trim(); if(!title || !content) return;
            await fetch('/api/national/publish', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ type, title, content, author: activeUser.displayName }) });
            document.getElementById('pub-title').value = ''; document.getElementById('pub-content').value = ''; soundSuccess();
        }

        async function updateTicker() {
            const msg = document.getElementById('pub-ticker').value.trim(); if(!msg) return;
            await fetch('/api/national/ticker', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }) });
            document.getElementById('pub-ticker').value = ''; soundSuccess();
        }

        async function deleteNews(id) { await fetch('/api/national/delete-announcement', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) }); }
        async function setSecurity(level) { await fetch('/api/national/security', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ level }) }); }
        async function provisionAccount(e) { e.preventDefault(); const username = document.getElementById('p-user').value.trim(); const password = document.getElementById('p-pass').value; const displayName = document.getElementById('p-name').value.trim(); const role = document.getElementById('p-role').value; const agency = document.getElementById('p-agency').value; const isEdit = document.getElementById('p-isEdit').value === "true"; await fetch('/api/officer/save', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, password, displayName, role, agency, isEdit }) }); resetProvisionForm(); soundSuccess(); }

        function searchCitizen() {
            const q = document.getElementById('id-search').value.trim(); const resArea = document.getElementById('id-result');
            if (registry[q]) {
                let r = registry[q]; soundSuccess();
                resArea.innerHTML = `
                    <div class="mt-4 p-4 bg-gray-950 border border-gray-800 rounded-xl text-xs space-y-2 shadow-inner animate-fade-in">
                        <p class="text-sm font-black text-amber-400 border-b border-gray-800/80 pb-1">${r.name}</p>
                        <p class="font-medium">Ngày sinh: <span class="text-white">${r.dob}</span> | Giới tính: <span class="text-white">${r.gender}</span></p>
                        <p class="font-medium">Nghề nghiệp kịch bản: <span class="text-white">${r.job}</span></p>
                        <p class="font-medium">Mã văn bằng đồng bộ: <span class="text-sky-400 font-bold">${r.licenses.join(' — ')}</span></p>
                        <p class="text-emerald-400 font-black">Tình trạng tư pháp: ${r.status}</p>
                    </div>
                `;
            } else { resArea.innerHTML = `<p class="mt-4 text-center text-red-400 text-xs font-black bg-red-950/20 p-3 rounded-xl border border-red-900/40">⚠️ KHÔNG TÌM THẤY DỮ LIỆU ĐỊNH DANH TRÊN CORE QUỐC GIA.</p>`; }
        }

        function openLogin() { document.getElementById('login-modal').classList.remove('hidden'); }
        function closeLogin() { document.getElementById('login-modal').classList.add('hidden'); }
        function login() { const u = document.getElementById('log-user').value; const p = document.getElementById('log-pass').value; if (state.authorizedPersonnel[u] && state.authorizedPersonnel[u].password === p) { activeUser = state.authorizedPersonnel[u]; localStorage.setItem('sessionUser', JSON.stringify({ username: u, password: p })); closeLogin(); soundSuccess(); applyUserRoleLayout(); } else { alert("Mật mã chứng thư nghiệp vụ không chính xác!"); } }
        function applyUserRoleLayout() { if(!activeUser) return; document.getElementById('btn-tab-officer').classList.remove('hidden'); if(activeUser.role === 'ADMIN') document.getElementById('btn-tab-admin').classList.remove('hidden'); if(activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ') { document.getElementById('leader-publish-zone').classList.remove('hidden'); } else { document.getElementById('leader-publish-zone').classList.add('hidden'); } renderAuth(); renderAll(); let savedTab = sessionStorage.getItem('activeTab'); tab(savedTab || 'tab-officer'); }
        function logout() { activeUser = null; activeFileId = null; localStorage.removeItem('sessionUser'); document.getElementById('btn-tab-officer').classList.add('hidden'); document.getElementById('btn-tab-admin').classList.add('hidden'); renderAuth(); tab('tab-news'); }
        function renderAuth() { const p = document.getElementById('auth-panel'); if(!activeUser) { p.innerHTML = `<button onclick="openLogin()" class="bg-gradient-to-r from-amber-500 to-amber-600 text-black px-4 py-2 rounded-xl text-[11px] uppercase font-black tracking-wider shadow-md hover:brightness-110 transition-all"><i class="fa-solid fa-key mr-1"></i> Đăng Nhập Công Vụ</button>`; } else { p.innerHTML = `<div class="bg-gray-950 border border-gray-800 px-3 py-1.5 text-xs rounded-xl flex items-center gap-2 shadow-inner"><i class="fa-solid fa-circle-user text-emerald-400"></i> <b class="text-white">${activeUser.displayName}</b><button onclick="logout()" class="text-red-400 hover:text-red-500 ml-2 transition-all"><i class="fa-solid fa-power-off"></i></button></div>`; } }
        
        startClock();
    </script>
</body>
</html>
