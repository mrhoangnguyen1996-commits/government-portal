                        </div>
                    </div>
                    <div class="flex justify-between items-center pt-2 border-t border-slate-800">
                        <div class="card-chip shadow-md"></div>
                        <div class="text-right"><span class="text-[9px] font-black bg-emerald-950 text-emerald-400 border border-emerald-800/60 px-2 py-0.5 rounded uppercase tracking-wider">${citizen.status}</span></div>
                    </div>
                </div>
            `;

            // 2. Vòng lặp kết xuất các loại bằng cấp và giấy chứng nhận sử dụng vũ khí
            citizen.licenses.forEach(lic => {
                let isWeapon = lic.includes("Vũ Khí") || lic.includes("Công Cụ Hỗ Trợ");
                let isTruck = lic.includes("Hạng C");
                
                finalCardsHtml += `
                    <div class="national-card w-full max-w-md p-5 rounded-2xl ${isWeapon ? 'border-red-500/30' : isTruck ? 'border-amber-500/30' : 'border-emerald-500/30'} text-slate-100 font-sans space-y-3">
                        <div class="flex justify-between items-center border-b ${isWeapon ? 'border-red-500/20' : 'border-emerald-500/20'} pb-1.5">
                            <span class="text-[9px] font-black font-mono tracking-widest ${isWeapon ? 'text-red-400' : 'text-emerald-400'} uppercase"><i class="fa-solid fa-shield mr-1"></i> VĂN BẰNG QUỐC GIA CHỨNG CHỈ SỐ</span>
                            <span class="text-[9px] text-slate-500 font-mono">LP-${Math.floor(10000 + Math.random()*90000)}</span>
                        </div>
                        <div>
                            <p class="text-[10px] text-slate-400 font-bold uppercase">Họ tên người sở hữu:</p>
                            <p class="text-sm font-black text-white uppercase tracking-wide">${citizen.name} (@${username})</p>
                        </div>
                        <div class="p-2.5 bg-black/40 border border-slate-800 rounded-xl">
                            <p class="text-[9px] text-slate-400 font-bold uppercase">Nội dung văn bằng chứng nhận cấp pháp:</p>
