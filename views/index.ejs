    <div id="login-modal" class="fixed inset-0 bg-black/90 backdrop-blur-md flex items-center justify-center hidden p-4 z-50">
        <div class="bg-[#0a0f1d] border border-slate-800 p-6 rounded-2xl max-w-sm w-full space-y-4 text-xs shadow-2xl relative">
            <div class="text-center space-y-1">
                <i class="fa-solid fa-key text-3xl text-amber-500 mb-1"></i>
                <h3 class="text-sm font-black text-white uppercase tracking-widest">Mã Hóa Chứng Thư Nghiệp Vụ cán bộ</h3>
            </div>
            <div><label class="text-gray-400 block mb-1 font-bold uppercase">Mã Tài Khoản Định Danh</label><input type="text" id="log-user" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-mono focus:outline-none"></div>
            <div><label class="text-gray-400 block mb-1 font-bold uppercase">Mật Mã Hệ Thống</label><input type="password" id="log-pass" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white focus:outline-none"></div>
            <div class="flex gap-2 pt-2">
                <button onclick="closeLogin()" class="w-1/3 bg-slate-800 text-slate-400 py-2 rounded-lg uppercase font-black">Đóng</button>
                <button onclick="login()" class="w-2/3 bg-gradient-to-r from-amber-400 to-amber-500 text-black py-2 rounded-lg uppercase font-black">Xác Minh Nghiệp Vụ</button>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        let state = {}; let registry = {}; let violations = {}; 
        let activeUser = null; let activeFileId = null;

        /* ENGINE SÓNG ÂM AUDIO-CONTEXT ĐA DẠNG CHUYÊN NGHIỆP */
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        function playTone(freq, type, duration, vol) {
            try {
                const osc = audioCtx.createOscillator(); const gainNode = audioCtx.createGain();
                osc.type = type; osc.frequency.value = freq;
                gainNode.gain.setValueAtTime(vol, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.00001, audioCtx.currentTime + duration);
                osc.connect(gainNode); gainNode.connect(audioCtx.destination);
                osc.start(); osc.stop(audioCtx.currentTime + duration);
            } catch(e) {}
        }

        const soundClick = () => playTone(550, 'sine', 0.06, 0.1);
        const soundSuccess = () => { playTone(523.25, 'sine', 0.08, 0.12); setTimeout(() => playTone(659.25, 'sine', 0.12, 0.12), 70); };
        const soundAlert = () => { playTone(900, 'sawtooth', 0.18, 0.08); setTimeout(() => playTone(900, 'sawtooth', 0.18, 0.08), 160); };
        const soundStamp = () => { playTone(100, 'triangle', 0.22, 0.45); playTone(280, 'sawtooth', 0.08, 0.1); };
        const soundReject = () => { playTone(180, 'sawtooth', 0.25, 0.15); };

        document.addEventListener('click', (e) => {
            if(e.target.closest('button') || e.target.closest('nav button') || e.target.closest('select')) { soundClick(); }
        });

        function startClock() { 
            setInterval(() => { 
                document.getElementById('clock').innerText = new Date().toLocaleTimeString('vi-VN'); 
                drawAdminChart();
            }, 1000); 
        }

        /* ĐIỀU PHỐI KHÔNG GIAN TAB CON CỦA CÁN BỘ VÀ ADMIN */
        function subTab(id) {
            document.querySelectorAll('[id^="subtab-off-"]').forEach(s => s.classList.add('hidden'));
            document.getElementById(`subtab-${id}`).classList.remove('hidden');
            document.querySelectorAll('.subtab-btn').forEach(b => b.classList.remove('active'));
            if(document.getElementById(`btn-${id}`)) document.getElementById(`btn-${id}`).classList.add('active');
        }

        function adminSubTab(id) {
            document.querySelectorAll('[id^="subtab-adm-"]').forEach(s => s.classList.add('hidden'));
            document.getElementById(`subtab-${id}`).classList.remove('hidden');
        }

        /* KHU VỰC ĐỒ HỌA CANVAS BIỂU ĐỒ SỐ ĐỘNG ADMIN */
        function drawAdminChart() {
            const canvas = document.getElementById('adminPerformanceChart');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            let totalApps = Object.keys(state.applications || {}).length;
            let totalArchived = Object.keys(state.archivedApplications || {}).length;
            let totalPersonnel = Object.keys(state.authorizedPersonnel || {}).length - 1;

            let h1 = Math.max(10, Math.min(100, totalApps * 15));
            let h2 = Math.max(10, Math.min(100, totalArchived * 15));
            let h3 = Math.max(10, Math.min(100, totalPersonnel * 15));

            ctx.fillStyle = '#1e293b'; ctx.fillRect(20, 110, 50, -h1);
            ctx.fillStyle = '#f59e0b'; ctx.font = '9px monospace'; ctx.fillText(totalApps, 35, 105 - h1);

            ctx.fillStyle = '#a855f7'; ctx.fillRect(100, 110, 50, -h2);
            ctx.fillStyle = '#c084fc'; ctx.fillText(totalArchived, 115, 105 - h2);

            ctx.fillStyle = '#10b981'; ctx.fillRect(180, 110, 50, -h3);
            ctx.fillStyle = '#34d399'; ctx.fillText(totalPersonnel, 195, 105 - h3);

            ctx.fillStyle = '#64748b'; ctx.font = '8px sans-serif';
            ctx.fillText('Đơn Đang Chờ', 15, 125); ctx.fillText('Đã Lưu Kho', 102, 125); ctx.fillText('Nhân Sự', 188, 125);
        }

        /* LẮNG NGHE SỰ KIỆN REALTIME QUA SOCKET - XỬ LÝ KHÔNG DELAY */
        socket.on('initData', (data) => { updateDataAndRender(data); checkAndRestoreSession(); });
        socket.on('stateUpdate', (data) => { updateDataAndRender(data); });
        
        socket.on('newApplicationAlert', (appInfo) => {
            if (activeUser) {
                if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ' || appInfo.agency === activeUser.agency) {
                    document.getElementById('officer-alert-light').classList.remove('hidden');
                    soundAlert();
                }
            }
        });

        socket.on('newChatMessage', (chatInfo) => {
            if (document.getElementById('track-id').value === chatInfo.fileId) trackApplication();
            if (activeFileId === chatInfo.fileId) renderOfficerDesk();
        });

        function updateDataAndRender(data) {
            state = data.systemState; registry = data.citizenIdentityRegistry; violations = data.criminalRecordsRegistry;
            if (activeUser) activeUser = state.authorizedPersonnel[activeUser.username];
            
            if (activeUser) {
                let filtered = Object.values(state.applications).filter(a => {
                    if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ') return true;
                    return a.agency === activeUser.agency;
                });
                const badgeCount = document.getElementById('badge-count-app');
                if (filtered.length > 0) { badgeCount.innerText = filtered.length; badgeCount.classList.remove('hidden'); } 
                else { badgeCount.classList.add('hidden'); }
            }
            renderAll();
            if (activeFileId) renderOfficerDesk();
        }

        function checkAndRestoreSession() {
            let savedSession = localStorage.getItem('sessionUser');
            if(savedSession) {
                try {
                    let creds = JSON.parse(savedSession);
                    if (state.authorizedPersonnel[creds.username] && state.authorizedPersonnel[creds.username].password === creds.password) {
                        activeUser = state.authorizedPersonnel[creds.username];
                        applyUserRoleLayout();
                    }
                } catch(e) { localStorage.removeItem('sessionUser'); }
            } else { renderAuth(); }
        }

        function jumpToActiveNotification() { tab('tab-officer'); subTab('off-apps'); document.getElementById('officer-alert-light').classList.add('hidden'); }

        function tab(id) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            document.getElementById(id).classList.remove('hidden');
            document.querySelectorAll('nav button').forEach(b => { b.classList.remove('border-amber-500', 'text-amber-500'); b.classList.add('border-transparent', 'text-slate-400'); });
            const btn = document.getElementById(`btn-${id}`);
            if(btn) btn.classList.add('border-amber-500', 'text-amber-500');
            if (id === 'tab-officer') {
                document.getElementById('officer-alert-light').classList.add('hidden');
                if(activeUser && (activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN')) {
                    document.getElementById('btn-off-leader').classList.remove('hidden');
                }
                subTab('off-apps');
            }
            if (id === 'tab-admin') adminSubTab('adm-analytics');
            sessionStorage.setItem('activeTab', id);
        }

        // LẬP BIÊN BẢN VI PHẠM BAN HÀNH TỰ ĐỘNG CHUYỂN VỀ KHO LƯU TRỮ QUỐC GIA
        async function submitViolationForm(e) {
            e.preventDefault();
            const username = document.getElementById('vio-user').value.trim();
            const type = document.getElementById('vio-type').value;
            const lawClause = document.getElementById('vio-clause').value.trim();
            const fine = document.getElementById('vio-fine').value.trim() || "0 VND";
            const status = document.getElementById('vio-status').value;

            await fetch('/api/resident/violation', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, type, lawClause, fine, status, officerName: activeUser.displayName })
            });

            // Gói biên bản thành một hồ sơ gửi thẳng lên hệ thống để lưu kho quốc gia mở xem lại được
            await fetch('/api/applications/submit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ sender: username, agency: activeUser.agency, docType: "BIÊN BẢN XỬ PHẠT TƯ PHÁP", content: `Lập quyết định xử lý hành vi: ${lawClause}. Số tiền nộp phạt quy định: ${fine}. Tiến độ xử lý hiện thời: [${status}]. Trực ban lập biên bản: ${activeUser.displayName}` })
            });

            document.getElementById('vio-user').value = ''; document.getElementById('vio-clause').value = ''; document.getElementById('vio-fine').value = '';
            soundStamp(); alert(`Đã ban hành quyết định xử phạt & Tự động đẩy lưu trữ vào Kho quốc gia thành công!`);
        }

        // CẤP CĂN CƯỚC HOẶC VĂN BẰNG (TÁCH BIỆT HOÀN TOÀN, SỬA LỖI SỐ ĐỊNH DANH RANDOM KHI F5)
        async function registerResidentByOfficer(e, mode) {
            e.preventDefault();
            let username, name, dob, gender, pob, job, licenses, status;
            
            if (mode === 'cccd') {
                username = document.getElementById('cccd-user').value.trim();
                name = document.getElementById('cccd-name').value.trim();
                dob = document.getElementById('cccd-dob').value.trim();
                gender = document.getElementById('cccd-gender').value;
                pob = document.getElementById('cccd-pob').value.trim();
                job = document.getElementById('cccd-job').value.trim();
                licenses = "Căn Cước Công Dân Gắn Chíp Số Hóa";
                status = document.getElementById('cccd-status').value;
            } else {
                username = document.getElementById('doc-user').value.trim();
                const selectedLicense = document.getElementById('doc-license-type').value;
                if (!registry[username]) { soundReject(); alert("Cư dân này chưa được cấp Căn Cước Công Dân gốc! Vui lòng làm CCCD trước."); return; }
                let currentRes = registry[username];
                name = currentRes.name; dob = currentRes.dob; gender = currentRes.gender; pob = currentRes.pob; job = currentRes.job; status = currentRes.status;
                let existingLicenses = currentRes.licenses || [];
                if (!existingLicenses.includes(selectedLicense)) { existingLicenses.push(selectedLicense); }
                licenses = existingLicenses.join(', ');
            }

            await fetch('/api/resident/register', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, name, dob, gender, pob, job, licenses, status, officerName: activeUser.displayName }) });
            
            if(mode === 'cccd') {
                document.getElementById('cccd-user').value = ''; document.getElementById('cccd-name').value = ''; document.getElementById('cccd-dob').value = ''; document.getElementById('cccd-pob').value = ''; document.getElementById('cccd-job').value = '';
            } else { document.getElementById('doc-user').value = ''; }
            soundSuccess(); alert(`Đã cấp và phê chuẩn dữ liệu điện tử gốc lên máy chủ quốc gia thành công!`);
        }

        // TRUY XUẤT ĐỒ HỌA PHÔI CĂN CƯỚC VÀ VĂN BẰNG PHÂN TÁCH BIỆT LẬP (MÃ ID CỐ ĐỊNH THEO TÊN)
        function generateCitizenCards() {
            const username = document.getElementById('card-search-input').value.trim();
            const zone = document.getElementById('cards-render-zone'); const vioZone = document.getElementById('violation-render-zone');
            if(!registry[username]) {
                zone.innerHTML = `<p class="text-center text-xs text-red-400 col-span-2 py-6 font-black"><i class="fa-solid fa-circle-exclamation mr-1"></i> KHÔNG TÌM THẤY DỮ LIỆU ĐỊNH DANH SỐ CỦA DÂN CƯ.</p>`;
                vioZone.innerHTML = `<p class="text-center text-xs text-slate-600 col-span-2"></p>`; return;
            }
            const citizen = registry[username]; soundSuccess();
            
            // Giải thuật băm chuỗi tên để tạo số CCCD cố định tuyệt đối khi F5
            let hashVal = 0; for (let i = 0; i < username.length; i++) { hashVal += username.charCodeAt(i); }
            let constantCccdId = 19600000 + (hashVal * 54321) % 8999999;

            let cardCcTmpl = `
                <div class="national-card w-full p-5 rounded-2xl border-l-4 border-amber-500 text-slate-100 font-sans space-y-4">
                    <div class="flex justify-between items-start border-b border-amber-500/30 pb-2">
                        <div>
                            <h4 class="text-[10px] font-black tracking-wider text-amber-400 uppercase">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</h4>
                            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">CĂN CƯỚC CÔNG DÂN / CITIZEN IDENTITY CARD</p>
                        </div>
                        <i class="fa-solid fa-star text-amber-400 text-lg"></i>
                    </div>
                    <div class="flex gap-4 items-center">
                        <div class="w-20 h-24 bg-slate-900 border border-slate-700 flex flex-col items-center justify-center rounded-lg text-slate-600 relative overflow-hidden">
                            <i class="fa-solid fa-user text-4xl mt-3 text-slate-400"></i>
                            <div class="absolute bottom-0 w-full bg-amber-500 text-[8px] font-mono font-black text-center text-black py-0.5">CHÍNH QUY</div>
                        </div>
                        <div class="flex-1 text-[11px] space-y-1">
                            <p class="font-mono text-amber-500 font-bold text-xs">Số / No: <span class="text-white tracking-widest font-black">${constantCccdId}</span></p>
                            <p class="text-slate-400 font-bold">Họ và tên: <span class="text-sm font-black text-white uppercase">${citizen.name}</span></p>
                            <p class="text-slate-400 font-bold">Ngày sinh: <span class="text-white font-mono">${citizen.dob}</span></p>
                            <p class="text-slate-400 font-bold">Giới tính: <span class="text-white">${citizen.gender}</span></p>
                            <p class="text-slate-400 font-bold">Nguyên quán: <span class="text-white">${citizen.pob}</span></p>
                        </div>
                    </div>
                    <div class="flex justify-between items-center pt-2 border-t border-slate-800">
                        <div class="card-chip shadow-md"></div>
                        <div class="text-right"><span class="text-[9px] font-black bg-emerald-950 text-emerald-400 border border-emerald-800/60 px-2 py-0.5 rounded uppercase tracking-wider">${citizen.status}</span></div>
                    </div>
                </div>
            `;

            let cardLicensesHtml = '';
            citizen.licenses.forEach(lic => {
                if(lic === "Căn Cước Công Dân Gắn Chíp Số Hóa") return; // Bỏ qua phôi căn cước ở phần văn bằng thêm
                let isWeapon = lic.includes("Vũ Khí") || lic.includes("Công Cụ");
                let isMil = lic.includes("Lực Lượng Vũ Trang") || lic.includes("Quân Đội") || lic.includes("Công An");
                let themeBorder = isWeapon ? 'border-l-4 border-red-500' : (isMil ? 'border-l-4 border-purple-500' : 'border-l-4 border-emerald-500');
                let themeIcon = isWeapon ? 'fa-gun text-red-500' : (isMil ? 'fa-shield-halved text-purple-400' : 'fa-id-card text-emerald-400');

                cardLicensesHtml += `
                    <div class="national-card w-full p-5 rounded-2xl ${themeBorder} text-slate-100 font-sans space-y-3">
                        <div class="flex justify-between items-center border-b border-slate-800 pb-1.5">
                            <span class="text-[9px] font-black font-mono tracking-widest text-slate-400 uppercase"><i class="fa-solid fa-shield mr-1"></i> GIẤY PHÉP CHỨNG CHỈ QUỐC GIA BAN HÀNH</span>
                            <i class="fa-solid ${themeIcon}"></i>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[10px] text-slate-400 font-bold">Người thụ hưởng văn bằng: <span class="text-white font-black">${citizen.name}</span></p>
                        </div>
                        <div class="p-2.5 bg-black/40 border border-slate-800 rounded-xl">
                            <p class="text-xs font-black text-amber-400 flex items-center gap-1.5 uppercase">${lic}</p>
                        </div>
                    </div>
                `;
            });
            zone.innerHTML = cardCcTmpl + cardLicensesHtml;

            let vioHtml = '';
            if (violations[username] && violations[username].length > 0) {
                violations[username].forEach(v => {
                    vioHtml += `
                        <div class="border-2 border-red-900/60 bg-red-950/10 p-4 rounded-xl relative space-y-3 shadow-lg">
                            <div class="flex justify-between items-center border-b border-red-900/40 pb-2">
                                <span class="text-xs font-black text-red-500 font-mono"><i class="fa-solid fa-gavel mr-1"></i> QUYẾT ĐỊNH SỐ: ${v.id}</span>
                                <span class="text-[10px] bg-red-950 text-red-400 font-mono px-2 py-0.5 rounded border border-red-800">${v.date}</span>
                            </div>
                            <div class="text-[11px] space-y-1">
