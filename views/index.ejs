                return;
            }
            
            const citizen = registry[username];
            soundSuccess();
            
            // 1. Kết xuất mô phỏng Thẻ CCCD gắn chíp thật
            let finalCardsHtml = `
                <div class="national-card w-full max-w-md p-5 rounded-2xl border-amber-500/30 text-slate-100 font-sans space-y-4">
