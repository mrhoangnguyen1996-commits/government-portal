                    `;
                }
            } else { actionsHtml = `<div class="text-center text-[10px] text-purple-400 font-bold uppercase bg-purple-950/20 p-2 rounded-xl border border-purple-900/40">🔒 Văn bản đã niêm phong lưu kho mật quốc gia</div>`; }

            desk.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3 max-h-[280px] pr-1">
                    <div class="bg-gray-950 p-2.5 rounded-xl border border-gray-900 text-[11px] relative shadow-inner">
                        <div class="absolute top-2 right-2 stamp-box ${app.stamp}">${app.status}</div>
                        <p class="font-black text-cyan-400 font-mono">MÃ ĐƠN: ${app.id}</p>
                        <p class="text-gray-400 italic mt-2 bg-black/40 p-2 rounded border border-gray-900 font-medium">"${app.content}"</p>
                    </div>
                    ${citizenInfoHtml}
                    <div class="space-y-2" id="officer-chat-flow">${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-gray-800 space-y-2">
                    ${actionsHtml}
                    <div class="flex gap-2">
                        <input type="text" id="officer-chat-msg" placeholder="Chỉ thị..." class="flex-1 bg-gray-950 border border-gray-800 p-2 text-xs text-white rounded-xl focus:outline-none">
                        <button onclick="officerChat()" class="bg-emerald-600 font-black text-white px-3 text-xs rounded-xl uppercase">Gửi</button>
                    </div>
                </div>
            `;
        }

        async function officerChat() {
            const msg = document.getElementById('officer-chat-msg').value.trim(); if (!msg) return;
            await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: activeFileId, action: 'chat', msg, officerName: `${activeUser.displayName} (${activeUser.agency})` }) });
            document.getElementById('officer-chat-msg').value = '';
        }

        async function sendAction(id, action, status = '', stamp = '') {
            if(action === 'satisfaction' && status === 'HÀI LÒNG' && typeof MatrixAudio !== 'undefined') MatrixAudio.lock();
            else if(typeof MatrixAudio !== 'undefined') MatrixAudio.stamp();
            
            const res = await fetch('/api/applications/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action, status, stamp, officerName: activeUser ? activeUser.displayName : 'Hệ thống', officerRole: activeUser ? activeUser.role : 'Hệ thống' }) });
            if (!res.ok) { const err = await res.json(); alert(err.error); }
        }

        async function publishDocument() {
            const type = document.getElementById('pub-type').value; const title = document.getElementById('pub-title').value.trim(); const content = document.getElementById('pub-content').value.trim(); if(!title || !content) return;
            await fetch('/api/national/publish', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ type, title, content }) });
            document.getElementById('pub-title').value = ''; document.getElementById('pub-content').value = ''; if(typeof MatrixAudio !== 'undefined') MatrixAudio.success();
        }

        async function updateTicker() {
            const msg = document.getElementById('pub-ticker').value.trim(); if(!msg) return;
            await fetch('/api/national/ticker', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }) });
            document.getElementById('pub-ticker').value = ''; if(typeof MatrixAudio !== 'undefined') MatrixAudio.success();
        }

        async function setSecurity(level) { await fetch('/api/national/security', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ level }) }); }
        
        async function provisionAccount(e) { 
            e.preventDefault(); const username = document.getElementById('p-user').value.trim(); const password = document.getElementById('p-pass').value; const displayName = document.getElementById('p-name').value.trim(); const role = document.getElementById('p-role').value; const agency = document.getElementById('p-agency').value;
            await fetch('/api/officer/save', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, password, displayName, role, agency }) });
            resetProvisionForm(); if(typeof MatrixAudio !== 'undefined') MatrixAudio.success(); alert('Đã bổ nhiệm nhân sự mới!');
        }

        // TÁCH BIỆT HÀM ĐỂ SỬA TRIỆT ĐỂ LỖI ĐĂNG NHẬP KHÔNG ĐƯỢC
        async function executeSystemLogin() { 
            const u = document.getElementById('log-user').value; const p = document.getElementById('log-pass').value;
            if (state.authorizedPersonnel[u] && state.authorizedPersonnel[u].password === p) { 
                activeUser = state.authorizedPersonnel[u]; 
                localStorage.setItem('sessionUser', JSON.stringify({ username: u, password: p })); 
                closeLogin(); if(typeof MatrixAudio !== 'undefined') MatrixAudio.success(); applyUserRoleLayout();
            } else { alert("Chứng thư định danh cán bộ không hợp lệ!"); } 
        }

        function applyUserRoleLayout() { 
            if(!activeUser) return; document.getElementById('btn-tab-officer').classList.remove('hidden'); 
            if(activeUser.role === 'ADMIN') document.getElementById('btn-tab-admin').classList.remove('hidden'); 
            if(activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ') { document.getElementById('leader-publish-zone').classList.remove('hidden'); } 
            else { document.getElementById('leader-publish-zone').classList.add('hidden'); } 
            renderAuth(); renderAll(); let savedTab = sessionStorage.getItem('activeTab'); tab(savedTab || 'tab-officer');
        }

        function logout() { activeUser = null; activeFileId = null; localStorage.removeItem('sessionUser'); document.getElementById('btn-tab-officer').classList.add('hidden'); document.getElementById('btn-tab-admin').classList.add('hidden'); renderAuth(); tab('tab-news'); }
        function openLogin() { document.getElementById('login-modal').classList.remove('hidden'); }
        function closeLogin() { document.getElementById('login-modal').classList.add('hidden'); }
        function renderAuth() { 
            const p = document.getElementById('auth-panel');
            if(!activeUser) { p.innerHTML = `<button onclick="openLogin()" class="bg-cyan-500 text-black px-3 py-1.5 rounded-xl text-[11px] uppercase font-black shadow-[0_0_10px_rgba(6,182,212,0.4)]">Đăng Nhập Nghiệp Vụ</button>`; } 
            else { p.innerHTML = `<div class="bg-gray-950 border border-gray-800 p-1 rounded-xl flex items-center gap-2"><b class="text-white text-[11px]">${activeUser.displayName}</b><button onclick="logout()" class="text-red-400 text-xs ml-1"><i class="fa-solid fa-power-off"></i></button></div>`; } 
        }
        
        startClock();
    </script>
</body>
</html>
