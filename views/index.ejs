<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CỔNG LIÊN THÔNG QUỐC GIA - PHÂN HỆ ĐIỀU HÀNH v9.0.0</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Space+Grotesk:wght@300;400;500;600;700&display=swap');
        body { font-family: 'Space Grotesk', sans-serif; background-color: #030611; color: #cbd5e1; overflow-x: hidden; }
        .font-mono-tech { font-family: 'Share Tech Mono', monospace; }
        
        /* Hiệu ứng Phôi Hologram Cao Cấp Bản v9.0 */
        .hologram-card {
            background: linear-gradient(135deg, #0d1527 0%, #020512 100%);
            border: 2px solid #2d3a4f;
            position: relative;
            overflow: hidden;
            box-shadow: 0 20px 45px rgba(0,0,0,0.8), inset 0 1px 2px rgba(255,255,255,0.05);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .hologram-card:hover { transform: translateY(-4px); border-color: #fbbf24; box-shadow: 0 0 25px rgba(251,191,36,0.15); }
        
        /* Hiệu ứng Con dấu cơ quan ban ngành dập chìm đỏ rực cực kỳ chuyên nghiệp */
        .red-seal-mộc {
            position: absolute; right: 15px; bottom: 15px;
            width: 75px; height: 75px; border: 3px double #ef4444;
            border-radius: 50%; color: #ef4444; font-size: 8px; font-weight: 900;
            display: flex; flex-content: center; align-items: center; justify-content: center;
            text-align: center; text-transform: uppercase; transform: rotate(-15deg);
            opacity: 0.75; letter-spacing: 0.5px; line-height: 1.1; pointer-events: none;
            box-shadow: 0 0 4px rgba(239, 68, 68, 0.4); text-shadow: 0 0 1px #ef4444;
        }

        .stamp-box {
            position: relative; font-size: 10px; font-weight: 900; text-transform: uppercase;
            padding: 5px 12px; border-radius: 4px; border: 2.5px dashed; display: inline-block;
            text-align: center; letter-spacing: 1px; transform: rotate(-5deg) scale(1.02);
            text-shadow: 0 0 5px currentColor; animation: stampAppear 0.25s ease;
        }
        .stamp-approved { border-color: #10b981; color: #10b981; background: rgba(16, 185, 129, 0.1); }
        .stamp-rejected { border-color: #ef4444; color: #ef4444; background: rgba(239, 68, 68, 0.1); }
        .stamp-pending { border-color: #f59e0b; color: #f59e0b; background: rgba(245, 158, 11, 0.1); }
        .stamp-forwarded { border-color: #3b82f6; color: #3b82f6; background: rgba(59, 130, 246, 0.1); }
        .stamp-archived { border-color: #94a3b8; color: #94a3b8; background: rgba(148, 163, 184, 0.15); border-style: double; }

        @keyframes stampAppear { 0% { transform: scale(3) rotate(-35deg); opacity: 0; } 100% { transform: scale(1.02) rotate(-5deg); opacity: 1; } }
        
        .marquee-container { width: 100%; overflow: hidden; white-space: nowrap; background: #060a16; border-top: 1px solid #1e293b; border-bottom: 1px solid #1e293b; }
        .marquee-content { display: inline-block; padding-left: 100%; animation: marquee 35s linear infinite; font-size: 12px; font-weight: 600; color: #f59e0b; }
        @keyframes marquee { 0% { transform: translate3d(0, 0, 0); } 100% { transform: translate3d(-100%, 0, 0); } }

        .subtab-btn.active { background-color: #1e293b; color: #f59e0b; border-color: #f59e0b; box-shadow: 0 0 10px rgba(245,158,11,0.15); }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between">

    <div class="flex-1">
        <header class="bg-[#050915] border-b border-slate-800 px-6 py-4 flex flex-wrap justify-between items-center shadow-2xl relative">
            <div class="flex items-center space-x-4">
                <div class="relative flex items-center justify-center">
                    <div class="absolute inset-0 bg-amber-500/20 blur-lg rounded-full animate-pulse"></div>
                    <div class="bg-gradient-to-br from-amber-400 to-amber-600 p-3 rounded-xl text-black border border-amber-300 shadow-xl z-10">
                        <i class="fa-solid fa-building-columns text-2xl"></i>
                    </div>
                </div>
                <div>
                    <span class="text-[10px] tracking-widest text-amber-500 uppercase font-black font-mono-tech block">Roblox Gaming Roleplay Community Platform</span>
                    <h1 class="text-xl font-black text-white tracking-tight flex items-center gap-2">CỔNG LIÊN THÔNG QUỐC GIA <span class="text-[11px] font-mono bg-slate-900 text-amber-400 px-2 py-0.5 rounded border border-slate-700">v9.0.0-PRO COMPREHENSIVE</span></h1>
                </div>
            </div>

            <div class="flex items-center space-x-4 text-xs mt-4 lg:mt-0">
                <div id="officer-alert-light" onclick="jumpToActiveNotification()" class="hidden bg-red-950 border border-red-500 px-3 py-2 rounded-lg flex items-center gap-2 animate-pulse cursor-pointer shadow-[0_0_15px_#ef4444]">
                    <span class="h-2 w-2 rounded-full bg-red-500"></span>
                    <span class="text-red-400 font-black text-[11px] tracking-wide uppercase">CÓ TÍN HIỆU NGHIỆP VỤ MỚI LIÊN THÔNG</span>
                </div>
                <div class="bg-[#090d16] px-4 py-2 rounded-lg border border-slate-800 font-mono text-amber-400 font-black tracking-widest text-sm shadow-inner" id="clock">00:00:00</div>
                <div class="bg-[#090d16] px-3 py-2 rounded-lg border border-slate-800 flex items-center gap-2">
                    <span id="security-txt" class="font-black text-[11px] tracking-wider uppercase text-emerald-400"><%= state.securityLevel %></span>
                </div>
                <div id="auth-panel"></div>
            </div>
        </header>

        <div class="marquee-container py-2 flex items-center">
            <div class="bg-red-950 text-red-400 border border-red-900 font-black text-[9px] px-2.5 py-0.5 rounded uppercase tracking-wider mx-4 z-10 shadow-md">Thông báo cơ mật</div>
            <div class="marquee-content" id="live-marquee"><%= state.tickerMessage %></div>
        </div>

        <nav class="bg-[#050915]/90 border-b border-slate-800 px-6 flex flex-wrap space-x-1 backdrop-blur-md sticky top-0 z-40 shadow-md">
            <button onclick="tab('tab-news')" id="btn-tab-news" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-amber-500 text-amber-500 transition-all"><i class="fa-solid fa-newspaper mr-1.5"></i> Trung Tâm Ấn Bản</button>
            <button onclick="tab('tab-id')" id="btn-tab-id" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-slate-400 hover:text-white transition-all"><i class="fa-solid fa-address-card mr-1.5"></i> Tra cứu định danh</button>
            <button onclick="tab('tab-cards')" id="btn-tab-cards" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-sky-400 hover:text-sky-300 transition-all"><i class="fa-solid fa-id-badge mr-1.5"></i> Thẩm Tra Văn Bằng & Vi Phạm</button>
            <button onclick="tab('tab-services')" id="btn-tab-services" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-slate-400 hover:text-white transition-all"><i class="fa-solid fa-file-invoice-dollar mr-1.5"></i> Khởi tạo hồ sơ đa dạng</button>
            <button onclick="tab('tab-officer')" id="btn-tab-officer" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-emerald-500 hover:text-emerald-400 hidden relative">
                <i class="fa-solid fa-user-shield mr-1.5"></i> Bàn Làm Việc Bộ Ngành 
                <span id="badge-count-app" class="absolute top-2 right-1.5 bg-red-600 text-white text-[9px] px-1.5 rounded-full font-black hidden">0</span>
            </button>
            <button onclick="tab('tab-admin')" id="btn-tab-admin" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-purple-400 hover:text-purple-300 hidden"><i class="fa-solid fa-crown mr-1.5"></i> Phòng Giám Sát Tối Cao</button>
        </nav>

        <main class="p-6 max-w-[1700px] w-full mx-auto space-y-6">
            
            <section id="tab-news" class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <div class="lg:col-span-2 space-y-4">
                    <h2 class="text-xs font-black text-slate-400 uppercase tracking-widest border-b border-slate-800 pb-2 flex items-center gap-2"><i class="fa-solid fa-scroll text-amber-500"></i> Sắc Lệnh / Văn Bản Chỉ Thị Khẩn Toàn Toàn Quốc</h2>
                    <div id="news-feed" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
                </div>
                <div class="space-y-4">
                    <h2 class="text-xs font-black text-red-400 uppercase tracking-widest border-b border-slate-800 pb-2 flex items-center gap-2"><i class="fa-solid fa-triangle-exclamation animate-pulse"></i> Đối Tượng Truy Nã Quốc Gia Đặc Biệt</h2>
                    <div id="wanted-feed" class="space-y-3"></div>
                </div>
            </section>

            <section id="tab-id" class="hidden max-w-3xl mx-auto bg-[#0a0f1d] border border-slate-800 p-6 rounded-2xl shadow-xl">
                <h2 class="text-xs font-black text-center text-white uppercase tracking-widest mb-4"><i class="fa-solid fa-shield-halved text-amber-500"></i> Truy Xuất Căn Cước / Tra Cứu Hệ Thống Dân Cư</h2>
                <div class="flex gap-2 mb-4">
                    <input type="text" id="id-search" placeholder="Nhập tên tài khoản cư dân (Ví dụ: Nguyen_Manh_Hoang)..." class="flex-1 bg-slate-900 border border-slate-700 px-4 py-2 text-sm rounded-lg text-white font-mono focus:outline-none">
                    <button onclick="searchCitizen()" class="bg-amber-500 hover:bg-amber-600 text-black px-5 text-xs font-black uppercase rounded-lg transition-colors">Truy xuất thông tin</button>
                </div>
                <div id="id-result" class="flex justify-center"></div>
            </section>

            <section id="tab-cards" class="hidden max-w-6xl mx-auto space-y-8">
                <div class="bg-[#0a0f1d] border border-slate-800 p-6 rounded-2xl shadow-xl max-w-xl mx-auto">
                    <h2 class="text-xs font-black text-center text-sky-400 uppercase tracking-widest mb-4"><i class="fa-solid fa-id-card text-sky-500"></i> Hệ Thống Đồ Họa Kết Xuất Giấy Tờ Công Dân</h2>
                    <div class="flex gap-2">
                        <input type="text" id="card-search-input" placeholder="Nhập tài khoản cư dân nghiệp vụ..." class="flex-1 bg-slate-900 border border-slate-700 px-4 py-2 text-sm rounded-lg text-white font-mono focus:outline-none">
                        <button onclick="generateCitizenCards()" class="bg-sky-600 hover:bg-sky-700 text-white px-5 text-xs font-black uppercase rounded-lg transition-colors">Kết xuất phôi</button>
                    </div>
                </div>

                <div class="space-y-4">
                    <h3 class="text-xs font-black uppercase text-slate-400 tracking-wider flex items-center gap-1.5"><i class="fa-solid fa-passport text-sky-400"></i> Phôi Thẻ Hành Chính & Giấy Phép Nghiệp Vụ Kết Xuất Hologram</h3>
                    <div id="cards-render-zone" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <p class="text-center text-xs text-slate-500 col-span-2 py-8">Vui lòng nhập tài khoản công dân để dập phôi đồ họa lập tức.</p>
                    </div>
                </div>

                <div class="space-y-4">
                    <h3 class="text-xs font-black uppercase text-red-400 tracking-wider flex items-center gap-2"><i class="fa-solid fa-gavel text-red-500"></i> Danh Sách Lịch Sử Biên Bản & Quyết Định Vi Phạm Lưu Kho Quốc Gia</h3>
                    <div id="violation-render-zone" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <p class="text-center text-xs text-slate-500 col-span-2 py-4">Chưa thực hiện truy xuất lý lịch tư pháp số.</p>
                    </div>
                </div>
            </section>

            <section id="tab-services" class="hidden grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl space-y-4 shadow-lg">
                    <h3 class="text-xs font-black text-slate-300 uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-file-pen text-amber-500"></i> Khởi Tạo Đơn Thư / Đăng Ký Văn Bằng Trực Tuyến</h3>
                    <form onsubmit="submitForm(event)" class="space-y-4 text-xs">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            <div>
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Tên Tài Khoản Hệ Thống (Họ_Tên)</label>
                                <input type="text" id="app-sender" required placeholder="Nguyen_Manh_Hoang" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-mono focus:outline-none">
                            </div>
                            <div>
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Thủ Tục Cần Tiếp Nhận Thẩm Định</label>
                                <select id="app-docType" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-bold text-amber-400 focus:outline-none">
                                    <option value="CĂN CƯỚC CÔNG DÂN">Căn Cước Công Dân Gắn Chíp Điện Tử</option>
                                    <option value="BẰNG LÁI XE HẠNG B2">Bằng Lái Xe Ô Tô Hạng B2 Quốc Gia</option>
                                    <option value="BẰNG LÁI XE TẢI HẠNG C">Bằng Lái Xe Tải Nặng Hạng C</option>
                                    <option value="GIẤY PHÉP SỬ DỤNG CÔNG CỤ HỖ TRỢ">Giấy Phép Sử Dụng Vũ Khí & Công Cụ Hỗ Trợ</option>
                                    <option value="CHỨNG NHẬN LỰC LƯỢNG VŨ TRANG">Chứng Nhận Tuyển Dụng Lực Lượng Vũ Trang QĐND</option>
                                    <option value="THẺ NGÀNH CÔNG CHỨC">Thẻ Ngành Công Chức / Chứng Thư Bổ Nhiệm Tư Pháp</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Cơ Quan Ban Ngành Tiếp Nhận</label>
                            <select id="app-agency" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-bold text-sky-400 focus:outline-none">
                                <option value="CHÍNH PHỦ">VĂN PHÒNG CHÍNH PHỦ TỐI CAO</option>
                                <option value="THANH TRA">THANH TRA CHÍNH PHỦ ỦY BAN</option>
                                <option value="CÔNG AN">BỘ CÔNG AN CHÍNH QUY</option>
                                <option value="QUÂN ĐỘI">BỘ CHỈ HUY QUÂN SỰ ĐẠI QUỐC PHÒNG</option>
                                <option value="UBND PHƯỜNG">ỦY BAN NHÂN DÂN THÀNH PHỐ THỦ PHỦ</option>
                                <option value="TOÀ ÁN">TÒA ÁN NHÂN DÂN TỐI CAO TƯ PHÁP</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Trình Bày Nội Dung Chi Tiết Nghiệp Vụ Kịch Bản</label>
                            <textarea id="app-content" rows="4" required placeholder="Ghi rõ thông tin yêu cầu giải quyết kịch bản nhập vai..." class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white focus:outline-none"></textarea>
                        </div>
                        <button type="submit" class="w-full bg-gradient-to-r from-amber-400 to-amber-500 font-black text-black py-3 rounded-lg uppercase tracking-widest shadow-lg">Gửi Đơn Thư Lên Hệ Thống</button>
                    </form>
                </div>

                <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl flex flex-col h-full min-h-[480px] shadow-lg">
                    <h3 class="text-xs font-black text-slate-300 uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-satellite-dish text-sky-400 animate-pulse"></i> Cổng Đàm Thoại Trực Tuyến & Ký Nhận Biên Bản Công Dân (Realtime Tức Thời)</h3>
                    <div class="flex gap-2 my-3">
                        <input type="text" id="track-id" placeholder="Nhập mã đơn thư hoặc biên bản (Ví dụ: HS-1001, BB-1002)..." class="flex-1 bg-slate-900 border border-slate-700 px-3 py-2 text-xs rounded-lg text-white font-mono focus:outline-none">
                        <button onclick="trackApplication()" class="bg-sky-600 hover:bg-sky-700 text-white px-5 text-xs font-black rounded-lg transition-colors">Truy vấn</button>
                    </div>
                    <div id="track-details" class="flex-1 flex flex-col justify-between hidden space-y-3"></div>
                    <div id="track-empty" class="text-center py-20 text-slate-500 text-xs flex-1 flex flex-col justify-center items-center"><i class="fa-solid fa-folder-open text-4xl mb-3 text-slate-700"></i> Nhập chính xác mã số đơn thư/biên bản vi phạm để tiến hành đàm thoại trực tuyến, ký nhận hoặc khiếu nại lên cấp cao.</div>
                </div>
            </section>

            <section id="tab-officer" class="hidden grid grid-cols-1 xl:grid-cols-3 gap-6">
                <div class="xl:col-span-2 space-y-5">
                    
                    <div class="bg-[#0b111e] border border-slate-700 p-1.5 rounded-xl flex flex-wrap gap-1 shadow-md">
                        <button onclick="subTab('off-apps')" id="btn-off-apps" class="subtab-btn px-4 py-2 text-[11px] font-black uppercase border border-slate-700 text-slate-400 rounded-md transition-all"><i class="fa-solid fa-inbox mr-1"></i> Hồ sơ ban ngành</button>
                        <button onclick="subTab('off-cccd')" id="btn-off-cccd" class="subtab-btn px-4 py-2 text-[11px] font-black uppercase border border-slate-700 text-slate-400 rounded-md transition-all"><i class="fa-solid fa-address-card mr-1"></i> Cấp Thẻ Căn Cước</button>
                        <button onclick="subTab('off-docs')" id="btn-off-docs" class="subtab-btn px-4 py-2 text-[11px] font-black uppercase border border-slate-700 text-slate-400 rounded-md transition-all"><i class="fa-solid fa-id-badge mr-1"></i> Cấp Giấy Phép / Thẻ Ngành</button>
                        <button onclick="subTab('off-gavel')" id="btn-off-gavel" class="subtab-btn px-4 py-2 text-[11px] font-black uppercase border border-slate-700 text-slate-400 rounded-md transition-all"><i class="fa-solid fa-gavel mr-1"></i> Quyết định xử phạt (Ký luồng)</button>
                        <button onclick="subTab('off-leader')" id="btn-off-leader" class="subtab-btn px-4 py-2 text-[11px] font-black uppercase border border-purple-800 text-purple-400 rounded-md transition-all hidden"><i class="fa-solid fa-crown mr-1"></i> Phân Hệ Lãnh Đạo cao cấp</button>
                    </div>

                    <div id="subtab-off-apps" class="bg-[#0a0f1d] border border-slate-800 p-4 rounded-xl shadow-md space-y-3">
                        <div class="flex justify-between items-center border-b border-slate-800 pb-2">
                            <h3 class="text-xs font-black text-emerald-400 uppercase tracking-wider flex items-center gap-2"><i class="fa-solid fa-folder-closed"></i> Thẩm định danh sách hồ sơ đơn thư trực tuyến</h3>
                            <span id="office-badge" class="text-[10px] font-mono font-bold bg-emerald-950 text-emerald-400 px-2 py-0.5 rounded border border-emerald-800">Cơ quan tiếp nhận</span>
                        </div>
                        <div class="overflow-x-auto text-xs">
                            <table class="w-full text-left">
                                <thead class="bg-slate-900 text-slate-400 font-bold uppercase text-[9px] tracking-wider">
                                    <tr>
                                        <th class="p-3">Mã Đơn</th>
                                        <th class="p-3">Tài Khoản</th>
                                        <th class="p-3">Loại Giấy Tờ</th>
                                        <th class="p-3">Trạng Thái</th>
                                        <th class="p-3 text-right">Hành Động</th>
                                    </tr>
                                </thead>
                                <tbody id="officer-table" class="divide-y divide-slate-800"></tbody>
                            </table>
                        </div>
                    </div>

                    <div id="subtab-off-cccd" class="hidden bg-[#0a0f1d] border border-slate-800 p-5 rounded-xl space-y-4 shadow-lg">
                        <h3 class="text-xs font-black text-amber-500 uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-address-card"></i> Nghiệp Vụ Cấp Căn Cước Công Dân Gắn Chíp Cơ Sở Dữ Liệu Quốc Gia</h3>
                        <form onsubmit="registerResidentByOfficer(event, 'cccd')" class="grid grid-cols-1 md:grid-cols-3 gap-4 text-xs">
                            <div><label class="block text-gray-400 mb-1 font-bold uppercase">Tài Khoản Định Danh (Họ_Tên)</label><input type="text" id="cccd-user" required placeholder="Nguyen_Manh_Hoang" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-mono focus:outline-none"></div>
                            <div><label class="block text-gray-400 mb-1 font-bold uppercase">Họ Và Tên Khai Sinh Gốc</label><input type="text" id="cccd-name" required placeholder="Nguyễn Mạnh Hoàng" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white focus:outline-none"></div>
                            <div><label class="block text-gray-400 mb-1 font-bold uppercase">Ngày Tháng Năm Sinh</label><input type="text" id="cccd-dob" required placeholder="18/05/1996" class="w-full bg-slate-900 border border-slate-700 p-2.5 rounded-lg text-white font-mono focus:outline-none"></div>
