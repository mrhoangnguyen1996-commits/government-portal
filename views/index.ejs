                <div id="subtab-adm-vault-apps" class="hidden space-y-4">
                    <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl shadow-lg space-y-3">
                        <h3 class="text-xs font-black text-white uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-file-contract text-sky-400"></i> Toàn Văn Toàn Bộ Hồ Sơ Đơn Thư Công Dân Đã Niêm Phong (Admin Có Quyền Bác Tái Thẩm)</h3>
                        <div id="admin-vault-apps-list" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 text-xs"></div>
                    </div>
                </div>

                <div id="subtab-adm-vault-sanctions" class="hidden space-y-4">
                    <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl shadow-lg space-y-3">
                        <h3 class="text-xs font-black text-red-400 uppercase tracking-widest border-b border-slate-800 pb-2"><i class="fa-solid fa-handcuffs"></i> Toàn Văn Toàn Bộ Biên Bản Quyết Định Xử Phạt Hành Chính Gốc Đã Lưu Kho</h3>
                        <div id="admin-vault-sanctions-list" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 text-xs"></div>
                    </div>
                </div>

                <div class="bg-[#0a0f1d] border border-slate-800 p-5 rounded-2xl flex flex-col h-full shadow-xl">
                    <h3 class="text-xs font-black text-red-400 uppercase tracking-widest border-b border-slate-800 pb-2 flex items-center gap-1.5"><i class="fa-solid fa-terminal mr-1 text-xs animate-pulse"></i> Nhật Ký Máy Chủ Liên Thông Quốc Gia Realtime v8.0</h3>
                    <div id="admin-system-logs" class="flex-1 space-y-2 mt-3 font-mono text-[11px] overflow-y-auto max-h-[280px] bg-black/60 p-3 rounded-xl border border-slate-900 shadow-inner"></div>
                </div>
            </section>
        </main>
    </div>

    <footer class="mt-12 bg-[#050914] border-t-2 border-red-900/80 py-6 px-6 text-center shadow-inner relative z-50">
